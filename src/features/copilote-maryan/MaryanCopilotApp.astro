---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { FREE_LIMIT, SUGGESTIONS, WELCOME_PARAGRAPHS } from './config';
---
<BaseLayout
  title="Copilote — MARYAN"
  description="Votre copilote de mandat. Posez vos questions, préparez vos prises de parole et gérez les situations sensibles."
>
  <div
    class="copilot-shell"
    data-maryan-copilot-root
    data-upgrade-url="/offres"
    data-endpoint="/api/chat"
  >
    <header class="site-header copilot-header">
      <div class="container">
        <div class="header-inner">
          <div>
            <a href="/" class="brand">MARYAN</a>
            <p class="brand-sub">appui intelligent pour élus municipaux</p>
          </div>
          <nav class="nav">
            <a href="/">Accueil</a>
            <a href="/diagnostic">Diagnostic</a>
            <a href="/offres">Offres</a>
            <a href="/copilote" class="active">Copilote</a>
          </nav>
        </div>
      </div>
    </header>

    <main class="copilot-page">
      <div class="app-layout">
        <aside class="sidebar">
          <div class="sidebar-header">
            <p class="sidebar-title">Votre copilote</p>
            <h1>MARYAN vous accompagne dans votre mandat</h1>
          </div>

          <div class="mode-toggle" role="tablist" aria-label="Modes du copilote">
            <button class="mode-btn active" data-mode="libre" type="button">Version libre</button>
            <button class="mode-btn" data-mode="profil" type="button">Mon profil</button>
          </div>

          <div class="msg-counter" data-msg-counter>
            <span data-counter-text>{FREE_LIMIT} messages disponibles</span>
            <div class="counter-dots" data-counter-dots></div>
          </div>

          <div class="profile-block hidden" data-profile-block>
            <div data-profile-filled class="hidden">
              <p class="profile-label">Votre profil MARYAN</p>
              <p class="profile-name" data-profile-name>—</p>
              <p class="profile-summary" data-profile-summary></p>
              <div class="profile-tags" data-profile-tags></div>
            </div>
            <div data-profile-empty>
              <p class="profile-label">Mode personnalisé</p>
              <p class="profile-empty-title">Aucun profil détecté</p>
              <p class="profile-empty-text">
                Faites d’abord le diagnostic pour que MARYAN adapte ses réponses à votre situation.
              </p>
              <a class="profile-link" href="/diagnostic">Faire le diagnostic</a>
            </div>
          </div>

          <div class="suggestions">
            <p class="suggestions-label">Suggestions</p>
            {SUGGESTIONS.map((suggestion) => (
              <button class="suggestion-btn" data-suggestion type="button">
                {suggestion}
              </button>
            ))}
          </div>

          <div class="disclaimer">
            MARYAN vous aide à réfléchir, cadrer et préparer vos interventions. Il ne remplace pas un avis
            juridique, un expert métier ou un accompagnement professionnel sur une situation sensible.
          </div>
        </aside>

        <section class="chat-area" aria-label="Conversation avec MARYAN">
          <div class="messages" data-messages aria-live="polite">
            <div class="msg assistant">
              <div class="msg-bubble">
                {WELCOME_PARAGRAPHS.map((paragraph) => <p>{paragraph}</p>)}
              </div>
              <span class="msg-time" data-welcome-time></span>
            </div>
          </div>

          <div class="input-area">
            <div class="input-row">
              <div class="input-wrap">
                <textarea
                  data-user-input
                  placeholder="Posez votre question…"
                  rows="1"
                  aria-label="Votre message"
                ></textarea>
              </div>
              <button class="send-btn" data-send-btn type="button" aria-label="Envoyer">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"></path></svg>
              </button>
            </div>
            <p class="input-hint" data-input-hint>Version libre · {FREE_LIMIT} messages par session</p>
          </div>
        </section>
      </div>
    </main>
  </div>

  <script>
    import './client.ts';
  </script>
</BaseLayout>

<style>
  .copilot-shell {
    --copilot-bg: #fcfaf6;
    --copilot-surface: #f5ebdd;
    --copilot-surface-2: #fffdf8;
    --copilot-text: #1e2a32;
    --copilot-muted: #54636c;
    --copilot-blue: #2a6fca;
    --copilot-blue-light: rgba(42, 111, 202, 0.09);
    --copilot-blue-mid: rgba(42, 111, 202, 0.18);
    --copilot-red: #d93b3b;
    --copilot-neon: #39ff6e;
    --copilot-border: #d8d3ca;
    --copilot-shadow: 0 8px 24px rgba(30, 42, 50, 0.07);
    --copilot-radius: 18px;
    color: var(--copilot-text);
    background: var(--copilot-bg);
  }

  .copilot-shell .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(252, 250, 246, 0.96);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(216, 211, 202, 0.7);
    padding: 0.75rem 0;
  }

  .copilot-shell .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .copilot-shell .brand {
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: 0.07em;
  }

  .copilot-shell .brand-sub {
    font-size: 0.78rem;
    color: var(--copilot-muted);
  }

  .copilot-shell .nav {
    display: flex;
    gap: 1.2rem;
    font-size: 0.85rem;
  }

  .copilot-shell .nav a {
    text-decoration: none;
    color: var(--copilot-muted);
  }

  .copilot-shell .nav a:hover,
  .copilot-shell .nav a.active {
    color: var(--copilot-blue);
    font-weight: 600;
  }

  .copilot-page {
    min-height: calc(100vh - 210px);
  }

  .app-layout {
    display: grid;
    grid-template-columns: 300px minmax(0, 1fr);
    min-height: calc(100vh - 210px);
  }

  .sidebar {
    border-right: 1px solid var(--copilot-border);
    background: var(--copilot-surface-2);
    display: flex;
    flex-direction: column;
  }

  .sidebar-header {
    padding: 1.2rem 1.2rem 0.9rem;
    border-bottom: 1px solid var(--copilot-border);
  }

  .sidebar-title {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--copilot-red);
    margin-bottom: 0.5rem;
  }

  .sidebar-header h1 {
    font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
    font-size: 1.18rem;
    line-height: 1.2;
    margin: 0;
  }

  .mode-toggle {
    display: flex;
    gap: 0.4rem;
    padding: 1rem 1.2rem 0.6rem;
  }

  .mode-btn {
    flex: 1;
    padding: 0.5rem 0.2rem;
    border-radius: 8px;
    font-size: 0.78rem;
    font-weight: 700;
    font-family: inherit;
    cursor: pointer;
    border: 1px solid var(--copilot-border);
    background: transparent;
    color: var(--copilot-muted);
    transition: all 0.15s;
  }

  .mode-btn.active {
    background: var(--copilot-blue);
    color: white;
    border-color: var(--copilot-blue);
  }

  .msg-counter {
    margin: 0 1.2rem 0.8rem;
    background: var(--copilot-blue-light);
    border: 1px solid var(--copilot-blue-mid);
    border-radius: 10px;
    padding: 0.55rem 0.8rem;
    font-size: 0.8rem;
    color: var(--copilot-blue);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
  }

  .msg-counter.hidden,
  .profile-block.hidden,
  [data-profile-filled].hidden {
    display: none;
  }

  .counter-dots {
    display: flex;
    gap: 4px;
  }

  .counter-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--copilot-blue-mid);
  }

  .counter-dot.used {
    background: var(--copilot-blue);
  }

  .profile-block {
    margin: 0 1.2rem 1rem;
    background: var(--copilot-surface);
    border: 1px solid var(--copilot-border);
    border-radius: 12px;
    padding: 0.95rem;
  }

  .profile-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--copilot-muted);
    margin-bottom: 0.45rem;
  }

  .profile-name,
  .profile-empty-title {
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
  }

  .profile-summary,
  .profile-empty-text {
    font-size: 0.8rem;
    color: var(--copilot-muted);
    line-height: 1.5;
    margin-bottom: 0.65rem;
  }

  .profile-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .profile-tag {
    font-size: 0.72rem;
    background: var(--copilot-blue-light);
    color: var(--copilot-blue);
    border-radius: 99px;
    padding: 0.15rem 0.6rem;
    border: 1px solid var(--copilot-blue-mid);
  }

  .profile-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    border: 1px solid var(--copilot-blue);
    color: var(--copilot-blue);
    font-size: 0.8rem;
    font-weight: 700;
    text-decoration: none;
  }

  .suggestions {
    padding: 0.2rem 1.2rem 1rem;
  }

  .suggestions-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--copilot-muted);
    margin-bottom: 0.6rem;
  }

  .suggestion-btn {
    display: block;
    width: 100%;
    text-align: left;
    background: var(--copilot-bg);
    border: 1px solid var(--copilot-border);
    border-radius: 10px;
    padding: 0.6rem 0.78rem;
    font-size: 0.82rem;
    font-family: inherit;
    color: var(--copilot-text);
    cursor: pointer;
    margin-bottom: 0.45rem;
    line-height: 1.35;
    transition: all 0.15s;
  }

  .suggestion-btn:hover {
    border-color: var(--copilot-blue);
    background: var(--copilot-blue-light);
    color: var(--copilot-blue);
  }

  .disclaimer {
    margin: auto 1.2rem 1rem;
    padding: 0.75rem 0.8rem;
    background: rgba(245, 235, 221, 0.6);
    border: 1px solid var(--copilot-border);
    border-radius: 10px;
    font-size: 0.75rem;
    color: var(--copilot-muted);
    line-height: 1.5;
  }

  .chat-area {
    display: flex;
    flex-direction: column;
    min-width: 0;
    background: linear-gradient(180deg, rgba(255, 253, 248, 0.6), rgba(252, 250, 246, 0.96));
  }

  .messages {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-height: 28rem;
  }

  .msg {
    display: flex;
    flex-direction: column;
    max-width: 78%;
  }

  .msg.user {
    align-self: flex-end;
    align-items: flex-end;
  }

  .msg.assistant,
  .msg.paywall-msg {
    align-self: flex-start;
    align-items: flex-start;
  }

  .paywall-msg {
    max-width: min(100%, 42rem);
    width: 100%;
  }

  .msg-bubble {
    padding: 0.8rem 1rem;
    border-radius: 16px;
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .msg.user .msg-bubble {
    background: var(--copilot-blue);
    color: white;
    border-bottom-right-radius: 4px;
  }

  .msg.assistant .msg-bubble {
    background: var(--copilot-surface-2);
    border: 1px solid var(--copilot-border);
    border-bottom-left-radius: 4px;
    box-shadow: var(--copilot-shadow);
  }

  .msg-bubble p {
    margin: 0 0 0.55rem;
  }

  .msg-bubble p:last-child {
    margin-bottom: 0;
  }

  .msg-bubble ul {
    margin: 0.35rem 0 0.55rem;
    padding-left: 1.15rem;
  }

  .msg-bubble li {
    margin-bottom: 0.2rem;
  }

  .msg-bubble a {
    color: var(--copilot-blue);
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .msg-time {
    font-size: 0.7rem;
    color: var(--copilot-muted);
    margin-top: 0.3rem;
    padding: 0 0.2rem;
  }

  .typing-bubble {
    background: var(--copilot-surface-2);
    border: 1px solid var(--copilot-border);
    border-radius: 16px;
    border-bottom-left-radius: 4px;
    padding: 0.75rem 1rem;
    display: flex;
    gap: 5px;
    align-items: center;
  }

  .typing-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--copilot-muted);
    animation: bounce 1.2s infinite;
  }

  .typing-dot:nth-child(2) {
    animation-delay: 0.2s;
  }

  .typing-dot:nth-child(3) {
    animation-delay: 0.4s;
  }

  @keyframes bounce {
    0%,
    60%,
    100% {
      transform: translateY(0);
    }

    30% {
      transform: translateY(-6px);
    }
  }

  .paywall-bubble {
    background: linear-gradient(135deg, rgba(42, 111, 202, 0.06), rgba(57, 255, 110, 0.05));
    border: 1.5px solid var(--copilot-blue);
    border-radius: 16px;
    padding: 1.2rem 1.3rem;
    text-align: center;
    box-shadow: var(--copilot-shadow);
  }

  .paywall-bubble p {
    font-size: 0.88rem;
    color: var(--copilot-muted);
    margin-bottom: 0.9rem;
    line-height: 1.55;
  }

  .paywall-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0.65rem 1.4rem;
    border-radius: 999px;
    background: var(--copilot-blue);
    color: white;
    font-size: 0.88rem;
    font-weight: 700;
    text-decoration: none;
  }

  .input-area {
    flex-shrink: 0;
    border-top: 1px solid var(--copilot-border);
    padding: 1rem 1.2rem;
    background: var(--copilot-surface-2);
  }

  .input-row {
    display: flex;
    gap: 0.6rem;
    align-items: flex-end;
  }

  .input-wrap {
    flex: 1;
    background: var(--copilot-bg);
    border: 1px solid var(--copilot-border);
    border-radius: 14px;
    padding: 0.65rem 0.9rem;
    transition: border-color 0.2s;
  }

  .input-wrap:focus-within {
    border-color: var(--copilot-blue);
  }

  textarea {
    width: 100%;
    background: transparent;
    border: none;
    outline: none;
    font-family: inherit;
    font-size: 0.9rem;
    color: var(--copilot-text);
    resize: none;
    min-height: 24px;
    max-height: 140px;
    line-height: 1.5;
  }

  textarea::placeholder {
    color: var(--copilot-muted);
  }

  .send-btn {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    background: var(--copilot-blue);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: opacity 0.15s, transform 0.15s;
  }

  .send-btn:hover {
    opacity: 0.92;
    transform: translateY(-1px);
  }

  .send-btn:disabled {
    opacity: 0.35;
    cursor: not-allowed;
    transform: none;
  }

  .send-btn svg {
    width: 18px;
    height: 18px;
    fill: white;
  }

  .input-hint {
    font-size: 0.72rem;
    color: var(--copilot-muted);
    margin-top: 0.45rem;
    text-align: center;
  }

  @media (max-width: 860px) {
    .app-layout {
      grid-template-columns: 1fr;
    }

    .sidebar {
      border-right: none;
      border-bottom: 1px solid var(--copilot-border);
    }
  }

  @media (max-width: 700px) {
    .copilot-shell .nav {
      display: none;
    }

    .messages {
      padding: 1rem;
    }

    .msg,
    .paywall-msg {
      max-width: 100%;
    }

    .input-area {
      padding: 0.9rem;
    }
  }
</style>
