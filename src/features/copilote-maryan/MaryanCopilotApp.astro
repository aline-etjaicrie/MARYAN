---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { FREE_LIMIT, PARCOURS_TYPES, PROFILE_REQUIRED_HTML, SUGGESTIONS, WELCOME_PARAGRAPHS } from './config';
---

<BaseLayout
  title="Copilote — MARYAN"
  description="Votre copilote de mandat personnel. Posez vos questions, cadrez une décision, préparez une prise de parole."
>
  <style is:global>
    .site-footer,
    .site-header {
      display: none !important;
    }

    .hidden {
      display: none !important;
    }

    .msg {
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
      margin-bottom: 1.2rem;
    }

    .msg.user {
      align-items: flex-end;
      margin-left: auto;
      max-width: min(100%, 34rem);
    }

    .msg.assistant {
      align-items: flex-start;
      max-width: min(100%, 42rem);
    }

    .msg-sender {
      font-size: 0.68rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--deep);
      opacity: 0.64;
      padding-left: 0.25rem;
    }

    .msg.user .msg-sender {
      display: none;
    }

    .msg-bubble {
      width: 100%;
      border-radius: 1.35rem;
      padding: 0.95rem 1rem 0.88rem;
      border: 1px solid rgba(10, 25, 47, 0.08);
      background: #fff;
      box-shadow: 0 10px 24px rgba(10, 25, 47, 0.05);
      line-height: 1.56;
      overflow-wrap: anywhere;
    }

    .msg.user .msg-bubble {
      background: var(--deep);
      color: #fff;
      border-color: transparent;
      border-bottom-right-radius: 0.45rem;
      box-shadow: 0 14px 28px rgba(10, 25, 47, 0.18);
    }

    .msg.assistant .msg-bubble {
      color: var(--ink);
      border-bottom-left-radius: 0.45rem;
    }

    .msg-bubble p {
      margin: 0 0 0.8rem;
      font-size: 0.95rem;
    }

    .msg-attachment-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      font-size: 0.78rem;
      font-weight: 700;
      padding: 0.22rem 0.55rem;
      background: rgba(255, 255, 255, 0.14);
      border-radius: 999px;
      margin-bottom: 0.45rem;
      opacity: 0.88;
    }

    .msg-bubble p:last-child {
      margin-bottom: 0;
    }

    .reply-lead {
      font-size: 1rem;
      font-weight: 600;
      color: var(--deep);
    }

    .reply-section + .reply-section {
      margin-top: 0.8rem;
      padding-top: 0.8rem;
      border-top: 1px solid rgba(10, 25, 47, 0.08);
    }

    .reply-section h3 {
      color: var(--deep);
      font-size: 0.76rem;
      line-height: 1.2;
      letter-spacing: 0.11em;
      text-transform: uppercase;
      margin: 0 0 0.65rem;
    }

    .reply-list {
      margin: 0;
      padding-left: 1.15rem;
      display: grid;
      gap: 0.45rem;
    }

    .reply-list li {
      margin: 0;
      padding-left: 0.1rem;
    }

    .reply-resource-list {
      list-style: none;
      display: grid;
      gap: 0.8rem;
      margin: 0;
      padding: 0;
    }

    .reply-resource-list li {
      display: grid;
      gap: 0.22rem;
      padding: 0.8rem 0.9rem;
      border-radius: 1rem;
      background: rgba(10, 25, 47, 0.03);
      border: 1px solid rgba(10, 25, 47, 0.06);
    }

    .reply-resource-link {
      color: var(--deep);
      font-weight: 700;
      text-decoration: none;
    }

    .reply-resource-link:hover,
    .reply-resource-link:focus-visible {
      color: var(--accent-red);
      outline: none;
    }

    .reply-resource-promise {
      font-size: 0.88rem;
      line-height: 1.45;
      color: rgba(30, 42, 50, 0.74);
    }

    .typing-indicator {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      min-height: 3.25rem;
    }

    .dot {
      width: 0.42rem;
      height: 0.42rem;
      border-radius: 999px;
      background: rgba(10, 25, 47, 0.32);
      animation: maryan-bounce 1.2s infinite ease-in-out;
    }

    .dot:nth-child(2) {
      animation-delay: 0.15s;
    }

    .dot:nth-child(3) {
      animation-delay: 0.3s;
    }

    @keyframes maryan-bounce {
      0%,
      80%,
      100% {
        transform: translateY(0);
        opacity: 0.35;
      }

      40% {
        transform: translateY(-0.22rem);
        opacity: 1;
      }
    }

    .paywall-card {
      background: linear-gradient(180deg, rgba(10, 25, 47, 0.98) 0%, rgba(10, 25, 47, 0.92) 100%) !important;
      color: #fff !important;
      border-color: transparent !important;
    }

    .paywall-card p,
    .paywall-card strong {
      color: #fff !important;
    }

    .paywall-cta {
      width: 100%;
      margin-top: 1rem;
      text-align: center;
    }

    @media (min-width: 900px) {
      .msg.user {
        max-width: 38rem;
      }

      .msg.assistant {
        max-width: 44rem;
      }

      .msg-bubble {
        padding: 1.05rem 1.2rem 1rem;
      }
    }
  </style>

  <!-- ══════════════════════════════════════════════════
       HUB SCREEN — écran d'accueil, sélection du mode
       ══════════════════════════════════════════════════ -->
  <div id="maryan-hub" class="maryan-hub">
    <div class="hub-inner">
      <p class="hub-kicker">MARYAN · Copilote de mandat</p>
      <h1 class="hub-title">Que voulez-vous faire&nbsp;?</h1>
      <div class="hub-cards">
        <button class="hub-card" data-hub-mode="compte-rendu" type="button">
          <span class="hub-card-icon">🎙️</span>
          <strong class="hub-card-label">Compte rendu de réunion</strong>
          <span class="hub-card-desc">Enregistrez ou collez le contenu d'une réunion — MARYAN rédige le compte rendu.</span>
        </button>
        <button class="hub-card" data-hub-mode="document" type="button">
          <span class="hub-card-icon">📄</span>
          <strong class="hub-card-label">Décrypter un document</strong>
          <span class="hub-card-desc">Déposez une délibération, un arrêté, un courrier — MARYAN vous en donne les points essentiels.</span>
        </button>
        <button class="hub-card" data-hub-mode="chat" type="button">
          <span class="hub-card-icon">💬</span>
          <strong class="hub-card-label">Discuter avec MARYAN</strong>
          <span class="hub-card-desc">Posez une question, explorez une situation, trouvez une piste.</span>
        </button>
      </div>
      <div class="hub-footer-links">
        <a href="/">← Accueil</a>
        <a href="/mon-compte">Mon espace MARYAN</a>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════
       MODE COMPTE RENDU
       ══════════════════════════════════════════════════ -->
  <div id="maryan-cr-mode" class="maryan-mode-screen" style="display:none">
    <header class="mode-header">
      <button class="mode-back-btn" data-hub-back type="button">← Changer de mode</button>
      <span class="mode-header-title">Compte rendu de réunion</span>
    </header>

    <div class="mode-body">
      <!-- Phase 1 : saisie -->
      <div id="cr-input-phase">
        <div class="mode-card">
          <div class="cr-tabs">
            <button class="cr-tab cr-tab--active" data-cr-tab="paste" type="button">📝 Coller une transcription</button>
            <button class="cr-tab" data-cr-tab="voice" type="button">🎙️ Dictée vocale</button>
          </div>

          <div id="cr-paste-panel" class="cr-panel">
            <label class="cr-label" for="cr-textarea">Collez la transcription ou le contenu brut de la réunion</label>
            <textarea id="cr-textarea" class="cr-textarea" rows="10" placeholder="Copiez-collez ici le contenu brut : transcription, notes, PV…"></textarea>
          </div>

          <div id="cr-voice-panel" class="cr-panel" style="display:none">
            <div class="cr-voice-controls">
              <button id="cr-mic-btn" class="cr-mic-btn" type="button" aria-label="Démarrer la dictée">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3Z"/><path d="M17 11c0 2.76-2.24 5-5 5s-5-2.24-5-5H5c0 3.53 2.61 6.43 6 6.92V21h2v-3.08c3.39-.49 6-3.39 6-6.92h-2Z"/></svg>
                <span id="cr-mic-label">Démarrer la dictée</span>
              </button>
              <p id="cr-mic-status" class="cr-mic-status">Cliquez pour dicter votre réunion en temps réel.</p>
            </div>
            <textarea id="cr-voice-textarea" class="cr-textarea cr-textarea--voice" rows="8" placeholder="La transcription apparaîtra ici…" readonly></textarea>
          </div>

          <p id="cr-input-error" class="mode-error" style="display:none"></p>

          <div class="mode-actions">
            <button id="cr-generate-btn" class="btn-mode-primary" type="button">
              <span id="cr-btn-label">Générer le compte rendu</span>
              <span id="cr-btn-spinner" class="mode-spinner" style="display:none"></span>
            </button>
          </div>
        </div>
      </div>

      <!-- Phase 2 : résultat -->
      <div id="cr-result-phase" style="display:none">
        <div class="mode-card">
          <div class="result-actions-top">
            <h2 class="result-heading">Compte rendu généré</h2>
            <div class="result-btn-row">
              <button id="cr-copy-btn" class="btn-mode-secondary" type="button">Copier</button>
              <button id="cr-save-btn" class="btn-mode-secondary" type="button">Sauvegarder</button>
              <button id="cr-new-btn" class="btn-mode-outline" type="button">Nouvelle réunion</button>
            </div>
          </div>
          <p id="cr-save-status" class="save-status" style="display:none"></p>
          <div id="cr-result-content" class="result-markdown"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════
       MODE DOCUMENT
       ══════════════════════════════════════════════════ -->
  <div id="maryan-doc-mode" class="maryan-mode-screen" style="display:none">
    <header class="mode-header">
      <button class="mode-back-btn" data-hub-back type="button">← Changer de mode</button>
      <span class="mode-header-title">Décrypter un document</span>
    </header>

    <div class="mode-body">
      <!-- Phase 1 : upload -->
      <div id="doc-input-phase">
        <div class="mode-card">
          <p class="mode-intro">Déposez un document — MARYAN vous en donne les points essentiels.</p>

          <div id="doc-drop-zone" class="doc-drop-zone" role="button" tabindex="0" aria-label="Zone de dépôt de fichier">
            <div class="doc-drop-icon">📄</div>
            <p class="doc-drop-title">Glissez votre document ici</p>
            <p class="doc-drop-sub">ou <button type="button" id="doc-browse-btn" class="btn-inline-link">choisissez un fichier</button></p>
            <p class="doc-drop-formats">PDF, JPG, PNG · max 10 Mo</p>
            <input type="file" id="doc-file-input" accept=".pdf,image/jpeg,image/png" style="display:none" />
          </div>

          <div id="doc-file-preview" class="doc-file-preview" style="display:none">
            <span class="doc-file-icon">📎</span>
            <span id="doc-file-name" class="doc-file-name"></span>
            <button type="button" id="doc-remove-file" class="doc-remove-btn" aria-label="Supprimer">✕</button>
          </div>

          <div class="form-group-doc">
            <label class="form-label-doc" for="doc-type-select">Type de document</label>
            <select id="doc-type-select" class="form-select-doc">
              <option value="deliberation">Délibération</option>
              <option value="ordre_du_jour">Ordre du jour</option>
              <option value="budget">Document budgétaire</option>
              <option value="courrier">Courrier reçu</option>
              <option value="autre">Autre</option>
            </select>
          </div>

          <p id="doc-input-error" class="mode-error" style="display:none"></p>

          <div class="mode-actions">
            <button id="doc-analyse-btn" class="btn-mode-primary" type="button" disabled>
              <span id="doc-btn-label">Analyser le document</span>
              <span id="doc-btn-spinner" class="mode-spinner" style="display:none"></span>
            </button>
          </div>
        </div>
      </div>

      <!-- Phase 2 : résultat -->
      <div id="doc-result-phase" style="display:none">
        <div class="mode-card">
          <div class="result-actions-top">
            <h2 class="result-heading">Analyse du document</h2>
            <div class="result-btn-row">
              <button id="doc-copy-btn" class="btn-mode-secondary" type="button">Copier</button>
              <button id="doc-save-btn" class="btn-mode-secondary" type="button">Sauvegarder</button>
              <button id="doc-new-btn" class="btn-mode-outline" type="button">Nouveau document</button>
            </div>
          </div>
          <p id="doc-save-status" class="save-status" style="display:none"></p>

          <div class="doc-result-blocks">
            <div class="doc-result-block">
              <p class="doc-result-label">En résumé</p>
              <p id="doc-res-resume" class="doc-result-text"></p>
            </div>
            <div class="doc-result-block">
              <p class="doc-result-label">Points d'attention</p>
              <ul id="doc-res-attention" class="doc-result-list"></ul>
            </div>
            <div class="doc-result-block">
              <p class="doc-result-label">Ce que ça engage</p>
              <p id="doc-res-engagements" class="doc-result-text"></p>
            </div>
            <div class="doc-result-block doc-result-block--accent">
              <p class="doc-result-label">Prochaine étape suggérée</p>
              <p id="doc-res-prochain" class="doc-result-text"></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════
       MODE CHAT — copilote existant (masqué par défaut)
       ══════════════════════════════════════════════════ -->
  <div class="copilot-app-root" data-maryan-copilot-root data-upgrade-url="/offres" data-endpoint="/api/chat" style="display:none">
    <div class="drawer-overlay" data-drawer-overlay></div>

    <aside class="profile-drawer" data-profile-drawer aria-label="Profil MARYAN">
      <div class="drawer-top">
        <div>
          <p class="drawer-kicker">Votre espace</p>
          <h2>Profil et niveau d'appui</h2>
        </div>
        <button class="drawer-close" type="button" aria-label="Fermer" data-close-drawer>×</button>
      </div>

      <div class="drawer-panel hidden" data-profile-filled>
        <p class="drawer-status" data-profile-status></p>
        <h3 class="drawer-name" data-profile-name>—</h3>
        <p class="drawer-summary" data-profile-summary></p>
        <div class="drawer-tags" data-profile-tags></div>
        <div class="drawer-note">
          MARYAN tient compte de votre profil pour nuancer la pédagogie, le niveau de cadrage et le type d'appui proposé.
        </div>
      </div>

      <div class="drawer-panel" data-profile-empty>
        <p class="drawer-status">Mode libre actif</p>
        <div class="drawer-note" set:html={PROFILE_REQUIRED_HTML}></div>
      </div>

      <div class="drawer-links">
        <a href="/diagnostic">Faire le diagnostic</a>
        <a href="/mon-compte">Mon espace MARYAN</a>
        <a href="/offres">Voir les offres</a>
      </div>
    </aside>

    <div class="chat-shell">
      <header class="app-header">
        <button class="home-link" type="button" data-hub-back>← Changer de mode</button>

        <div class="header-copy">
          <span class="app-title">MARYAN</span>
          <span class="app-subtitle">Copilote de mandat</span>
        </div>

        <div class="header-meta">
          <span class="mode-pill" data-mode-badge>Version libre</span>
          <span class="counter-label" data-counter-label>{FREE_LIMIT}/{FREE_LIMIT}</span>
        </div>

        <button class="profile-trigger" type="button" aria-label="Ouvrir le profil" data-open-drawer>
          <span class="profile-trigger-icon">M</span>
        </button>
      </header>

      <main class="chat-thread" data-chat-thread>
        <div class="chat-inner">
          <section class="intro-card" data-intro-card>
            <p class="intro-kicker">Le bon niveau d'appui, au bon moment</p>
            <h1>Parlez d'abord de ce que vous vivez.</h1>
            <p class="intro-text">
              Décrivez une situation concrète, un stress, un arbitrage, une prise de parole ou un dossier
              qui vous bloque. MARYAN commence par lire la situation avant de proposer une réponse.
            </p>
            <div class="counter-row">
              <div class="counter-dots" data-counter-dots></div>
              <span class="counter-caption">Version libre : 5 messages par session</span>
            </div>
            <p class="intro-linkline">
              Pour des réponses plus personnalisées, vous pouvez aussi <a href="/diagnostic">faire le diagnostic</a>.
            </p>
          </section>

          <div class="messages-container" data-messages>
            <article class="msg assistant">
              <span class="msg-sender">MARYAN</span>
              <div class="msg-bubble">
                {WELCOME_PARAGRAPHS.map((paragraph) => <p>{paragraph}</p>)}
              </div>
            </article>
          </div>

          <section class="suggestions-strip" data-suggestions>
            <!-- Notice RGPD tiers — AIPD R3 -->
            <p class="tiers-notice">🔒 Pour protéger les données des personnes que vous mentionnez, évitez d'indiquer des noms ou informations permettant d'identifier des tiers (collègues, agents, élus).</p>

            <!-- Parcours types : 3 portes d'entrée situationnelles -->
            <p class="suggestions-title">Quelle est votre situation ?</p>
            <div class="parcours-grid">
              {PARCOURS_TYPES.map((p) => (
                <button type="button" class="parcours-card" data-suggestion={p.message}>
                  <span class="parcours-icon">{p.icon}</span>
                  <span class="parcours-label">{p.label}</span>
                  <span class="parcours-desc">{p.description}</span>
                </button>
              ))}
            </div>

            <!-- Exemples libres -->
            <p class="suggestions-title suggestions-title-secondary">Ou décrivez librement</p>
            <div class="suggestions-grid">
              {SUGGESTIONS.map((suggestion) => (
                <button type="button" class="suggestion-chip" data-suggestion={suggestion}>
                  {suggestion}
                </button>
              ))}
            </div>
          </section>
        </div>
      </main>

      <footer class="app-input-bar">
        <p class="privacy-notice">Pour votre confidentialité, évitez de mentionner des noms de personnes ou des informations permettant d'identifier des tiers.</p>
        <div class="attach-preview hidden" data-attach-preview>
          <span data-attach-filename class="attach-preview-name"></span>
          <button type="button" class="attach-remove-btn" data-remove-attach title="Retirer">✕</button>
        </div>
        <div class="input-shell">
          <button class="mic-btn" type="button" aria-label="Dicter" data-mic-btn>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3Z"></path>
              <path d="M17 11c0 2.76-2.24 5-5 5s-5-2.24-5-5H5c0 3.53 2.61 6.43 6 6.92V21h2v-3.08c3.39-.49 6-3.39 6-6.92h-2Z"></path>
            </svg>
          </button>

          <button class="attach-btn" type="button" aria-label="Joindre un document" data-attach-btn>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 18 8.84l-8.59 8.57a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
          </button>
          <input type="file" style="display:none" accept=".pdf,image/png,image/jpeg,image/webp,image/jpg" data-attach-input>

          <label class="input-wrap">
            <span class="sr-only">Votre message</span>
            <textarea
              rows="1"
              data-user-input
              placeholder="Décrivez votre situation..."
              aria-label="Votre message à MARYAN"
            ></textarea>
          </label>

          <button class="send-btn" type="button" aria-label="Envoyer" data-send-btn>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M2.01 21 23 12 2.01 3 2 10l15 2-15 2Z"></path>
            </svg>
          </button>
        </div>

        <p class="input-hint" data-input-hint>Version libre · 5 messages restants</p>
      </footer>
    </div>
  </div>

  <script>
    import './client.ts';
  </script>

  <!-- Hub + mode management -->
  <script>
    import { createClient } from '@supabase/supabase-js';

    const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL as string;
    const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY as string;

    const COMPTE_RENDU_SYSTEM = `Tu es MARYAN, assistant des élus municipaux français.
On te fournit la transcription brute d'une réunion. Produis un compte rendu structuré, sobre et directement utile pour un élu.

FORMAT DE SORTIE :

## 📅 Réunion
- Date : [si mentionnée, sinon "non précisée"]
- Participants : [noms ou rôles mentionnés]
- Objet : [sujet principal en une phrase]

## ✅ Décisions prises
[Liste des décisions actées. Si aucune : "Aucune décision formelle actée."]

## ⏳ Points en suspens
[Ce qui n'a pas été tranché. Si aucun : "Aucun."]

## 📌 Actions à faire
[Format : Action — Responsable (si mentionné) — Échéance (si mentionnée)]

## 💬 Verbatim notable
[1 à 3 phrases importantes entre guillemets. Uniquement si vraiment significatif.]

## ❓ Questions pour la suite
[2 à 4 questions utiles pour avancer — pas rhétoriques.]

## 💡 Suggestions MARYAN
[1 à 2 pistes concrètes. Peut renvoyer à une thématique ressources MARYAN si pertinent.]

RÈGLES : ton sobre et factuel, pas de remplissage, ne jamais inventer, suggestions spécifiques, maximum 600 mots.`;

    // ── Markdown minimal renderer ──────────────────────────────────
    function renderMarkdown(md: string): string {
      const esc = (s: string) => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      const lines = md.split('\n');
      const out: string[] = [];
      let inList = false;

      for (const raw of lines) {
        const line = raw.trimEnd();

        if (line.startsWith('## ')) {
          if (inList) { out.push('</ul>'); inList = false; }
          out.push(`<h2 class="md-h2">${esc(line.slice(3))}</h2>`);
        } else if (line.startsWith('### ')) {
          if (inList) { out.push('</ul>'); inList = false; }
          out.push(`<h3 class="md-h3">${esc(line.slice(4))}</h3>`);
        } else if (line.startsWith('- ') || line.startsWith('* ')) {
          if (!inList) { out.push('<ul class="md-list">'); inList = true; }
          out.push(`<li>${inlineMarkdown(line.slice(2))}</li>`);
        } else if (line === '') {
          if (inList) { out.push('</ul>'); inList = false; }
          out.push('<br>');
        } else {
          if (inList) { out.push('</ul>'); inList = false; }
          out.push(`<p class="md-p">${inlineMarkdown(line)}</p>`);
        }
      }
      if (inList) out.push('</ul>');
      return out.join('\n');
    }

    function inlineMarkdown(s: string): string {
      const esc = (t: string) => t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      return esc(s)
        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.+?)\*/g, '<em>$1</em>')
        .replace(/`(.+?)`/g, '<code>$1</code>');
    }

    // ── Mode state ─────────────────────────────────────────────────
    type HubMode = 'compte-rendu' | 'document' | 'chat' | null;
    let currentMode: HubMode = null;

    const hubEl = document.getElementById('maryan-hub')!;
    const crModeEl = document.getElementById('maryan-cr-mode')!;
    const docModeEl = document.getElementById('maryan-doc-mode')!;
    const chatRootEl = document.querySelector('[data-maryan-copilot-root]') as HTMLElement;

    function showHub() {
      currentMode = null;
      hubEl.style.display = '';
      crModeEl.style.display = 'none';
      docModeEl.style.display = 'none';
      chatRootEl.style.display = 'none';
    }

    function showMode(mode: HubMode) {
      currentMode = mode;
      hubEl.style.display = 'none';
      crModeEl.style.display = mode === 'compte-rendu' ? '' : 'none';
      docModeEl.style.display = mode === 'document' ? '' : 'none';
      chatRootEl.style.display = mode === 'chat' ? '' : 'none';
    }

    // Hub card clicks
    document.querySelectorAll('[data-hub-mode]').forEach(btn => {
      btn.addEventListener('click', () => {
        const mode = btn.getAttribute('data-hub-mode') as HubMode;
        showMode(mode);
      });
    });

    // Back buttons
    document.querySelectorAll('[data-hub-back]').forEach(btn => {
      btn.addEventListener('click', showHub);
    });

    // Check URL param ?mode= and ?intent=
    const urlParams = new URLSearchParams(window.location.search);
    const paramMode = urlParams.get('mode') as HubMode;
    const paramIntent = urlParams.get('intent');

    if (paramMode && ['compte-rendu', 'document', 'chat'].includes(paramMode)) {
      showMode(paramMode);
    }

    if (paramIntent) {
      const INTENT_PREFILLS: Record<string, string> = {
        comprendre: "Je voudrais comprendre une situation dans mon mandat : ",
        decider: "Je dois prendre une décision importante et j'ai besoin d'aide pour l'arbitrer : ",
        sensible: "Je gère une situation sensible dans mon mandat : ",
        rediger: "Je dois rédiger une réponse et j'ai besoin d'aide pour la formuler : "
      };
      const prefill = INTENT_PREFILLS[paramIntent];
      if (prefill) {
        const chatInput = document.querySelector('[data-user-input]') as HTMLTextAreaElement | null;
        if (chatInput) {
          chatInput.value = prefill;
          chatInput.focus();
          // Trigger resize if the textarea auto-resizes
          chatInput.dispatchEvent(new Event('input'));
          // Place cursor at end
          chatInput.selectionStart = chatInput.selectionEnd = prefill.length;
        }
        // Ensure we're in chat mode
        if (!paramMode || paramMode === 'chat') {
          showMode('chat');
        }
      }
    }

    // ── Auth helper ────────────────────────────────────────────────
    async function getAccessToken(): Promise<string | null> {
      if (!SUPABASE_URL || !SUPABASE_KEY) return null;
      const supabase = createClient(SUPABASE_URL, SUPABASE_KEY);
      const { data: { session } } = await supabase.auth.getSession();
      return session?.access_token || null;
    }

    // ═══════════════════════════════════════════════════════════
    // MODE COMPTE RENDU
    // ═══════════════════════════════════════════════════════════
    let crResult = '';
    let crRecognition: SpeechRecognition | null = null;
    let crIsRecording = false;

    // Tab switching
    document.querySelectorAll('[data-cr-tab]').forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-cr-tab')!;
        document.querySelectorAll('[data-cr-tab]').forEach(t => t.classList.remove('cr-tab--active'));
        tab.classList.add('cr-tab--active');
        (document.getElementById('cr-paste-panel') as HTMLElement).style.display = target === 'paste' ? '' : 'none';
        (document.getElementById('cr-voice-panel') as HTMLElement).style.display = target === 'voice' ? '' : 'none';
      });
    });

    // Voice dictation
    const crMicBtn = document.getElementById('cr-mic-btn')!;
    const crMicLabel = document.getElementById('cr-mic-label')!;
    const crMicStatus = document.getElementById('cr-mic-status')!;
    const crVoiceTextarea = document.getElementById('cr-voice-textarea') as HTMLTextAreaElement;

    crMicBtn.addEventListener('click', () => {
      const SpeechRecognition = (window as any).SpeechRecognition || (window as any).webkitSpeechRecognition;
      if (!SpeechRecognition) {
        crMicStatus.textContent = 'La dictée vocale n\'est pas supportée par ce navigateur.';
        return;
      }

      if (crIsRecording && crRecognition) {
        crRecognition.stop();
        return;
      }

      crRecognition = new SpeechRecognition();
      crRecognition.lang = 'fr-FR';
      crRecognition.continuous = true;
      crRecognition.interimResults = true;

      let finalTranscript = crVoiceTextarea.value;

      crRecognition.onstart = () => {
        crIsRecording = true;
        crMicBtn.classList.add('cr-mic-btn--recording');
        crMicLabel.textContent = 'Arrêter la dictée';
        crMicStatus.textContent = '🔴 Dictée en cours…';
      };

      crRecognition.onresult = (event: SpeechRecognitionEvent) => {
        let interim = '';
        for (let i = event.resultIndex; i < event.results.length; i++) {
          const transcript = event.results[i][0].transcript;
          if (event.results[i].isFinal) {
            finalTranscript += transcript + ' ';
          } else {
            interim = transcript;
          }
        }
        crVoiceTextarea.value = finalTranscript + interim;
      };

      crRecognition.onend = () => {
        crIsRecording = false;
        crMicBtn.classList.remove('cr-mic-btn--recording');
        crMicLabel.textContent = 'Démarrer la dictée';
        crMicStatus.textContent = 'Dictée terminée. Cliquez sur "Générer" pour obtenir le compte rendu.';
      };

      crRecognition.onerror = () => {
        crIsRecording = false;
        crMicBtn.classList.remove('cr-mic-btn--recording');
        crMicLabel.textContent = 'Démarrer la dictée';
        crMicStatus.textContent = 'Erreur de dictée. Réessayez.';
      };

      crRecognition.start();
    });

    // Generate compte rendu
    const crGenerateBtn = document.getElementById('cr-generate-btn') as HTMLButtonElement;
    const crBtnLabel = document.getElementById('cr-btn-label')!;
    const crBtnSpinner = document.getElementById('cr-btn-spinner')!;
    const crInputError = document.getElementById('cr-input-error')!;

    crGenerateBtn.addEventListener('click', async () => {
      const activeTab = (document.querySelector('[data-cr-tab].cr-tab--active') as HTMLElement)?.getAttribute('data-cr-tab');
      const transcription = activeTab === 'voice'
        ? (crVoiceTextarea.value || '').trim()
        : ((document.getElementById('cr-textarea') as HTMLTextAreaElement).value || '').trim();

      if (!transcription) {
        crInputError.textContent = 'Veuillez saisir ou dicter une transcription.';
        crInputError.style.display = 'block';
        return;
      }
      crInputError.style.display = 'none';

      crGenerateBtn.disabled = true;
      crBtnLabel.style.display = 'none';
      crBtnSpinner.style.display = 'inline-block';

      try {
        const token = await getAccessToken();
        const headers: Record<string, string> = { 'Content-Type': 'application/json' };
        if (token) headers['Authorization'] = `Bearer ${token}`;

        const res = await fetch('/api/chat', {
          method: 'POST',
          headers,
          body: JSON.stringify({
            messages: [
              { role: 'user', content: transcription }
            ],
            message: transcription,
            _overrideSystemPrompt: COMPTE_RENDU_SYSTEM
          })
        });

        const data = await res.json() as Record<string, any>;

        if (!res.ok || data.error) {
          throw new Error(data.message || data.error || 'Erreur lors de la génération.');
        }

        crResult = data.reply || '';
        document.getElementById('cr-result-content')!.innerHTML = renderMarkdown(crResult);
        document.getElementById('cr-input-phase')!.style.display = 'none';
        document.getElementById('cr-result-phase')!.style.display = '';
      } catch (e: any) {
        crInputError.textContent = e.message || 'Erreur de connexion. Réessayez.';
        crInputError.style.display = 'block';
      } finally {
        crGenerateBtn.disabled = false;
        crBtnLabel.style.display = 'inline';
        crBtnSpinner.style.display = 'none';
      }
    });

    // Copy CR
    document.getElementById('cr-copy-btn')?.addEventListener('click', () => {
      navigator.clipboard.writeText(crResult).then(() => {
        const btn = document.getElementById('cr-copy-btn')!;
        btn.textContent = '✓ Copié';
        setTimeout(() => { btn.textContent = 'Copier'; }, 2000);
      });
    });

    // Save CR
    document.getElementById('cr-save-btn')?.addEventListener('click', async () => {
      const token = await getAccessToken();
      if (!token) {
        showSaveStatus('cr', 'Connectez-vous pour sauvegarder.', true);
        return;
      }
      const saveBtn = document.getElementById('cr-save-btn') as HTMLButtonElement;
      saveBtn.disabled = true;
      try {
        const res = await fetch('/api/documents', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
          body: JSON.stringify({ type: 'compte-rendu', contenu: crResult, generate_title: true })
        });
        const data = await res.json() as Record<string, any>;
        if (!res.ok) throw new Error(data.error || 'Erreur');
        showSaveStatus('cr', `✓ Sauvegardé : "${data.document?.titre || 'Document'}"`, false);
      } catch (e: any) {
        showSaveStatus('cr', e.message, true);
      } finally {
        saveBtn.disabled = false;
      }
    });

    // New CR
    document.getElementById('cr-new-btn')?.addEventListener('click', () => {
      crResult = '';
      (document.getElementById('cr-textarea') as HTMLTextAreaElement).value = '';
      crVoiceTextarea.value = '';
      document.getElementById('cr-result-content')!.innerHTML = '';
      document.getElementById('cr-result-phase')!.style.display = 'none';
      document.getElementById('cr-input-phase')!.style.display = '';
      document.getElementById('cr-save-status')!.style.display = 'none';
    });

    // ═══════════════════════════════════════════════════════════
    // MODE DOCUMENT
    // ═══════════════════════════════════════════════════════════
    let docSelectedFile: File | null = null;
    let docResultText = '';
    let docFileName = '';

    const docDropZone = document.getElementById('doc-drop-zone')!;
    const docFileInput = document.getElementById('doc-file-input') as HTMLInputElement;
    const docBrowseBtn = document.getElementById('doc-browse-btn')!;
    const docFilePreview = document.getElementById('doc-file-preview')!;
    const docFileNameEl = document.getElementById('doc-file-name')!;
    const docRemoveFile = document.getElementById('doc-remove-file')!;
    const docAnalyseBtn = document.getElementById('doc-analyse-btn') as HTMLButtonElement;
    const docInputError = document.getElementById('doc-input-error')!;

    docBrowseBtn.addEventListener('click', () => docFileInput.click());
    docDropZone.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') docFileInput.click();
    });
    docDropZone.addEventListener('dragover', (e: DragEvent) => {
      e.preventDefault();
      docDropZone.classList.add('doc-drop-zone--over');
    });
    docDropZone.addEventListener('dragleave', () => docDropZone.classList.remove('doc-drop-zone--over'));
    docDropZone.addEventListener('drop', (e: DragEvent) => {
      e.preventDefault();
      docDropZone.classList.remove('doc-drop-zone--over');
      const file = e.dataTransfer?.files?.[0];
      if (file) handleDocFile(file);
    });
    docFileInput.addEventListener('change', () => {
      if (docFileInput.files?.[0]) handleDocFile(docFileInput.files[0]);
    });
    docRemoveFile.addEventListener('click', () => {
      docSelectedFile = null;
      docFileInput.value = '';
      docFilePreview.style.display = 'none';
      docDropZone.style.display = '';
      docAnalyseBtn.disabled = true;
    });

    function handleDocFile(file: File) {
      const maxSize = 10 * 1024 * 1024;
      const allowed = ['application/pdf', 'image/jpeg', 'image/png'];
      if (!allowed.includes(file.type)) {
        docInputError.textContent = 'Format non supporté. Utilisez PDF, JPG ou PNG.';
        docInputError.style.display = 'block';
        return;
      }
      if (file.size > maxSize) {
        docInputError.textContent = 'Fichier trop volumineux (max 10 Mo).';
        docInputError.style.display = 'block';
        return;
      }
      docInputError.style.display = 'none';
      docSelectedFile = file;
      docFileName = file.name;
      docFileNameEl.textContent = file.name;
      docFilePreview.style.display = 'flex';
      docDropZone.style.display = 'none';
      docAnalyseBtn.disabled = false;
    }

    docAnalyseBtn.addEventListener('click', async () => {
      if (!docSelectedFile) return;
      const docBtnLabel = document.getElementById('doc-btn-label')!;
      const docBtnSpinner = document.getElementById('doc-btn-spinner')!;
      docAnalyseBtn.disabled = true;
      docBtnLabel.style.display = 'none';
      docBtnSpinner.style.display = 'inline-block';
      docInputError.style.display = 'none';

      try {
        const token = await getAccessToken();
        const docType = (document.getElementById('doc-type-select') as HTMLSelectElement).value;
        const base64 = await fileToBase64(docSelectedFile);
        const headers: Record<string, string> = { 'Content-Type': 'application/json' };
        if (token) headers['Authorization'] = `Bearer ${token}`;

        const res = await fetch('/api/analyse', {
          method: 'POST',
          headers,
          body: JSON.stringify({ fileData: base64, mimeType: docSelectedFile.type, docType })
        });

        const data = await res.json() as Record<string, any>;

        // Paywall : abonnement requis
        if (res.status === 401 || res.status === 403) {
          docAnalyseBtn.disabled = false;
          document.getElementById('doc-btn-label')!.style.display = 'inline';
          document.getElementById('doc-btn-spinner')!.style.display = 'none';
          docInputError.innerHTML = `
            <strong>Service réservé aux abonné·es MARYAN Plus.</strong><br>
            <a href="/offres" style="color:var(--deep);font-weight:800;text-decoration:underline">Découvrir MARYAN Plus →</a>
          `;
          docInputError.style.display = 'block';
          return;
        }

        if (!res.ok || data.error) throw new Error(data.error || 'Erreur lors de l\'analyse.');

        // Build text for copy/save
        docResultText = [
          `# Analyse : ${docFileName}`,
          '',
          `## En résumé`,
          data.resume || '',
          '',
          `## Points d'attention`,
          ...(Array.isArray(data.pointsAttention) ? data.pointsAttention.map((p: string) => `- ${p}`) : []),
          '',
          `## Ce que ça engage`,
          data.engagements || '',
          '',
          `## Prochaine étape suggérée`,
          data.prochainEtape || ''
        ].join('\n');

        document.getElementById('doc-res-resume')!.textContent = data.resume || '';
        document.getElementById('doc-res-engagements')!.textContent = data.engagements || '';
        document.getElementById('doc-res-prochain')!.textContent = data.prochainEtape || '';

        const ul = document.getElementById('doc-res-attention')!;
        ul.innerHTML = (Array.isArray(data.pointsAttention) ? data.pointsAttention : [])
          .map((p: string) => `<li>${p}</li>`).join('');

        document.getElementById('doc-input-phase')!.style.display = 'none';
        document.getElementById('doc-result-phase')!.style.display = '';
      } catch (e: any) {
        docInputError.textContent = e.message || 'Erreur de connexion. Réessayez.';
        docInputError.style.display = 'block';
        docAnalyseBtn.disabled = false;
        document.getElementById('doc-btn-label')!.style.display = 'inline';
        document.getElementById('doc-btn-spinner')!.style.display = 'none';
      } finally {
        docBtnLabel.style.display = 'inline';
        docBtnSpinner.style.display = 'none';
      }
    });

    // Copy doc result
    document.getElementById('doc-copy-btn')?.addEventListener('click', () => {
      navigator.clipboard.writeText(docResultText).then(() => {
        const btn = document.getElementById('doc-copy-btn')!;
        btn.textContent = '✓ Copié';
        setTimeout(() => { btn.textContent = 'Copier'; }, 2000);
      });
    });

    // Save doc result
    document.getElementById('doc-save-btn')?.addEventListener('click', async () => {
      const token = await getAccessToken();
      if (!token) {
        showSaveStatus('doc', 'Connectez-vous pour sauvegarder.', true);
        return;
      }
      const saveBtn = document.getElementById('doc-save-btn') as HTMLButtonElement;
      saveBtn.disabled = true;
      try {
        const res = await fetch('/api/documents', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
          body: JSON.stringify({ type: 'document', contenu: docResultText, source_nom: docFileName, generate_title: true })
        });
        const data = await res.json() as Record<string, any>;
        if (!res.ok) throw new Error(data.error || 'Erreur');
        showSaveStatus('doc', `✓ Sauvegardé : "${data.document?.titre || 'Document'}"`, false);
      } catch (e: any) {
        showSaveStatus('doc', e.message, true);
      } finally {
        saveBtn.disabled = false;
      }
    });

    // New doc analysis
    document.getElementById('doc-new-btn')?.addEventListener('click', () => {
      docSelectedFile = null;
      docResultText = '';
      docFileName = '';
      docFileInput.value = '';
      docFilePreview.style.display = 'none';
      docDropZone.style.display = '';
      docAnalyseBtn.disabled = true;
      document.getElementById('doc-result-phase')!.style.display = 'none';
      document.getElementById('doc-input-phase')!.style.display = '';
      document.getElementById('doc-save-status')!.style.display = 'none';
    });

    // ── Shared helpers ─────────────────────────────────────────────
    function showSaveStatus(mode: 'cr' | 'doc', message: string, isError: boolean) {
      const el = document.getElementById(`${mode}-save-status`)!;
      el.textContent = message;
      el.className = 'save-status' + (isError ? ' save-status--error' : ' save-status--ok');
      el.style.display = 'block';
      if (!isError) setTimeout(() => { el.style.display = 'none'; }, 4000);
    }

    function fileToBase64(file: File): Promise<string> {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve((reader.result as string).split(',')[1]);
        reader.onerror = reject;
        reader.readAsDataURL(file);
      });
    }
  </script>

