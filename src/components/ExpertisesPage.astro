---
import BaseLayout from '../layouts/BaseLayout.astro';
import ExpertiseCard from './ExpertiseCard.astro';
import { thematicExpertises, transversalExpertises } from '../data/expertises';

const orientationPaths = [
  'des ressources en autonomie',
  'un appui digital renforcé',
  'ou une expertise ciblée, lorsque la situation le justifie'
];

const methodChecks = [
  'si des ressources autonomes peuvent suffire',
  'si un appui digital régulier est plus pertinent',
  'ou si une expertise ciblée doit être activée'
];
---
<BaseLayout
  title="Les expertises mobilisables autour de votre mandat — MARYAN"
  description="MARYAN oriente les élus municipaux vers les bons outils digitaux, les bonnes ressources et, si nécessaire, les expertises les plus pertinentes."
>
  <header class="site-header">
    <div class="container header-inner">
      <div>
        <a href="/" class="brand">MARYAN</a>
        <p class="brand-sub">appui intelligent pour élus municipaux</p>
      </div>
      <a href="/" class="back-link">← Accueil</a>
    </div>
  </header>

  <main class="page-main">
    <section class="page-hero">
      <div class="container narrow">
        <p class="section-kicker">Expertises mobilisables</p>
        <h1>Les expertises mobilisables autour de votre mandat</h1>
        <p class="lead">Parce qu’un mandat local ne se résume ni à une seule question, ni à une seule réponse.</p>
        <p class="lead lead-secondary">
          Selon votre situation, votre délégation, votre niveau d’expérience et vos enjeux du moment,
          MARYAN peut vous orienter vers les bons outils digitaux, les bonnes ressources et, si nécessaire,
          vers les professionnels les plus pertinents. L’objectif n’est pas de vous envoyer systématiquement
          vers un consultant, mais de proposer l’appui juste : autonome, ciblé, progressif, utile.
        </p>
        <div class="actions">
          <a class="btn btn-primary" href="/diagnostic">Faire mon diagnostic</a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <p class="section-kicker">Orientation</p>
        <h2>Un mandat local demande souvent plusieurs types d’appui</h2>
        <div class="intro-grid">
          <article class="card content-card">
            <p>
              Prendre ses fonctions, comprendre les circuits de décision, expliquer son action, gérer son
              temps, intervenir en réunion publique, utiliser les réseaux sociaux avec discernement, faire
              face à un sujet sensible, porter une délégation technique : selon les moments, les besoins ne
              sont pas les mêmes.
            </p>
          </article>
          <article class="card content-card accent-card">
            <p class="card-subtitle">MARYAN commence par un diagnostic. Ensuite, nous orientons vers :</p>
            <ul class="feature-list">
              {orientationPaths.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        </div>
      </div>
    </section>

    <section class="section alt">
      <div class="container">
        <p class="section-kicker">Expertises transversales</p>
        <h2>Des expertises transversales pour les besoins communs du mandat</h2>
        <p class="section-intro">
          Ces expertises répondent aux besoins que beaucoup d’élus rencontrent, quelle que soit leur
          délégation : prendre leur place, s’organiser, mieux communiquer, mieux parler, mieux traverser les
          moments sensibles.
        </p>
        <div class="expertise-grid">
          {transversalExpertises.map((expertise) => <ExpertiseCard expertise={expertise} />)}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <p class="section-kicker">Expertises thématiques</p>
        <h2>Des expertises thématiques selon votre délégation ou vos sujets</h2>
        <p class="section-intro">
          Selon les dossiers du moment, certaines situations demandent aussi une lecture plus métier. MARYAN
          peut alors orienter vers l’expertise la plus cohérente avec le sujet traité.
        </p>
        <div class="expertise-grid">
          {thematicExpertises.map((expertise) => <ExpertiseCard expertise={expertise} />)}
        </div>
      </div>
    </section>

    <section class="section alt">
      <div class="container narrow">
        <p class="section-kicker">Méthode</p>
        <h2>Une méthode d’orientation, pas un catalogue figé</h2>
        <div class="cta-panel method-panel">
          <p>
            MARYAN ne mobilise pas la même expertise pour un adjoint à l’urbanisme, une élue à la culture,
            un conseiller municipal qui débute, ou un élu confronté à une séquence sensible.
          </p>
          <p class="card-subtitle">Le diagnostic permet d’abord d’identifier :</p>
          <ul class="feature-list">
            {methodChecks.map((item) => <li>{item}</li>)}
          </ul>
          <p>
            Notre logique est simple : pas de réponse standard, pas de vente forcée, mais un aiguillage
            adapté à votre réalité.
          </p>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container narrow">
        <div class="cta-panel">
          <p class="section-kicker">Commencer</p>
          <h2>Commencer par le bon diagnostic</h2>
          <p>
            Avant de vous orienter vers des ressources, des outils ou un professionnel, MARYAN vous aide à
            faire le point sur votre mandat, vos sujets et vos besoins prioritaires.
          </p>
          <div class="actions">
            <a class="btn btn-primary" href="/diagnostic">Faire mon diagnostic</a>
            <a class="btn btn-secondary" href="/offres">Découvrir les offres MARYAN</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .intro-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
    gap: 1rem;
    align-items: start;
  }

  .expertise-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .method-panel {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (max-width: 1080px) {
    .expertise-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 800px) {
    .intro-grid,
    .expertise-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
