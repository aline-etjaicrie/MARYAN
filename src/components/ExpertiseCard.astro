---
import type { ExpertiseCardData } from '../data/expertises';

interface Props {
  expertise: ExpertiseCardData;
}

const { expertise } = Astro.props;
---
<article class="card expertise-card">
  <h3>{expertise.title}</h3>

  <div class="expertise-block">
    <p class="expertise-label">À quoi sert cette expertise ?</p>
    <p>{expertise.purpose}</p>
  </div>

  <div class="expertise-block">
    <p class="expertise-label">Quand la mobiliser ?</p>
    <p>{expertise.when}</p>
  </div>

  <div class="expertise-block">
    <p class="expertise-label">Appui possible</p>
    <p>{expertise.support}</p>
  </div>
</article>

<style>
  .expertise-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
    padding-top: 1.35rem;
    overflow: hidden;
  }

  .expertise-card::before {
    content: '';
    position: absolute;
    inset: 0 auto auto 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(90deg, var(--blue), rgba(57, 255, 110, 0.65));
  }

  .expertise-card h3 {
    margin-bottom: 0;
    line-height: 1.2;
  }

  .expertise-block {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding-top: 0.95rem;
    border-top: 1px solid rgba(216, 211, 202, 0.85);
  }

  .expertise-block:first-of-type {
    padding-top: 0.2rem;
    border-top: none;
  }

  .expertise-label {
    margin: 0;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pink);
  }

  .expertise-block p:last-child {
    margin: 0;
    color: var(--muted);
    line-height: 1.55;
  }
</style>
