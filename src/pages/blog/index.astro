---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../../data/blog';

const posts = getPublishedPosts();

const CATEGORY_LABELS: Record<string, string> = {
  droits: 'Droits & statut',
  methode: 'Méthode',
  temoignage: 'Témoignage',
  actualite: 'Actualité',
  outil: 'Outil & pratique'
};

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<BaseLayout
  title="Blog — Conseils pour élus locaux | MARYAN"
  description="Articles pratiques pour les élus municipaux : droits, méthodes, gestion des conflits, prise de décision. Rédigés par l'équipe MARYAN.">

  <main class="blog-page">
    <div class="blog-hero">
      <div class="container">
        <p class="blog-label">Ressources & conseils</p>
        <h1>Le blog MARYAN</h1>
        <p class="blog-sub">Des articles pratiques pour les élus qui prennent leur mandat au sérieux. Droits, méthodes, situations difficiles — sans jargon.</p>
      </div>
    </div>

    <div class="container blog-content">
      {posts.length === 0 ? (
        <p class="no-posts">Aucun article pour le moment. Revenez bientôt.</p>
      ) : (
        <div class="posts-grid">
          {posts.map((post, i) => (
            <article class={`post-card ${i === 0 ? 'post-featured' : ''}`}>
              <div class="post-meta">
                <span class="post-category">{CATEGORY_LABELS[post.category] || post.category}</span>
                <span class="post-date">{formatDate(post.date)}</span>
                <span class="post-time">{post.readingTime} min de lecture</span>
              </div>
              <h2 class="post-title">
                <a href={`/blog/${post.slug}`}>{post.title}</a>
              </h2>
              <p class="post-excerpt">{post.excerpt}</p>
              <div class="post-tags">
                {post.tags.slice(0, 3).map(tag => (
                  <span class="post-tag">{tag}</span>
                ))}
              </div>
              <a href={`/blog/${post.slug}`} class="post-link">Lire l'article →</a>
            </article>
          ))}
        </div>
      )}
    </div>
  </main>

</BaseLayout>

<style>
  .blog-hero {
    background: var(--deep);
    padding: 4rem 1.5rem 3rem;
    color: white;
  }

  .blog-label {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--neon);
    margin-bottom: 1rem;
  }

  .blog-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }

  .blog-sub {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.6);
    max-width: 580px;
    line-height: 1.6;
  }

  .blog-content {
    padding: 3rem 1.5rem 5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .post-card {
    background: white;
    border-radius: 12px;
    padding: 2rem;
    border: 1px solid var(--border);
    transition: border-color 0.2s;
  }

  .post-card:hover { border-color: var(--deep); }

  .post-featured {
    border-color: var(--deep);
    border-width: 2px;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .post-category {
    background: var(--deep);
    color: white;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }

  .post-date, .post-time {
    font-size: 0.82rem;
    color: #888;
  }

  .post-title {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--deep);
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .post-title a {
    color: inherit;
    text-decoration: none;
  }
  .post-title a:hover { color: var(--accent-red); }

  .post-excerpt {
    font-size: 0.92rem;
    color: #54636C;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .post-tag {
    font-size: 0.75rem;
    color: #666;
    background: #f4f4f0;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }

  .post-link {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--deep);
    text-decoration: none;
  }
  .post-link:hover { color: var(--accent-red); }

  .no-posts {
    text-align: center;
    color: #888;
    padding: 4rem 0;
  }

  .container { max-width: 900px; margin: 0 auto; }
</style>
