  />

  <main>
    <section class="section-v3 bg-light">
      <div class="container container-narrow">
        <div class="about-prose intro-prose">
          <p class="lead">Les premiers articles arrivent bientôt.</p>
          <p>En attendant, retrouvez les ressources pratiques dans la <a href="/ressources">bibliothèque</a> ou posez vos questions au <a href="/copilote">copilote</a>.</p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
