---
import BaseLayout from '../layouts/BaseLayout.astro';
import InternalHeader from '../components/InternalHeader.astro';
import ExpertiseCard from '../components/ExpertiseCard.astro';
import { thematicExpertises, transversalExpertises } from '../data/expertises';

// Abstract avatars for experts (V3 Incarnation)
const expertIcons = [
  'M 12 4 L 4 20 L 20 20 Z', // Triangle
  'M 4 4 H 20 V 20 H 4 Z',   // Square
  'C 12 2, 2 12, 12 22, 22 12, 12 2 Z', // Circle/Diamond
  'M 12 2 L 15 9 H 22 L 17 14 L 19 21 L 12 17 L 5 21 L 7 14 L 2 9 H 9 Z' // Star
];
---
<BaseLayout
  title="Le Hub d'Experts — MARYAN"
  description="L'appui humain au cœur du dispositif. Une constellation d'experts pour éclairer vos arbitrages les plus sensibles."
>
  
  <InternalHeader 
    label="Appui Humain & Relais"
    title="Le Hub <span class='emphasis'>d'Experts</span> MARYAN"
    subtitle="L'IA pour la méthode, l'expertise pour l'arbitrage. Un réseau de spécialistes du mandat local pour prendre le relais quand la situation l'exige."
  />

  <main class="hub-v3-main">

    <!-- NETWORK VISUALIZATION (ABSTRACT MATIERE) -->
    <section class="section-v3 no-top bg-grid-reveal">
      <div class="bg-grid-v3"></div>
      <div class="container text-center">
        <div class="hub-vision-box card-v3 border-neon">
           <div class="constellation-svg">
              <svg width="200" height="100" viewBox="0 0 200 100">
                 <circle cx="20" cy="50" r="3" fill="var(--neon)" />
                 <circle cx="100" cy="20" r="3" fill="var(--accent-red)" />
                 <circle cx="100" cy="80" r="3" fill="var(--neon)" />
                 <circle cx="180" cy="50" r="3" fill="var(--accent-red)" />
                 <line x1="20" y1="50" x2="100" y2="20" stroke="var(--border)" stroke-width="1" />
                 <line x1="20" y1="50" x2="100" y2="80" stroke="var(--border)" stroke-width="1" />
                 <line x1="100" y1="20" x2="180" y2="50" stroke="var(--border)" stroke-width="1" />
                 <line x1="100" y1="80" x2="180" y2="50" stroke="var(--border)" stroke-width="1" />
                 <line x1="100" y1="20" x2="100" y2="80" stroke="var(--border)" stroke-dasharray="2,2" />
              </svg>
           </div>
           <h3>Un réseau <span class="emphasis">hybridé</span></h3>
           <p>
              Prendre ses fonctions, porter une délégation technique, gérer une séquence sensible... 
              Notre réseau intervient en <em class="emphasis">complémentarité</em> de MARYAN pour proposer l’appui 
              juste : autonome, ciblé, progressif et surtout utile.
           </p>
           <div class="hub-stat-v3">
              <span>+12 Experts</span>
              <span>100% Mandats Locaux</span>
           </div>
        </div>
      </div>
    </section>

    <!-- TRANSVERSAL SECTION -->
    <section class="section-v3 bg-light-ivory">
      <div class="container">
        <div class="section-header-v3">
          <span class="label-v3">Mandat & Posture</span>
          <h2>Expertises <span class="emphasis">transversales</span></h2>
          <p class="intro-v3">Pour les enjeux communs à tous les élu·es : organisation, posture et stratégie.</p>
        </div>

        <div class="hub-grid-v3">
          {transversalExpertises.map((expertise) => (
             <div class="expert-file-v3">
                <ExpertiseCard expertise={expertise} />
             </div>
          ))}
        </div>
      </div>
    </section>

    <!-- THEMATIC SECTION -->
    <section class="section-v3">
      <div class="container">
        <div class="section-header-v3">
          <span class="label-v3">Matières & Métiers</span>
          <h2>Expertises <span class="emphasis">thématiques</span></h2>
          <p class="intro-v3">Selon les dossiers du moment, certaines situations demandent un regard métier spécialisé.</p>
        </div>

        <div class="hub-grid-v3">
          {thematicExpertises.map((expertise) => (
             <div class="expert-file-v3">
                <ExpertiseCard expertise={expertise} />
             </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FINAL CTA V3 (INCARNATION) -->
    <section class="section-v3 bg-deep text-white text-center overflow-hidden">
       <div class="glow-v3 glow-red"></div>
       <div class="container-narrow">
          <div class="final-hub-box">
             <span class="label-v3">Co-construction</span>
             <h2 class="text-white">Besoin d'un <span class="emphasis text-neon">éclairage</span> humain ?</h2>
             <p class="intro-v3 text-white opacity-70">MARYAN qualifie votre besoin pour vous orienter vers l'expert le plus adapté à votre contexte local.</p>
             <div class="hub-actions-v3">
                <a href="/diagnostic" class="btn-primary-v3 big">👉 Faire mon diagnostic</a>
                <a href="/contact" class="btn-secondary-v3 dark">Contacter directement l'équipe</a>
             </div>
          </div>
       </div>
    </section>
  </main>
</BaseLayout>

<style>
  .no-top { padding-top: 0 !important; }
  .bg-light-ivory { background-color: #FDFBFA; }

  /* ─── HUB VISION ─── */
  .hub-vision-box {
    max-width: 700px; margin: 0 auto; text-align: center; padding: 4rem;
  }
  .constellation-svg { margin-bottom: 2rem; opacity: 0.8; }
  .hub-vision-box h3 { font-size: 2.25rem; margin-bottom: 1.5rem; }
  .hub-vision-box p { font-size: 1.15rem; color: #54636C; line-height: 1.6; margin-bottom: 2rem; }
  .hub-stat-v3 { display: flex; justify-content: center; gap: 3rem; font-weight: 800; font-size: 0.8rem; text-transform: uppercase; color: var(--accent-red); border-top: 1px solid var(--border); padding-top: 2rem; }

  /* ─── GRID / FILES ─── */
  .section-header-v3 { text-align: left; margin-bottom: 4rem; max-width: 600px; }
  .hub-grid-v3 { display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 2rem; }
  
  .expert-file-v3 { 
    position: relative; transition: all 0.3s ease; 
  }
  .expert-file-v3:hover { transform: translateY(-3px); }

  .final-hub-box { padding: 4rem 0; position: relative; z-index: 2; }
  .hub-actions-v3 { display: flex; flex-direction: column; align-items: center; gap: 1.5rem; margin-top: 3.5rem; }
  .btn-secondary-v3.dark { background: transparent; color: white; border-color: rgba(255,255,255,0.2); }
  .btn-secondary-v3.dark:hover { border-color: white; background: rgba(255,255,255,0.05); }

  @media (max-width: 768px) {
    .hub-grid-v3 { grid-template-columns: 1fr; }
    .hub-vision-box { padding: 3rem 1.5rem; }
    .section-header-v3 { text-align: center; }
  }
</style>
