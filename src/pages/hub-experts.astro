---
import BaseLayout from '../layouts/BaseLayout.astro';
import InternalHeader from '../components/InternalHeader.astro';

const expertises = [
  {
    icon: '⚖️',
    title: 'Juridique & déontologie',
    desc: 'Risques pénaux, conflits d\'intérêts, protection fonctionnelle, obligations statutaires.'
  },
  {
    icon: '💰',
    title: 'Finances publiques & budget',
    desc: 'Lecture d\'un budget, marges de manœuvre, arbitrages financiers, dette et investissement.'
  },
  {
    icon: '👥',
    title: 'RH & management territorial',
    desc: 'Relations avec les agents, conflits internes, management de l\'administration, situations de tension.'
  },
  {
    icon: '🎤',
    title: 'Communication & prise de parole',
    desc: 'Gestion de crise, prise de parole publique, relations médias, communication de mandat.'
  },
  {
    icon: '🏛️',
    title: 'Gouvernance & stratégie territoriale',
    desc: 'Conduite de projet, relations intercommunales, pilotage politique, gouvernance locale.'
  },
  {
    icon: '🛡️',
    title: 'Prévention des risques & VSS',
    desc: 'Situations de harcèlement, VSS, signalement, posture de l\'élu face aux situations sensibles.'
  }
];

const steps = [
  {
    num: '01',
    title: 'Vous identifiez votre besoin',
    text: 'Le copilote vous a aidé à cadrer. Vous savez ce dont vous avez besoin. Vous cherchez le bon interlocuteur.'
  },
  {
    num: '02',
    title: 'Vous êtes orienté vers le bon profil',
    text: 'Selon votre situation, votre mandat, votre collectivité — pas un annuaire, une orientation ciblée.'
  },
  {
    num: '03',
    title: 'Vous échangez directement',
    text: 'Conseil ponctuel, relecture, accompagnement — selon ce que l\'expert propose et ce dont vous avez besoin.'
  }
];
---

<BaseLayout
  title="Hub experts — MARYAN"
  description="Quand le copilote ne suffit plus. MARYAN vous oriente vers des experts du mandat local — juridique, finances, RH, communication, gouvernance."
>
  <InternalHeader
    label="Hub experts"
    title="Quand MARYAN <span class='emphasis'>ne suffit plus</span>."
    subtitle="Le copilote cadre, les ressources construisent. Parfois il faut un regard humain, spécialisé, sur votre situation. C'est le rôle du hub."
  />

  <main>

    <!-- INTRO -->
    <section class="section-v3">
      <div class="container-narrow">
        <p class="hub-intro-text">
          Les ressources donnent le socle. Le copilote aide à formuler et cadrer.
          Le hub prend le relais quand il faut un regard contextuel, qualifié, humain —
          ou quand un crédit formation peut financer un accompagnement sur mesure.
        </p>
      </div>
    </section>

    <!-- EXPERTISES -->
    <section class="section-v3 bg-light">
      <div class="container">
        <div class="hub-section-head">
          <span class="label-v3">Expertises</span>
          <h2>Les domaines où un expert <span class="hub-accent">fait la différence</span>.</h2>
        </div>
        <div class="hub-expertises-grid">
          {expertises.map((exp) => (
            <article class="card-v3 hub-expertise-card">
              <span class="hub-expertise-icon">{exp.icon}</span>
              <h3>{exp.title}</h3>
              <p>{exp.desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- COMMENT ÇA MARCHE -->
    <section class="section-v3">
      <div class="container">
        <div class="hub-section-head">
          <span class="label-v3">Fonctionnement</span>
          <h2>Simple. <span class="hub-accent">Sans engagement</span>.</h2>
        </div>
        <div class="hub-steps-grid">
          {steps.map((step) => (
            <article class="card-v3 hub-step-card">
              <span class="hub-step-num">{step.num}</span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </article>
          ))}
        </div>
        <div class="hub-dif-encart">
          <p>
            Certains accompagnements sont mobilisables via le <strong>Droit Individuel à la Formation
            des élus (DIF élu)</strong>. Renseignez-vous auprès de votre référent formation ou
            contactez-nous pour être orienté·e.
          </p>
          <a
            href="https://www.collectivites-locales.gouv.fr/finances-locales/droit-individuel-la-formation-des-elus"
            target="_blank"
            rel="noopener noreferrer"
            class="hub-dif-link"
          >En savoir plus sur le DIF élu →</a>
        </div>
      </div>
    </section>

    <!-- DEUX CTA -->
    <section class="section-v3 bg-light">
      <div class="container">
        <div class="hub-cta-grid">
          <article class="card-v3 hub-cta-card">
            <h3>Vous avez besoin d'un appui ?</h3>
            <p>Décrivez votre situation, on vous oriente vers le bon profil.</p>
            <a href="/contact" class="btn-primary-v3">Faire une demande</a>
          </article>
          <article class="card-v3 hub-cta-card hub-cta-card--dark">
            <h3>Vous travaillez avec des élus locaux ?</h3>
            <p>Proposez votre expertise. On référence des profils sérieux, ancrés dans le réel du mandat.</p>
            <a href="/contact" class="btn-secondary-v3">Proposer mon expertise</a>
          </article>
        </div>
      </div>
    </section>

    <!-- BANDEAU WIP -->
    <section class="section-v3">
      <div class="container-narrow">
        <p class="hub-wip-text">
          Le hub est en cours de constitution.<br />
          Les premiers experts référencés seront disponibles prochainement.
        </p>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .hub-intro-text {
    text-align: center;
    font-size: 1.08rem;
    line-height: 1.75;
    color: var(--deep);
    opacity: 0.82;
    max-width: 54ch;
    margin: 0 auto;
  }

  .hub-section-head {
    max-width: 46rem;
    margin: 0 0 2.5rem;
  }

  .hub-section-head h2 {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    line-height: 1.1;
    margin: 0.3rem 0 0;
  }

  .hub-accent {
    color: var(--neon);
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 700;
    text-transform: none;
  }

  .hub-expertises-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .hub-expertise-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.6rem;
  }

  .hub-expertise-icon {
    font-size: 1.6rem;
    line-height: 1;
  }

  .hub-expertise-card h3 {
    font-size: 1.1rem;
    margin: 0;
  }

  .hub-expertise-card p {
    margin: 0;
    color: #54636c;
    line-height: 1.6;
    font-size: 0.95rem;
  }

  .hub-steps-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .hub-step-card {
    padding: 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .hub-step-num {
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    color: var(--accent-red);
  }

  .hub-step-card h3 {
    font-size: 1.1rem;
    margin: 0;
  }

  .hub-step-card p {
    margin: 0;
    color: #54636c;
    line-height: 1.6;
    font-size: 0.95rem;
  }

  .hub-dif-encart {
    background: rgba(10, 25, 47, 0.04);
    border: 1px solid rgba(10, 25, 47, 0.08);
    border-radius: 16px;
    padding: 1.2rem 1.5rem;
    max-width: 56rem;
  }

  .hub-dif-encart p {
    margin: 0 0 0.6rem;
    color: #54636c;
    line-height: 1.65;
    font-size: 0.95rem;
  }

  .hub-dif-encart strong {
    color: var(--deep);
  }

  .hub-dif-link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--deep);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .hub-dif-link:hover {
    color: var(--accent-red);
  }

  .hub-cta-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .hub-cta-card {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .hub-cta-card h3 {
    font-size: 1.25rem;
    margin: 0;
  }

  .hub-cta-card p {
    margin: 0;
    color: #54636c;
    line-height: 1.6;
    flex: 1;
  }

  .hub-cta-card--dark {
    background: var(--deep);
    border-color: var(--deep);
  }

  .hub-cta-card--dark h3 {
    color: white;
  }

  .hub-cta-card--dark p {
    color: rgba(255, 255, 255, 0.72);
  }

  .hub-wip-text {
    text-align: center;
    font-style: italic;
    color: var(--deep);
    opacity: 0.45;
    line-height: 1.7;
    font-size: 0.98rem;
  }

  @media (max-width: 900px) {
    .hub-steps-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .hub-expertises-grid,
    .hub-cta-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
