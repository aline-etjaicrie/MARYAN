---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Le Radar de MARYAN — À venir"
  description="Le Radar de MARYAN sera mis en ligne prochainement."
>
  <main class="radar-hold-page">
    <section class="radar-hold-hero">
      <div class="container radar-hold-hero__inner">
        <span class="label-v3">Le Radar de MARYAN</span>
        <p class="radar-hold-status">À venir</p>
        <h1>À venir.</h1>
        <p class="radar-hold-copy">
          Le Radar de MARYAN sera mis en ligne prochainement.
        </p>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .radar-hold-page {
    min-height: calc(100vh - 10rem);
    background:
      radial-gradient(circle at top left, rgba(173, 255, 47, 0.08), transparent 24%),
      linear-gradient(180deg, #f7f9fb 0%, #f3f6f8 100%);
    color: var(--deep);
  }

  .radar-hold-hero {
    padding: clamp(6rem, 12vw, 8rem) 0;
  }

  .radar-hold-hero__inner {
    max-width: 44rem;
    display: grid;
    gap: 1rem;
  }

  .radar-hold-status {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    background: rgba(10, 25, 47, 0.06);
    border: 1px solid rgba(10, 25, 47, 0.12);
    color: #41525d;
    font-weight: 700;
    margin: 0;
  }

  .radar-hold-hero h1 {
    font-size: clamp(2.8rem, 8vw, 5rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
    color: var(--deep);
    margin: 0;
  }

  .radar-hold-copy {
    margin: 0;
    max-width: 32rem;
    color: #4f626d;
    font-size: 1.05rem;
    line-height: 1.7;
  }
</style>
