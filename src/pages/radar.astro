---
import BaseLayout from '../layouts/BaseLayout.astro';
import { maryanRadarItems, maryanRadarThemes, maryanRadarTypes, maryanRadarLevels } from '../data/radar';

// UX NOTE — Option B retenue :
// Le Radar est une fonctionnalité éditoriale d’appui, utile mais secondaire dans la découverte initiale.
// Il est plus cohérent de le rendre visible depuis la home, le dashboard, le copilote et le footer,
// plutôt que dans la navigation primaire globale. La page reste publique, mais n’est plus surexposée.
---

<BaseLayout
  title="Le Radar de MARYAN — Veille utile du mandat"
  description="Les signaux institutionnels et politiques qui comptent vraiment pour le mandat, traduits en lecture utile."
>
  <main class="radar-page">
    <section class="radar-hero">
      <div class="container radar-hero-inner">
        <span class="label-v3">Veille utile du mandat</span>
        <h1>Le Radar de MARYAN</h1>
        <p class="radar-hero-subtitle">
          Les signaux institutionnels et politiques qui comptent vraiment pour votre mandat.
        </p>
        <p class="radar-hero-copy">
          Vous n’avez pas besoin de tout suivre. Vous avez besoin de savoir ce qui change concrètement pour vous.
        </p>

        <div class="radar-hero-actions">
          <a href="#radar-results" class="btn-primary-v3">Consulter le Radar</a>
          <a href="#radar-email" class="btn-secondary-v3">Recevoir le Radar</a>
        </div>
      </div>
    </section>

    <section class="section-v3 radar-proof-section">
      <div class="container">
        <div class="section-header radar-section-header">
          <span class="label-v3">Comment ça marche</span>
          <h2>Une lecture courte. Une utilité immédiate.</h2>
        </div>

        <div class="radar-proof-grid">
          <article class="card-v3 radar-proof-card">
            <h3>Repérer les signaux</h3>
            <p>MARYAN met de côté le bruit et garde ce qui mérite vraiment votre attention.</p>
          </article>

          <article class="card-v3 radar-proof-card">
            <h3>Comprendre les implications</h3>
            <p>Chaque signal est relu pour faire apparaître ce qu’il change réellement.</p>
          </article>

          <article class="card-v3 radar-proof-card">
            <h3>Relier au quotidien du mandat</h3>
            <p>Le Radar traduit l’information en points de vigilance, d’arbitrage ou de méthode.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section-v3 section-soft radar-purpose-section">
      <div class="container">
        <div class="radar-purpose-panel card-v3">
          <div class="radar-purpose-copy">
            <span class="label-v3">Pourquoi c’est utile</span>
            <h2>Le Radar existe pour remettre de la clarté dans le bruit institutionnel.</h2>
          </div>

          <div class="radar-purpose-points">
            <p>Trop d’informations circulent. Peu sont vraiment utiles au mandat.</p>
            <p>Le Radar trie, cadre et relie.</p>
            <p>Il ne remplace pas votre jugement. Il vous aide à décider en connaissance de cause.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section-v3 radar-filters-section">
      <div class="container">
        <div class="radar-filters-shell card-v3">
          <div class="radar-filters-head">
            <div>
              <span class="label-v3">Affiner</span>
              <h2>Affiner les signaux sans se perdre</h2>
            </div>
            <button type="button" id="toggleFiltersBtn" class="radar-filter-toggle">Filtrer</button>
          </div>

          <div id="filtersPanel" class="radar-filters-panel">
            <label class="radar-field radar-search-field">
              <span>Recherche</span>
              <input id="radarSearch" type="search" placeholder="Rechercher un sujet…" />
            </label>

            <div class="radar-filters-grid">
              <label class="radar-field">
                <span>Thème</span>
                <select id="radarTheme">
                  <option value="all">Tous</option>
                  {maryanRadarThemes.map((theme) => <option value={theme}>{theme}</option>)}
                </select>
              </label>

              <label class="radar-field">
                <span>Niveau</span>
                <select id="radarLevel">
                  <option value="all">Tous</option>
                  {maryanRadarLevels.map((level) => <option value={level}>{level}</option>)}
                </select>
              </label>

              <label class="radar-field">
                <span>Type</span>
                <select id="radarType">
                  <option value="all">Tous</option>
                  {maryanRadarTypes.map((type) => <option value={type}>{type}</option>)}
                </select>
              </label>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="radar-results" class="section-v3 radar-results-section">
      <div class="container">
        <div class="radar-results-head">
          <div>
            <span class="label-v3">Le moment utile</span>
            <h2>Les signaux utiles du moment</h2>
            <p>Une lecture rapide de ce qui mérite votre attention maintenant.</p>
          </div>

          <div class="radar-results-toolbar">
            <p id="radarResultsCount" class="radar-results-count">0 signal</p>
            <button type="button" id="savedToggleBtn" class="radar-saved-toggle">Mes sujets</button>
          </div>
        </div>

        <div id="radarList" class="radar-list"></div>
      </div>
    </section>

    <section id="radar-email" class="section-v3 radar-email-section">
      <div class="container">
        <div class="card-v3 radar-email-card">
          <div class="radar-email-copy">
            <span class="label-v3">Recevoir le Radar</span>
            <h2>Une synthèse claire, utile, sans bruit.</h2>
            <p>
              Choisissez un rythme simple. Le Radar reste court, lisible et centré sur ce qui aide vraiment à décider.
            </p>
          </div>

          <div class="radar-email-options" role="radiogroup" aria-label="Fréquence du Radar">
            <label class="radar-email-option">
              <input type="radio" name="radarEmailPref" value="quotidien" />
              <span>Quotidien</span>
            </label>
            <label class="radar-email-option">
              <input type="radio" name="radarEmailPref" value="hebdomadaire" />
              <span>Hebdomadaire</span>
            </label>
            <label class="radar-email-option">
              <input type="radio" name="radarEmailPref" value="aucun" />
              <span>Non merci</span>
            </label>
          </div>

          <div class="radar-email-actions">
            <button type="button" id="saveEmailPrefBtn" class="btn-primary-v3">Enregistrer ma préférence</button>
            <p id="radarEmailNote" class="radar-email-note"></p>
          </div>

          <div class="radar-digest">
            <p class="radar-digest-title">Aperçu</p>
            <div id="digestPreview" class="radar-digest-list"></div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-v3 section-soft radar-links-section">
      <div class="container">
        <div class="section-header radar-section-header">
          <span class="label-v3">Continuer dans MARYAN</span>
          <h2>Le Radar ne reste pas seul.</h2>
        </div>

        <div class="radar-links-grid">
          <a href="/diagnostic" class="card-v3 radar-link-card">
            <h3>Diagnostic</h3>
            <p>Le Radar vous aide à repérer. Le diagnostic vous aide à clarifier votre situation.</p>
          </a>

          <a href="/copilote" class="card-v3 radar-link-card">
            <h3>Copilote</h3>
            <p>Le Radar vous montre ce qui compte. Le copilote vous aide à arbitrer et à répondre.</p>
          </a>

          <a href="/ressources" class="card-v3 radar-link-card">
            <h3>Ressources</h3>
            <p>Le Radar ouvre une lecture. Les ressources vous aident à approfondir avec méthode.</p>
          </a>
        </div>
      </div>
    </section>

    <section class="radar-signature">
      <div class="container">
        <p>MARYAN éclaire. Il ne décide pas à votre place.</p>
      </div>
    </section>
  </main>
</BaseLayout>

<script
  define:vars={{
    initialItems: maryanRadarItems
  }}
>
  const SAVED_KEY = 'maryan_radar_saved_items';
  const EMAIL_PREF_KEY = 'maryan_radar_email_pref';

  const els = {
    toggleFiltersBtn: document.getElementById('toggleFiltersBtn'),
    filtersPanel: document.getElementById('filtersPanel'),
    radarSearch: document.getElementById('radarSearch'),
    radarTheme: document.getElementById('radarTheme'),
    radarLevel: document.getElementById('radarLevel'),
    radarType: document.getElementById('radarType'),
    radarList: document.getElementById('radarList'),
    radarResultsCount: document.getElementById('radarResultsCount'),
    savedToggleBtn: document.getElementById('savedToggleBtn'),
    saveEmailPrefBtn: document.getElementById('saveEmailPrefBtn'),
    radarEmailNote: document.getElementById('radarEmailNote'),
    digestPreview: document.getElementById('digestPreview')
  };

  const state = {
    search: '',
    theme: 'all',
    level: 'all',
    type: 'all',
    saved: [],
    emailPref: 'aucun',
    savedOnly: false,
    filtersOpen: false
  };

  function esc(value) {
    return String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');
  }

  function loadState() {
    try {
      const saved = JSON.parse(localStorage.getItem(SAVED_KEY) || '[]');
      if (Array.isArray(saved)) state.saved = saved;

      const emailPref = localStorage.getItem(EMAIL_PREF_KEY);
      if (emailPref === 'quotidien' || emailPref === 'hebdomadaire' || emailPref === 'aucun') {
        state.emailPref = emailPref;
      }
    } catch {
      // noop
    }
  }

  function persistState() {
    localStorage.setItem(SAVED_KEY, JSON.stringify(state.saved));
    localStorage.setItem(EMAIL_PREF_KEY, state.emailPref);
  }

  function formatDate(value) {
    return new Date(value).toLocaleDateString('fr-FR', {
      day: 'numeric',
      month: 'short',
      year: 'numeric'
    });
  }

  function normalizeText(item) {
    return [
      item.title,
      item.source,
      item.type,
      item.level,
      item.theme,
      item.summary.whyImportant,
      item.summary.whoConcerned,
      item.summary.whatChanges,
      item.summary.toWatch
    ].join(' ').toLowerCase();
  }

  function filteredItems() {
    const query = state.search.trim().toLowerCase();
    return [...initialItems]
      .filter((item) => state.theme === 'all' || item.theme === state.theme)
      .filter((item) => state.level === 'all' || item.level === state.level)
      .filter((item) => state.type === 'all' || item.type === state.type)
      .filter((item) => !state.savedOnly || state.saved.includes(item.id))
      .filter((item) => !query || normalizeText(item).includes(query))
      .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
      .slice(0, 10);
  }

  function digestItems() {
    const source = state.saved.length
      ? initialItems.filter((item) => state.saved.includes(item.id))
      : filteredItems();
    const limit = state.emailPref === 'hebdomadaire' ? 5 : 3;
    return source.slice(0, limit);
  }

  function renderResultsCount() {
    const count = filteredItems().length;
    const label = count > 1 ? 'signaux' : 'signal';
    els.radarResultsCount.textContent = state.savedOnly
      ? `${count} ${label} sauvegardé${count > 1 ? 's' : ''}`
      : `${count} ${label}`;
  }

  function renderEmailNote(message = '') {
    if (message) {
      els.radarEmailNote.textContent = message;
      return;
    }

    if (state.emailPref === 'aucun') {
      els.radarEmailNote.textContent = 'Choisissez une fréquence si vous voulez retrouver le Radar plus simplement.';
      return;
    }

    els.radarEmailNote.textContent = `Préférence enregistrée sur cet appareil : ${state.emailPref}.`;
  }

  function renderDigest() {
    const items = digestItems();
    if (!items.length) {
      els.digestPreview.innerHTML = '<p class="radar-empty-copy">Aucun signal sauvegardé pour le moment.</p>';
      return;
    }

    els.digestPreview.innerHTML = items.map((item) => `
      <article class="radar-digest-item">
        <div class="radar-digest-item-title">${esc(item.title)}</div>
        <p><strong>Ce que cela implique</strong><br>${esc(item.summary.whatChanges)}</p>
      </article>
    `).join('');
  }

  function renderList() {
    const items = filteredItems();

    if (!items.length) {
      els.radarList.innerHTML = `
        <div class="card-v3 radar-empty-state">
          <span class="label-v3">Aucun signal</span>
          <h3>Aucun signal ne correspond à vos filtres pour le moment.</h3>
          <p>Essayez d’élargir vos critères ou laissez le Radar vous prévenir.</p>
          <a href="#radar-email" class="btn-secondary-v3">Recevoir le Radar</a>
        </div>
      `;
      return;
    }

    els.radarList.innerHTML = items.map((item) => {
      const isSaved = state.saved.includes(item.id);

      return `
        <article class="card-v3 radar-item">
          <div class="radar-item-top">
            <div class="radar-item-badges">
              <span class="radar-item-badge">${esc(item.type)}</span>
              <span class="radar-item-badge radar-item-badge--subtle">${esc(item.level)}</span>
              <span class="radar-item-theme">${esc(item.theme)}</span>
            </div>
            <button class="radar-save-btn${isSaved ? ' active' : ''}" data-save-id="${esc(item.id)}">
              ${isSaved ? 'Sauvegardé' : 'Sauvegarder'}
            </button>
          </div>

          <h3>${esc(item.title)}</h3>
          <p class="radar-item-source">${esc(item.source)} — ${esc(formatDate(item.date))}</p>
          <p class="radar-item-who"><strong>Qui est concerné :</strong> ${esc(item.summary.whoConcerned)}</p>

          <div class="radar-item-core">
            <div class="radar-item-implication">
              <span class="radar-item-label">Ce que cela implique</span>
              <p>${esc(item.summary.whatChanges)}</p>
            </div>

            <div class="radar-item-side">
              <div class="radar-item-block">
                <span class="radar-item-label">Impact</span>
                <p>${esc(item.summary.whyImportant)}</p>
              </div>

              <div class="radar-item-block">
                <span class="radar-item-label">À surveiller</span>
                <p>${esc(item.summary.toWatch)}</p>
              </div>
            </div>
          </div>

          <div class="radar-item-actions">
            <button class="radar-action-btn" data-save-id="${esc(item.id)}">${isSaved ? 'Retirer' : 'Sauvegarder'}</button>
            <a class="radar-action-link" href="${esc(item.sourceUrl || '#')}" ${item.sourceUrl ? 'target="_blank" rel="noopener noreferrer"' : 'aria-disabled="true"'}>Voir la source</a>
          </div>
        </article>
      `;
    }).join('');

    els.radarList.querySelectorAll('[data-save-id]').forEach((button) => {
      button.addEventListener('click', () => toggleSaved(button.getAttribute('data-save-id')));
    });
  }

  function toggleSaved(id) {
    if (!id) return;

    if (state.saved.includes(id)) {
      state.saved = state.saved.filter((itemId) => itemId !== id);
    } else {
      state.saved = [...state.saved, id];
    }

    persistState();
    render();
  }

  function render() {
    renderResultsCount();
    renderList();
    renderDigest();
    renderEmailNote();

    if (els.savedToggleBtn) {
      els.savedToggleBtn.textContent = state.savedOnly ? 'Voir tous les signaux' : 'Mes sujets';
      els.savedToggleBtn.classList.toggle('active', state.savedOnly);
    }
  }

  function bindEvents() {
    els.toggleFiltersBtn?.addEventListener('click', () => {
      state.filtersOpen = !state.filtersOpen;
      els.filtersPanel?.classList.toggle('is-open', state.filtersOpen);
    });

    els.savedToggleBtn?.addEventListener('click', () => {
      state.savedOnly = !state.savedOnly;
      render();
    });

    els.radarSearch?.addEventListener('input', () => {
      state.search = els.radarSearch.value;
      render();
    });

    els.radarTheme?.addEventListener('change', () => {
      state.theme = els.radarTheme.value;
      render();
    });

    els.radarLevel?.addEventListener('change', () => {
      state.level = els.radarLevel.value;
      render();
    });

    els.radarType?.addEventListener('change', () => {
      state.type = els.radarType.value;
      render();
    });

    document.querySelectorAll('input[name="radarEmailPref"]').forEach((input) => {
      input.addEventListener('change', () => {
        state.emailPref = input.value;
      });
    });

    els.saveEmailPrefBtn?.addEventListener('click', () => {
      persistState();
      renderDigest();
      renderEmailNote('Préférence enregistrée.');
    });
  }

  loadState();

  const selectedEmailPref = document.querySelector(`input[name="radarEmailPref"][value="${state.emailPref}"]`);
  if (selectedEmailPref instanceof HTMLInputElement) {
    selectedEmailPref.checked = true;
  }

  bindEvents();
  render();
</script>

<style>
  .radar-page {
    background: var(--bg);
    color: var(--deep);
  }

  .radar-hero {
    padding: 7rem 0 5rem;
    background:
      radial-gradient(circle at top left, rgba(230, 57, 70, 0.11), transparent 32%),
      radial-gradient(circle at bottom right, rgba(173, 255, 47, 0.08), transparent 28%),
      var(--deep);
  }

  .radar-hero-inner {
    max-width: 52rem;
  }

  .radar-hero h1 {
    color: white;
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.04;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }

  .radar-hero-subtitle {
    color: white;
    font-size: clamp(1.2rem, 2vw, 1.7rem);
    line-height: 1.45;
    max-width: 44rem;
    margin-bottom: 0.9rem;
  }

  .radar-hero-copy {
    color: rgba(255, 255, 255, 0.74);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 42rem;
    margin-bottom: 1.75rem;
  }

  .radar-hero-actions,
  .radar-results-toolbar,
  .radar-email-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .radar-section-header {
    max-width: 46rem;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .radar-section-header h2 {
    font-size: clamp(2rem, 3.5vw, 2.9rem);
    line-height: 1.12;
    letter-spacing: -0.02em;
  }

  .section-soft {
    background: linear-gradient(180deg, rgba(10, 25, 47, 0.03), rgba(10, 25, 47, 0.01));
  }

  .radar-proof-grid,
  .radar-links-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .radar-proof-card,
  .radar-link-card,
  .radar-purpose-panel,
  .radar-filters-shell,
  .radar-email-card,
  .radar-item,
  .radar-empty-state {
    border-radius: 1.75rem;
  }

  .radar-proof-card {
    padding: 1.65rem;
  }

  .radar-proof-card h3,
  .radar-link-card h3 {
    font-size: 1.2rem;
    margin-bottom: 0.8rem;
  }

  .radar-proof-card p,
  .radar-link-card p,
  .radar-purpose-points p,
  .radar-results-head p,
  .radar-email-copy p,
  .radar-email-note,
  .radar-digest-item p,
  .radar-signature p,
  .radar-empty-state p {
    color: #54636C;
    line-height: 1.65;
  }

  .radar-purpose-panel {
    padding: 2.2rem;
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .radar-purpose-copy h2 {
    font-size: clamp(2rem, 3vw, 2.8rem);
    line-height: 1.12;
  }

  .radar-purpose-points {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .radar-filters-section {
    padding-top: 0;
  }

  .radar-filters-shell {
    padding: 1.85rem;
  }

  .radar-filters-head,
  .radar-results-head,
  .radar-item-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.25rem;
  }

  .radar-filters-head h2,
  .radar-results-head h2,
  .radar-email-copy h2 {
    font-size: clamp(1.8rem, 3vw, 2.35rem);
    line-height: 1.14;
    margin-top: 0.2rem;
  }

  .radar-filter-toggle,
  .radar-saved-toggle {
    border: 1px solid var(--border);
    background: white;
    color: var(--deep);
    padding: 0.8rem 1rem;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
  }

  .radar-saved-toggle.active {
    border-color: rgba(10, 25, 47, 0.2);
    background: #EEF2F5;
  }

  .radar-filters-panel {
    display: grid;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .radar-filters-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .radar-field {
    display: grid;
    gap: 0.55rem;
  }

  .radar-field span {
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #7A8791;
  }

  .radar-field input,
  .radar-field select {
    width: 100%;
    border: 1.5px solid rgba(10, 25, 47, 0.12);
    background: white;
    color: var(--deep);
    border-radius: 14px;
    padding: 0.95rem 1rem;
    font: inherit;
  }

  .radar-field input:focus,
  .radar-field select:focus,
  .radar-save-btn:focus-visible,
  .radar-action-btn:focus-visible,
  .radar-action-link:focus-visible,
  .radar-filter-toggle:focus-visible,
  .radar-saved-toggle:focus-visible,
  .radar-email-option:focus-within {
    outline: 2px solid rgba(173, 255, 47, 0.55);
    outline-offset: 2px;
  }

  .radar-results-section {
    padding-top: 0;
  }

  .radar-results-head {
    margin-bottom: 1.5rem;
  }

  .radar-results-count {
    color: #7A8791;
    font-weight: 700;
  }

  .radar-list {
    display: grid;
    gap: 1.25rem;
  }

  .radar-item {
    padding: 1.65rem;
  }

  .radar-item-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .radar-item-badge,
  .radar-item-theme {
    display: inline-flex;
    align-items: center;
    padding: 0.38rem 0.7rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

