---
import BaseLayout from '../layouts/BaseLayout.astro';
import { maryanRadarItems, maryanRadarThemes, maryanRadarTypes, maryanRadarLevels } from '../data/radar';
---

<BaseLayout
  title="Le Radar de MARYAN — Veille institutionnelle et politique du mandat"
  description="Comprendre ce que les évolutions institutionnelles changent pour votre mandat, sans bruit ni surcharge."
>
  <main class="radar-page">
    <section class="radar-hero">
      <div class="container radar-hero-inner">
        <span class="label-v3">Veille institutionnelle</span>
        <h1>LE RADAR DE MARYAN</h1>
        <p class="radar-hero-title">Veille institutionnelle et politique du mandat</p>
        <p class="radar-hero-accent">Vous n’avez pas besoin de plus d’informations. Vous avez besoin de comprendre ce que cela implique pour vous.</p>
        <p class="radar-hero-copy">
          Le Radar de MARYAN analyse les signaux institutionnels et vous aide à en comprendre les implications concrètes pour votre mandat.
        </p>

        <div class="radar-hero-actions">
          <a href="#radar-list-section" class="btn-primary-v3">Consulter le Radar</a>
          <a href="#radar-email" class="btn-secondary-v3">Recevoir le Radar</a>
          <button type="button" id="heroSavedBtn" class="btn-secondary-v3 radar-saved-btn">Mes sujets</button>
        </div>
      </div>
    </section>

    <section class="radar-how">
      <div class="container radar-how-inner">
        <div>
          <span class="label-v3">Comment ça fonctionne</span>
          <h2>Une lecture courte. Une utilité immédiate.</h2>
        </div>
        <div class="radar-how-list">
          <p>MARYAN analyse les signaux institutionnels.</p>
          <p>MARYAN identifie ce qui vous concerne.</p>
          <p>MARYAN met en lien avec votre quotidien d’élu·e.</p>
        </div>
      </div>
    </section>

    <section class="radar-controls-section">
      <div class="container">
        <div class="radar-controls-head">
          <div>
            <span class="label-v3">Filtrer</span>
            <h2>Affiner sans compliquer</h2>
          </div>
          <button type="button" id="toggleFiltersBtn" class="radar-filter-toggle">Filtrer</button>
        </div>

        <div id="filtersPanel" class="radar-filters-panel">
          <label class="radar-field radar-search-field">
            <span>Recherche</span>
            <input id="radarSearch" type="search" placeholder="Rechercher un sujet…" />
          </label>

          <div class="radar-filters-grid">
            <label class="radar-field">
              <span>Thème</span>
              <select id="radarTheme">
                <option value="all">Tous</option>
                {maryanRadarThemes.map((theme) => <option value={theme}>{theme}</option>)}
              </select>
            </label>

            <label class="radar-field">
              <span>Niveau</span>
              <select id="radarLevel">
                <option value="all">Tous</option>
                {maryanRadarLevels.map((level) => <option value={level}>{level}</option>)}
              </select>
            </label>

            <label class="radar-field">
              <span>Type</span>
              <select id="radarType">
                <option value="all">Tous</option>
                {maryanRadarTypes.map((type) => <option value={type}>{type}</option>)}
              </select>
            </label>
          </div>
        </div>
      </div>
    </section>

    <section id="radar-list-section" class="radar-list-section">
      <div class="container">
        <div class="radar-list-head">
          <div>
            <span class="label-v3">Aujourd’hui</span>
            <h2>Ce qui compte pour vous aujourd’hui</h2>
          </div>
          <p id="radarResultsCount" class="radar-results-count">0 signal</p>
        </div>

        <div id="radarList" class="radar-list"></div>
      </div>
    </section>

    <section id="radar-email" class="radar-email-section">
      <div class="container">
        <div class="card-v3 radar-email-card">
          <div class="radar-email-copy">
            <span class="label-v3">Recevoir le Radar</span>
            <h2>Recevoir le Radar de MARYAN</h2>
            <p>Une synthèse claire, utile, sans bruit.</p>
          </div>

          <div class="radar-email-options" role="radiogroup" aria-label="Fréquence du Radar">
            <label class="radar-email-option">
              <input type="radio" name="radarEmailPref" value="quotidien" />
              <span>Quotidien</span>
            </label>
            <label class="radar-email-option">
              <input type="radio" name="radarEmailPref" value="hebdomadaire" />
              <span>Hebdomadaire</span>
            </label>
            <label class="radar-email-option">
              <input type="radio" name="radarEmailPref" value="aucun" />
              <span>Non merci</span>
            </label>
          </div>

          <div class="radar-email-actions">
            <button type="button" id="saveEmailPrefBtn" class="btn-primary-v3">S’abonner</button>
            <p id="radarEmailNote" class="radar-email-note"></p>
          </div>

          <div class="radar-digest">
            <p class="radar-digest-title">Aperçu</p>
            <div id="digestPreview" class="radar-digest-list"></div>
          </div>
        </div>
      </div>
    </section>

    <section class="radar-signature">
      <div class="container">
        <p>MARYAN n’est pas là pour décider à votre place. Il est là pour vous permettre de décider en connaissance de cause.</p>
      </div>
    </section>
  </main>
</BaseLayout>

<script
  define:vars={{
    initialItems: maryanRadarItems
  }}
>
  const SAVED_KEY = 'maryan_radar_saved_items';
  const EMAIL_PREF_KEY = 'maryan_radar_email_pref';

  const els = {
    heroSavedBtn: document.getElementById('heroSavedBtn'),
    toggleFiltersBtn: document.getElementById('toggleFiltersBtn'),
    filtersPanel: document.getElementById('filtersPanel'),
    radarSearch: document.getElementById('radarSearch'),
    radarTheme: document.getElementById('radarTheme'),
    radarLevel: document.getElementById('radarLevel'),
    radarType: document.getElementById('radarType'),
    radarList: document.getElementById('radarList'),
    radarResultsCount: document.getElementById('radarResultsCount'),
    saveEmailPrefBtn: document.getElementById('saveEmailPrefBtn'),
    radarEmailNote: document.getElementById('radarEmailNote'),
    digestPreview: document.getElementById('digestPreview')
  };

  const state = {
    search: '',
    theme: 'all',
    level: 'all',
    type: 'all',
    saved: [],
    emailPref: 'aucun',
    savedOnly: false,
    filtersOpen: false
  };

  function esc(value) {
    return String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');
  }

  function loadState() {
    try {
      const saved = JSON.parse(localStorage.getItem(SAVED_KEY) || '[]');
      if (Array.isArray(saved)) state.saved = saved;

      const emailPref = localStorage.getItem(EMAIL_PREF_KEY);
      if (emailPref === 'quotidien' || emailPref === 'hebdomadaire' || emailPref === 'aucun') {
        state.emailPref = emailPref;
      }
    } catch {
      // noop
    }
  }

  function persistState() {
    localStorage.setItem(SAVED_KEY, JSON.stringify(state.saved));
    localStorage.setItem(EMAIL_PREF_KEY, state.emailPref);
  }

  function formatDate(value) {
    return new Date(value).toLocaleDateString('fr-FR', {
      day: 'numeric',
      month: 'short',
      year: 'numeric'
    });
  }

  function normalizeText(item) {
    return [
      item.title,
      item.source,
      item.type,
      item.level,
      item.theme,
      item.summary.whyImportant,
      item.summary.whoConcerned,
      item.summary.whatChanges,
      item.summary.toWatch
    ].join(' ').toLowerCase();
  }

  function filteredItems() {
    const query = state.search.trim().toLowerCase();
    return [...initialItems]
      .filter((item) => state.theme === 'all' || item.theme === state.theme)
      .filter((item) => state.level === 'all' || item.level === state.level)
      .filter((item) => state.type === 'all' || item.type === state.type)
      .filter((item) => !state.savedOnly || state.saved.includes(item.id))
      .filter((item) => !query || normalizeText(item).includes(query))
      .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
      .slice(0, 10);
  }

  function digestItems() {
    const source = state.saved.length
      ? initialItems.filter((item) => state.saved.includes(item.id))
      : filteredItems();
    const limit = state.emailPref === 'hebdomadaire' ? 5 : 3;
    return source.slice(0, limit);
  }

  function renderResultsCount() {
    const count = filteredItems().length;
    const prefix = state.savedOnly ? 'Mes sujets' : 'Signaux';
    els.radarResultsCount.textContent = `${prefix} · ${count} ${count > 1 ? 'items' : 'item'}`;
  }

  function renderEmailNote(message = '') {
    if (message) {
      els.radarEmailNote.textContent = message;
      return;
    }

    if (state.emailPref === 'aucun') {
      els.radarEmailNote.textContent = 'Aucun envoi automatique pour le moment.';
      return;
    }

    els.radarEmailNote.textContent = `Préférence enregistrée sur cet appareil : ${state.emailPref}.`;
  }

  function renderDigest() {
    const items = digestItems();
    if (!items.length) {
      els.digestPreview.innerHTML = '<p class="radar-empty-copy">Aucun signal sauvegardé pour le moment.</p>';
      return;
    }

    els.digestPreview.innerHTML = items.map((item) => `
      <article class="radar-digest-item">
        <div class="radar-digest-item-title">${esc(item.title)}</div>
        <p>${esc(item.summary.whatChanges)}</p>
      </article>
    `).join('');
  }

  function renderList() {
    const items = filteredItems();

    if (!items.length) {
      els.radarList.innerHTML = `
        <div class="card-v3 radar-empty-state">
          <h3>Aucun signal pour ce filtre</h3>
          <p>Revenez à un filtre plus large ou repassez sur tous les signaux.</p>
        </div>
      `;
      return;
    }

    els.radarList.innerHTML = items.map((item) => {
      const isSaved = state.saved.includes(item.id);
      return `
        <article class="card-v3 radar-item">
          <div class="radar-item-top">
            <div class="radar-item-badges">
              <span class="radar-item-badge">${esc(item.type)}</span>
              <span class="radar-item-badge radar-item-badge--subtle">${esc(item.level)}</span>
            </div>
            <button class="radar-save-btn${isSaved ? ' active' : ''}" data-save-id="${esc(item.id)}">
              ${isSaved ? 'Sauvegardé' : 'Sauvegarder'}
            </button>
          </div>

          <h3>${esc(item.title)}</h3>
          <p class="radar-item-source">${esc(item.source)} — ${esc(formatDate(item.date))}</p>
          <p class="radar-item-who"><strong>Qui est concerné :</strong> ${esc(item.summary.whoConcerned)}</p>

          <div class="radar-item-grid">
            <div class="radar-item-block">
              <span class="radar-item-label">Impact</span>
              <p>${esc(item.summary.whyImportant)}</p>
            </div>
            <div class="radar-item-block radar-item-block--accent">
              <span class="radar-item-label">Ce que cela implique</span>
              <p>${esc(item.summary.whatChanges)}</p>
            </div>
            <div class="radar-item-block">
              <span class="radar-item-label">À surveiller</span>
              <p>${esc(item.summary.toWatch)}</p>
            </div>
          </div>

          <div class="radar-item-actions">
            <button class="radar-action-btn" data-save-id="${esc(item.id)}">${isSaved ? 'Retirer' : 'Sauvegarder'}</button>
            <a class="radar-action-link" href="${esc(item.sourceUrl || '#')}" ${item.sourceUrl ? 'target="_blank" rel="noopener noreferrer"' : 'aria-disabled="true"'}>Voir la source</a>
          </div>
        </article>
      `;
    }).join('');

    els.radarList.querySelectorAll('[data-save-id]').forEach((button) => {
      button.addEventListener('click', () => {
        const id = button.getAttribute('data-save-id');
        if (!id) return;

        if (state.saved.includes(id)) {
          state.saved = state.saved.filter((entry) => entry !== id);
        } else {
          state.saved = [...state.saved, id];
        }

        persistState();
        renderAll();
      });
    });
  }

  function syncFilterPanel() {
    els.filtersPanel.classList.toggle('is-open', state.filtersOpen);
    els.toggleFiltersBtn.setAttribute('aria-expanded', String(state.filtersOpen));
    els.heroSavedBtn.textContent = state.savedOnly ? 'Tous les signaux' : 'Mes sujets';
  }

  function renderAll() {
    renderResultsCount();
    renderList();
    renderEmailNote();
    renderDigest();
    syncFilterPanel();
  }

  function bindEvents() {
    els.heroSavedBtn.addEventListener('click', () => {
      state.savedOnly = !state.savedOnly;
      renderAll();
      document.getElementById('radar-list-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    els.toggleFiltersBtn.addEventListener('click', () => {
      state.filtersOpen = !state.filtersOpen;
      syncFilterPanel();
    });

    els.radarSearch.addEventListener('input', () => {
      state.search = els.radarSearch.value;
      renderAll();
    });

    els.radarTheme.addEventListener('change', () => {
      state.theme = els.radarTheme.value;
      renderAll();
    });

    els.radarLevel.addEventListener('change', () => {
      state.level = els.radarLevel.value;
      renderAll();
    });

    els.radarType.addEventListener('change', () => {
      state.type = els.radarType.value;
      renderAll();
    });

    document.querySelectorAll('input[name="radarEmailPref"]').forEach((input) => {
      input.addEventListener('change', () => {
        state.emailPref = input.value;
      });
    });

    els.saveEmailPrefBtn.addEventListener('click', () => {
      persistState();
      renderEmailNote('Préférence enregistrée sur cet appareil.');
      renderDigest();
    });
  }

  loadState();
  const selectedEmailPref = document.querySelector(`input[name="radarEmailPref"][value="${state.emailPref}"]`);
  if (selectedEmailPref) selectedEmailPref.checked = true;
  bindEvents();
  renderAll();
</script>

<style>
  .radar-page {
    background: var(--bg);
    padding-bottom: 6rem;
  }

  .radar-hero {
    background: var(--deep);
    color: white;
    padding: 5.5rem 0 4rem;
  }

  .radar-hero-inner {
    max-width: 56rem;
  }

  .radar-hero h1 {
    color: white;
    font-size: clamp(2.4rem, 7vw, 4.5rem);
    line-height: 0.95;
    margin-bottom: 0.9rem;
  }

  .radar-hero-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: rgba(255,255,255,0.82);
    margin-bottom: 1.5rem;
  }

  .radar-hero-accent {
    max-width: 42rem;
    font-size: clamp(1.15rem, 2.6vw, 1.55rem);
    line-height: 1.35;
    color: white;
    margin-bottom: 1rem;
  }

  .radar-hero-copy {
    max-width: 44rem;
    font-size: 1rem;
    line-height: 1.65;
    color: rgba(255,255,255,0.75);
    margin-bottom: 2rem;
  }

  .radar-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .radar-how,
  .radar-controls-section,
  .radar-list-section,
  .radar-email-section,
  .radar-signature {
    padding-top: 2rem;
  }

  .radar-how-inner {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .radar-how-inner h2,
  .radar-list-head h2,
  .radar-controls-head h2,
  .radar-email-copy h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--deep);
    margin-bottom: 0.3rem;
  }

  .radar-how-list {
    display: grid;
    gap: 0.6rem;
  }

  .radar-how-list p {
    margin: 0;
    color: #41505B;
    font-size: 1rem;
    line-height: 1.5;
  }

  .radar-controls-head,
  .radar-list-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .radar-filter-toggle {
    display: none;
    padding: 0.95rem 1.15rem;
    border-radius: 16px;
    border: 1px solid var(--border);
    background: white;
    color: var(--deep);
    font-size: 0.95rem;
    font-weight: 800;
    font-family: inherit;
    cursor: pointer;
  }

  .radar-filters-panel {
    background: white;
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 1.5rem;
  }

  .radar-filters-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .radar-field {
    display: grid;
    gap: 0.45rem;
  }

  .radar-search-field {
    margin-bottom: 0.85rem;
  }

  .radar-field span {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #4F5E68;
  }

  .radar-field input,
  .radar-field select {
    width: 100%;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: #FCFCFB;
    padding: 0.95rem 1rem;
    font-size: 0.98rem;
    color: var(--deep);
    font-family: inherit;
  }

  .radar-field input:focus,
  .radar-field select:focus,
  .radar-save-btn:focus-visible,
  .radar-action-btn:focus-visible,
  .radar-action-link:focus-visible,
  .radar-filter-toggle:focus-visible,
  .radar-email-option:focus-within {
    outline: 2px solid var(--accent-red);
    outline-offset: 2px;
  }

  .radar-results-count {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-red);
  }

  .radar-list {
    display: grid;
    gap: 1rem;
  }

  .radar-item {
    padding: 1.5rem;
    border-radius: 24px;
  }

  .radar-item:hover {
    transform: none;
    border-color: var(--border);
    box-shadow: none;
  }

  .radar-item-top {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .radar-item-badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .radar-item-badge {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    background: var(--deep);
    color: white;
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .radar-item-badge--subtle {
    background: #F4F6F7;
    color: #51606B;
    border: 1px solid var(--border);
  }

  .radar-item h3 {
    font-size: clamp(1.2rem, 2.5vw, 1.55rem);
    line-height: 1.2;
    color: var(--deep);
    margin-bottom: 0.45rem;
  }

  .radar-item-source,
  .radar-item-who {
    margin: 0;
    color: #4D5B66;
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .radar-item-who {
    margin-top: 0.7rem;
    margin-bottom: 1rem;
  }

  .radar-item-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .radar-item-block {
    border-radius: 18px;
    border: 1px solid var(--border);
    background: #FCFCFB;
    padding: 1rem;
  }

  .radar-item-block--accent {
    background: var(--deep);
    border-color: transparent;
  }

  .radar-item-label {
    display: inline-block;
    margin-bottom: 0.45rem;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-red);
  }

  .radar-item-block--accent .radar-item-label {
    color: var(--neon);
  }

  .radar-item-block p {
    margin: 0;
    color: #3F4D58;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .radar-item-block--accent p {
    color: white;
  }

  .radar-item-actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .radar-save-btn,
  .radar-action-btn,
  .radar-action-link {
    border-radius: 999px;
    padding: 0.7rem 1rem;
    font-size: 0.82rem;
    font-weight: 800;
    font-family: inherit;
    text-decoration: none;
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease, color 0.15s ease;
  }

  .radar-save-btn,
  .radar-action-btn {
    border: 1px solid var(--border);
    background: white;
    color: var(--deep);
  }

  .radar-save-btn.active,
  .radar-action-btn:hover {
    background: var(--deep);
    border-color: var(--deep);
    color: white;
  }

  .radar-action-link {
    border: 1px solid rgba(10, 25, 47, 0.12);
    color: var(--accent-red);
    background: transparent;
  }

  .radar-action-link:hover {
    border-color: var(--accent-red);
  }

  .radar-email-card {
    padding: 1.75rem;
    border-radius: 24px;
    display: grid;
    gap: 1.25rem;
  }

  .radar-email-copy p,
  .radar-email-note,
  .radar-empty-copy,
  .radar-signature p {
    margin: 0;
    color: #41505B;
    font-size: 0.98rem;
    line-height: 1.6;
  }

  .radar-email-options {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .radar-email-option {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.9rem 1rem;
    border-radius: 16px;
    border: 1px solid var(--border);
    background: #FCFCFB;
    color: var(--deep);
    font-weight: 700;
    cursor: pointer;
  }

  .radar-email-option input {
    accent-color: var(--deep);
  }

  .radar-email-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .radar-digest {
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .radar-digest-title {
    margin: 0 0 0.75rem;
    font-size: 0.78rem;
