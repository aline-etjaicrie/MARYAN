---
import BaseLayout from '../layouts/BaseLayout.astro';
import InternalHeader from '../components/InternalHeader.astro';
---

<BaseLayout
  title="Droits & devoirs des élus — MARYAN"
  description="Comprendre les droits et obligations des élu·es municipaux : statut, indemnités, formation, déontologie."
>
  <InternalHeader
    label="Droits & devoirs"
    title="Les droits et devoirs des <span class='emphasis'>élu·es municipaux</span>"
    subtitle="Statut, indemnités, obligations déontologiques, droit à la formation — cette section est en cours de construction."
  />

  <main>
    <section class="section-v3 bg-light">
      <div class="container container-narrow">
        <div class="about-prose intro-prose">
          <p class="lead">Cette section arrive bientôt.</p>
          <p>
            MARYAN prépare un espace dédié aux droits et devoirs des élu·es locaux : statut de l'élu,
            indemnités de fonction, droit à la formation, obligations déclaratives et règles déontologiques.
          </p>
          <p>
            En attendant, vous pouvez poser vos questions directement au <a href="/copilote">Copilote MARYAN</a>
            ou consulter les <a href="/ressources">ressources disponibles</a>.
          </p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
