---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Offres & Tarifs — MARYAN"
  description="MARYAN, le copilote des élu·es. Choisissez votre rythme, dès 10 €/mois. Offres individuelles, pack groupe et collectivités."
>

  <main class="offres-v3">

    <!-- ═══════════════════════════════════════
         HERO
    ═══════════════════════════════════════ -->
    <section class="hero-offres bg-deep">
      <div class="container">
        <div class="hero-offres-inner">
          <span class="label-v3">MARYAN — le copilote des élu·es</span>
          <h1>
            Un doute sur une décision ?<br>
            Une prise de parole à préparer ?<br>
            Une situation sensible à gérer ?
          </h1>
          <p class="hero-lead">
            MARYAN vous aide à <strong>trancher et à agir</strong> rapidement.
          </p>
          <ul class="hero-bullets">
            <li>Utilisable en quelques minutes</li>
            <li>Pensé pour le réel du mandat</li>
          </ul>
          <a href="/copilote" class="btn-primary-v3">Tester maintenant</a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         OFFRE INDIVIDUELLE
    ═══════════════════════════════════════ -->
    <section class="section-v3">
      <div class="container">
        <div class="section-header">
          <span class="label-v3">Offre individuelle</span>
          <h2>Choisissez votre <em>rythme</em></h2>
        </div>

        <div class="plans-grid">

          <div class="plan-card">
            <div class="plan-name">Essai libre</div>
            <div class="plan-price-row">
              <span class="plan-amount">19 €</span>
              <span class="plan-period">/mois</span>
            </div>
            <p class="plan-engagement">Sans engagement</p>
            <ul class="plan-list">
              <li>Pour tester en situation réelle</li>
              <li>Accès complet à la plateforme</li>
            </ul>
            <button class="btn-secondary-v3 checkout-btn w-full" data-price-id="price_INDIVIDUAL_MONTHLY">
              Tester maintenant
            </button>
          </div>

          <div class="plan-card">
            <div class="plan-name">Engagement 6 mois</div>
            <div class="plan-price-row">
              <span class="plan-amount">15 €</span>
              <span class="plan-period">/mois</span>
            </div>
            <p class="plan-engagement">&nbsp;</p>
            <ul class="plan-list">
              <li>Pour une utilisation régulière</li>
              <li>Accès complet à la plateforme</li>
            </ul>
            <button class="btn-secondary-v3 checkout-btn w-full" data-price-id="price_INDIVIDUAL_6M">
              Tester maintenant
            </button>
          </div>

          <div class="plan-card plan-featured">
            <div class="plan-badge">Le plus utilisé</div>
            <div class="plan-name">Engagement 12 mois</div>
            <div class="plan-price-row">
              <span class="plan-amount">10 €</span>
              <span class="plan-period">/mois</span>
            </div>
            <p class="plan-engagement">&nbsp;</p>
            <ul class="plan-list">
              <li>Pour un usage dans la durée</li>
              <li>2 mois offerts</li>
            </ul>
            <button class="btn-primary-v3 checkout-btn w-full btn-neon" data-price-id="price_INDIVIDUAL_12M">
              Tester maintenant
            </button>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         PACK GROUPE POLITIQUE
    ═══════════════════════════════════════ -->
    <section class="section-v3 pack-section">
      <div class="container">
        <div class="pack-banner">
          <div class="pack-text">
            <span class="label-v3">Accès rapide</span>
            <h2>Pack groupe politique</h2>
            <p class="pack-price"><strong>600 € / an</strong> — jusqu'à 8 élu·es</p>
            <ul class="pack-signals">
              <li>Idéal pour un groupe municipal</li>
              <li>Activation immédiate</li>
            </ul>
          </div>
          <a href="/contact" class="btn-primary-v3 pack-cta">Activer le pack</a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         OFFRES COLLECTIVITÉS
    ═══════════════════════════════════════ -->
    <section id="collectivites" class="section-v3">
      <div class="container">
        <div class="section-header">
          <span class="label-v3">Collectivités</span>
          <h2>Équiper une équipe <em>simplement</em></h2>
        </div>

        <div class="collec-grid">

          <div class="collec-card">
            <div class="collec-tier">Starter</div>
            <p class="collec-subtitle">petite équipe</p>
            <p class="collec-size">5 à 10 élu·es</p>
            <div class="collec-price">
              8 € <span class="collec-unit">/mois/élu</span>
              <span class="collec-billing">(annuel)</span>
            </div>
            <ul class="v3-list-dots">
              <li>Accès complet à la plateforme</li>
              <li>Mise en route autonome</li>
            </ul>
          </div>

          <div class="collec-card collec-card-mid">
            <div class="collec-tier">Équipe</div>
            <p class="collec-subtitle">exécutif élargi</p>
            <p class="collec-size">10 à 30 élu·es</p>
            <div class="collec-price">
              6 € <span class="collec-unit">/mois/élu</span>
              <span class="collec-billing">(annuel)</span>
            </div>
            <ul class="v3-list-dots">
              <li>Accès multi-utilisateurs</li>
              <li>Utilisation collective possible</li>
            </ul>
          </div>

          <div class="collec-card">
            <div class="collec-tier">Mandat</div>
            <p class="collec-subtitle">grande collectivité</p>
            <p class="collec-size">30 à 100+ élu·es</p>
            <div class="collec-price">
              4 € <span class="collec-unit">/mois/élu</span>
              <span class="collec-billing">(annuel)</span>
            </div>
            <ul class="v3-list-dots">
              <li>Accès étendu à l'ensemble des élu·es</li>
              <li>Outil partagé à l'échelle du mandat</li>
            </ul>
          </div>

        </div>

        <div class="collec-cta-row">
          <a href="/contact" class="btn-primary-v3">Équiper ma collectivité</a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         POURQUOI MARYAN
    ═══════════════════════════════════════ -->
    <section class="section-v3 bg-deep why-section">
      <div class="container">
        <div class="why-header">
          <span class="label-v3">Pourquoi MARYAN</span>
        </div>
        <div class="why-grid">
          <div class="why-item">
            <p>Aide à prendre des décisions rapidement</p>
          </div>
          <div class="why-item">
            <p>Aide à structurer les prises de parole</p>
          </div>
          <div class="why-item">
            <p>Clarifie les situations complexes</p>
          </div>
        </div>
        <p class="why-signal">Un outil simple, utilisable immédiatement</p>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         CTA FINAL
    ═══════════════════════════════════════ -->
    <section class="section-v3 cta-final-section">
      <div class="container-narrow">
        <div class="cta-final-panel">
          <h2>Commencer en quelques minutes</h2>
          <p class="cta-lead">
            Pas de formation.<br>
            Pas de mise en place complexe.<br>
            Juste un outil utile, tout de suite.
          </p>
          <a href="/copilote" class="btn-primary-v3 big">Tester maintenant</a>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>

<script>
  const checkoutButtons = document.querySelectorAll<HTMLButtonElement>('.checkout-btn');

  checkoutButtons.forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const priceId = target.dataset.priceId;
      if (!priceId) return;

      target.innerText = 'Chargement…';
      target.disabled = true;

      try {
        const response = await fetch('/api/create-checkout-session', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            priceId,
            customerEmail: localStorage.getItem('user_email') || null,
          }),
        });

        const session = await response.json();

        if (session.url) {
          window.location.href = session.url;
        } else {
          alert('Erreur de session. Veuillez vérifier vos clés Stripe.');
          target.innerText = 'Tester maintenant';
          target.disabled = false;
        }
      } catch (err) {
        console.error(err);
        alert('La connexion à Stripe a échoué.');
        target.innerText = 'Tester maintenant';
        target.disabled = false;
      }
    });
  });
</script>

<style>
  .offres-v3 { color: var(--deep); }

  /* ── HERO ── */
  .hero-offres {
    padding: 7rem 0 6rem;
  }

  .hero-offres-inner {
    max-width: 46rem;
  }

  .hero-offres-inner h1 {
    color: white;
    font-size: clamp(1.9rem, 3.5vw, 2.8rem);
    line-height: 1.25;
    margin-bottom: 1.5rem;
  }

  .hero-lead {
    color: rgba(255,255,255,0.8);
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .hero-lead strong { color: white; }

  .hero-bullets {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .hero-bullets li {
    color: var(--neon);
    font-weight: 600;
    font-size: 0.95rem;
    padding-left: 1.4rem;
    position: relative;
  }

  .hero-bullets li::before {
    content: '→';
    position: absolute;
    left: 0;
  }

  /* ── Section header ── */
  .offres-v3 .section-header {
    max-width: 44rem;
    margin: 0 auto 4rem;
    text-align: center;
  }

  .offres-v3 .section-header h2 {
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  /* ── PLANS INDIVIDUELS ── */
  .plans-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
    align-items: start;
  }

  .plan-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: 2rem;
    padding: 2.2rem;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .plan-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 48px rgba(10,25,47,0.07);
  }

  .plan-featured {
    background: var(--deep);
    border-color: var(--deep);
  }

  .plan-badge {
    display: inline-block;
    background: var(--neon);
    color: var(--deep);
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.8rem;
    border-radius: 99px;
    margin-bottom: 1.25rem;
    width: fit-content;
  }

  .plan-name {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(10,25,47,0.4);
    margin-bottom: 1rem;
  }

  .plan-featured .plan-name {
    color: rgba(255,255,255,0.5);
  }

  .plan-price-row {
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
    margin-bottom: 0.3rem;
  }

  .plan-amount {
    font-size: clamp(2.4rem, 4vw, 3.4rem);
    font-weight: 800;
    line-height: 1;
    color: var(--deep);
  }

  .plan-featured .plan-amount { color: white; }

  .plan-period {
    font-size: 1rem;
    color: #54636C;
  }

  .plan-featured .plan-period { color: rgba(255,255,255,0.55); }

  .plan-engagement {
    font-size: 0.84rem;
    color: #54636C;
    margin-bottom: 1.75rem;
    min-height: 1.25em;
  }

  .plan-featured .plan-engagement { color: rgba(255,255,255,0.45); }

  .plan-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    margin-bottom: 2rem;
    flex: 1;
  }

  .plan-list li {
    font-size: 0.94rem;
    color: #54636C;
    padding-left: 1.2rem;
    position: relative;
    line-height: 1.5;
  }

  .plan-featured .plan-list li { color: rgba(255,255,255,0.7); }

  .plan-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent-red);
    font-size: 0.8rem;
  }

  .plan-featured .plan-list li::before { color: var(--neon); }

  .w-full { width: 100%; justify-content: center; }

  .btn-neon {
    background: var(--neon) !important;
    color: var(--deep) !important;
    border-color: var(--neon) !important;
  }

  .btn-neon:hover {
    background: white !important;
    color: var(--deep) !important;
    border-color: white !important;
  }

  /* ── PACK GROUPE ── */
  .pack-section {
    background: var(--deep);
  }

  .pack-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 2rem;
    padding: 3rem 3.5rem;
  }

  .pack-text h2 {
    color: white;
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    margin-bottom: 0.75rem;
    line-height: 1.1;
  }

  .pack-price {
    color: rgba(255,255,255,0.7);
    font-size: 1rem;
    margin-bottom: 1.25rem;
  }

  .pack-price strong {
    color: var(--neon);
    font-size: 1.1rem;
  }

  .pack-signals {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .pack-signals li {
    color: rgba(255,255,255,0.7);
    font-size: 0.94rem;
    padding-left: 1.4rem;
    position: relative;
  }

  .pack-signals li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--neon);
  }

  .pack-cta {
    flex-shrink: 0;
    background: var(--neon) !important;
    color: var(--deep) !important;
    border-color: var(--neon) !important;
  }

  .pack-cta:hover {
    background: white !important;
    color: var(--deep) !important;
    border-color: white !important;
  }

  .pack-section .label-v3 { color: rgba(255,255,255,0.55) !important; }
  .pack-section .label-v3::before { background: var(--neon) !important; }

  /* ── COLLECTIVITÉS ── */
  .collec-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .collec-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: 2rem;
    padding: 2.2rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .collec-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 48px rgba(10,25,47,0.07);
  }

  .collec-card-mid {
    background: var(--deep);
    border-color: var(--deep);
  }

  .collec-tier {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--deep);
    margin-bottom: 0.2rem;
  }

  .collec-card-mid .collec-tier { color: white; }

  .collec-subtitle {
    font-size: 0.8rem;
    color: #54636C;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .collec-card-mid .collec-subtitle { color: rgba(255,255,255,0.45); }

  .collec-size {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--accent-red);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.4rem;
  }

  .collec-card-mid .collec-size { color: var(--neon); }

  .collec-price {
    font-size: 1.9rem;
    font-weight: 800;
    color: var(--deep);
    line-height: 1;
    margin-bottom: 1.75rem;
  }

  .collec-card-mid .collec-price { color: white; }

  .collec-unit {
    font-size: 0.85rem;
    font-weight: 600;
    color: #54636C;
  }

  .collec-card-mid .collec-unit { color: rgba(255,255,255,0.5); }

  .collec-billing {
    display: block;
    font-size: 0.76rem;
    font-weight: 600;
    color: #54636C;
    margin-top: 0.2rem;
  }

  .collec-card-mid .collec-billing { color: rgba(255,255,255,0.4); }

  .collec-cta-row { text-align: center; }

  .v3-list-dots {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    font-size: 0.9rem;
  }

  .v3-list-dots li {
    position: relative;
    padding-left: 1rem;
    color: #54636c;
    line-height: 1.5;
  }

  .collec-card-mid .v3-list-dots li { color: rgba(255,255,255,0.65); }

  .v3-list-dots li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65rem;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(10,25,47,0.2);
    transform: translateY(-50%);
  }

  .collec-card-mid .v3-list-dots li::before { background: var(--neon); }

  /* ── POURQUOI MARYAN ── */
  .why-header { margin-bottom: 3rem; }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .why-item {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 1.5rem;
    padding: 2rem;
  }

  .why-item p {
    color: white;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.45;
    margin: 0;
  }

  .why-signal {
    color: var(--neon);
    font-size: 0.92rem;
    font-weight: 700;
    padding-left: 1.4rem;
    position: relative;
    width: fit-content;
  }

  .why-signal::before {
    content: '→';
    position: absolute;
    left: 0;
  }

  /* ── CTA FINAL ── */
  .cta-final-section {
    background: linear-gradient(180deg, #f8f3eb 0%, var(--bg) 100%);
  }

  .cta-final-panel {
    background: white;
    border: 1px solid var(--border);
    border-radius: 2rem;
    padding: 4rem 3rem;
    text-align: center;
    box-shadow: 0 20px 50px rgba(10,25,47,0.05);
  }

  .cta-final-panel h2 {
    font-size: clamp(1.9rem, 3.5vw, 2.8rem);
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .cta-lead {
    color: #54636C;
    font-size: 1.05rem;
    line-height: 1.9;
    margin-bottom: 2.5rem;
  }

  .btn-primary-v3.big {
    padding: 1.4rem 3.5rem;
    font-size: 1.05rem;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .plans-grid,
    .collec-grid,
    .why-grid {
      grid-template-columns: 1fr;
    }

    .pack-banner {
      flex-direction: column;
      padding: 2rem;
      text-align: center;
    }

    .pack-signals { align-items: center; }

    .pack-cta,
    .w-full { width: 100%; justify-content: center; }

    .why-signal { margin: 0 auto; }

    .cta-final-panel { padding: 2.5rem 1.5rem; }
  }
</style>
