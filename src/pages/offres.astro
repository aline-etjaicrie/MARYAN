---
import BaseLayout from '../layouts/BaseLayout.astro';
import InternalHeader from '../components/InternalHeader.astro';

const repereWho = [
  'de clarifier leur situation',
  'de comprendre leurs points de vigilance',
  "d'identifier les premières ressources utiles",
  'de ne pas partir dans tous les sens'
];

const repereWhat = [
  'un diagnostic structuré',
  'un profil de situation',
  'des recommandations ciblées',
  'une première orientation'
];

const repereFit = [
  'vous débutez',
  'vous manquez de repères',
  "vous voulez d'abord comprendre avant d'investir plus loin",
  'vous cherchez un point de départ simple et sérieux'
];

const outillerWhat = [
  'une bibliothèque de ressources complète',
  'des fiches par situation',
  'des trames utiles',
  'un copilote conversationnel spécialisé',
  'un appui continu pour mieux formuler et prioriser'
];

const outillerFit = [
  'vous manquez de méthode',
  'vous voulez gagner du temps',
  "vous avez besoin d'un cadre plus stable",
  'vous cherchez un outil utile dans la durée'
];

const epaulerExamples = [
  'sujet sensible localement',
  'forte exposition publique',
  'technicité élevée',
  'difficulté de communication',
  "besoin de cadrage ou d'arbitrage"
];

const epaulerWhat = [
  'une visio de cadrage',
  'un échange ponctuel',
  'une orientation vers un expert',
  'un accompagnement ciblé sur une situation précise'
];

const epaulerFit = [
  'vous sentez que vous tournez en rond',
  "vous avez besoin d'un regard compétent",
  'la situation devient trop sensible pour rester seul·e',
  "vous avez besoin d'une aide très ajustée"
];

const progression = [
  { step: '01. Clarifier', title: 'Faire le point', text: 'Comprendre, repérer ses besoins réels.' },
  { step: '02. Outiller', title: 'Accéder aux outils', text: 'Ressources, méthodes, copilote IA.' },
  { step: '03. Renforcer', title: 'Cadrage stratégique', text: 'Monter en appui quand la situation l\'exige.' },
  { step: '04. Relayer', title: 'Experts Humains', text: 'Orienter vers un accompagnement humain.' }
];
---
<BaseLayout
  title="Les Niveaux d'Appui — MARYAN"
  description="Trouvez le bon niveau d'accompagnement selon votre situation : se repérer, s'outiller ou se faire épauler."
>
  
  <InternalHeader 
    label="Système d'appui"
    title="Le bon niveau d'appui, au <em class='emphasis'>bon moment</em>"
    subtitle="MARYAN n'a pas vocation à vendre la même chose à tout le monde. Nous vous orientons vers la forme d'appui la plus utile selon votre situation réelle."
  />

  <main class="offres-main-v3">
    
    <!-- 1. SE REPERER -->
    <section class="section-v3 bg-grid-reveal">
      <div class="bg-grid-v3"></div>
      <div class="container">
        <div class="offer-level-box">
           <div class="level-indicator">
              <span class="level-num">Niveau 01</span>
              <div class="level-line"></div>
           </div>
           <div class="level-content">
              <h2>Se <span class="emphasis">repérer</span></h2>
              <p class="level-intro">L'entrée dans le mandat nécessite d'abord de la clarté.</p>
              
              <div class="level-grid">
                <div class="card-v3">
                   <span class="card-kicker">Pour qui ?</span>
                   <ul class="v3-list">
                      {repereWho.map(item => <li>{item}</li>)}
                   </ul>
                </div>
                <div class="card-v3 highlight-neon">
                   <span class="card-kicker text-red">Apport MARYAN</span>
                   <ul class="v3-list-check">
                      {repereWhat.map(item => <li>{item}</li>)}
                   </ul>
                   <div class="card-footer-v3">
                      <p><strong>Idéal si :</strong> {repereFit.slice(0,2).join(', ')}...</p>
                   </div>
                </div>
              </div>
           </div>
        </div>
      </div>
    </section>

    <!-- 2. S'OUTILLER -->
    <section class="section-v3 bg-deep text-white">
      <div class="glow-v3 glow-red"></div>
      <div class="container">
        <div class="offer-level-box reverse">
           <div class="level-indicator">
              <span class="level-num text-neon">Niveau 02</span>
              <div class="level-line bg-neon"></div>
           </div>
           <div class="level-content">
              <h2 class="text-white">S'<span class="emphasis text-neon">outiller</span></h2>
              <p class="level-intro opacity-70">Un appui régulier et digital pour sécuriser le quotidien.</p>
              
              <div class="level-grid">
                <div class="card-v3 dark-card">
                   <span class="card-kicker opacity-50">L'appui Copilote</span>
                   <p>Pour les élu·es qui ont besoin d'une méthode stable sans basculer vers l'humain lourd.</p>
                   <ul class="v3-list-white">
                      {outillerWhat.map(item => <li>{item}</li>)}
                   </ul>
                </div>
                <div class="card-v3 dark-card border-red">
                   <span class="card-kicker text-red">Pertinence</span>
                   <p>Ce niveau convient si vous voulez gagner du temps et structurer vos dossiers stratégiques.</p>
                   <ul class="v3-list-check-neon">
                      {outillerFit.map(item => <li>{item}</li>)}
                   </ul>
                </div>
              </div>
           </div>
        </div>
      </div>
    </section>

    <!-- 3. SE FAIRE EPAULER -->
    <section class="section-v3">
      <div class="container">
        <div class="offer-level-box">
           <div class="level-indicator">
              <span class="level-num">Niveau 03</span>
              <div class="level-line"></div>
           </div>
           <div class="level-content">
              <h2>Se faire <span class="emphasis">épauler</span></h2>
              <p class="level-intro">L'expertise humaine prend le relais sur les sujets complexes.</p>
              
              <div class="level-grid">
                <div class="card-v3">
                   <span class="card-kicker">Situations cibles</span>
                   <p>Quand l'outil seul ne suffit plus à l'arbitrage :</p>
                   <ul class="v3-list-dots">
                      {epaulerExamples.map(item => <li>{item}</li>)}
                   </ul>
                </div>
                <div class="card-v3 border-neon">
                   <span class="card-kicker text-sauge">Le Hub d'Experts</span>
                   <p>Accès direct à notre réseau de consultants stratégiques, juridiques et RH.</p>
                   <ul class="v3-list-check">
                      {epaulerWhat.map(item => <li>{item}</li>)}
                   </ul>
                </div>
              </div>
           </div>
        </div>
      </div>
    </section>

    <!-- PROGRESSION LOGIC -->
    <section class="section-v3 bg-ivory">
      <div class="container">
        <div class="section-header text-center">
           <span class="label-v3">Philosophie</span>
           <h2>Une logique <span class="emphasis">progressive</span></h2>
           <p class="intro-v3">Pas plus d'outils que nécessaire, mais pas moins d'appui qu'il n'en faut.</p>
        </div>

        <div class="progression-steps-v3">
           {progression.map(item => (
             <div class="p-step-v3">
                <span class="p-step-num">{item.step}</span>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
             </div>
           ))}
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="section-v3 bg-deep text-white text-center">
       <div class="container-narrow">
          <h2>Vous ne savez pas par où <span class="emphasis text-neon">commencer</span> ?</h2>
          <p class="intro-v3 text-white opacity-70">Laissez-vous guider par le diagnostic. C'est lui qui définit votre trajectoire d'appui.</p>
          <div class="offres-cta-v3">
             <a href="/diagnostic" class="btn-primary-v3 big">Faire mon diagnostic</a>
             <a href="/contact" class="btn-secondary-v3 dark">Contacter l'équipe</a>
          </div>
       </div>
    </section>
  </main>
</BaseLayout>

<style>
  .offres-main-v3 {
    --border-soft: rgba(30, 42, 50, 0.08);
  }

  .bg-grid-reveal { position: relative; overflow: hidden; }

  /* ─── LEVEL LAYOUT ─── */
  .offer-level-box { display: flex; gap: 4rem; }
  .offer-level-box.reverse { flex-direction: row-reverse; }
  
  .level-indicator { flex-shrink: 0; width: 100px; padding-top: 1rem; }
  .level-num { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; display: block; margin-bottom: 1.5rem; }
  .level-line { width: 40px; height: 3px; background: var(--deep); }
  .level-line.bg-neon { background: var(--neon); }

  .level-content { flex: 1; }
  .level-content h2 { font-size: 3.5rem; margin-bottom: 1rem; }
  .level-intro { font-size: 1.4rem; font-family: var(--font-accent); font-style: italic; margin-bottom: 3.5rem; color: #54636C; }
  .level-intro.opacity-70 { opacity: 0.7; color: white; }

  .level-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }

  /* ─── CARDS SPECIFIC ─── */
  .card-kicker { font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1.5rem; display: block; }
  .v3-list, .v3-list-white, .v3-list-check, .v3-list-check-neon, .v3-list-dots { 
    list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.85rem; font-size: 0.95rem;
  }
  .v3-list li, .v3-list-white li { position: relative; padding-left: 1.5rem; }
  .v3-list li::before { content: '→'; position: absolute; left: 0; color: var(--accent-red); font-weight: 900; }
  .v3-list-white li::before { content: '→'; position: absolute; left: 0; color: var(--neon); font-weight: 900; }
  
  .v3-list-check li, .v3-list-check-neon li { position: relative; padding-left: 2rem; }
  .v3-list-check li::before { content: '✓'; position: absolute; left: 0; color: #8DA08E; font-weight: 900; }
  .v3-list-check-neon li::before { content: '✓'; position: absolute; left: 0; color: var(--neon); font-weight: 900; }

  .dark-card { background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.1); color: white; }
  .card-footer-v3 { margin-top: auto; padding-top: 1.5rem; border-top: 1px dashed var(--border-soft); font-size: 0.85rem; color: #54636C; }
  
  .border-red { border-color: var(--accent-red); border-width: 1.5px; }
  .border-neon { border-color: var(--neon); border-width: 1.5px; }

  /* ─── PROGRESSION ─── */
  .progression-steps-v3 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; margin-top: 4rem; }
  .p-step-v3 { position: relative; }
  .p-step-num { font-size: 0.8rem; font-weight: 800; color: var(--accent-red); display: block; margin-bottom: 1rem; }
  .p-step-v3 h3 { font-size: 1.2rem; margin-bottom: 0.75rem; }
  .p-step-v3 p { font-size: 0.9rem; opacity: 0.7; line-height: 1.5; }

  .offres-cta-v3 { display: flex; flex-direction: column; align-items: center; gap: 1.5rem; margin-top: 4rem; }
  .btn-secondary-v3.dark { background: transparent; color: white; border-color: rgba(255,255,255,0.2); }
  .btn-secondary-v3.dark:hover { border-color: white; background: rgba(255,255,255,0.05); }

  @media (max-width: 900px) {
    .offer-level-box, .offer-level-box.reverse { flex-direction: column; gap: 2rem; }
    .level-indicator { width: 100%; display: flex; align-items: center; gap: 1.5rem; }
    .level-line { flex: 1; height: 2px; }
    .level-grid { grid-template-columns: 1fr; }
    .progression-steps-v3 { grid-template-columns: 1fr 1fr; }
  }
</style>
