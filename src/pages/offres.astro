---
import BaseLayout from '../layouts/BaseLayout.astro';

const concreteBlocks = [
  {
    title: 'Un diagnostic rapide',
    body: 'Six questions pour clarifier votre situation, vos priorités et le type d’appui le plus utile.'
  },
  {
    title: 'Un copilote contextuel',
    body: 'Un échange direct pour comprendre, arbitrer, rédiger et sécuriser les situations concrètes du mandat.'
  },
  {
    title: 'Des fiches expertes',
    body: 'Des fiches réservées aux abonné·es pour approfondir un sujet, retrouver un cadre clair et éviter les erreurs classiques.'
  },
  {
    title: 'Un espace personnel orienté action',
    body: 'Un point d’entrée simple pour retrouver l’essentiel, reprendre son fil et passer plus vite à l’action.'
  }
];

const entryLevels = [
  {
    label: 'Découvrir',
    title: 'Commencer sans engagement',
    body: 'Commencez sans engagement immédiat. Vous testez la logique du produit avant de décider si vous voulez aller plus loin.',
    items: [
      'Diagnostic public en 6 questions',
      'Copilote en accès libre avec quota gratuit',
      'Premiers repères publics visibles dans les ressources et droits & devoirs',
      'Entrée simple, sans friction'
    ],
    ctaLabel: 'Faire le diagnostic',
    ctaHref: '/diagnostic'
  },
  {
    label: 'S’abonner',
    title: 'MARYAN Plus',
    body: 'Vous utilisez MARYAN comme un outil du quotidien : plus vite pour comprendre, mieux pour décider, plus clairement pour agir.',
    items: [
      'Copilote illimité',
      'Fiches détaillées réservées aux abonné·es',
      'Analyseur de documents',
      'Espace personnel, reprise d’usage et historique'
    ],
    ctaLabel: 'Voir les formules',
    ctaHref: '#offre-individuelle',
    featured: true
  },
  {
    label: 'Équiper une équipe',
    title: 'Déployer MARYAN à plusieurs',
    body: 'Le même socle d’usage pour plusieurs profils, avec un déploiement lisible et un coût maîtrisé.',
    items: [
      'Même outil pour plusieurs élu·es',
      'Même socle de repères et de questions',
      'Déploiement simple à l’échelle d’un groupe ou d’une équipe',
      'Adaptation crédible au contexte local'
    ],
    ctaLabel: 'Demander une démo',
    ctaHref: '/contact'
  }
];

const individualPlans = [
  {
    name: 'Sans engagement',
    price: '19 €',
    period: '/mois',
    detail: 'Pour tester en conditions réelles.',
    features: [
      'Accès MARYAN Plus complet',
      'Pour démarrer seul·e sans contrainte'
    ],
    checkoutUrl: 'https://buy.stripe.com/9B6eVdeY23ZueXQe2q0gw00',
    cta: 'Tester maintenant'
  },
  {
    name: 'Engagement 6 mois',
    price: '15 €',
    period: '/mois',
    detail: 'Pour un usage régulier.',
    features: [
      'Accès MARYAN Plus complet',
      'Pour intégrer MARYAN dans le rythme du mandat'
    ],
    checkoutUrl: 'https://buy.stripe.com/28E8wP3fk1Rm02W5vU0gw01',
    cta: 'Choisir cette formule'
  },
  {
    name: 'Engagement 12 mois',
    price: '10 €',
    period: '/mois',
    detail: 'Pour un usage dans la durée.',
    features: [
      'Accès MARYAN Plus complet',
      'Pour installer un vrai réflexe d’usage'
    ],
    checkoutUrl: 'https://buy.stripe.com/5kQ00j03853ybLEe2q0gw02',
    cta: 'Choisir cette formule',
    featured: true,
    badge: 'Le plus utilisé'
  }
];

const collectiveTiers = [
  {
    title: '5 à 10 élu·es',
    subtitle: 'petite équipe',
    price: '8 €',
    unit: '/mois/élu',
    note: 'en annuel'
  },
  {
    title: '10 à 30 élu·es',
    subtitle: 'équipe élargie',
    price: '6 €',
    unit: '/mois/élu',
    note: 'en annuel',
    featured: true
  },
  {
    title: '30 à 100+ élu·es',
    subtitle: 'déploiement plus large',
    price: '4 €',
    unit: '/mois/élu',
    note: 'en annuel'
  }
];

const activationItems = [
  'Un diagnostic pour clarifier la situation de départ',
  'Un copilote pour traiter les questions concrètes du mandat',
  'Des fiches ciblées pour approfondir',
  'Un espace personnel pour retrouver l’essentiel et passer à l’action'
];

const easyToMobilizeItems = [
  'Accompagnement du mandat',
  'Organisation du travail des élu·es',
  'Amélioration des pratiques internes'
];
---

<BaseLayout
  title="Offres — MARYAN"
  description="Choisir le bon niveau d’accès à MARYAN : découverte, abonnement individuel ou déploiement équipe."
>
  <main class="offres-page">
    <section class="offres-hero bg-deep">
      <div class="container">
        <div class="offres-hero-inner">
          <span class="label-v3">Offres</span>
          <h1>Choisir le bon niveau d’accès à MARYAN</h1>
          <p class="offres-hero-subtitle">
            Un <span class="accent-keyword">diagnostic</span> pour clarifier.
            Un <span class="accent-keyword">copilote</span> pour décider.
            Un espace pour <span class="accent-keyword">agir</span>.
          </p>
          <p class="offres-hero-copy">
            Un·e élu·e peut démarrer seul·e en quelques minutes. Une équipe peut équiper plusieurs élu·es avec le même socle d’usage.
          </p>
          <div class="offres-hero-actions">
            <a href="/diagnostic" class="btn-primary-v3">Faire le diagnostic</a>
            <a href="/copilote" class="btn-secondary-v3">Tester le copilote</a>
            <a href="/contact" class="btn-secondary-v3">Demander une démo</a>
          </div>
          <div class="offres-hero-signals" aria-label="Niveaux d'accès MARYAN">
            <span>Public</span>
            <span>Découverte</span>
            <span>MARYAN Plus</span>
            <span>Collectif</span>
          </div>
          <p class="offres-hero-note">
            Une partie de MARYAN reste libre d’accès. L’abonnement ouvre l’usage complet.
          </p>
        </div>
      </div>
    </section>

    <section class="section-v3">
      <div class="container">
        <div class="section-header">
          <span class="label-v3">Le produit</span>
          <h2>Concrètement, MARYAN, c’est quoi ?</h2>
        </div>

        <div class="concrete-grid">
          {concreteBlocks.map((block) => (
            <article class="concrete-card card-v3">
              <h3>{block.title}</h3>
              <p>{block.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-v3 section-soft">
      <div class="container">
        <div class="section-header">
          <span class="label-v3">Entrer dans MARYAN</span>
          <h2>Trois façons d’entrer dans MARYAN</h2>
        </div>

        <div class="entry-grid">
          {entryLevels.map((level) => (
            <article class:list={['entry-card', 'card-v3', level.featured && 'entry-card-featured']}>
              <span class="entry-label">{level.label}</span>
              <h3>{level.title}</h3>
              <p class="entry-body">{level.body}</p>
              <ul class="entry-list">
                {level.items.map((item) => <li>{item}</li>)}
              </ul>
              <a href={level.ctaHref} class:list={[level.featured ? 'btn-primary-v3 btn-neon' : 'btn-secondary-v3', 'entry-cta']}>
                {level.ctaLabel}
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="offre-individuelle" class="section-v3">
      <div class="container">
        <div class="section-header">
          <span class="label-v3">Offre individuelle</span>
          <h2>Pour un·e élu·e</h2>
          <p class="section-intro-copy">
            Vous démarrez seul·e, à votre rythme, selon votre fréquence d’usage.
          </p>
        </div>

        <div class="plans-grid">
          {individualPlans.map((plan) => (
            <article class:list={['plan-card', plan.featured && 'plan-card-featured']}>
              {plan.badge && <span class="plan-badge">{plan.badge}</span>}
              <p class="plan-name">{plan.name}</p>
              <div class="plan-price-row">
                <span class="plan-amount">{plan.price}</span>
                <span class="plan-period">{plan.period}</span>
              </div>
              <p class="plan-detail">{plan.detail}</p>
              <ul class="plan-list">
                {plan.features.map((feature) => <li>{feature}</li>)}
              </ul>
              <a href={plan.checkoutUrl} class:list={['w-full', plan.featured ? 'btn-primary-v3 btn-neon' : 'btn-secondary-v3']}>
                {plan.cta}
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-v3 group-pack-section">
      <div class="container">
        <div class="group-pack-panel">
          <div class="group-pack-copy">
            <span class="label-v3">Petit collectif</span>
            <h2>Pour un groupe politique</h2>
            <p class="group-pack-text">
              Un accès commun pour un petit collectif d’élu·es qui veut partager le même outil et les mêmes repères.
            </p>
            <div class="group-pack-meta">
              <strong>600 € / an</strong>
              <span>jusqu’à 8 élu·es</span>
              <span>activation simple</span>
            </div>
          </div>
          <a href="/contact" class="btn-primary-v3 group-pack-cta">Activer le pack</a>
        </div>
      </div>
    </section>

    <section id="collectivites" class="section-v3">
      <div class="container">
        <div class="section-header">
          <span class="label-v3">Déploiement collectif</span>
          <h2>Pour équiper plusieurs élu·es</h2>
          <p class="section-intro-copy">
            Exécutif, groupe d’élu·es ou collectivité : MARYAN peut être déployé à plusieurs avec le même socle d’usage.
          </p>
        </div>

        <div class="collective-grid">
          {collectiveTiers.map((tier) => (
            <article class:list={['collective-card', tier.featured && 'collective-card-featured']}>
              <p class="collective-subtitle">{tier.subtitle}</p>
              <h3>{tier.title}</h3>
              <p class="collective-price">
                <strong>{tier.price}</strong>
                <span>{tier.unit}</span>
              </p>
              <p class="collective-note">{tier.note}</p>
            </article>
          ))}
        </div>

        <div class="collective-actions">
          <a href="/contact" class="btn-primary-v3">Demander une démo</a>
          <a href="/contact" class="btn-secondary-v3">Obtenir un chiffrage</a>
        </div>
      </div>
    </section>

    <section class="section-v3 section-soft">
      <div class="container">
        <div class="section-header">
          <span class="label-v3">Usage</span>
          <h2>Ce que vous activez</h2>
        </div>

        <div class="activation-grid">
          {activationItems.map((item) => (
            <article class="activation-item">
              <p>{item}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-v3">
      <div class="container">
        <div class="mobilize-panel card-v3">
          <div class="mobilize-copy">
            <span class="label-v3">Usage quotidien</span>
            <h2>Un outil facile à mobiliser</h2>
            <p>
              MARYAN s’intègre dans le quotidien du mandat, sans dispositif lourd.
            </p>
          </div>

          <ul class="mobilize-list">
            {easyToMobilizeItems.map((item) => <li>{item}</li>)}
          </ul>

          <p class="mobilize-note">
            Un outil activable rapidement, sans dépendre d’un calendrier spécifique.
          </p>
        </div>
      </div>
    </section>

    <section class="section-v3 cta-final-section">
      <div class="container-narrow">
        <div class="cta-final-panel">
          <span class="label-v3">Aide au choix</span>
          <h2>Vous hésitez sur la bonne formule ?</h2>
          <p class="cta-lead">
            Si vous êtes seul·e, commencez par le diagnostic.<br />
            Si vous équipez plusieurs élu·es, demandez une démo et un chiffrage adapté.
          </p>
          <div class="cta-final-actions">
            <a href="/diagnostic" class="btn-primary-v3 big">Faire le diagnostic</a>
            <a href="/contact" class="btn-secondary-v3">Demander une démo</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .offres-page {
    color: var(--deep);
  }

  .section-soft {
    background: linear-gradient(180deg, rgba(10, 25, 47, 0.03), rgba(10, 25, 47, 0.01));
  }

  .accent-keyword {
    color: var(--neon) !important;
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 700;
    display: inline;
    white-space: normal;
  }

  .offres-hero {
    padding: 7rem 0 5rem;
    background:
      radial-gradient(circle at top left, rgba(230, 57, 70, 0.14), transparent 32%),
      radial-gradient(circle at bottom right, rgba(173, 255, 47, 0.1), transparent 30%),
      var(--deep);
  }

  .offres-hero-inner {
    max-width: 54rem;
  }

  .offres-hero h1 {
    color: white;
    font-size: clamp(2.4rem, 5vw, 4rem);
    line-height: 1.06;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  .offres-hero-subtitle {
    color: white;
    font-size: clamp(1.15rem, 2vw, 1.55rem);
    line-height: 1.45;
    max-width: 46rem;
    margin-bottom: 1rem;
  }

  .offres-hero-copy {
    color: rgba(255, 255, 255, 0.74);
    font-size: 1.05rem;
    line-height: 1.65;
    max-width: 42rem;
    margin-bottom: 1.75rem;
  }

  .offres-hero-actions,
  .collective-actions,
  .cta-final-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .offres-hero-signals {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 1.5rem;
  }

  .offres-hero-signals span {
    border: 1px solid rgba(255, 255, 255, 0.14);
    color: rgba(255, 255, 255, 0.76);
    border-radius: 999px;
    padding: 0.45rem 0.8rem;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .offres-hero-note {
    margin-top: 1rem;
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.94rem;
    line-height: 1.55;
  }

  .section-header {
    max-width: 48rem;
    margin: 0 auto 3.25rem;
    text-align: center;
  }

  .section-header h2 {
    font-size: clamp(2rem, 3.5vw, 3rem);
    line-height: 1.12;
    letter-spacing: -0.02em;
  }

  .section-intro-copy {
    color: #54636C;
    font-size: 1rem;
    line-height: 1.65;
    max-width: 42rem;
    margin: 1rem auto 0;
  }

  .concrete-grid,
  .activation-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .concrete-card,
  .entry-card,
  .mobilize-panel,
  .plan-card,
  .collective-card {
    border-radius: 1.75rem;
  }

  .concrete-card {
    padding: 1.6rem;
  }

  .concrete-card h3 {
    font-size: 1.15rem;
    margin-bottom: 0.85rem;
  }

  .concrete-card p,
  .entry-body,
  .activation-item p,
  .group-pack-text,
  .mobilize-copy p,
  .mobilize-note {
    color: #54636C;
    line-height: 1.65;
  }

  .entry-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .entry-card {
    padding: 1.85rem;
    border: 1px solid var(--border);
    background: white;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .entry-card-featured {
    background: var(--deep);
    border-color: var(--deep);
  }

  .entry-card-featured h3,
  .entry-card-featured .entry-body,
  .entry-card-featured .entry-list li {
    color: white;
  }

  .entry-label {
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-red);
  }

  .entry-card-featured .entry-label {
    color: var(--neon);
  }

  .entry-card h3 {
    font-size: 1.35rem;
    line-height: 1.2;
  }

  .entry-list,
  .plan-list,
  .mobilize-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .entry-list {
    margin-top: 0.25rem;
    margin-bottom: 1rem;
    flex: 1;
  }

  .entry-list li,
  .plan-list li,
  .mobilize-list li {
    position: relative;
    padding-left: 1.2rem;
    line-height: 1.55;
  }

  .entry-list li::before,
  .plan-list li::before,
  .mobilize-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent-red);
    font-size: 0.8rem;
  }

  .entry-card-featured .entry-list li::before {
    color: var(--neon);
  }

  .entry-cta {
    width: 100%;
    justify-content: center;
  }

  .plans-grid,
  .collective-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .plan-card {
    background: white;
    border: 1px solid var(--border);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .plan-card-featured {
    background: var(--deep);
    border-color: var(--deep);
  }

  .plan-badge {
    display: inline-flex;
    width: fit-content;
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    background: var(--neon);
    color: var(--deep);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .plan-name {
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #6C7B84;
  }

  .plan-card-featured .plan-name,
  .plan-card-featured .plan-detail,
  .plan-card-featured .plan-list li,
  .plan-card-featured .plan-period {
    color: rgba(255, 255, 255, 0.76);
  }

  .plan-price-row {
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
  }

  .plan-amount {
    font-size: clamp(2.4rem, 4vw, 3.2rem);
    font-weight: 800;
    line-height: 1;
  }

  .plan-card-featured .plan-amount {
    color: white;
  }

  .plan-period {
    color: #54636C;
    font-size: 1rem;
  }

  .plan-detail {
    min-height: 1.4em;
    color: #54636C;
  }

  .plan-list {
    margin-bottom: 1rem;
    flex: 1;
  }

  .w-full {
    width: 100%;
    justify-content: center;
  }

  .btn-neon {
    background: var(--neon) !important;
    color: var(--deep) !important;
    border-color: var(--neon) !important;
  }

  .group-pack-section {
    background: var(--deep);
  }

  .group-pack-panel {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 2.6rem 3rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 2rem;
  }

  .group-pack-copy h2 {
    color: white;
    font-size: clamp(1.9rem, 3vw, 2.6rem);
    margin-bottom: 0.9rem;
  }

  .group-pack-copy .label-v3 {
    color: rgba(255, 255, 255, 0.55) !important;
  }

  .group-pack-copy .label-v3::before {
    background: var(--neon) !important;
  }

  .group-pack-text {
    color: rgba(255, 255, 255, 0.75);
    max-width: 38rem;
    margin-bottom: 1rem;
  }

  .group-pack-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .group-pack-meta strong,
  .group-pack-meta span {
    border-radius: 999px;
    padding: 0.45rem 0.8rem;
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.82);
  }

  .group-pack-meta strong {
    color: var(--neon);
  }

  .group-pack-cta {
    flex-shrink: 0;
  }

  .collective-card {
    padding: 1.85rem;
    border: 1px solid var(--border);
    background: white;
  }

  .collective-card-featured {
    border-color: rgba(10, 25, 47, 0.18);
    background: #FBFCF7;
  }

  .collective-subtitle {
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6C7B84;
    margin-bottom: 0.8rem;
  }

  .collective-card h3 {
    font-size: 1.4rem;
    line-height: 1.2;
    margin-bottom: 0.9rem;
  }

  .collective-price {
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
    margin-bottom: 0.45rem;
  }

  .collective-price strong {
    font-size: 2.5rem;
    line-height: 1;
  }

  .collective-price span {
    color: #54636C;
  }

  .collective-note {
    color: #6C7B84;
  }

  .collective-actions {
    margin-top: 2rem;
    justify-content: center;
  }

  .activation-item {
    padding: 1.5rem;
    border-radius: 1.4rem;
    background: white;
    border: 1px solid var(--border);
  }

  .activation-item p {
    color: var(--deep);
    font-weight: 700;
  }

  .mobilize-panel {
    padding: 2.4rem;
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .mobilize-copy h2 {
    font-size: clamp(2rem, 3vw, 2.8rem);
    line-height: 1.12;
    margin-bottom: 1rem;
  }

  .mobilize-note {
    grid-column: 1 / -1;
    color: var(--deep);
    font-weight: 600;
  }

