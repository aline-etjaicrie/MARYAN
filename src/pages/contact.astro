---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact — MARYAN" description="Contacter MARYAN.">
  <header class="site-header">
    <div class="container header-inner">
      <div>
        <a href="/" class="brand">MARYAN</a>
        <p class="brand-sub">appui intelligent pour élus municipaux</p>
      </div>
      <a href="/" class="back-link">← Accueil</a>
    </div>
  </header>
  <main class="page-main">
    <section class="page-hero">
      <div class="container narrow">
        <p class="section-kicker">Contact</p>
        <h1>Échanger autour de MARYAN.</h1>
        <p class="lead">Pour une démonstration, un échange exploratoire, un partenariat ou un premier retour sur le projet, cette page servira de point d'entrée simple.</p>
      </div>
    </section>
    <section class="section">
      <div class="container narrow">
        <div class="card">
          <h3>Contact de travail</h3>
          <p>À compléter avec l'adresse email, le formulaire ou le lien de prise de rendez-vous que tu voudras utiliser.</p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
