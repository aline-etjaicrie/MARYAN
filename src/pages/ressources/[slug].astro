---
// Cette page est rendue côté SERVEUR — le contenu protégé
// n'est JAMAIS envoyé au navigateur si l'utilisateur n'est pas abonné.
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { maryanResources } from '../../data/resources';

const { slug } = Astro.params;
const res = maryanResources.find((r) => r.slug === slug);

if (!res) {
  return Astro.redirect('/ressources');
}

// ─── VÉRIFICATION ABONNEMENT CÔTÉ SERVEUR ───
// On lit le cookie Supabase pour savoir si l'utilisateur est connecté et abonné.
// Si non abonné → on n'envoie pas le contenu protégé du tout.

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

let hasAccess = false;

if (supabaseUrl && supabaseKey) {
  try {
    // Récupérer le token depuis les cookies de la requête
    const cookieHeader = Astro.request.headers.get('cookie') || '';
    
    // Supabase stocke le token dans un cookie nommé "sb-<ref>-auth-token"
    // On extrait la ref depuis l'URL Supabase
    const supabaseRef = supabaseUrl.replace('https://', '').split('.')[0];
    const cookieName = `sb-${supabaseRef}-auth-token`;
    
    // Parser les cookies manuellement
    const cookies = Object.fromEntries(
      cookieHeader.split(';').map(c => {
        const [key, ...val] = c.trim().split('=');
        return [key, decodeURIComponent(val.join('='))];
      })
    );
    
    const rawToken = cookies[cookieName];
    
    if (rawToken) {
      const tokenData = JSON.parse(rawToken);
      const accessToken = tokenData?.access_token;
      
      if (accessToken) {
        // Vérifier le token auprès de Supabase
        const userResponse = await fetch(`${supabaseUrl}/auth/v1/user`, {
          headers: {
            'Authorization': `Bearer ${accessToken}`,
            'apikey': supabaseKey,
          }
        });
        
        if (userResponse.ok) {
          const userData = await userResponse.json();
          const plan = userData?.user_metadata?.plan;
          hasAccess = plan === 'plus' || plan === 'admin';
        }
      }
    }
  } catch (e) {
    // En cas d'erreur → pas d'accès par sécurité
    hasAccess = false;
  }
}

// ─── FIN VÉRIFICATION ───

const pillarLabels = {
  se_situer: "Se Situer",
  comprendre: "Comprendre",
  agir: "Agir",
  se_proteger: "Se Protéger"
};

const ctaContent = {
  copilote: {
    title: "Tester cette fiche avec le copilote",
    desc: "Posez vos questions spécifiques sur ce sujet directement à l'IA MARYAN.",
    label: "Ouvrir le copilote",
    link: "/copilote"
  },
  offre_individuelle: {
    title: "Besoin d'un appui sur ce sujet ?",
    desc: "L'offre AVANCER vous propose un accompagnement confidentiel et réactif.",
    label: "Découvrir l'offre Avancer",
    link: "/offres#avancer"
  },
  offre_collectivite: {
    title: "Déployer cette méthode en équipe ?",
    desc: "Nos outils peuvent être adaptés pour toute votre collectivité ou votre groupe d'élus.",
    label: "Voir l'offre collectivité",
    link: "/offres#collectivites"
  },
  formation_irl: {
    title: "Se former sur cette thématique",
    desc: "Nous organisons des sessions de formation et de cadrage en présentiel.",
    label: "Découvrir les formations",
    link: "/methode"
  }
};

const cta = ctaContent[res.ctaType];
---

<BaseLayout 
  title={`${res.title} — Fiche MARYAN`} 
  description={res.promise}>
  
  <article class="resource-detail-v4">
    
    <!-- HEADER — visible par tous -->
    <header class="res-page-header">
      <div class="container-narrow">
        <a href="/ressources" class="back-link-v4">← Bibliothèque</a>
        <div class="header-meta">
          <span class="pillar-tag">{pillarLabels[res.pillar]}</span>
          <span class="format-badge">{res.format}</span>
        </div>
        <h1 class="res-page-title">{res.title}</h1>
        <p class="res-page-promise">{res.promise}</p>
      </div>
    </header>

    <div class="container-narrow">

      <!-- INTRO — visible par tous -->
      <section class="res-main-section">
        <div class="intro-box">
          <p>{res.intro}</p>
        </div>
      </section>

      {hasAccess ? (
        /* ══════════════════════════════════════════
           CONTENU COMPLET — abonnés uniquement
           Jamais envoyé au navigateur si pas abonné
           ══════════════════════════════════════════ */
        <>
          <section class="res-main-section">
            <h2 class="sub-title-v4">Ce qu'il faut bien comprendre</h2>
            <ul class="res-check-list">
              {res.understand.map(item => (
                <li>
                  <span class="check-icon">✓</span>
                  <p>{item}</p>
                </li>
              ))}
            </ul>
          </section>

          <section class="res-main-section">
            <div class="trap-box">
              <div class="trap-icon">⚠️</div>
              <div class="trap-content">
                <h3>Le piège classique</h3>
                <p>{res.commonTrap}</p>
              </div>
            </div>
          </section>

          <section class="res-main-section">
            <h2 class="sub-title-v4">Ce que vous pouvez faire</h2>
            <div class="actions-steps">
              {res.actions.map((action, idx) => (
                <div class="step-item">
                  <span class="step-num">{idx + 1}</span>
                  <p>{action}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="res-main-section">
            <div class="reflex-card">
              <span class="reflex-label">Le Réflexe MARYAN</span>
              <p class="reflex-text">" {res.reflex} "</p>
            </div>
          </section>

          {res.sensitiveNote && (
            <section class="res-main-section">
              <div class="note-box">
                <p><strong>Note :</strong> {res.sensitiveNote}</p>
              </div>
            </section>
          )}

          <footer class="res-page-footer">
            <div class="tags-container">
              {res.tags.map(tag => <span class="res-tag">#{tag}</span>)}
            </div>
          </footer>

          <section class="res-cta-block card-v3">
            <div class="cta-inner">
              <div class="cta-info">
                <h3>{cta.title}</h3>
                <p>{cta.desc}</p>
              </div>
              <a href={cta.link} class="btn-primary-v4">{cta.label}</a>
            </div>
          </section>
        </>
      ) : (
        /* ══════════════════════════════════════════
           PAYWALL — non abonnés
           Le contenu protégé n'existe pas dans ce HTML
           ══════════════════════════════════════════ */
        <div class="paywall-block">
          <div class="paywall-inner">
            <div class="paywall-icon">🔒</div>
            <h2>Contenu réservé aux abonné·es</h2>
            <p>
              Cette fiche complète — les points de vigilance, les actions concrètes
              et le Réflexe MARYAN — est accessible avec l'abonnement Plus.
            </p>
            <div class="paywall-actions">
              <a href="/offres" class="btn-primary-v4">Voir les offres</a>
              <a href="/login" class="btn-secondary-v4">Se connecter</a>
            </div>
            <p class="paywall-note">
              Déjà abonné·e ? <a href="/login">Connectez-vous</a> pour accéder à la fiche.
            </p>
          </div>
        </div>
      )}

    </div>
  </article>

</BaseLayout>

<style>
  :root {
    --deep: #0A192F;
    --neon: #ADFF2F;
    --red: #E63946;
    --bg: #F8F9FA;
    --border: rgba(10, 25, 47, 0.08);
  }

  .resource-detail-v4 { background: var(--bg); padding-bottom: 8rem; min-height: 100vh; }
  .container-narrow { max-width: 720px; margin: 0 auto; padding: 0 1.5rem; }

  /* ─── HEADER ─── */
  .res-page-header { background: white; padding: 6rem 0 4rem; border-bottom: 1px solid var(--border); margin-bottom: 4rem; }
  .back-link-v4 { display: inline-block; text-decoration: none; color: var(--deep); opacity: 0.4; font-weight: 700; font-size: 0.9rem; margin-bottom: 2.5rem; transition: opacity 0.2s; }
  .back-link-v4:hover { opacity: 1; }
  
  .header-meta { display: flex; gap: 1rem; align-items: center; margin-bottom: 1.5rem; }
  .pillar-tag { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--red); letter-spacing: 0.05em; }
  .format-badge { font-size: 0.65rem; font-weight: 800; background: var(--deep); color: white; padding: 0.3rem 0.6rem; border-radius: 4px; text-transform: uppercase; }
  
  .res-page-title { font-size: clamp(2.2rem, 6vw, 3.4rem); line-height: 1.1; font-weight: 900; color: var(--deep); letter-spacing: -0.03em; margin-bottom: 1.5rem; }
  .res-page-promise { font-size: 1.3rem; line-height: 1.4; color: #54636C; font-weight: 600; }

  /* ─── SECTIONS ─── */
  .res-main-section { margin-bottom: 4rem; }
  .sub-title-v4 { font-size: 1.5rem; font-weight: 800; margin-bottom: 2rem; color: var(--deep); }
  .intro-box { font-size: 1.25rem; line-height: 1.6; color: var(--deep); opacity: 0.85; }

  .res-check-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1.5rem; }
  .res-check-list li { display: flex; gap: 1rem; align-items: flex-start; }
  .check-icon { font-weight: 900; color: var(--neon); background: var(--deep); width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; flex-shrink: 0; margin-top: 0.2rem; }
  .res-check-list p { font-size: 1.15rem; font-weight: 600; color: #333; line-height: 1.4; }

  .trap-box { background: #FFF5F5; border: 1.5px solid #FFEBEB; padding: 2.5rem; border-radius: 20px; display: flex; gap: 1.5rem; align-items: flex-start; }
  .trap-icon { font-size: 2rem; }
  .trap-content h3 { font-size: 1rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--red); margin-bottom: 0.5rem; }
  .trap-content p { font-size: 1.1rem; line-height: 1.5; color: #444; font-weight: 600; }

  .actions-steps { display: flex; flex-direction: column; gap: 1rem; }
  .step-item { display: flex; gap: 1.5rem; align-items: center; background: white; padding: 1.5rem 2rem; border-radius: 16px; border: 1px solid var(--border); }
  .step-num { width: 32px; height: 32px; background: var(--bg); border: 1px solid var(--border); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.9rem; font-weight: 800; color: var(--deep); flex-shrink: 0; }
  .step-item p { font-size: 1.1rem; font-weight: 700; color: var(--deep); }

  .reflex-card { background: var(--deep); color: white; padding: 3.5rem; border-radius: 32px; text-align: center; box-shadow: 0 20px 40px rgba(0,0,0,0.1); position: relative; overflow: hidden; }
  .reflex-label { display: block; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--neon); letter-spacing: 0.2em; margin-bottom: 1.5rem; }
  .reflex-text { font-size: 1.8rem; font-weight: 800; line-height: 1.25; letter-spacing: -0.01em; }
  .reflex-card::after { content: "\201C"; position: absolute; top: -20px; left: 20px; font-size: 10rem; opacity: 0.05; font-family: serif; }

  .note-box { font-size: 1rem; opacity: 0.6; font-style: italic; border-left: 3px solid var(--border); padding-left: 1.5rem; }

  .res-page-footer { margin-top: 5rem; padding-top: 3rem; border-top: 1px solid var(--border); }
  .tags-container { display: flex; gap: 0.8rem; flex-wrap: wrap; }
  .res-tag { font-size: 0.85rem; font-weight: 700; color: #99A1A7; }

  /* ─── CTA BLOCK ─── */
  .res-cta-block { margin-top: 6rem; background: white; border: 1.5px solid var(--deep); padding: 3rem; border-radius: 32px; }
  .cta-inner { display: flex; justify-content: space-between; align-items: center; gap: 3rem; }
  .cta-info h3 { font-size: 1.5rem; margin-bottom: 0.5rem; }
  .cta-info p { opacity: 0.6; font-size: 1rem; }

  /* ─── PAYWALL ─── */
  .paywall-block { display: flex; justify-content: center; margin: 2rem 0 6rem; }
  .paywall-inner { background: white; border: 2px solid var(--deep); border-radius: 32px; padding: 4rem 3rem; text-align: center; max-width: 520px; width: 100%; }
  .paywall-icon { font-size: 2.5rem; margin-bottom: 1.5rem; }
  .paywall-inner h2 { font-size: 1.6rem; font-weight: 900; color: var(--deep); margin-bottom: 1rem; }
  .paywall-inner > p { font-size: 1.05rem; color: #54636C; line-height: 1.5; margin-bottom: 2.5rem; }
  .paywall-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-bottom: 1.5rem; }
  .paywall-note { font-size: 0.85rem; color: #99A1A7; }
  .paywall-note a { color: var(--deep); font-weight: 700; }

  /* ─── BOUTONS ─── */
  .btn-primary-v4 { background: var(--deep); color: #fff; border: none; padding: 1.1rem 2.2rem; border-radius: 14px; font-weight: 800; font-size: 1rem; cursor: pointer; transition: all 0.2s; display: inline-block; text-align: center; text-decoration: none; }
  .btn-primary-v4:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(0,0,0,0.1); }
  .btn-secondary-v4 { background: transparent; color: var(--deep); border: 2px solid var(--deep); padding: 1.1rem 2.2rem; border-radius: 14px; font-weight: 800; font-size: 1rem; cursor: pointer; transition: all 0.2s; display: inline-block; text-align: center; text-decoration: none; }
  .btn-secondary-v4:hover { background: var(--deep); color: white; }

  @media (max-width: 800px) {
    .cta-inner { flex-direction: column; text-align: center; gap: 2rem; }
    .res-page-header { padding: 4rem 0 3rem; }
    .res-page-title { font-size: 2.3rem; }
    .reflex-card { padding: 2.5rem 1.5rem; }
    .reflex-text { font-size: 1.4rem; }
    .paywall-inner { padding: 3rem 1.5rem; }
  }
</style>
