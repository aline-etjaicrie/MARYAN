---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import methodHeroImage from '../assets/maryan-hero-mandat.png';

const missingToday = [
  "des repères entre deux temps de formation",
  "une première lecture claire quand une situation se tend",
  "un moyen de prioriser sans tout mettre au même niveau",
  "un appui simple pour relier compréhension, décision et parole publique"
];

const especiallyUsefulFor = [
  "les élu·es qui commencent leur mandat",
  "les adjoint·es qui découvrent une délégation",
  "les élu·es de petites et moyennes collectivités",
  "les élu·es qui gardent une activité professionnelle en parallèle"
];

const firstSteps = [
  "faire le point sur sa situation",
  "identifier ce qui mérite d'être traité en premier",
  "accéder aux ressources utiles sans se disperser",
  "poser une question ciblée au copilote quand le sujet se précise"
];

const specializedApproach = [
  "aider à décider, pas seulement à reformuler",
  "tenir compte des situations sensibles et des angles morts",
  "orienter vers le bon niveau d'appui au lieu de produire une réponse standard",
  "garder un relais humain quand une situation l'exige"
];

const supportLevels = [
  {
    title: 'Démarrer',
    intro: "Quand il faut d'abord retrouver des repères.",
    points: ['un diagnostic rapide', 'des ressources fiables', "une première direction"]
  },
  {
    title: 'Avancer',
    intro: "Quand le mandat demande un appui régulier.",
    points: ['un copilote spécialisé', "des ressources ciblées", 'un cadre pour mieux prioriser']
  },
  {
    title: 'Arbitrer',
    intro: "Quand la situation devient technique, tendue ou exposée.",
    points: ['une lecture plus fine', 'un relais humain si besoin', "un appui plus sûr pour décider"]
  }
];
---

<BaseLayout
  title="Méthode — MARYAN"
  description="MARYAN aide les élu·es à clarifier une situation, prioriser et accéder au bon niveau d’appui dans l’exercice du mandat."
>
  <main class="method-page">
    <section class="method-hero">
      <div class="container method-hero-shell">
        <div class="method-hero-copy">
          <span class="label-v3">Méthode</span>
          <h1>
            Pourquoi Maryan, pourquoi <span class="accent-keyword">maintenant</span> ?
          </h1>
          <p class="method-lead">
            Le mandat local demande aujourd’hui de décider vite, de comprendre des sujets
            techniques, de travailler avec l’administration et de tenir une parole lisible,
            souvent avec peu d’appuis stables.
          </p>
          <p class="method-sublead">
            MARYAN a été conçu pour combler ce manque : un appui simple entre la formation
            ponctuelle et les situations concrètes du mandat.
          </p>
          <div class="method-actions">
            <a href="/diagnostic" class="btn-primary-v3">Faire le diagnostic</a>
            <a href="/offres" class="btn-secondary-v3">Voir les offres</a>
          </div>
        </div>

        <div class="method-hero-visual">
          <div class="method-image-frame">
            <Image
              src={methodHeroImage}
              alt="Carnet, smartphone et écharpe tricolore sur une table de travail."
              class="method-hero-image"
              sizes="(max-width: 900px) 100vw, 42vw"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="section-v3 method-section">
      <div class="container container-medium">
        <header class="method-section-header">
          <span class="label-v3">Le constat</span>
          <h2>Le mandat s’exerce avec moins d’<span class="accent-keyword">appuis</span> stables.</h2>
          <p>
            Les élu·es n’ont pas seulement besoin d’information. Il leur faut aussi des repères
            utilisables au bon moment.
          </p>
        </header>

        <div class="method-grid method-grid-2">
          <article class="method-card">
            <h3>Ce qui manque souvent aujourd’hui</h3>
            <ul class="method-list">
              {missingToday.map((item) => <li>{item}</li>)}
            </ul>
          </article>

          <article class="method-card method-card-soft">
            <h3>Particulièrement utile pour</h3>
            <ul class="method-list">
              {especiallyUsefulFor.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        </div>
      </div>
    </section>

    <section class="section-v3 method-section method-section-alt">
      <div class="container container-medium">
        <header class="method-section-header">
          <span class="label-v3">Ce que fait MARYAN</span>
          <h2>Un appui pour <span class="accent-keyword">clarifier</span>, prioriser, agir.</h2>
          <p>
            MARYAN n’est pas là pour ajouter du texte. Il sert à reprendre de la clarté dans une
            situation avant de décider.
          </p>
        </header>

        <div class="method-grid method-grid-2">
          <article class="method-card method-card-deep">
            <h3>Concrètement</h3>
            <ul class="method-list">
              {firstSteps.map((item) => <li>{item}</li>)}
            </ul>
            <p class="method-note">
              Le diagnostic, les ressources et le copilote se répondent dans un même parcours.
            </p>
          </article>

          <article class="method-card">
            <h3>Pourquoi ce n’est pas une IA généraliste</h3>
            <p class="method-card-copy">
              Une IA généraliste peut aider à reformuler. MARYAN est conçu pour des situations de
              mandat, avec une logique d’orientation et de discernement.
            </p>
            <ul class="method-list">
              {specializedApproach.map((item) => <li>{item}</li>)}
            </ul>
            <p class="method-note">Un appui, pas un substitut.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section-v3 method-section">
      <div class="container">
        <header class="method-section-header method-section-header-centered">
          <span class="label-v3">Progression</span>
          <h2>Le bon niveau d’<span class="accent-keyword">appui</span>, au bon moment.</h2>
          <p>
            Tous les mandats n’ont pas besoin de la même intensité d’accompagnement. MARYAN part
            de cette réalité.
          </p>
        </header>

        <div class="method-grid method-grid-3">
          {supportLevels.map((level) => (
            <article class="method-card method-level-card">
              <h3>{level.title}</h3>
              <p class="method-card-copy">{level.intro}</p>
              <ul class="method-list">
                {level.points.map((point) => <li>{point}</li>)}
              </ul>
            </article>
          ))}
        </div>

        <p class="method-statement">
          MARYAN repose sur une idée simple : proposer le bon niveau d’appui selon la situation
          réelle, sans surcharger le mandat.
        </p>
      </div>
    </section>

    <section class="section-v3 method-cta-section">
      <div class="container container-narrow">
        <div class="method-cta-card">
          <span class="label-v3">Commencer</span>
          <h2>La bonne première étape reste le <span class="accent-keyword">diagnostic</span>.</h2>
          <p>
            En quelques minutes, vous clarifiez votre situation, vos priorités et le type d’appui
            le plus utile pour la suite.
          </p>
          <div class="method-actions method-actions-centered">
            <a href="/diagnostic" class="btn-primary-v3">Faire le diagnostic</a>
            <a href="/copilote" class="btn-secondary-v3">Ouvrir le copilote</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .accent-keyword {
    color: var(--neon) !important;
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 700;
    text-transform: none;
    display: inline;
    white-space: normal;
  }

  .method-page {
    padding-bottom: 6rem;
  }

  .method-hero {
    padding: 6rem 0 4rem;
    background:
      radial-gradient(circle at top left, rgba(230, 57, 70, 0.14), transparent 34%),
      radial-gradient(circle at bottom right, rgba(173, 255, 47, 0.12), transparent 36%),
      var(--deep);
    color: white;
  }

  .method-hero-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, 0.9fr);
    gap: 2.75rem;
    align-items: center;
  }

  .method-hero-copy {
    max-width: 42rem;
  }

  .method-hero h1 {
    color: white;
    font-size: clamp(2.4rem, 5.8vw, 4.35rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
    margin: 1.25rem 0 1.5rem;
  }

  .method-lead,
  .method-sublead {
    font-size: 1.08rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.82);
    max-width: 38rem;
  }

  .method-sublead {
    margin-top: 1rem;
  }

  .method-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
  }

  .method-hero-visual {
    position: relative;
  }

  .method-image-frame {
    border-radius: 2rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 24px 60px rgba(3, 10, 22, 0.22);
    background: rgba(255, 255, 255, 0.04);
  }

  .method-hero-image {
    display: block;
    width: 100%;
    height: auto;
  }

  .method-section-header {
    max-width: 48rem;
    margin: 0 0 2.5rem;
  }

  .method-section-header-centered {
    margin: 0 auto 2.5rem;
    text-align: center;
  }

  .method-section-header h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin: 1.15rem 0 1rem;
  }

  .method-section-header p {
    color: #54636c;
    font-size: 1.05rem;
    line-height: 1.7;
    margin: 0;
  }

  .method-section-alt {
    background: linear-gradient(180deg, rgba(248, 243, 235, 0.7) 0%, transparent 100%);
  }

  .method-grid {
    display: grid;
    gap: 1.5rem;
  }

  .method-grid-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .method-grid-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .method-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: 1.75rem;
    padding: 2rem;
    box-shadow: 0 18px 45px rgba(10, 25, 47, 0.04);
  }

  .method-card-soft {
    background: #f8f3eb;
  }

  .method-card-deep {
    background: var(--deep);
    border-color: rgba(10, 25, 47, 0.9);
    color: white;
  }

  .method-card h3 {
    font-size: 1.35rem;
    line-height: 1.2;
    margin: 0 0 1rem;
    color: var(--deep);
  }

  .method-card-deep h3 {
    color: white;
  }

  .method-card-copy {
    color: #54636c;
    font-size: 1rem;
    line-height: 1.65;
    margin: 0 0 1rem;
  }

  .method-card-deep .method-card-copy {
    color: rgba(255, 255, 255, 0.76);
  }

  .method-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.85rem;
  }

  .method-list li {
    position: relative;
    padding-left: 1.15rem;
    color: #54636c;
    line-height: 1.55;
  }

  .method-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.7rem;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--accent-red);
    transform: translateY(-50%);
  }

  .method-card-deep .method-list li {
    color: rgba(255, 255, 255, 0.8);
  }

  .method-card-deep .method-list li::before {
    background: var(--neon);
  }

  .method-note {
    margin-top: 1.25rem;
    color: var(--deep);
    font-weight: 700;
    line-height: 1.55;
  }

  .method-card-deep .method-note {
    color: var(--neon);
  }

  .method-level-card {
    min-height: 100%;
  }

  .method-statement {
    margin: 2rem auto 0;
    max-width: 46rem;
    text-align: center;
    color: var(--deep);
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.65;
  }

  .method-cta-section {
    padding-top: 0;
  }

  .method-cta-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: 2rem;
    padding: 3rem 2.5rem;
    text-align: center;
    box-shadow: 0 20px 50px rgba(10, 25, 47, 0.05);
  }

  .method-cta-card h2 {
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 1rem 0 1rem;
  }

  .method-cta-card p {
    color: #54636c;
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 40rem;
    margin: 0 auto;
  }

  .method-actions-centered {
    justify-content: center;
  }

  @media (max-width: 980px) {
    .method-hero-shell,
    .method-grid-2,
    .method-grid-3 {
      grid-template-columns: 1fr;
    }

    .method-hero {
      padding: 5rem 0 3.5rem;
    }
  }

  @media (max-width: 720px) {
    .method-card,
    .method-cta-card {
      padding: 1.6rem;
      border-radius: 1.4rem;
    }

    .method-actions {
      flex-direction: column;
    }

    .method-actions :global(a) {
      width: 100%;
      justify-content: center;
    }
  }
</style>
