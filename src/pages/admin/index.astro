      <datalist id="radarThemes">
        ${radarState.options.themes.map((theme: string) => `<option value="${escapeHtml(theme)}"></option>`).join('')}
      </datalist>

      <div class="radar-preview-shell">
        <div class="radar-preview-shell__head">
          <strong>Aperçu premium interne</strong>
          <span>Prévisualisation de la carte une fois le Radar rouvert</span>
        </div>
        <div id="radarPreview"></div>
      </div>
    `;

    bindRadarEditorEvents();
  }

  function renderRadar() {
    radarModeBadge.textContent = radarState.mode === 'database' ? 'Base Supabase' : 'Seed local';
    radarModeLabel.textContent = radarState.persistenceAvailable
      ? 'Catalogue persisté et éditable.'
      : 'Lecture seule tant que la migration Radar n’est pas appliquée.';

    radarSeedBtn.disabled = !radarState.persistenceAvailable;
    radarCreateBtn.disabled = !radarState.persistenceAvailable;

    renderRadarNotice();
    renderRadarStats();
    renderRadarList();
    renderRadarEditor();
  }

  async function loadRadar(token: string, preferredId?: string | null) {
    const res = await fetch('/api/admin/radar', {
      headers: { Authorization: `Bearer ${token}` }
    });

    const data = await res.json();
    if (!res.ok || !data.ok) {
      throw new Error(data.error || 'Erreur chargement Radar.');
    }

    radarState.token = token;
    radarState.mode = data.mode || 'seed';
    radarState.persistenceAvailable = Boolean(data.persistenceAvailable);
    radarState.warning = data.warning || '';
    radarState.signals = data.signals || [];
    radarState.options = data.options || radarState.options;

    const nextSelectedId = preferredId || radarState.selectedId;
    radarState.selectedId = radarState.signals.some((signal: any) => signal.id === nextSelectedId)
      ? nextSelectedId
      : radarState.signals[0]?.id || null;

    renderRadar();
  }

  async function loadUsers(token: string) {
    const res = await fetch('/api/admin/users', { headers: { Authorization: `Bearer ${token}` } });
    const data = await res.json();
    if (!res.ok || !data.users) { showError('Erreur chargement utilisateurs.'); return; }

    const users = data.users as any[];
    document.getElementById('statTotal')!.textContent = String(users.length);
    document.getElementById('statPlus')!.textContent = String(users.filter((u: any) => u.plan === 'plus').length);
    document.getElementById('statFree')!.textContent = String(users.filter((u: any) => !u.plan || u.plan === 'gratuit').length);
    document.getElementById('statSessions')!.textContent = String(users.reduce((a: number, u: any) => a + (u.session_count || 0), 0));

    const tbody = document.getElementById('usersTableBody')!;
    tbody.innerHTML = users.map((u: any) => `
      <tr>
        <td>${escapeHtml(u.first_name || '—')}</td>
        <td>${escapeHtml(u.commune || '—')}</td>
        <td>${escapeHtml(u.role || '—')}</td>
        <td>${escapeHtml(u.parti_label || '—')}</td>
        <td>${u.diagnostic_label ? `<span class="diag-badge">${escapeHtml(u.diagnostic_label.slice(0, 20))}…</span>` : '—'}</td>
        <td>${u.session_count || 0}</td>
        <td><span class="plan-badge plan-${u.plan || 'gratuit'}">${escapeHtml(u.plan || 'gratuit')}</span></td>
        <td>
          <select class="plan-select" data-user-id="${u.id}" data-token="${token}">
            <option value="gratuit" ${(!u.plan || u.plan === 'gratuit') ? 'selected' : ''}>Gratuit</option>
            <option value="plus" ${u.plan === 'plus' ? 'selected' : ''}>Plus</option>
            <option value="admin" ${u.plan === 'admin' ? 'selected' : ''}>Admin</option>
          </select>
        </td>
      </tr>
    `).join('');

    tbody.querySelectorAll('.plan-select').forEach((sel) => {
      sel.addEventListener('change', async (event) => {
        const target = event.target as HTMLSelectElement;
        const userId = target.getAttribute('data-user-id')!;
        const t = target.getAttribute('data-token')!;
        const plan = target.value;
        const res = await fetch('/api/admin/users', {
          method: 'PATCH',
          headers: { Authorization: `Bearer ${t}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ user_id: userId, plan })
        });
        if (!res.ok) { alert('Erreur lors de la mise à jour.'); return; }
        const row = target.closest('tr')!;
        const badge = row.querySelector('.plan-badge')!;
        badge.className = `plan-badge plan-${plan}`;
        badge.textContent = plan;
      });
    });
  }

  async function loadGlossaire(token: string) {
    const res = await fetch('/api/admin/glossaire', { headers: { Authorization: `Bearer ${token}` } });
    const data = await res.json();
    if (!res.ok) return;

    const contributions = data.contributions as any[];
    const pending = contributions.filter((c: any) => c.statut === 'en_attente');
    const badge = document.getElementById('pendingBadge')!;
    if (pending.length > 0) {
      badge.textContent = String(pending.length);
      badge.style.display = 'inline-block';
    }

    const list = document.getElementById('glossaireList')!;
    if (!contributions.length) {
      list.innerHTML = '<p class="empty-state">Aucune contribution pour le moment.</p>';
      return;
    }

    list.innerHTML = contributions.map((c: any) => `
      <div class="contrib-card" id="contrib-${c.id}">
        <div class="contrib-meta">
          <span class="contrib-statut statut-${c.statut}">${escapeHtml(c.statut)}</span>
          <span class="contrib-date">${new Date(c.created_at).toLocaleDateString('fr-FR')}</span>
        </div>
        <div class="contrib-body">
          <strong>${escapeHtml(c.mot || c.terme || c.title || '(sans titre)')}</strong>
          <p>${escapeHtml(c.definition || c.content || c.message || c.pourquoi || '')}</p>
        </div>
        ${c.statut === 'en_attente' ? `
          <div class="contrib-actions">
            <button class="btn-valider" data-id="${c.id}" data-token="${token}">Valider</button>
            <button class="btn-rejeter" data-id="${c.id}" data-token="${token}">Rejeter</button>
          </div>
        ` : ''}
      </div>
    `).join('');

    list.querySelectorAll('.btn-valider').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-id')!;
        const t = btn.getAttribute('data-token')!;
        await moderateContrib(id, 'valide', t);
      });
    });

    list.querySelectorAll('.btn-rejeter').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-id')!;
        const t = btn.getAttribute('data-token')!;
        await moderateContrib(id, 'rejete', t);
      });
    });
  }

  async function moderateContrib(id: string, statut: string, token: string) {
    const res = await fetch('/api/admin/glossaire', {
      method: 'PATCH',
      headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
      body: JSON.stringify({ id, statut })
    });
    if (res.ok) {
      const card = document.getElementById(`contrib-${id}`);
      if (card) {
        const statutEl = card.querySelector('.contrib-statut');
        if (statutEl) {
          statutEl.className = `contrib-statut statut-${statut}`;
          statutEl.textContent = statut;
        }
        card.querySelector('.contrib-actions')?.remove();
      }
    }
  }

  async function init() {
    if (!SUPABASE_URL || !SUPABASE_KEY) { showError('Configuration manquante.'); return; }
    const supabase = createClient(SUPABASE_URL, SUPABASE_KEY);
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) { window.location.href = '/login'; return; }

    const token = session.access_token;

    const profileRes = await supabase.from('profiles').select('plan').eq('id', session.user.id).single();
    if (profileRes.data?.plan !== 'admin') {
      window.location.href = '/mon-compte';
      return;
    }

    adminLoader.style.display = 'none';
    adminContent.style.display = 'block';

    await loadUsers(token);
    await loadGlossaire(token);
    await loadRadar(token);

    document.querySelectorAll('.admin-tab').forEach((button) => {
      button.addEventListener('click', () => {
        document.querySelectorAll('.admin-tab').forEach((entry) => entry.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach((panel) => ((panel as HTMLElement).style.display = 'none'));
        button.classList.add('active');
        const tab = button.getAttribute('data-tab');
        const panel = document.getElementById(`tab-${tab}`);
        if (panel) panel.style.display = 'block';
      });
    });

    radarRefreshBtn.addEventListener('click', async () => {
      try {
        await loadRadar(token, radarState.selectedId);
        setRadarFeedback('Catalogue Radar actualisé.', 'info');
      } catch (error) {
        setRadarFeedback(error instanceof Error ? error.message : 'Actualisation impossible.', 'error');
      }
    });

    radarSeedBtn.addEventListener('click', async () => {
      if (!radarState.persistenceAvailable) {
        setRadarFeedback('La table Radar n’est pas encore disponible. Applique d’abord la migration Supabase.', 'error');
        return;
      }

      try {
        const res = await fetch('/api/admin/radar', {
          method: 'POST',
          headers: {
            Authorization: `Bearer ${token}`,
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ action: 'seed' })
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Import impossible.');
        setRadarFeedback(`Seed local importé: ${data.result?.inserted || 0} signal(s) ajouté(s).`, 'success');
        await loadRadar(token, radarState.selectedId);
      } catch (error) {
        setRadarFeedback(error instanceof Error ? error.message : 'Import impossible.', 'error');
      }
    });

    radarCreateBtn.addEventListener('click', async () => {
      if (!radarState.persistenceAvailable) {
        setRadarFeedback('La table Radar n’est pas encore disponible. Applique d’abord la migration Supabase.', 'error');
        return;
      }

      try {
        const res = await fetch('/api/admin/radar', {
          method: 'POST',
          headers: {
            Authorization: `Bearer ${token}`,
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ action: 'create' })
        });
        const data = await res.json();
        if (!res.ok || !data.signal) throw new Error(data.error || 'Création impossible.');
        setRadarFeedback('Nouveau brouillon créé.', 'success');
        await loadRadar(token, data.signal.id);
      } catch (error) {
        setRadarFeedback(error instanceof Error ? error.message : 'Création impossible.', 'error');
      }
    });
  }

  init();
</script>

