---
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = false;
---

<BaseLayout title="Dashboard Admin — MARYAN" description="Administration MARYAN">
  <main class="admin-page">
    <div class="admin-wrap">
      <div class="admin-header">
        <h1>Dashboard Admin</h1>
        <p class="admin-sub">Gestion des utilisateurs, abonnements, modération et pilotage éditorial du Radar.</p>
        <div id="adminError" class="admin-error" style="display:none;"></div>
      </div>

      <div id="adminLoader" class="admin-loader">Vérification des accès…</div>
      <div id="adminContent" style="display:none;">
        <div class="stats-grid" id="statsGrid">
          <div class="stat-card">
            <div class="stat-value" id="statTotal">—</div>
            <div class="stat-label">Utilisateurs</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="statPlus">—</div>
            <div class="stat-label">Abonnés Plus</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="statFree">—</div>
            <div class="stat-label">Gratuit</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="statSessions">—</div>
            <div class="stat-label">Sessions totales</div>
          </div>
        </div>

        <div class="admin-tools">
          <a href="/admin/prompts" class="admin-tool-card">
            <div class="admin-tool-eyebrow">Studio interne</div>
            <div class="admin-tool-title">MARYAN Prompt Studio</div>
            <p class="admin-tool-body">Structurer les réponses, les arbitrages et les situations sensibles du mandat.</p>
            <span class="admin-tool-cta">Ouvrir le studio →</span>
          </a>
        </div>

        <div class="admin-tabs">
          <button class="admin-tab active" data-tab="users">Utilisateurs</button>
          <button class="admin-tab" data-tab="glossaire">
            Glossaire
            <span id="pendingBadge" class="badge" style="display:none;"></span>
          </button>
          <button class="admin-tab" data-tab="radar">Radar</button>
        </div>

        <div id="tab-users" class="tab-content">
          <div class="table-wrap">
            <table class="admin-table" id="usersTable">
              <thead>
                <tr>
                  <th>Prénom</th>
                  <th>Commune</th>
                  <th>Rôle</th>
                  <th>Parti</th>
                  <th>Diagnostic</th>
                  <th>Sessions</th>
                  <th>Plan</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody id="usersTableBody"></tbody>
            </table>
          </div>
        </div>

        <div id="tab-glossaire" class="tab-content" style="display:none;">
          <div id="glossaireList"></div>
        </div>

        <div id="tab-radar" class="tab-content" style="display:none;">
          <section class="radar-admin-shell">
            <div class="radar-admin-toolbar">
              <div>
                <div class="radar-admin-eyebrow">Pilotage éditorial</div>
                <h2 class="radar-admin-title">Radar</h2>
                <p class="radar-admin-copy">
                  Vérifier les sources, distinguer le factuel de la lecture MARYAN et préparer une publication propre.
                </p>
              </div>
              <div class="radar-admin-toolbar__actions">
                <button id="radarRefreshBtn" type="button" class="admin-secondary-btn">Actualiser</button>
                <button id="radarSeedBtn" type="button" class="admin-secondary-btn">Importer le seed local</button>
                <button id="radarCreateBtn" type="button" class="admin-primary-btn">Nouveau signal</button>
              </div>
            </div>

            <div id="radarStatusNotice" class="radar-admin-notice" style="display:none;"></div>
            <div id="radarStats" class="radar-admin-stats"></div>

            <div class="radar-admin-grid">
              <aside class="radar-admin-panel radar-admin-panel--list">
                <div class="radar-admin-panel__head">
                  <div>
                    <strong>Catalogue</strong>
                    <p id="radarModeLabel" class="radar-admin-panel__sub">Chargement…</p>
                  </div>
                  <span id="radarModeBadge" class="radar-mode-badge">—</span>
                </div>
                <div id="radarList" class="radar-admin-list"></div>
              </aside>

              <section class="radar-admin-panel radar-admin-panel--editor">
                <div id="radarEditorEmpty" class="empty-state">
                  Sélectionnez un signal pour compléter la source, la preuve et l’analyse.
                </div>
                <div id="radarEditor" style="display:none;"></div>
              </section>
            </div>
          </section>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL as string;
  const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY as string;

  const adminError = document.getElementById('adminError') as HTMLDivElement;
  const adminLoader = document.getElementById('adminLoader') as HTMLDivElement;
  const adminContent = document.getElementById('adminContent') as HTMLDivElement;

  const radarList = document.getElementById('radarList') as HTMLDivElement;
  const radarEditor = document.getElementById('radarEditor') as HTMLDivElement;
  const radarEditorEmpty = document.getElementById('radarEditorEmpty') as HTMLDivElement;
  const radarStats = document.getElementById('radarStats') as HTMLDivElement;
  const radarStatusNotice = document.getElementById('radarStatusNotice') as HTMLDivElement;
  const radarModeLabel = document.getElementById('radarModeLabel') as HTMLParagraphElement;
  const radarModeBadge = document.getElementById('radarModeBadge') as HTMLSpanElement;
  const radarRefreshBtn = document.getElementById('radarRefreshBtn') as HTMLButtonElement;
  const radarSeedBtn = document.getElementById('radarSeedBtn') as HTMLButtonElement;
  const radarCreateBtn = document.getElementById('radarCreateBtn') as HTMLButtonElement;

  const radarState = {
    token: '',
    mode: 'seed',
    persistenceAvailable: false,
    warning: '',
    signals: [] as any[],
    selectedId: null as string | null,
    options: {
      statuses: ['draft', 'review', 'ready', 'published', 'archived'],
      sourceKinds: ['external', 'internal_maryan'],
      proofStatuses: ['verified', 'internal', 'unverified'],
      types: ['loi', 'décret', 'jurisprudence', 'signal', 'article de presse'],
      levels: ['national', 'interco', 'local'],
      themes: [] as string[]
    },
    feedback: null as null | { message: string; tone: 'info' | 'success' | 'error' }
  };

  function showError(msg: string) {
    adminError.textContent = msg;
    adminError.style.display = 'block';
    adminLoader.style.display = 'none';
  }

  function escapeHtml(value: unknown) {
    return String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');
  }

  function formatDate(value: string | null | undefined) {
    if (!value) return 'Date non renseignée';

    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return value;

    return new Intl.DateTimeFormat('fr-FR', {
      day: 'numeric',
      month: 'short',
      year: 'numeric'
    }).format(date);
  }

  function proofLabel(proofStatus: string) {
    if (proofStatus === 'verified') return 'Source vérifiée';
    if (proofStatus === 'internal') return 'Signal éditorial MARYAN';
    return 'Source à vérifier';
  }

  function setRadarFeedback(message: string, tone: 'info' | 'success' | 'error' = 'info') {
    radarState.feedback = { message, tone };
    renderRadarNotice();
  }

  function renderRadarNotice() {
    const activeMessage = radarState.feedback || (radarState.warning ? { message: radarState.warning, tone: 'info' as const } : null);

    if (!activeMessage) {
      radarStatusNotice.style.display = 'none';
      radarStatusNotice.textContent = '';
      radarStatusNotice.className = 'radar-admin-notice';
      return;
    }

    radarStatusNotice.style.display = 'block';
    radarStatusNotice.textContent = activeMessage.message;
    radarStatusNotice.className = `radar-admin-notice radar-admin-notice--${activeMessage.tone}`;
  }

  function renderSelectOptions(options: string[], current: string | null | undefined) {
    return options.map((entry) => `
      <option value="${escapeHtml(entry)}" ${entry === current ? 'selected' : ''}>${escapeHtml(entry)}</option>
    `).join('');
  }

  function getSelectedRadarSignal() {
    return radarState.signals.find((signal: any) => signal.id === radarState.selectedId) || null;
  }

  function renderRadarStats() {
    const total = radarState.signals.length;
    const published = radarState.signals.filter((signal: any) => signal.isPublished).length;
    const ready = radarState.signals.filter((signal: any) => signal.canPublish && signal.status === 'ready').length;
    const verified = radarState.signals.filter((signal: any) => signal.proofStatus === 'verified').length;
    const withIssues = radarState.signals.filter((signal: any) => signal.issues?.length).length;

    radarStats.innerHTML = `
      <div class="radar-stat-card">
        <div class="radar-stat-card__value">${total}</div>
        <div class="radar-stat-card__label">Signaux</div>
      </div>
      <div class="radar-stat-card">
        <div class="radar-stat-card__value">${published}</div>
        <div class="radar-stat-card__label">Publiés</div>
      </div>
      <div class="radar-stat-card">
        <div class="radar-stat-card__value">${ready}</div>
        <div class="radar-stat-card__label">Prêts</div>
      </div>
      <div class="radar-stat-card">
        <div class="radar-stat-card__value">${verified}</div>
        <div class="radar-stat-card__label">Sources vérifiées</div>
      </div>
      <div class="radar-stat-card">
        <div class="radar-stat-card__value">${withIssues}</div>
        <div class="radar-stat-card__label">À corriger</div>
      </div>
    `;
  }

  function renderRadarList() {
    if (!radarState.signals.length) {
      radarList.innerHTML = '<p class="empty-state empty-state--compact">Aucun signal pour le moment.</p>';
      return;
    }

    radarList.innerHTML = radarState.signals.map((signal: any) => {
      const isSelected = signal.id === radarState.selectedId;
      const metaLine = [signal.source?.publisher || 'Source à renseigner', formatDate(signal.source?.publishedAt || signal.capturedAt)]
        .filter(Boolean)
        .join(' · ');
      const issueLabel = signal.issues?.length
        ? `${signal.issues.length} point${signal.issues.length > 1 ? 's' : ''} à corriger`
        : signal.isPublished
        ? 'Publié'
        : signal.canPublish
        ? 'Prêt à publier'
        : 'À compléter';

      return `
        <button type="button" class="radar-list-item ${isSelected ? 'is-selected' : ''}" data-radar-select="${escapeHtml(signal.id)}">
          <div class="radar-list-item__top">
            <span class="mini-badge mini-badge--status">${escapeHtml(signal.status)}</span>
            <span class="mini-badge mini-badge--proof ${signal.proofStatus === 'verified' ? 'mini-badge--verified' : ''}">
              ${escapeHtml(proofLabel(signal.proofStatus))}
            </span>
          </div>
          <strong>${escapeHtml(signal.title)}</strong>
          <p>${escapeHtml(metaLine)}</p>
          <div class="radar-list-item__meta">
            <span>${escapeHtml(signal.type)}</span>
            <span>${escapeHtml(signal.level)}</span>
            <span>${escapeHtml(signal.theme)}</span>
          </div>
          <div class="radar-list-item__footer">${escapeHtml(issueLabel)}</div>
        </button>
      `;
    }).join('');

    radarList.querySelectorAll('[data-radar-select]').forEach((button) => {
      button.addEventListener('click', () => {
        radarState.selectedId = button.getAttribute('data-radar-select');
        renderRadarList();
        renderRadarEditor();
      });
    });
  }

  function buildRadarPreview(signal: any) {
    const sourceLine = [signal.source?.publisher || 'Source à renseigner', formatDate(signal.source?.publishedAt || signal.capturedAt), signal.source?.documentType]
      .filter(Boolean)
      .join(' · ');
    const proof = proofLabel(signal.proofStatus);
    const actions = Array.isArray(signal.analysis?.actions) ? signal.analysis.actions : [];

    return `
      <article class="radar-preview-card">
        <div class="radar-preview-card__meta">
          <div class="radar-preview-card__badges">
            <span class="radar-preview-pill radar-preview-pill--proof ${signal.proofStatus === 'verified' ? 'is-verified' : ''}">
              ${escapeHtml(proof)}
            </span>
            <span class="radar-preview-pill">${escapeHtml(signal.type)}</span>
            <span class="radar-preview-pill">${escapeHtml(signal.level)}</span>
            <span class="radar-preview-pill">${escapeHtml(signal.theme)}</span>
          </div>
          <div class="radar-preview-card__source">${escapeHtml(sourceLine)}</div>
        </div>

        <div class="radar-preview-card__body">
          <div class="radar-preview-card__section">
            <h3>${escapeHtml(signal.title || 'Signal sans titre')}</h3>
            <p>${escapeHtml(signal.publicSummary || 'Résumé public à renseigner.')}</p>
          </div>

          <div class="radar-preview-card__section">
            <div class="radar-preview-card__label">Ce que dit la source</div>
            <p>${escapeHtml(signal.factSummary || 'Résumé factuel à renseigner.')}</p>
            ${signal.source?.title ? `<p class="radar-preview-card__source-title">Texte repéré : ${escapeHtml(signal.source.title)}</p>` : ''}
          </div>

          <div class="radar-preview-card__grid">
            <section class="radar-preview-card__section">
              <div class="radar-preview-card__label">Lecture MARYAN</div>
              <p>${escapeHtml(signal.analysis?.whyImportant || 'Analyse MARYAN à renseigner.')}</p>
            </section>
            <section class="radar-preview-card__section">
              <div class="radar-preview-card__label">Qui est concerné</div>
              <p>${escapeHtml(signal.analysis?.whoIsConcerned || 'Champ à renseigner.')}</p>
            </section>
          </div>

          <div class="radar-preview-card__grid">
            <section class="radar-preview-card__section">
              <div class="radar-preview-card__label">Ce que cela change</div>
              <p>${escapeHtml(signal.analysis?.mandateImpact || 'Champ à renseigner.')}</p>
            </section>
            <section class="radar-preview-card__section">
              <div class="radar-preview-card__label">À surveiller</div>
              <p>${escapeHtml(signal.analysis?.watchpoints || 'Champ à renseigner.')}</p>
            </section>
          </div>

          ${actions.length ? `
            <section class="radar-preview-card__section">
              <div class="radar-preview-card__label">Ce que MARYAN conseille</div>
              <ul class="radar-preview-card__list">
                ${actions.map((entry: string) => `<li>${escapeHtml(entry)}</li>`).join('')}
              </ul>
            </section>
          ` : ''}
        </div>

        <div class="radar-preview-card__actions">
          ${signal.source?.url
            ? `<a class="radar-preview-card__primary" href="${escapeHtml(signal.source.url)}" target="_blank" rel="noopener noreferrer">Lire la source complète</a>`
            : `<span class="radar-preview-card__note">${signal.sourceKind === 'internal_maryan' ? 'Signal éditorial MARYAN, sans source externe directe.' : 'Source exacte non encore validée pour publication.'}</span>`}
          <span class="radar-preview-card__secondary">Accès abonné : analyse MARYAN complète</span>
        </div>
      </article>
    `;
  }

  function collectRadarFormPayload(form: HTMLFormElement) {
    const formData = new FormData(form);

    const sourceKind = String(formData.get('sourceKind') || 'external');
    const actions = String(formData.get('analysisActions') || '')
      .split('\n')
      .map((entry) => entry.trim())
      .filter(Boolean);

    return {
      id: String(formData.get('id') || ''),
      slug: String(formData.get('slug') || ''),
      status: String(formData.get('status') || 'draft'),
      capturedAt: String(formData.get('capturedAt') || ''),
      title: String(formData.get('title') || ''),
      type: String(formData.get('type') || 'signal'),
      level: String(formData.get('level') || 'local'),
      theme: String(formData.get('theme') || ''),
      isPriority: formData.get('isPriority') === 'on',
      priorityRank: String(formData.get('priorityRank') || ''),
      importanceScore: String(formData.get('importanceScore') || '0'),
      mandateScore: String(formData.get('mandateScore') || '0'),
      sourceKind,
      proofStatus: sourceKind === 'internal_maryan' ? 'internal' : String(formData.get('proofStatus') || 'unverified'),
      source: {
        title: String(formData.get('sourceTitle') || ''),
        publisher: String(formData.get('sourcePublisher') || ''),
        url: String(formData.get('sourceUrl') || ''),
        domain: '',
        publishedAt: String(formData.get('sourcePublishedAt') || ''),
        checkedAt: String(formData.get('sourceCheckedAt') || ''),
        documentType: String(formData.get('sourceDocumentType') || '')
      },
      factSummary: String(formData.get('factSummary') || ''),
      publicSummary: String(formData.get('publicSummary') || ''),
      analysis: {
        whyImportant: String(formData.get('analysisWhyImportant') || ''),
        whoIsConcerned: String(formData.get('analysisWhoIsConcerned') || ''),
        mandateImpact: String(formData.get('analysisMandateImpact') || ''),
        watchpoints: String(formData.get('analysisWatchpoints') || ''),
        actions
      },
      promptKey: String(formData.get('promptKey') || ''),
      reviewerName: String(formData.get('reviewerName') || ''),
      internalNotes: String(formData.get('internalNotes') || ''),
      publishedAt: String(formData.get('publishedAt') || '')
    };
  }

  function bindRadarEditorEvents() {
    const form = document.getElementById('radarEditorForm') as HTMLFormElement | null;
    const preview = document.getElementById('radarPreview') as HTMLDivElement | null;
    const sourceKind = document.getElementById('radarSourceKind') as HTMLSelectElement | null;
    const proofStatus = document.getElementById('radarProofStatus') as HTMLSelectElement | null;

    if (!form || !preview) return;

    const refreshPreview = () => {
      const payload = collectRadarFormPayload(form);
      preview.innerHTML = buildRadarPreview(payload);

      if (sourceKind && proofStatus) {
        const isInternal = sourceKind.value === 'internal_maryan';
        proofStatus.value = isInternal ? 'internal' : proofStatus.value === 'internal' ? 'unverified' : proofStatus.value;
        proofStatus.disabled = isInternal;
      }
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!radarState.persistenceAvailable) {
        setRadarFeedback('La base Radar n’est pas encore persistée. Applique la migration puis réessaie.', 'error');
        return;
      }

      const payload = collectRadarFormPayload(form);
      const saveButton = form.querySelector('[data-radar-save]') as HTMLButtonElement | null;
      if (saveButton) saveButton.disabled = true;

      try {
        const res = await fetch('/api/admin/radar', {
          method: 'PATCH',
          headers: {
            Authorization: `Bearer ${radarState.token}`,
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ signal: payload })
        });

        const data = await res.json();
        if (!res.ok || !data.signal) {
          throw new Error(data.error || 'Sauvegarde impossible.');
        }

        setRadarFeedback('Signal enregistré.', 'success');
        await loadRadar(radarState.token, data.signal.id);
      } catch (error) {
        setRadarFeedback(error instanceof Error ? error.message : 'Sauvegarde impossible.', 'error');
      } finally {
        if (saveButton) saveButton.disabled = false;
      }
    });

    form.addEventListener('input', refreshPreview);
    form.addEventListener('change', refreshPreview);
    refreshPreview();
  }

  function renderRadarEditor() {
    const signal = getSelectedRadarSignal();

    if (!signal) {
      radarEditor.style.display = 'none';
      radarEditorEmpty.style.display = 'block';
      radarEditorEmpty.textContent = radarState.signals.length
        ? 'Sélectionnez un signal pour compléter la source, la preuve et l’analyse.'
        : radarState.persistenceAvailable
        ? 'La base Radar est prête mais vide. Créez un brouillon ou importez le seed local.'
        : 'La base Radar n’est pas encore branchée. Appliquez la migration Supabase pour activer l’édition.';
      return;
    }

    radarEditorEmpty.style.display = 'none';
    radarEditor.style.display = 'block';

    radarEditor.innerHTML = `
      <div class="radar-editor-head">
        <div>
          <div class="radar-editor-head__eyebrow">Édition du signal</div>
          <h3>${escapeHtml(signal.title)}</h3>
          <p>La publication reste bloquée tant que la source, la preuve et les blocs MARYAN ne sont pas propres.</p>
        </div>
        <button type="submit" form="radarEditorForm" class="admin-primary-btn" data-radar-save ${!radarState.persistenceAvailable ? 'disabled' : ''}>
          Enregistrer
        </button>
      </div>

      <div class="radar-editor-issues ${signal.issues?.length ? 'has-issues' : 'is-clear'}">
        <strong>${signal.issues?.length ? 'Points à corriger avant publication' : signal.isPublished ? 'Signal publié proprement' : signal.canPublish ? 'Signal prêt à publier' : 'Signal encore en préparation'}</strong>
        ${signal.issues?.length
          ? `<ul>${signal.issues.map((issue: string) => `<li>${escapeHtml(issue)}</li>`).join('')}</ul>`
          : `<p>Aucun blocage détecté côté contrat éditorial.</p>`}
      </div>

      <form id="radarEditorForm" class="radar-editor-form">
        <div class="form-grid form-grid--compact">
          <label class="field">
            <span>ID technique</span>
            <input type="text" name="id" value="${escapeHtml(signal.id)}" readonly />
          </label>
          <label class="field">
            <span>Slug</span>
            <input type="text" name="slug" value="${escapeHtml(signal.slug)}" />
          </label>
          <label class="field">
            <span>Statut</span>
            <select name="status">${renderSelectOptions(radarState.options.statuses, signal.status)}</select>
          </label>
          <label class="field">
            <span>Type</span>
            <select name="type">${renderSelectOptions(radarState.options.types, signal.type)}</select>
          </label>
          <label class="field">
            <span>Niveau</span>
            <select name="level">${renderSelectOptions(radarState.options.levels, signal.level)}</select>
          </label>
          <label class="field">
            <span>Thème</span>
            <input list="radarThemes" name="theme" value="${escapeHtml(signal.theme)}" />
          </label>
          <label class="field">
            <span>Date de repérage</span>
            <input type="date" name="capturedAt" value="${escapeHtml(signal.capturedAt)}" />
          </label>
          <label class="field">
            <span>Publié le</span>
            <input type="text" name="publishedAt" value="${escapeHtml(signal.publishedAt || '')}" placeholder="2026-04-06T09:00:00.000Z" />
          </label>
          <label class="field">
            <span>Importance</span>
            <input type="number" min="0" max="5" name="importanceScore" value="${escapeHtml(signal.importanceScore)}" />
          </label>
          <label class="field">
            <span>Proximité mandat</span>
            <input type="number" min="0" max="5" name="mandateScore" value="${escapeHtml(signal.mandateScore)}" />
          </label>
          <label class="field">
            <span>Source</span>
            <select id="radarSourceKind" name="sourceKind">${renderSelectOptions(radarState.options.sourceKinds, signal.sourceKind)}</select>
          </label>
          <label class="field">
            <span>Preuve</span>
            <select id="radarProofStatus" name="proofStatus">${renderSelectOptions(radarState.options.proofStatuses, signal.proofStatus)}</select>
          </label>
          <label class="field">
            <span>Prioritaire</span>
            <input type="checkbox" name="isPriority" ${signal.isPriority ? 'checked' : ''} />
          </label>
          <label class="field">
            <span>Rang priorité</span>
            <input type="number" min="1" name="priorityRank" value="${escapeHtml(signal.priorityRank ?? '')}" />
          </label>
          <label class="field">
            <span>Reviewer</span>
            <input type="text" name="reviewerName" value="${escapeHtml(signal.reviewerName || '')}" />
          </label>
          <label class="field">
            <span>Prompt key</span>
            <input type="text" name="promptKey" value="${escapeHtml(signal.promptKey || '')}" />
          </label>
        </div>

        <label class="field">
          <span>Titre</span>
          <input type="text" name="title" value="${escapeHtml(signal.title)}" />
        </label>

        <div class="form-section">
          <div class="form-section__title">Source vérifiable</div>
          <div class="form-grid">
            <label class="field">
              <span>Titre exact du texte ou de l’article</span>
              <input type="text" name="sourceTitle" value="${escapeHtml(signal.source?.title || '')}" />
            </label>
            <label class="field">
              <span>Éditeur / institution</span>
              <input type="text" name="sourcePublisher" value="${escapeHtml(signal.source?.publisher || '')}" />
            </label>
            <label class="field">
              <span>URL directe</span>
              <input type="url" name="sourceUrl" value="${escapeHtml(signal.source?.url || '')}" placeholder="https://..." />
