          </label>
          <label class="field">
            <span>Résumé public</span>
            <textarea name="publicSummary" rows="3">${escapeHtml(signal.publicSummary || '')}</textarea>
          </label>
          <div class="form-grid">
            <label class="field">
              <span>Lecture MARYAN</span>
              <textarea name="analysisWhyImportant" rows="5">${escapeHtml(signal.analysis?.whyImportant || '')}</textarea>
            </label>
            <label class="field">
              <span>Qui est concerné</span>
              <textarea name="analysisWhoIsConcerned" rows="5">${escapeHtml(signal.analysis?.whoIsConcerned || '')}</textarea>
            </label>
            <label class="field">
              <span>Ce que cela change</span>
              <textarea name="analysisMandateImpact" rows="5">${escapeHtml(signal.analysis?.mandateImpact || '')}</textarea>
            </label>
            <label class="field">
              <span>À surveiller</span>
              <textarea name="analysisWatchpoints" rows="5">${escapeHtml(signal.analysis?.watchpoints || '')}</textarea>
            </label>
          </div>
          <label class="field">
            <span>Actions MARYAN (une ligne = une action)</span>
            <textarea name="analysisActions" rows="4">${escapeHtml((signal.analysis?.actions || []).join('\n'))}</textarea>
          </label>
