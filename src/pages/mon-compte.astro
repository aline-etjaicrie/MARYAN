---
import BaseLayout from '../layouts/BaseLayout.astro';
import CompteRenduManager from '../components/CompteRenduManager.astro';
import CompteRenduRecorder from '../components/CompteRenduRecorder.astro';
---

<BaseLayout
  title="Mon Compte — MARYAN"
  description="Votre espace personnel MARYAN : diagnostic, copilote, ressources et tests.">

  <main class="dashboard-v3">
    <div class="container">

      <!-- PAYMENT SUCCESS BANNER (shown when ?session_id is present) -->
      <div id="paymentSuccessBanner" class="payment-success-banner" style="display:none;">
        <div class="payment-success-inner">
          <span class="payment-success-icon">✓</span>
          <div>
            <strong>Abonnement activé !</strong>
            <p>Votre paiement a été validé. Bienvenue dans MARYAN Plus — toutes les fonctionnalités sont maintenant disponibles.</p>
          </div>
        </div>
      </div>

      <!-- SUCCESS BANNER -->
      <div id="successBanner" class="success-banner" style="display:none;">
        <strong>Bienvenue dans MARYAN Plus !</strong>
        Votre abonnement a été activé. Accès illimité au Copilote et à la Bibliothèque.
      </div>

      <div class="dashboard-grid">

        <!-- ═══ SIDEBAR ═══ -->
        <aside class="dash-sidebar">
          <div class="dash-profile card-v3">

            <div class="profile-header">
              <div class="avatar-circle" id="avatarInitials">–</div>
              <div class="profile-text">
                <h3 id="profileName">Chargement…</h3>
                <p id="profileRole" class="profile-role-line"></p>
              </div>
            </div>

            <hr class="dash-sep" />

            <div class="profile-stat">
              <span class="stat-label">Compte</span>
              <p id="userEmail" class="stat-email"></p>
              <button id="logoutBtn" class="logout-btn">Se déconnecter →</button>
            </div>

            <hr class="dash-sep" />

            <div class="profile-stat">
              <span class="stat-label">Forfait</span>
              <p id="planVal" class="stat-val">–</p>
              <a href="/offres" id="upgradeBtn" class="upgrade-btn" style="display:none;">Passer à MARYAN Plus →</a>
            </div>

            <div class="profile-stat">
              <span class="stat-label">Copilote</span>
              <div class="progress-bar">
                <div id="progressFill" class="progress-fill" style="width:0%;"></div>
              </div>
              <p id="counterText" class="stat-sub"></p>
            </div>

          </div>
        </aside>

        <!-- ═══ CONTENU PRINCIPAL ═══ -->
        <div class="dash-content">

          <!-- 1. BONJOUR -->
          <section class="dash-section dash-hello">
            <h1 id="helloTitle" class="hello-title">Bonjour élu·e</h1>
            <p id="helloSub" class="hello-sub">Que voulez-vous faire aujourd'hui ?</p>
          </section>

          <!-- 2. DIAGNOSTIC -->
          <section class="dash-section" id="diagSection">
            <div class="section-header-row">
              <h2 class="dash-h2">Votre diagnostic MARYAN</h2>
              <a href="/diagnostic" class="btn-link">Refaire →</a>
            </div>

            <!-- Diagnostic présent -->
            <div id="diagPresent" class="diag-card card-v3" style="display:none;">
              <div class="diag-header-row">
                <div>
                  <span class="diag-kicker">Résultat</span>
                  <p id="diagLabel" class="diag-val">–</p>
                </div>
                <span id="diagBadge" class="diag-badge">–</span>
              </div>
              <p id="diagAccroche" class="diag-accroche"></p>
            </div>

            <!-- Pas de diagnostic -->
            <div id="diagAbsent" class="diag-cta-card" style="display:none;">
              <p>Vous n'avez pas encore effectué votre diagnostic MARYAN.</p>
              <a href="/diagnostic" class="btn-primary-v3" style="margin-top:1.5rem; display:inline-flex;">Faire mon diagnostic</a>
            </div>
          </section>

          <!-- 3. RESSOURCES RECOMMANDÉES -->
          <section class="dash-section" id="ressourcesSection">
            <div class="section-header-row">
              <h2 class="dash-h2">Vos ressources recommandées</h2>
              <a href="/ressources" class="btn-link">Toutes les fiches →</a>
            </div>
            <div id="ressourcesGrid" class="ressources-grid">
              <!-- Injecté côté client -->
            </div>
          </section>

          <!-- 4. SESSIONS RÉCENTES -->
          <section class="dash-section" id="sessionsSection" style="display:none;">
            <div class="section-header-row">
              <h2 class="dash-h2">Vos sessions récentes</h2>
              <div class="sessions-header-actions">
                <button id="deleteAllSessionsBtn" class="btn-delete-all" title="Supprimer toutes mes sessions">Supprimer toutes mes sessions</button>
                <a href="/copilote" class="btn-link">Nouveau →</a>
              </div>
            </div>
            <div id="sessionsList" class="sessions-list"></div>
          </section>

          <!-- 5. RGPD — MES DONNÉES & CONFIDENTIALITÉ -->
          <section class="dash-section rgpd-section" id="rgpdSection">
            <h2>Mes données &amp; confidentialité</h2>

            <!-- 5a. Affiliation politique (Article 9) -->
            <div class="rgpd-item" id="rgpdAffilItem" style="display:none;">
              <div class="rgpd-item-info">
                <span class="rgpd-item-label">Affiliation politique</span>
                <p id="rgpdAffilText"></p>
              </div>
              <button class="btn-rgpd btn-rgpd-danger" id="rgpdAffilBtn">Retirer mon affiliation</button>
            </div>

            <!-- 5b. Diagnostic -->
            <div class="rgpd-item" id="rgpdDiagItem" style="display:none;">
              <div class="rgpd-item-info">
                <span class="rgpd-item-label">Diagnostic MARYAN</span>
                <p id="rgpdDiagText"></p>
              </div>
              <button class="btn-rgpd btn-rgpd-danger" id="rgpdDiagBtn">Effacer mon diagnostic</button>
            </div>

            <!-- 5c. Export des données -->
            <div class="rgpd-item">
              <div class="rgpd-item-info">
                <span class="rgpd-item-label">Export de mes données</span>
                <p>Téléchargez une copie de toutes vos données personnelles (RGPD, Art. 20).</p>
              </div>
              <button class="btn-rgpd btn-rgpd-primary" id="rgpdExportBtn">Télécharger mes données (RGPD)</button>
            </div>

            <!-- 5d. Suppression du compte -->
            <div class="rgpd-item">
              <div class="rgpd-item-info" style="width:100%;">
                <div class="rgpd-danger-zone">
                  <p>La suppression est définitive et irréversible. Toutes vos données, sessions et profil seront supprimés.</p>
                  <button class="btn-rgpd btn-rgpd-danger" id="rgpdDeleteAccountBtn">Supprimer mon compte définitivement</button>
                </div>
              </div>
            </div>

          </section>

          <!-- 6. TESTS -->
          <section class="dash-section" id="tests">
            <div class="section-header-row">
              <h2 class="dash-h2">Vos tests thématiques</h2>
              <a href="/tests" class="btn-link">Voir tous →</a>
            </div>
            <div class="tests-grid">
              <a href="/tests/style-decision" class="test-tile card-v3" data-key="maryan_test_decision">
                <span class="test-num">01</span>
                <h3>Mon style de décision</h3>
                <p>Profil décisionnel, forces et angles morts.</p>
                <span class="test-cta">Faire le test →</span>
              </a>
              <a href="/tests/posture-conflit" class="test-tile card-v3" data-key="maryan_test_conflit">
                <span class="test-num">02</span>
                <h3>Ma posture face au conflit</h3>
                <p>Mode de gestion dominant et signaux d'alerte.</p>
                <span class="test-cta">Faire le test →</span>
              </a>
              <a href="/tests/prise-de-parole" class="test-tile card-v3" data-key="maryan_test_parole">
                <span class="test-num">03</span>
                <h3>Préparer une prise de parole difficile</h3>
                <p>Niveau de préparation réelle avant une prise de position.</p>
                <span class="test-cta">Faire le test →</span>
              </a>
              <a href="/tests/travail-equipe" class="test-tile card-v3" data-key="maryan_test_equipe">
                <span class="test-num">04</span>
                <h3>Mon rapport au travail en équipe</h3>
                <p>Profil d'équipe dominant et ce qu'il coûte aux autres.</p>
                <span class="test-cta">Faire le test →</span>
              </a>
              <a href="/tests/deliberation" class="test-tile card-v3" data-key="maryan_test_deliberation">
                <span class="test-num">05</span>
                <h3>Préparer une délibération en conseil municipal</h3>
                <p>Niveau de préparation avant le vote en conseil.</p>
                <span class="test-cta">Faire le test →</span>
              </a>
            </div>
          </section>

          <!-- 6. COMPTES RENDUS -->
          <section class="dash-section" id="cr">
            <div class="section-header-row">
              <h2 class="dash-h2">Mes Comptes Rendus</h2>
              <button id="openRecorderBtn" class="upgrade-btn" style="border-bottom-color:var(--accent-red);">🎤 Créer par dictée</button>
            </div>
            <div id="recorderModal" class="recorder-modal" style="display:none;">
              <div class="recorder-modal-overlay" onclick="document.getElementById('recorderModal').style.display='none';"></div>
              <div class="recorder-modal-content card-v3">
                <button class="recorder-close-btn" onclick="document.getElementById('recorderModal').style.display='none';">✕</button>
                <CompteRenduRecorder />
              </div>
            </div>
            <CompteRenduManager readonly={false} />
          </section>

        </div>
      </div>
    </div>
  </main>

</BaseLayout>

<script>
  import { createClient } from '@supabase/supabase-js';
  import { getRecommendedResources, maryanResources } from '../data/resources';
  import { buildStoredDiagnosticEntry, getDiagnosticAccroche } from '../lib/diagnostic-personalization';

  // ── Payment success banner (when redirected from Stripe checkout) ──
  if (window.location.search.includes('session_id')) {
    const paymentBanner = document.getElementById('paymentSuccessBanner');
    if (paymentBanner) paymentBanner.style.display = 'block';
    // Clean up URL to avoid showing banner on refresh
    window.history.replaceState({}, '', '/mon-compte');
  }

  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL as string;
  const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY as string;

  // ── Fiches génériques si pas de diagnostic ──
  const FICHES_GENERIQUES = [
    { slug: 'qui-decide-quoi-dans-la-collectivite', title: 'Qui décide quoi dans la collectivité ?' },
    { slug: 'le-conseil-municipal-a-quoi-il-sert-vraiment', title: 'Le conseil municipal : à quoi sert-il vraiment ?' },
    { slug: 'prendre-la-parole-en-conseil', title: 'Prendre la parole en conseil municipal' }
  ];

  // ── Formatage de date ──
  function formatDate(iso: string): string {
    try {
      return new Date(iso).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long' });
    } catch { return ''; }
  }

  // ── Badge session type ──
  function sessionTypeBadge(type: string): string {
    const labels: Record<string, string> = {
      copilote: 'Copilote',
      cr_reunion: 'CR réunion',
      analyse: 'Analyse'
    };
    return labels[type] || type;
  }

  if (!SUPABASE_URL || !SUPABASE_KEY) {
    window.location.href = '/login';
  } else {
    const supabase = createClient(SUPABASE_URL, SUPABASE_KEY);
    const { data: { session } } = await supabase.auth.getSession();

    if (!session) {
      window.location.href = '/login';
    } else {
      const user = session.user;
      const token = session.access_token;

      // ── Email & avatar ──
      const emailEl = document.getElementById('userEmail');
      if (emailEl) emailEl.textContent = user.email || '';
      const initials = (user.email || 'EU').slice(0, 2).toUpperCase();
      const avatarEl = document.getElementById('avatarInitials');
      if (avatarEl) avatarEl.textContent = initials;

      // ── Déconnexion ──
      document.getElementById('logoutBtn')?.addEventListener('click', async () => {
        await supabase.auth.signOut();
        window.location.href = '/login';
      });

      // ── Profil Supabase ──
      const { data: profile } = await supabase
        .from('profiles')
        .select('first_name, commune, role, diagnostic_key, diagnostic_label, plan, parti_id, parti_label')
        .eq('id', user.id)
        .single();

      const firstName = profile?.first_name || '';
      const diagKey = profile?.diagnostic_key || '';
      const diagLabel = profile?.diagnostic_label || '';
      const plan = profile?.plan || 'gratuit';

      // ── Bonjour ──
      const helloTitle = document.getElementById('helloTitle');
      if (helloTitle) {
        helloTitle.textContent = firstName ? `Bonjour ${firstName}` : 'Bonjour élu·e';
      }
      const helloSub = document.getElementById('helloSub');
      if (helloSub && profile?.role) {
        helloSub.textContent = `${profile.role}${profile.commune ? ' — ' + profile.commune : ''}`;
      }

      // ── Profil sidebar ──
      const profileNameEl = document.getElementById('profileName');
      if (profileNameEl) profileNameEl.textContent = firstName || user.email?.split('@')[0] || 'Mon compte';
      const profileRoleEl = document.getElementById('profileRole');
      if (profileRoleEl && (profile?.role || profile?.commune)) {
        profileRoleEl.textContent = [profile.role, profile.commune].filter(Boolean).join(' — ');
      }

      // ── Plan ──
      const planVal = document.getElementById('planVal');
      if (planVal) planVal.textContent = plan === 'plus' ? 'MARYAN Plus' : plan === 'admin' ? 'Admin' : 'Découverte';
      const upgradeBtn = document.getElementById('upgradeBtn');
      if (upgradeBtn && plan !== 'plus' && plan !== 'admin') {
        (upgradeBtn as HTMLElement).style.display = 'inline-block';
      }

      // ── Avatar initiales depuis prénom ──
      if (firstName && avatarEl) {
        avatarEl.textContent = firstName.slice(0, 2).toUpperCase();
      }

      // ── Crédit copilote (simulé) ──
      const progressFill = document.getElementById('progressFill') as HTMLElement | null;
      const counterText = document.getElementById('counterText');
      if (plan === 'plus' || plan === 'admin') {
        if (progressFill) progressFill.style.width = '100%';
        if (counterText) counterText.textContent = 'Accès illimité';
      } else {
        if (progressFill) progressFill.style.width = '60%';
        if (counterText) counterText.textContent = '3 messages restants aujourd\'hui';
      }

      // ── Diagnostic ──
      const diagPresent = document.getElementById('diagPresent');
      const diagAbsent = document.getElementById('diagAbsent');

      let localDiagnosticRaw = {} as Record<string, any>;
      try {
        const raw = localStorage.getItem('maryan_v4_diag');
        if (raw) {
          localDiagnosticRaw = JSON.parse(raw);
        }
      } catch (_) {}

      const diagnosticState = buildStoredDiagnosticEntry({
        ...localDiagnosticRaw,
        diagnostic_key: diagKey || localDiagnosticRaw?.diagnostic_key,
        diagnostic_label: diagLabel || localDiagnosticRaw?.diagnostic_label
      }, maryanResources);

      try {
        if (diagnosticState.diagnostic_key || diagnosticState.profile || diagnosticState.recommended_slugs?.length) {
          localStorage.setItem('maryan_v4_diag', JSON.stringify(diagnosticState));
        }
        const storedProfile = JSON.parse(localStorage.getItem('maryan_profile') || '{}');
        if (diagnosticState.profile) {
          localStorage.setItem('maryan_profile', JSON.stringify({
            ...storedProfile,
            diagnosticProfile: diagnosticState.profile
          }));
        }
      } catch (_) {}

      if (diagnosticState.diagnostic_key || diagnosticState.diagnostic_label) {
        if (diagPresent) diagPresent.style.display = 'block';
        if (diagAbsent) diagAbsent.style.display = 'none';
        const diagLabelEl = document.getElementById('diagLabel');
        if (diagLabelEl) diagLabelEl.textContent = diagnosticState.diagnostic_label || diagnosticState.diagnostic_key;
        const diagBadge = document.getElementById('diagBadge');
        if (diagBadge) diagBadge.textContent = (diagnosticState.profile || diagnosticState.diagnostic_key || '').replaceAll('_', ' ');
        const diagAccroche = document.getElementById('diagAccroche');
        if (diagAccroche) {
          diagAccroche.textContent = getDiagnosticAccroche(diagnosticState);
        }
      } else {
        if (diagPresent) diagPresent.style.display = 'none';
        if (diagAbsent) diagAbsent.style.display = 'block';
      }

      // ── Ressources recommandées ──
      const ressourcesGrid = document.getElementById('ressourcesGrid');
      if (ressourcesGrid) {
        let resources = diagnosticState.profile
          ? getRecommendedResources(maryanResources, diagnosticState.profile)
          : [];

        if (!resources.length && diagnosticState.recommended_slugs?.length) {
          resources = diagnosticState.recommended_slugs
            .slice(0, 3)
            .map((slug: string) => maryanResources.find((resource) => resource.slug === slug))
            .filter(Boolean);
        }

        if (!resources.length) {
          resources = FICHES_GENERIQUES
            .map(({ slug }) => maryanResources.find((resource) => resource.slug === slug))
            .filter(Boolean);
        }

        ressourcesGrid.innerHTML = resources.map((resource) => `
          <a href="/ressources/${resource.slug}" class="ressource-tile card-v3">
            <span class="ressource-num">→</span>
            <p class="ressource-title">${resource.title}</p>
            <span class="ressource-cta">Consulter →</span>
          </a>
        `).join('');
      }

      // ── Sessions récentes ──
      try {
        const res = await fetch('/api/sessions', {
          headers: { Authorization: `Bearer ${token}` }
        });
        if (res.ok) {
          const { sessions } = await res.json();
          const sessionsSection = document.getElementById('sessionsSection');
          const sessionsList = document.getElementById('sessionsList');
          if (sessions?.length && sessionsSection && sessionsList) {
            sessionsSection.style.display = 'block';

            function renderSessions(list: { id: string; session_type: string; titre: string; updated_at: string; }[]) {
              if (!sessionsList) return;
              sessionsList.innerHTML = list.slice(0, 5).map((s) => `
                <div class="session-row" data-session-id="${s.id}">
                  <a href="/copilote?session_id=${s.id}" class="session-item">
                    <div class="session-meta">
                      <span class="session-badge session-badge-${s.session_type}">${sessionTypeBadge(s.session_type)}</span>
                      <span class="session-date">${formatDate(s.updated_at)}</span>
                    </div>
                    <p class="session-titre">${s.titre || 'Session sans titre'}</p>
                    <span class="session-cta">Reprendre →</span>
                  </a>
                  <button class="btn-delete-session" data-session-id="${s.id}" title="Supprimer cette session" aria-label="Supprimer cette session">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                    Supprimer
                  </button>
                </div>
              `).join('');

              // Attacher les écouteurs sur les boutons de suppression
              sessionsList.querySelectorAll('.btn-delete-session').forEach(btn => {
                btn.addEventListener('click', async (e) => {
                  e.preventDefault();
                  const sessionId = (btn as HTMLElement).dataset.sessionId;
                  if (!sessionId) return;
                  if (!confirm('Supprimer cette session ? Cette action est irréversible.')) return;
                  try {
                    const delRes = await fetch('/api/sessions', {
                      method: 'DELETE',
                      headers: {
                        Authorization: `Bearer ${token}`,
                        'Content-Type': 'application/json'
                      },
                      body: JSON.stringify({ session_id: sessionId })
                    });
                    if (delRes.ok) {
                      const row = sessionsList?.querySelector(`.session-row[data-session-id="${sessionId}"]`);
                      if (row) row.remove();
                      if (!sessionsList?.querySelector('.session-row')) {
                        if (sessionsSection) sessionsSection.style.display = 'none';
                      }
                    }
                  } catch (_) { /* non bloquant */ }
                });
              });
            }

            renderSessions(sessions);

            // Bouton "Supprimer toutes mes sessions"
            document.getElementById('deleteAllSessionsBtn')?.addEventListener('click', async () => {
              if (!confirm('Supprimer toutes vos sessions ? Cette action est irréversible.')) return;
              try {
                const delRes = await fetch('/api/sessions', {
                  method: 'DELETE',
                  headers: {
                    Authorization: `Bearer ${token}`,
                    'Content-Type': 'application/json'
                  },
                  body: JSON.stringify({ delete_all: true })
                });
                if (delRes.ok) {
                  if (sessionsList) sessionsList.innerHTML = '';
                  if (sessionsSection) sessionsSection.style.display = 'none';
                }
              } catch (_) { /* non bloquant */ }
            });
          }
        }
      } catch (_) { /* non bloquant */ }

      // ── Activation abonnement via session_id Stripe ──
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('session_id')) {
        const banner = document.getElementById('successBanner');
        if (banner) banner.style.display = 'block';
        if (planVal) planVal.textContent = 'MARYAN Plus';
        if (upgradeBtn) (upgradeBtn as HTMLElement).style.display = 'none';
        if (progressFill) progressFill.style.width = '100%';
        if (counterText) counterText.textContent = 'Accès illimité';
      }

      // ── Tests : marquer ceux déjà faits ──
      document.querySelectorAll('.test-tile[data-key]').forEach(el => {
        const key = el.getAttribute('data-key');
        if (key && localStorage.getItem(key)) {
          el.classList.add('test-done');
          const cta = el.querySelector('.test-cta');
          if (cta) cta.textContent = '✓ Refaire →';
        }
      });

      // ── Recorder modal ──
      document.getElementById('openRecorderBtn')?.addEventListener('click', () => {
        const modal = document.getElementById('recorderModal');
        if (modal) modal.style.display = 'flex';
      });

      // ══════════════════════════════════════════
      // ── RGPD — Mes données & confidentialité ──
      // ══════════════════════════════════════════

      // 5a. Affiliation politique (Article 9)
      const partiLabel = profile?.parti_label || '';
      const partiId = profile?.parti_id || '';
      if (partiLabel || partiId) {
        const affilItem = document.getElementById('rgpdAffilItem');
        const affilText = document.getElementById('rgpdAffilText');
        if (affilItem) affilItem.style.display = 'flex';
        if (affilText) affilText.textContent = `Affiliation renseignée : ${partiLabel || partiId}`;
      }

      document.getElementById('rgpdAffilBtn')?.addEventListener('click', async () => {
        const confirmed = confirm('Retirer votre affiliation politique ? Cette donnée sera supprimée de votre profil et ne sera plus utilisée par le copilote.');
        if (!confirmed) return;
        try {
          await fetch('/api/profile-update', {
            method: 'PATCH',
            headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
            body: JSON.stringify({ field: 'parti_id', value: null })
          });
          await fetch('/api/profile-update', {
            method: 'PATCH',
            headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
            body: JSON.stringify({ field: 'parti_label', value: null })
          });
          const affilItem = document.getElementById('rgpdAffilItem');
          if (affilItem) {
            affilItem.innerHTML = '<p style="color:#2E7D32;font-size:0.9rem;font-weight:600;">Affiliation retirée.</p>';
          }
        } catch (_) {
          alert('Une erreur est survenue. Veuillez réessayer.');
        }
      });

      // 5b. Diagnostic
      if (diagnosticState.diagnostic_key || diagnosticState.diagnostic_label) {
        const diagItem = document.getElementById('rgpdDiagItem');
        const diagText = document.getElementById('rgpdDiagText');
        if (diagItem) diagItem.style.display = 'flex';
        if (diagText) diagText.textContent = `Diagnostic actuel : ${diagnosticState.diagnostic_label || diagnosticState.diagnostic_key}`;
      }

      document.getElementById('rgpdDiagBtn')?.addEventListener('click', async () => {
        const confirmed = confirm('Effacer votre diagnostic ? Cette donnée sera supprimée de votre profil.');
        if (!confirmed) return;
        try {
          await fetch('/api/profile-update', {
            method: 'PATCH',
            headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
            body: JSON.stringify({ field: 'diagnostic_key', value: null })
          });
          await fetch('/api/profile-update', {
            method: 'PATCH',
            headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
            body: JSON.stringify({ field: 'diagnostic_label', value: null })
          });
          try { localStorage.removeItem('maryan_v4_diag'); } catch (_) {}
          try { localStorage.removeItem('maryan_profile'); } catch (_) {}
          const diagItem = document.getElementById('rgpdDiagItem');
          if (diagItem) {
            diagItem.innerHTML = '<p style="color:#2E7D32;font-size:0.9rem;font-weight:600;">Diagnostic effacé.</p>';
          }
        } catch (_) {
          alert('Une erreur est survenue. Veuillez réessayer.');
        }
      });

      // 5c. Export des données (Article 20)
      document.getElementById('rgpdExportBtn')?.addEventListener('click', async () => {
        try {
          const res = await fetch('/api/export-data', {
            headers: { Authorization: `Bearer ${token}` }
          });
          if (!res.ok) {
            alert("Erreur lors de l'export. Veuillez réessayer.");
            return;
          }
          const blob = await res.blob();
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = 'maryan-mes-donnees.json';
          document.body.appendChild(a);
          a.click();
          a.remove();
          URL.revokeObjectURL(url);
        } catch (_) {
          alert("Erreur lors de l'export. Veuillez réessayer.");
        }
      });

      // 5d. Suppression du compte (Article 17)
      document.getElementById('rgpdDeleteAccountBtn')?.addEventListener('click', async () => {
        const input = prompt('Pour confirmer la suppression définitive de votre compte, tapez SUPPRIMER :');
        if (input !== 'SUPPRIMER') {
          if (input !== null) alert('Suppression annulée. Vous devez taper exactement SUPPRIMER.');
          return;
        }
        try {
          const res = await fetch('/api/delete-account', {
            method: 'DELETE',
            headers: { Authorization: `Bearer ${token}` }
          });
          if (res.ok) {
            // Effacement de toutes les données locales
            try { localStorage.clear(); } catch (_) {}
            try { sessionStorage.clear(); } catch (_) {}
            window.location.href = '/?compte=supprime';
          } else {
            const data = await res.json().catch(() => ({}));
            alert(data?.error || 'Une erreur est survenue. Veuillez contacter le support.');
          }
        } catch (_) {
          alert('Une erreur est survenue. Veuillez contacter le support.');
        }
      });
    }
  }
</script>

