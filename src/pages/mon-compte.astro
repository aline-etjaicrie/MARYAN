---
import BaseLayout from '../layouts/BaseLayout.astro';
import CompteRenduManager from '../components/CompteRenduManager.astro';
import CompteRenduRecorder from '../components/CompteRenduRecorder.astro';
---

<BaseLayout
  title="Mon Compte — MARYAN"
  description="Votre espace personnel MARYAN : diagnostic, copilote, ressources et tests.">

  <main class="dashboard-v3">
    <div class="container">

      <!-- SUCCESS BANNER -->
      <div id="successBanner" class="success-banner" style="display:none;">
        <strong>Bienvenue dans MARYAN Plus !</strong>
        Votre abonnement a été activé. Accès illimité au Copilote et à la Bibliothèque.
      </div>

      <div class="dashboard-grid">

        <!-- ═══ SIDEBAR ═══ -->
        <aside class="dash-sidebar">
          <div class="dash-profile card-v3">

            <div class="profile-header">
              <div class="avatar-circle" id="avatarInitials">–</div>
              <div class="profile-text">
                <h3 id="profileName">Chargement…</h3>
                <p id="profileRole" class="profile-role-line"></p>
              </div>
            </div>

            <hr class="dash-sep" />

            <div class="profile-stat">
              <span class="stat-label">Compte</span>
              <p id="userEmail" class="stat-email"></p>
              <button id="logoutBtn" class="logout-btn">Se déconnecter →</button>
            </div>

            <hr class="dash-sep" />

            <div class="profile-stat">
              <span class="stat-label">Forfait</span>
              <p id="planVal" class="stat-val">–</p>
              <a href="/offres" id="upgradeBtn" class="upgrade-btn" style="display:none;">Passer à MARYAN Plus →</a>
            </div>

            <div class="profile-stat">
              <span class="stat-label">Copilote</span>
              <div class="progress-bar">
                <div id="progressFill" class="progress-fill" style="width:0%;"></div>
              </div>
              <p id="counterText" class="stat-sub"></p>
            </div>

          </div>
        </aside>

        <!-- ═══ CONTENU PRINCIPAL ═══ -->
        <div class="dash-content">

          <!-- 1. BONJOUR -->
          <section class="dash-section dash-hello">
            <h1 id="helloTitle" class="hello-title">Bonjour élu·e</h1>
            <p id="helloSub" class="hello-sub">Que voulez-vous faire aujourd'hui ?</p>
          </section>

          <!-- 2. DIAGNOSTIC -->
          <section class="dash-section" id="diagSection">
            <div class="section-header-row">
              <h2 class="dash-h2">Votre diagnostic MARYAN</h2>
              <a href="/diagnostic" class="btn-link">Refaire →</a>
            </div>

            <!-- Diagnostic présent -->
            <div id="diagPresent" class="diag-card card-v3" style="display:none;">
              <div class="diag-header-row">
                <div>
                  <span class="diag-kicker">Résultat</span>
                  <p id="diagLabel" class="diag-val">–</p>
                </div>
                <span id="diagBadge" class="diag-badge">–</span>
              </div>
              <p id="diagAccroche" class="diag-accroche"></p>
            </div>

            <!-- Pas de diagnostic -->
            <div id="diagAbsent" class="diag-cta-card" style="display:none;">
              <p>Vous n'avez pas encore effectué votre diagnostic MARYAN.</p>
              <a href="/diagnostic" class="btn-primary-v3" style="margin-top:1.5rem; display:inline-flex;">Faire mon diagnostic</a>
            </div>
          </section>

          <!-- 3. RESSOURCES RECOMMANDÉES -->
          <section class="dash-section" id="ressourcesSection">
            <div class="section-header-row">
              <h2 class="dash-h2">Vos ressources recommandées</h2>
              <a href="/ressources" class="btn-link">Toutes les fiches →</a>
            </div>
            <div id="ressourcesGrid" class="ressources-grid">
              <!-- Injecté côté client -->
            </div>
          </section>

          <!-- 4. SESSIONS RÉCENTES -->
          <section class="dash-section" id="sessionsSection" style="display:none;">
            <div class="section-header-row">
              <h2 class="dash-h2">Vos sessions récentes</h2>
              <a href="/copilote" class="btn-link">Nouveau →</a>
            </div>
            <div id="sessionsList" class="sessions-list"></div>
          </section>

          <!-- 5. TESTS -->
          <section class="dash-section" id="tests">
            <div class="section-header-row">
              <h2 class="dash-h2">Vos tests thématiques</h2>
              <a href="/tests" class="btn-link">Voir tous →</a>
            </div>
            <div class="tests-grid">
              <a href="/tests/style-decision" class="test-tile card-v3" data-key="maryan_test_decision">
                <span class="test-num">01</span>
                <h3>Mon style de décision</h3>
                <p>Profil décisionnel, forces et angles morts.</p>
                <span class="test-cta">Faire le test →</span>
              </a>
              <a href="/tests/posture-conflit" class="test-tile card-v3" data-key="maryan_test_conflit">
                <span class="test-num">02</span>
                <h3>Ma posture face au conflit</h3>
                <p>Mode de gestion dominant et signaux d'alerte.</p>
                <span class="test-cta">Faire le test →</span>
              </a>
              <a href="/tests/prise-de-parole" class="test-tile card-v3" data-key="maryan_test_parole">
                <span class="test-num">03</span>
                <h3>Préparer une prise de parole difficile</h3>
                <p>Niveau de préparation réelle avant une prise de position.</p>
                <span class="test-cta">Faire le test →</span>
              </a>
              <a href="/tests/travail-equipe" class="test-tile card-v3" data-key="maryan_test_equipe">
                <span class="test-num">04</span>
                <h3>Mon rapport au travail en équipe</h3>
                <p>Profil d'équipe dominant et ce qu'il coûte aux autres.</p>
                <span class="test-cta">Faire le test →</span>
              </a>
              <a href="/tests/deliberation" class="test-tile card-v3" data-key="maryan_test_deliberation">
                <span class="test-num">05</span>
                <h3>Préparer une délibération en conseil municipal</h3>
                <p>Niveau de préparation avant le vote en conseil.</p>
                <span class="test-cta">Faire le test →</span>
              </a>
            </div>
          </section>

          <!-- 6. COMPTES RENDUS -->
          <section class="dash-section" id="cr">
            <div class="section-header-row">
              <h2 class="dash-h2">Mes Comptes Rendus</h2>
              <button id="openRecorderBtn" class="upgrade-btn" style="border-bottom-color:var(--accent-red);">🎤 Créer par dictée</button>
            </div>
            <div id="recorderModal" class="recorder-modal" style="display:none;">
              <div class="recorder-modal-overlay" onclick="document.getElementById('recorderModal').style.display='none';"></div>
              <div class="recorder-modal-content card-v3">
                <button class="recorder-close-btn" onclick="document.getElementById('recorderModal').style.display='none';">✕</button>
                <CompteRenduRecorder />
              </div>
            </div>
            <CompteRenduManager readonly={false} />
          </section>

        </div>
      </div>
    </div>
  </main>

</BaseLayout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL as string;
  const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY as string;

  // ── Mapping diagnostic_key → accroche ──
  const DIAG_ACCROCHES: Record<string, string> = {
    'vigilance-institutionnelle': 'Vous êtes attentif·ve à vos droits et à la régularité des procédures. MARYAN peut vous aider à les faire valoir.',
    'isolation-politique': 'Vous traversez une période d\'isolement. MARYAN vous aide à identifier vos alliés et à construire des coalitions.',
    'surcharge-operationnelle': 'Vous êtes en surcharge. MARYAN va à l\'essentiel pour vous aider à prioriser et agir rapidement.',
    'mandat-recent': 'Vous débutez votre mandat. MARYAN vous accompagne dans la prise de repères et la compréhension de votre rôle.',
    'tension-relationnelle': 'Des tensions relationnelles compliquent votre mandat. MARYAN vous aide à les désamorcer.',
  };

  // ── Fiches génériques si pas de diagnostic ──
  const FICHES_GENERIQUES = [
    { slug: 'comprendre-votre-role', title: 'Comprendre votre rôle d\'élu·e' },
    { slug: 'droits-fondamentaux-elu', title: 'Les droits fondamentaux de l\'élu·e' },
    { slug: 'prendre-la-parole-en-conseil', title: 'Prendre la parole en conseil municipal' }
  ];

  // ── Formatage de date ──
  function formatDate(iso: string): string {
    try {
      return new Date(iso).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long' });
    } catch { return ''; }
  }

  // ── Badge session type ──
  function sessionTypeBadge(type: string): string {
    const labels: Record<string, string> = {
      copilote: 'Copilote',
      cr_reunion: 'CR réunion',
      analyse: 'Analyse'
    };
    return labels[type] || type;
  }

  if (!SUPABASE_URL || !SUPABASE_KEY) {
    window.location.href = '/login';
  } else {
    const supabase = createClient(SUPABASE_URL, SUPABASE_KEY);
    const { data: { session } } = await supabase.auth.getSession();

    if (!session) {
      window.location.href = '/login';
    } else {
      const user = session.user;
      const token = session.access_token;

      // ── Email & avatar ──
      const emailEl = document.getElementById('userEmail');
      if (emailEl) emailEl.textContent = user.email || '';
      const initials = (user.email || 'EU').slice(0, 2).toUpperCase();
      const avatarEl = document.getElementById('avatarInitials');
      if (avatarEl) avatarEl.textContent = initials;

      // ── Déconnexion ──
      document.getElementById('logoutBtn')?.addEventListener('click', async () => {
        await supabase.auth.signOut();
        window.location.href = '/login';
      });

      // ── Profil Supabase ──
      const { data: profile } = await supabase
        .from('profiles')
        .select('first_name, commune, role, diagnostic_key, diagnostic_label, plan')
        .eq('id', user.id)
        .single();

      const firstName = profile?.first_name || '';
      const diagKey = profile?.diagnostic_key || '';
      const diagLabel = profile?.diagnostic_label || '';
      const plan = profile?.plan || 'gratuit';

      // ── Bonjour ──
      const helloTitle = document.getElementById('helloTitle');
      if (helloTitle) {
        helloTitle.textContent = firstName ? `Bonjour ${firstName}` : 'Bonjour élu·e';
      }
      const helloSub = document.getElementById('helloSub');
      if (helloSub && profile?.role) {
        helloSub.textContent = `${profile.role}${profile.commune ? ' — ' + profile.commune : ''}`;
      }

      // ── Profil sidebar ──
      const profileNameEl = document.getElementById('profileName');
      if (profileNameEl) profileNameEl.textContent = firstName || user.email?.split('@')[0] || 'Mon compte';
      const profileRoleEl = document.getElementById('profileRole');
      if (profileRoleEl && (profile?.role || profile?.commune)) {
        profileRoleEl.textContent = [profile.role, profile.commune].filter(Boolean).join(' — ');
      }

      // ── Plan ──
      const planVal = document.getElementById('planVal');
      if (planVal) planVal.textContent = plan === 'plus' ? 'MARYAN Plus' : plan === 'admin' ? 'Admin' : 'Découverte';
      const upgradeBtn = document.getElementById('upgradeBtn');
      if (upgradeBtn && plan !== 'plus' && plan !== 'admin') {
        (upgradeBtn as HTMLElement).style.display = 'inline-block';
      }

      // ── Avatar initiales depuis prénom ──
      if (firstName && avatarEl) {
        avatarEl.textContent = firstName.slice(0, 2).toUpperCase();
      }

      // ── Crédit copilote (simulé) ──
      const progressFill = document.getElementById('progressFill') as HTMLElement | null;
      const counterText = document.getElementById('counterText');
      if (plan === 'plus' || plan === 'admin') {
        if (progressFill) progressFill.style.width = '100%';
        if (counterText) counterText.textContent = 'Accès illimité';
      } else {
        if (progressFill) progressFill.style.width = '60%';
        if (counterText) counterText.textContent = '3 messages restants aujourd\'hui';
      }

      // ── Diagnostic ──
      const diagPresent = document.getElementById('diagPresent');
      const diagAbsent = document.getElementById('diagAbsent');

      // Tente aussi localStorage en fallback
      let localDiagKey = diagKey;
      let localDiagLabel = diagLabel;
      try {
        const raw = localStorage.getItem('maryan_v4_diag');
        if (raw) {
          const parsed = JSON.parse(raw);
          if (!localDiagKey && parsed?.diagnostic_key) localDiagKey = parsed.diagnostic_key;
          if (!localDiagLabel && parsed?.diagnostic_label) localDiagLabel = parsed.diagnostic_label;
        }
      } catch (_) {}

      if (localDiagKey || localDiagLabel) {
        if (diagPresent) diagPresent.style.display = 'block';
        if (diagAbsent) diagAbsent.style.display = 'none';
        const diagLabelEl = document.getElementById('diagLabel');
        if (diagLabelEl) diagLabelEl.textContent = localDiagLabel || localDiagKey;
        const diagBadge = document.getElementById('diagBadge');
        if (diagBadge) diagBadge.textContent = localDiagKey;
        const diagAccroche = document.getElementById('diagAccroche');
        if (diagAccroche) {
          diagAccroche.textContent = DIAG_ACCROCHES[localDiagKey] || 'MARYAN adapte ses réponses à votre profil.';
        }
      } else {
        if (diagPresent) diagPresent.style.display = 'none';
        if (diagAbsent) diagAbsent.style.display = 'block';
      }

      // ── Ressources recommandées ──
      const ressourcesGrid = document.getElementById('ressourcesGrid');
      if (ressourcesGrid) {
        let slugs: { slug: string; title: string }[] = [];

        // Depuis localStorage diagnostic
        try {
          const raw = localStorage.getItem('maryan_v4_diag');
          if (raw) {
            const parsed = JSON.parse(raw);
            const keys = parsed?.recommended_slugs || parsed?.priorites || [];
            slugs = keys.slice(0, 3).map((s: string) => ({ slug: s, title: s.replace(/-/g, ' ') }));
          }
        } catch (_) {}

        if (!slugs.length) slugs = FICHES_GENERIQUES;

        ressourcesGrid.innerHTML = slugs.map(({ slug, title }) => `
          <a href="/ressources/${slug}" class="ressource-tile card-v3">
            <span class="ressource-num">→</span>
            <p class="ressource-title">${title}</p>
            <span class="ressource-cta">Consulter →</span>
          </a>
        `).join('');
      }

      // ── Sessions récentes ──
      try {
        const res = await fetch('/api/sessions', {
          headers: { Authorization: `Bearer ${token}` }
        });
        if (res.ok) {
          const { sessions } = await res.json();
          const sessionsSection = document.getElementById('sessionsSection');
          const sessionsList = document.getElementById('sessionsList');
          if (sessions?.length && sessionsSection && sessionsList) {
            sessionsSection.style.display = 'block';
            sessionsList.innerHTML = sessions.slice(0, 3).map((s: {
              id: string;
              session_type: string;
              titre: string;
              updated_at: string;
            }) => `
              <a href="/copilote?session_id=${s.id}" class="session-item">
                <div class="session-meta">
                  <span class="session-badge session-badge-${s.session_type}">${sessionTypeBadge(s.session_type)}</span>
                  <span class="session-date">${formatDate(s.updated_at)}</span>
                </div>
                <p class="session-titre">${s.titre || 'Session sans titre'}</p>
                <span class="session-cta">Reprendre →</span>
              </a>
            `).join('');
          }
        }
      } catch (_) { /* non bloquant */ }

      // ── Activation abonnement via session_id Stripe ──
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('session_id')) {
        const banner = document.getElementById('successBanner');
        if (banner) banner.style.display = 'block';
        if (planVal) planVal.textContent = 'MARYAN Plus';
        if (upgradeBtn) (upgradeBtn as HTMLElement).style.display = 'none';
        if (progressFill) progressFill.style.width = '100%';
        if (counterText) counterText.textContent = 'Accès illimité';
      }

      // ── Tests : marquer ceux déjà faits ──
      document.querySelectorAll('.test-tile[data-key]').forEach(el => {
        const key = el.getAttribute('data-key');
        if (key && localStorage.getItem(key)) {
          el.classList.add('test-done');
          const cta = el.querySelector('.test-cta');
          if (cta) cta.textContent = '✓ Refaire →';
        }
      });

      // ── Recorder modal ──
      document.getElementById('openRecorderBtn')?.addEventListener('click', () => {
        const modal = document.getElementById('recorderModal');
        if (modal) modal.style.display = 'flex';
      });
    }
  }
</script>

<style>
  .dashboard-v3 {
    padding: 4rem 0 8rem;
    background: var(--bg);
    min-height: 80vh;
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* ── Success banner ── */
  .success-banner {
    background: #F0FFF4;
    border: 1px solid #A5D6A7;
    color: #2E7D32;
    padding: 1.25rem 1.75rem;
    border-radius: 12px;
    margin-bottom: 2.5rem;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  /* ── Sidebar ── */
  .dash-sidebar { position: sticky; top: 2rem; }
  .dash-profile { padding: 2rem; background: white; }

  .profile-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.75rem;
  }

  .avatar-circle {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--deep);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .profile-text h3 { font-size: 1.05rem; margin-bottom: 0.2rem; }
  .profile-role-line { font-size: 0.85rem; color: #54636C; }

  .dash-sep { border: none; border-top: 1px solid var(--border); margin: 1.5rem 0; }

  .profile-stat { margin-bottom: 1.5rem; }
  .stat-label {
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #54636C;
    display: block;
    margin-bottom: 0.5rem;
  }
  .stat-email { font-size: 0.82rem; color: var(--deep); font-weight: 500; word-break: break-all; }
  .stat-val { font-size: 1rem; font-weight: 700; color: var(--deep); }
  .stat-sub { font-size: 0.82rem; color: #54636C; margin-top: 0.4rem; }

  .upgrade-btn {
    display: inline-block;
    margin-top: 0.75rem;
    color: var(--accent-red);
    font-weight: 800;
    font-size: 0.85rem;
    text-decoration: none;
    border-bottom: 2px solid var(--accent-red);
  }

  .logout-btn {
    display: inline-block;
    margin-top: 0.6rem;
    background: none;
    border: none;
    padding: 0;
    color: #54636C;
    font-weight: 700;
    font-size: 0.82rem;
    font-family: inherit;
    cursor: pointer;
    border-bottom: 1px solid #ccc;
  }
  .logout-btn:hover { color: var(--accent-red); border-bottom-color: var(--accent-red); }

  .progress-bar {
    width: 100%;
    height: 7px;
    background: var(--bg);
    border-radius: 99px;
    overflow: hidden;
    margin-top: 0.75rem;
  }
  .progress-fill { height: 100%; background: var(--accent-red); border-radius: 99px; transition: width 0.4s; }

  /* ── Contenu principal ── */
  .dash-content { display: flex; flex-direction: column; gap: 4rem; }
  .dash-section {}

  .dash-h2 { font-size: 1.4rem; color: var(--deep); }
  .section-header-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.75rem;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .section-header-row .dash-h2 { margin: 0; }

  .btn-link {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--accent-red);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }
  .btn-link:hover { border-bottom-color: var(--accent-red); }

  /* ── Bonjour ── */
  .dash-hello { padding-bottom: 0; }
  .hello-title { font-size: clamp(2rem, 4vw, 2.8rem); color: var(--deep); margin-bottom: 0.5rem; }
  .hello-sub { font-size: 1rem; color: #54636C; }

  /* ── Diagnostic ── */
  .diag-card { padding: 2.5rem; }
  .diag-header-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.25rem;
    gap: 1rem;
  }
  .diag-kicker {
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #54636C;
    display: block;
    margin-bottom: 0.5rem;
  }
  .diag-val { font-size: 1.5rem; font-weight: 800; color: var(--deep); line-height: 1.2; }
  .diag-badge {
    font-size: 0.72rem;
    font-weight: 700;
    background: rgba(10,25,47,0.06);
    color: var(--deep);
    padding: 0.35rem 0.75rem;
    border-radius: 99px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .diag-accroche { font-size: 0.97rem; color: #54636C; line-height: 1.6; }

  .diag-cta-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: 1.5rem;
    padding: 2.5rem;
    text-align: center;
    color: #54636C;
  }

  /* ── Ressources ── */
  .ressources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
  }
  .ressource-tile {
    text-decoration: none;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: all 0.2s;
  }
  .ressource-tile:hover { transform: translateY(-3px); border-color: var(--border-neon); }
  .ressource-num { font-size: 1.1rem; color: var(--neon); }
  .ressource-title { font-size: 0.95rem; font-weight: 700; color: var(--deep); line-height: 1.4; flex: 1; margin: 0; text-transform: capitalize; }
  .ressource-cta { font-size: 0.82rem; font-weight: 700; color: var(--accent-red); margin-top: auto; }

  /* ── Sessions ── */
  .sessions-list { display: flex; flex-direction: column; gap: 1rem; }
  .session-item {
    text-decoration: none;
    background: white;
    border: 1px solid var(--border);
    border-radius: 1.25rem;
    padding: 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: all 0.2s;
  }
  .session-item:hover { border-color: var(--accent-red); transform: translateY(-2px); }
  .session-meta { display: flex; align-items: center; gap: 0.75rem; }
  .session-badge {
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.25rem 0.65rem;
    border-radius: 99px;
    background: rgba(10,25,47,0.07);
    color: var(--deep);
  }
