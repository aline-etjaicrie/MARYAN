---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Mon Compte — MARYAN"
  description="Votre point d'entrée MARYAN : agir, comprendre et reprendre rapidement.">

  <main class="dashboard-page">
    <div class="container dashboard-layout">
      <aside class="dashboard-sidebar">
        <div class="dashboard-account card-v3">
          <span class="label-v3">Compte</span>
          <h2 id="profileName">Chargement…</h2>
          <p id="profileMeta" class="dashboard-account-meta"></p>

          <div class="dashboard-account-stats">
            <div class="dashboard-account-stat">
              <span>Forfait</span>
              <strong id="planVal">–</strong>
            </div>
            <div class="dashboard-account-stat">
              <span>Email</span>
              <strong id="userEmail">–</strong>
            </div>
          </div>

          <div class="dashboard-account-actions">
            <a href="/copilote?mode=document" class="btn-secondary-v3">Décrypter un document</a>
            <a href="/tests" class="btn-secondary-v3">Voir les tests</a>
            <button id="exportDataBtn" class="btn-secondary-v3" type="button">Télécharger mes données</button>
            <button id="logoutBtn" class="dashboard-logout-btn" type="button">Se déconnecter</button>
          </div>
        </div>
      </aside>

      <div class="dashboard-main">
        <div id="paymentBanner" class="dashboard-banner" style="display:none;">
          <strong>Abonnement activé</strong>
          <p>Votre accès MARYAN Plus est maintenant disponible.</p>
        </div>

        <section class="dashboard-hero card-v3">
          <span class="label-v3">Mon espace</span>
          <h1 id="helloTitle">Bonjour élu·e,</h1>
          <p id="helloLead" class="dashboard-hero-copy">Chargement…</p>
        </section>

        <!-- ══ PROFIL ÉLU·E ══ -->
        <section class="dashboard-block" id="profile-section">
          <div class="dashboard-block-head">
            <div>
              <h2>Vos informations d'élu·e</h2>
              <p>Ces informations personnalisent votre copilote.</p>
            </div>
          </div>
          <form id="profileForm" class="profile-form" autocomplete="off" novalidate>
            <div class="profile-form-grid">
              <div class="profile-field">
                <label for="pf-first-name">Prénom</label>
                <input type="text" id="pf-first-name" name="first_name" placeholder="Votre prénom" autocomplete="given-name" />
              </div>
              <div class="profile-field">
                <label for="pf-last-name">Nom <span class="field-opt">(facultatif)</span></label>
                <input type="text" id="pf-last-name" name="last_name" placeholder="Votre nom" autocomplete="family-name" />
              </div>
              <div class="profile-field">
                <label for="pf-role">Mandat principal</label>
                <select id="pf-role" name="role">
                  <option value="">— Choisir —</option>
                  <optgroup label="Communes">
                    <option value="maire">Maire</option>
                    <option value="adjoint_maire">Adjoint au maire</option>
                    <option value="conseiller_maj">Conseiller municipal (majorité)</option>
                    <option value="conseiller_opp">Conseiller municipal (opposition)</option>
                  </optgroup>
                  <optgroup label="Intercommunalité">
                    <option value="president_interco">Président d'intercommunalité</option>
                    <option value="vice_president_interco">Vice-président intercommunalité</option>
                    <option value="conseiller_communautaire">Conseiller communautaire</option>
                  </optgroup>
                  <optgroup label="Paris">
                    <option value="conseiller_paris">Conseiller de Paris</option>
                    <option value="maire_arrondissement_paris">Maire d'arrondissement (Paris)</option>
                    <option value="adjoint_arrondissement_paris">Adjoint d'arrondissement (Paris)</option>
                    <option value="conseiller_arrondissement_paris">Conseiller d'arrondissement (Paris)</option>
                  </optgroup>
                  <optgroup label="Lyon">
                    <option value="conseiller_metropolitain_lyon">Conseiller métropolitain (Lyon)</option>
                    <option value="conseiller_arrondissement_lyon">Conseiller d'arrondissement (Lyon)</option>
                  </optgroup>
                  <optgroup label="Marseille">
                    <option value="maire_secteur_marseille">Maire de secteur (Marseille)</option>
                    <option value="adjoint_secteur_marseille">Adjoint de secteur (Marseille)</option>
                    <option value="conseiller_municipal_marseille">Conseiller municipal (Marseille)</option>
                  </optgroup>
                </select>
              </div>
              <div class="profile-field">
                <label for="pf-taille-ct">Taille de la collectivité</label>
                <select id="pf-taille-ct" name="taille_ct">
                  <option value="">— Choisir —</option>
                  <option value="moins500">Moins de 500 hab.</option>
                  <option value="500-3500">500 à 3 500 hab.</option>
                  <option value="3500-10000">3 500 à 10 000 hab.</option>
                  <option value="10000-50000">10 000 à 50 000 hab.</option>
                  <option value="plus50000">Plus de 50 000 hab.</option>
                </select>
              </div>
              <div class="profile-field">
                <label for="pf-type-ct">Type de collectivité</label>
                <select id="pf-type-ct" name="type_ct">
                  <option value="">— Choisir —</option>
                  <option value="commune_rurale">Commune rurale (- de 3 500 hab.)</option>
                  <option value="commune_urbaine">Commune urbaine (+ de 3 500 hab.)</option>
                  <option value="intercommunalite">Intercommunalité / EPCI</option>
                  <option value="metropole">Métropole</option>
                  <option value="plm_paris">Paris (régime PLM)</option>
                  <option value="plm_lyon">Lyon (régime PLM)</option>
                  <option value="plm_marseille">Marseille (régime PLM)</option>
                </select>
              </div>
              <div class="profile-field profile-field--full">
                <label for="pf-metier">Métier en dehors du mandat <span class="field-opt">(facultatif)</span></label>
                <input type="text" id="pf-metier" name="metier_hors_mandat" placeholder="Ex : enseignant, médecin, chef d'entreprise..." />
              </div>
              <div class="profile-field profile-field--full">
                <label for="pf-affiliation">Affiliation politique <span class="field-opt">(facultatif)</span></label>
                <input type="text" id="pf-affiliation" name="affiliation_politique" placeholder="Ex : divers gauche, LR, sans étiquette..." />
              </div>
            </div>
            <div class="profile-form-footer">
              <button type="submit" id="profileSaveBtn" class="btn-primary-v3">Enregistrer</button>
              <span id="profileSaveMsg" class="profile-save-msg" aria-live="polite"></span>
            </div>
          </form>
        </section>

        <section class="dashboard-block">
          <div class="dashboard-block-head">
            <div>
              <h2>Que souhaitez-vous faire ?</h2>
            </div>
          </div>

          <div class="dashboard-action-grid">
            <a href="/diagnostic" class="dashboard-action-card" data-intent="comprendre">
              <span>Comprendre une situation</span>
            </a>
            <a href="/copilote" class="dashboard-action-card" data-intent="decision">
              <span>Prendre une décision</span>
            </a>
            <a href="/copilote" class="dashboard-action-card" data-intent="sensible">
              <span>Gérer une situation sensible</span>
            </a>
            <a href="/copilote" class="dashboard-action-card" data-intent="reponse">
              <span>Rédiger une réponse</span>
            </a>
          </div>

          <div class="dashboard-support-row">
            <a href="/copilote?mode=document" class="dashboard-support-link">Décrypter un document officiel →</a>
          </div>
        </section>

        <section class="dashboard-block">
          <div class="dashboard-block-head">
            <div>
              <h2>Le Radar de MARYAN</h2>
              <p>À venir.</p>
            </div>
            <a href="/radar" class="btn-link">Voir la page →</a>
          </div>

          <div id="dashboardRadarList" class="dashboard-radar-list"></div>
        </section>

        <section class="dashboard-block">
          <div class="dashboard-block-head">
            <div>
              <h2>Vos sujets du moment</h2>
              <p id="topicsLead">Des points d'appui choisis à partir de votre diagnostic.</p>
            </div>
            <a href="/ressources" class="btn-link">Explorer les ressources →</a>
          </div>

          <div id="topicsGrid" class="dashboard-topics-grid"></div>
        </section>

        <!-- ══ AUTO-ÉVALUATIONS ══ -->
        <section class="dashboard-block" id="tests-section">
          <div class="dashboard-block-head">
            <div>
              <h2>Vos auto-évaluations</h2>
              <p>Cinq tests courts pour mieux vous connaître en tant qu'élu·e.</p>
            </div>
            <a href="/tests" class="btn-link">Voir tous →</a>
          </div>
          <div id="dashboardTestsList" class="dashboard-tests-list"></div>
        </section>

        <section class="dashboard-block">
          <div class="dashboard-block-head">
            <div>
              <h2>Reprendre</h2>
            </div>
          </div>

          <div id="resumeCard" class="dashboard-resume-card card-v3"></div>
        </section>

        <!-- ══ MES DOCUMENTS ══ -->
        <section class="dashboard-block" id="docs-section">
          <div class="dashboard-block-head">
            <div>
              <h2>Mes documents</h2>
              <p>Vos comptes rendus et analyses sauvegardés.</p>
            </div>
            <a href="/copilote" class="btn-link">Créer un document →</a>
          </div>

          <!-- Dossiers -->
          <div class="docs-folders-bar" id="docsFoldersBar">
            <div id="docsFoldersList" class="docs-folders-list"></div>
            <button id="docsNewFolderBtn" class="docs-new-folder-btn" type="button">+ Nouveau dossier</button>
          </div>
          <div id="docsNewFolderForm" class="docs-new-folder-form" style="display:none">
            <input id="docsNewFolderInput" type="text" class="docs-folder-input" placeholder="Nom du dossier" maxlength="60" />
            <button id="docsNewFolderSave" class="btn-mode-sm-primary" type="button">Créer</button>
            <button id="docsNewFolderCancel" class="btn-mode-sm-outline" type="button">Annuler</button>
          </div>

          <!-- Liste des documents -->
          <div id="docsListContainer" class="docs-list-container">
            <div id="docsLoading" class="docs-loading">Chargement…</div>
            <div id="docsEmpty" class="docs-empty" style="display:none">
              <p>Aucun document dans ce dossier.</p>
              <a href="/copilote" class="btn-primary-v3">Créer un compte rendu ou analyser un document</a>
            </div>
            <div id="docsList" class="docs-list" style="display:none"></div>
          </div>

          <!-- Panneau de lecture -->
          <div id="docsReadPanel" class="docs-read-panel" style="display:none">
            <div class="docs-read-header">
              <button id="docsClosePanel" class="docs-close-panel-btn" type="button">← Retour à la liste</button>
              <button id="docsPanelCopyBtn" class="btn-mode-sm-secondary" type="button">Copier</button>
            </div>
            <div class="docs-read-meta">
              <span id="docsPanelType" class="docs-type-badge"></span>
              <span id="docsPanelDate" class="docs-date"></span>
            </div>
            <h3 id="docsPanelTitle" class="docs-read-title"></h3>
            <div id="docsPanelContent" class="docs-read-content"></div>
          </div>
        </section>
      </div>
    </div>
  </main>

  <!-- Confirm modal -->
  <div id="docsDeleteModal" class="docs-modal-overlay" style="display:none" role="dialog" aria-modal="true">
    <div class="docs-modal">
      <p class="docs-modal-title">Supprimer ce document ?</p>
      <p class="docs-modal-text">Cette action est irréversible.</p>
      <div class="docs-modal-actions">
        <button id="docsDeleteConfirm" class="btn-mode-sm-danger" type="button">Supprimer</button>
        <button id="docsDeleteCancel" class="btn-mode-sm-outline" type="button">Annuler</button>
      </div>
    </div>
  </div>

</BaseLayout>

<script>
  import { createClient } from '@supabase/supabase-js';
  import { getRecommendedResources, maryanResources } from '../data/resources';
  import {
    buildDiagnosticStateFromProfileRow,
    buildMaryanProfileFromDiagnosticState
  } from '../lib/user-personalization';
  import { DIAGNOSTIC_ACCROCHES } from '../lib/diagnostic-personalization';

  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL as string;
  const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY as string;

  const ANGLES_BY_PROFILE = {
    mandat_recent: ['compréhension', 'repères', 'décision'],
    arbitrage: ['compréhension', 'arbitrage', 'décision'],
    isolement: ['clarification', 'appuis', 'sécurisation'],
    surcharge: ['priorisation', 'sécurisation', 'décision'],
    exposition: ['vigilance', 'parole', 'sécurisation'],
    tension_relationnelle: ['relation', 'cadre', 'décision'],
    besoin_methode: ['compréhension', 'méthode', 'décision'],
    prise_de_parole: ['parole', 'vigilance', 'décision'],
    gouvernance: ['circuits', 'sécurisation', 'décision']
  } as const;

  const GENERIC_RESOURCES = [
    'qui-decide-quoi-dans-la-collectivite',
    'le-conseil-municipal-a-quoi-il-sert-vraiment',
    'prendre-la-parole-en-conseil',
    'comment-se-prend-une-decision-dans-une-commune'
  ];

  function escapeHtml(value: unknown): string {
    return String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');
  }

  function formatShortDate(iso: string): string {
    try {
      return new Date(iso).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' });
    } catch {
      return '';
    }
  }

  function sessionLabel(type: string): string {
    const labels: Record<string, string> = {
      copilote: 'Copilote',
      cr_reunion: 'Compte rendu',
      analyse: 'Analyse'
    };
    return labels[type] || 'Session';
  }

  function sessionHref(session: { id: string; session_type: string }): string {
    if (session.session_type === 'analyse') return '/copilote?mode=document';
    return `/copilote?session_id=${session.id}`;
  }

  if (!SUPABASE_URL || !SUPABASE_KEY) {
    window.location.href = '/login';
  } else {
    const supabase = createClient(SUPABASE_URL, SUPABASE_KEY);

    if (window.location.search.includes('checkout=success')) {
      const paymentBanner = document.getElementById('paymentBanner');
      if (paymentBanner) paymentBanner.style.display = 'block';
      window.history.replaceState({}, '', '/mon-compte');
    }

    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      window.location.href = '/login';
    } else {
      const user = session.user;
      const token = session.access_token;

      let profileContext = null;
      try {
        const response = await fetch('/api/profile-context', {
          headers: { Authorization: `Bearer ${token}` }
        });
        if (response.ok) {
          profileContext = await response.json();
        }
      } catch {
        // noop
      }

      const profile = profileContext?.profile || (await supabase
        .from('profiles')
        .select('first_name, last_name, commune, role, plan, diagnostic_key, diagnostic_label, diagnostic_completed, last_diagnostic_summary, profile_context, profile_context_updated_at, affiliation_politique, taille_ct, type_ct, metier_hors_mandat')
        .eq('id', user.id)
        .single()).data;

      const firstName = profile?.first_name || session.user.user_metadata?.first_name || '';
      const role = profile?.role || 'élu·e local·e';
      const commune = profile?.commune || '';
      const plan = profile?.plan || 'gratuit';
      const isSubscriber = plan === 'plus' || plan === 'admin';

      const lastName = (profile as any)?.last_name || '';
      const displayName = [firstName, lastName].filter(Boolean).join(' ');
      document.getElementById('profileName')!.textContent = displayName || 'Profil à compléter';
      document.getElementById('profileMeta')!.textContent = role !== 'élu·e local·e' ? role : '';
      document.getElementById('userEmail')!.textContent = user.email || '';
      document.getElementById('planVal')!.textContent = plan === 'plus' ? 'MARYAN Plus' : plan === 'admin' ? 'Admin' : 'Découverte';

      // ── Pré-remplissage du formulaire profil ──
      {
        const fields: Record<string, string> = {
          'pf-first-name': profile?.first_name || '',
          'pf-last-name': (profile as any)?.last_name || '',
          'pf-role': role !== 'élu·e local·e' ? role : '',
          'pf-taille-ct': (profile as any)?.taille_ct || '',
          'pf-type-ct': (profile as any)?.type_ct || '',
          'pf-metier': (profile as any)?.metier_hors_mandat || '',
          'pf-affiliation': (profile as any)?.affiliation_politique || ''
        };
        for (const [id, val] of Object.entries(fields)) {
          const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null;
          if (el) el.value = val;
        }
      }

      // ── Soumission du formulaire profil ──
      document.getElementById('profileForm')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('profileSaveBtn') as HTMLButtonElement;
        const msg = document.getElementById('profileSaveMsg')!;
        btn.disabled = true;
        btn.textContent = 'Enregistrement…';
        msg.textContent = '';
        msg.style.color = '';
        try {
          const body: Record<string, string | null> = {};
          ['first_name', 'last_name', 'role', 'taille_ct', 'type_ct', 'metier_hors_mandat', 'affiliation_politique'].forEach(field => {
            const idMap: Record<string, string> = {
              first_name: 'pf-first-name', last_name: 'pf-last-name', role: 'pf-role',
              taille_ct: 'pf-taille-ct', type_ct: 'pf-type-ct',
              metier_hors_mandat: 'pf-metier', affiliation_politique: 'pf-affiliation'
            };
            const el = document.getElementById(idMap[field]) as HTMLInputElement | HTMLSelectElement | null;
            body[field] = el ? (el.value.trim() || null) : null;
          });
          const res = await fetch('/api/update-profile', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
            body: JSON.stringify(body)
          });
          const result = await res.json();
          if (!res.ok) throw new Error(result.error || 'Erreur serveur');
          msg.textContent = '✓ Profil mis à jour';
          msg.style.color = '#2E7D32';
          // Update sidebar after save
          const newFirstName = body.first_name || firstName;
          const newLastName = body.last_name || lastName;
          const newDisplayName = [newFirstName, newLastName].filter(Boolean).join(' ');
          if (newDisplayName) {
            document.getElementById('profileName')!.textContent = newDisplayName;
          }
          if (newFirstName) {
            document.getElementById('helloTitle')!.textContent = `Bonjour ${newFirstName},`;
          }
          const newRole = body.role || (role !== 'élu·e local·e' ? role : '');
          document.getElementById('profileMeta')!.textContent = newRole || '';
        } catch (err) {
          msg.textContent = `Erreur : ${(err as Error).message || 'Échec de la sauvegarde'}`;
          msg.style.color = '#C62828';
        } finally {
          btn.disabled = false;
          btn.textContent = 'Enregistrer';
          setTimeout(() => { msg.textContent = ''; }, 4000);
        }
      });

      const diagnosticState = profileContext?.diagnosticState || buildDiagnosticStateFromProfileRow(profile);

      try {
        if (diagnosticState.diagnostic_key || diagnosticState.profile || diagnosticState.recommended_slugs?.length) {
          localStorage.setItem('maryan_v4_diag', JSON.stringify(diagnosticState));
        }

        const maryanProfile = profileContext?.maryanProfile || buildMaryanProfileFromDiagnosticState(diagnosticState, {
          firstName,
          commune,
          plan,
          metierHorsMandat: (profile as any)?.metier_hors_mandat || null,
          tailleCtLabel: (profile as any)?.taille_ct || null,
          typeCtLabel: (profile as any)?.type_ct || null
        });

        if (maryanProfile) {
          localStorage.setItem('maryan_profile', JSON.stringify({
            ...maryanProfile,
            diagnosticProfile: diagnosticState.profile
          }));
        }
      } catch {
        // noop
      }

      const helloTitle = document.getElementById('helloTitle');
      if (helloTitle) {
        helloTitle.textContent = firstName ? `Bonjour ${firstName},` : 'Bonjour,';
      }

      const profileAngles = diagnosticState.profile
        ? ANGLES_BY_PROFILE[diagnosticState.profile as keyof typeof ANGLES_BY_PROFILE]
        : null;

      const angles = profileAngles
        ? profileAngles
        : ['compréhension', 'sécurisation', 'décision'];

      const helloLead = document.getElementById('helloLead');
      if (helloLead) {
        const roleSentence = [role, commune ? `à ${commune}` : 'dans votre collectivité'].join(' ');
        helloLead.textContent = `Vous êtes ${roleSentence}. MARYAN privilégie aujourd'hui : ${angles.join(', ')}.`;
      }


      const radarList = document.getElementById('dashboardRadarList');
      if (radarList) {
        radarList.innerHTML = `
          <article class="dashboard-radar-card">
            <h3>À venir.</h3>
            <p>Le Radar de MARYAN sera mis en ligne prochainement.</p>
          </article>
        `;
      }

      const topicsGrid = document.getElementById('topicsGrid');
      const topicsLead = document.getElementById('topicsLead');
      if (topicsGrid) {
        let resources = diagnosticState.profile
          ? getRecommendedResources(maryanResources, diagnosticState.profile).slice(0, 5)
          : [];

        if (!resources.length && diagnosticState.recommended_slugs?.length) {
          resources = diagnosticState.recommended_slugs
            .slice(0, 5)
            .map((slug: string) => maryanResources.find((resource) => resource.slug === slug))
            .filter(Boolean);
        }

        if (!resources.length) {
          resources = GENERIC_RESOURCES
            .map((slug) => maryanResources.find((resource) => resource.slug === slug))
            .filter(Boolean);
        }

        if (topicsLead && !diagnosticState.profile) {
          topicsLead.textContent = "Des points d'appui sobres pour avancer tout de suite.";
        }

        topicsGrid.innerHTML = resources.map((resource) => `
          <a href="/ressources/${escapeHtml(resource.slug)}" class="dashboard-topic-card">
            <span class="dtc-title">${escapeHtml(resource.title)}</span>
            ${resource.promise ? `<span class="dtc-promise">${escapeHtml(resource.promise)}</span>` : ''}
            ${resource.pillar ? `<span class="dtc-pillar dtc-pillar--${escapeHtml(resource.pillar)}">${escapeHtml(resource.pillar.replace('_', '\u00a0'))}</span>` : ''}
          </a>
        `).join('');
      }

      // ── Auto-évaluations ──
      {
        const DASHBOARD_TESTS = [
          { slug: 'style-decision',   title: 'Mon style de décision',             desc: 'Repérez votre profil décisionnel et vos angles morts.',       storageKey: 'maryan_test_decision' },
          { slug: 'posture-conflit',  title: 'Ma posture face au conflit',         desc: 'Comment traversez-vous les tensions ?',                       storageKey: 'maryan_test_conflit' },
          { slug: 'prise-de-parole',  title: 'Préparer une prise de parole',       desc: 'Évaluez votre niveau de préparation réelle.',                 storageKey: 'maryan_test_parole' },
          { slug: 'travail-equipe',   title: 'Mon rapport au travail en équipe',   desc: 'Repérez votre profil d\'équipe et ce qu\'il vous coûte.',     storageKey: 'maryan_test_equipe' },
          { slug: 'deliberation',     title: 'Préparer une délibération',          desc: 'Évaluez votre niveau de préparation avant le vote.',          storageKey: 'maryan_test_deliberation' }
        ];
        const testsList = document.getElementById('dashboardTestsList');
        if (testsList) {
          testsList.innerHTML = DASHBOARD_TESTS.map(t => {
            const done = !!localStorage.getItem(t.storageKey);
            const statusHtml = done
              ? `<span class="dash-test-status done">Complété</span>`
              : `<span class="dash-test-status todo">À faire</span>`;
            return `
              <a href="/tests/${escapeHtml(t.slug)}" class="dash-test-item">
                <div class="dash-test-info">
                  <span class="dash-test-title">${escapeHtml(t.title)}</span>
                  <span class="dash-test-desc">${escapeHtml(t.desc)}</span>
                </div>
                <div class="dash-test-right">
                  ${statusHtml}
                  <span class="dash-test-badge">Abonné·e</span>
                </div>
              </a>`;
          }).join('');
        }
      }

      const resumeCard = document.getElementById('resumeCard');
      if (resumeCard) {
        if (diagnosticState.profile || diagnosticState.diagnostic_key) {
          const diagLabel = escapeHtml(diagnosticState.diagnostic_label || diagnosticState.diagnostic_key || 'Votre profil');
          const accroche = diagnosticState.profile
            ? escapeHtml(DIAGNOSTIC_ACCROCHES[diagnosticState.profile as keyof typeof DIAGNOSTIC_ACCROCHES] || '')
            : '';
          const priorities: string[] = Array.isArray(diagnosticState.priorities) ? diagnosticState.priorities : [];
          const priorityTagsHtml = priorities.length
            ? `<div class="diag-priority-tags">${priorities.map(p => `<span class="diag-tag">${escapeHtml(p)}</span>`).join('')}</div>`
            : '';
          const recSlugs: string[] = Array.isArray(diagnosticState.recommended_slugs) ? diagnosticState.recommended_slugs.slice(0, 3) : [];
          const recResourcesHtml = recSlugs.length
            ? `<div class="diag-rec-list">${recSlugs.map(slug => {
                const r = maryanResources.find(x => x.slug === slug);
                return r ? `<a href="/ressources/${escapeHtml(r.slug)}" class="diag-rec-item">${escapeHtml(r.title)}</a>` : '';
              }).filter(Boolean).join('')}</div>`
            : '';
          resumeCard.innerHTML = `
            <div class="dashboard-resume-live">
              <p class="dashboard-resume-label">Diagnostic complété</p>
              <h3>${diagLabel}</h3>
              ${accroche ? `<p class="diag-situation">${accroche}</p>` : ''}
              ${priorityTagsHtml}
              ${recResourcesHtml}
              <a href="/diagnostic" class="btn-primary-v3" style="margin-top:1rem;display:inline-block;">Mettre à jour mon diagnostic</a>
            </div>
          `;
        } else {
          resumeCard.innerHTML = `
            <div class="dashboard-resume-empty">
              <p class="dashboard-resume-label">Point d'entrée</p>
              <h3>Faites votre diagnostic</h3>
              <p>Personnalisez MARYAN à votre situation de mandat en 3 minutes.</p>
              <a href="/diagnostic" class="btn-primary-v3">Faire le diagnostic →</a>
            </div>
          `;
        }
      }

      try {
        const response = await fetch('/api/sessions', {
          headers: { Authorization: `Bearer ${token}` }
        });

        if (response.ok) {
          const { sessions } = await response.json();
          const latestSession = Array.isArray(sessions) ? sessions[0] : null;

          if (latestSession && resumeCard) {
            resumeCard.innerHTML = `
              <div class="dashboard-resume-live">
                <p class="dashboard-resume-label">${escapeHtml(sessionLabel(latestSession.session_type))}</p>
                <h3>${escapeHtml(latestSession.titre || 'Reprendre votre dernière action')}</h3>
                <p>Dernière mise à jour : ${escapeHtml(formatShortDate(latestSession.updated_at))}</p>
                <a href="${escapeHtml(sessionHref(latestSession))}" class="btn-primary-v3">Reprendre</a>
              </div>
            `;
          }
        }
      } catch {
        // noop
      }

      document.querySelectorAll('[data-intent]').forEach((link) => {
        link.addEventListener('click', () => {
          const intent = link.getAttribute('data-intent');
          if (intent) localStorage.setItem('maryan_copilot_intent', intent);
        });
      });

      // ══════════════════════════════════════════════════
      // MES DOCUMENTS — logique complète
      // ══════════════════════════════════════════════════
      {
        let currentDossier: string | null = null;
        let allDossiers: string[] = [];
        let pendingDeleteId: string | null = null;
        let currentDocContent: string = '';

        const TYPE_ICONS: Record<string, string> = {
          'compte-rendu': '🎙️',
          'document': '📄',
          'note': '💬'
        };

        function escDoc(s: unknown): string {
          return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        function fmtDate(iso: string): string {
          try { return new Date(iso).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' }); }
          catch { return ''; }
        }

        // Markdown minimal pour l'affichage dans le panneau
        function renderDocMarkdown(md: string): string {
          const esc = (s: string) => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
          const lines = md.split('\n');
          const out: string[] = [];
          let inList = false;
          for (const raw of lines) {
            const line = raw.trimEnd();
            if (line.startsWith('## ')) {
              if (inList) { out.push('</ul>'); inList = false; }
              out.push(`<h3 class="doc-md-h2">${esc(line.slice(3))}</h3>`);
            } else if (line.startsWith('### ')) {
              if (inList) { out.push('</ul>'); inList = false; }
              out.push(`<h4 class="doc-md-h3">${esc(line.slice(4))}</h4>`);
            } else if (line.startsWith('- ') || line.startsWith('* ')) {
              if (!inList) { out.push('<ul class="doc-md-list">'); inList = true; }
              out.push(`<li>${esc(line.slice(2))}</li>`);
            } else if (line === '') {
              if (inList) { out.push('</ul>'); inList = false; }
            } else {
              if (inList) { out.push('</ul>'); inList = false; }
              out.push(`<p class="doc-md-p">${esc(line)}</p>`);
            }
          }
          if (inList) out.push('</ul>');
          return out.join('\n');
        }

        async function loadDossiers() {
          try {
            const res = await fetch('/api/documents', { headers: { Authorization: `Bearer ${token}` } });
            if (!res.ok) return;
            const data = await res.json() as { dossiers?: string[] };
            allDossiers = data.dossiers || [];
            // Dossiers par défaut toujours présents
            const defaults = ['Réunions', 'Documents', 'Notes'];
            defaults.forEach(d => { if (!allDossiers.includes(d)) allDossiers.unshift(d); });
            renderFolders();
            if (!currentDossier) {
              currentDossier = allDossiers[0] || 'Réunions';
            }
            loadDocuments(currentDossier);
          } catch { /* noop */ }
        }

        function renderFolders() {
          const list = document.getElementById('docsFoldersList')!;
          list.innerHTML = allDossiers.map(d => `
            <span class="docs-folder-chip${currentDossier === d ? ' docs-folder-btn--active' : ''}" data-folder="${escDoc(d)}">
              <button class="docs-folder-btn${currentDossier === d ? ' docs-folder-btn--active' : ''}"
                data-folder-select="${escDoc(d)}" type="button" title="Clic : sélectionner · Double-clic : renommer">
                ${escDoc(d)}
              </button>
            </span>
          `).join('');

          // Sélectionner dossier
          list.querySelectorAll('[data-folder-select]').forEach(btn => {
            btn.addEventListener('click', () => {
              currentDossier = btn.getAttribute('data-folder-select');
              renderFolders();
              loadDocuments(currentDossier!);
              closePanelIfOpen();
            });

            // Double-clic → renommer
            btn.addEventListener('dblclick', (e) => {
              e.stopPropagation();
              const folderName = btn.getAttribute('data-folder-select')!;
              const chip = btn.closest('[data-folder]') as HTMLElement;
              const input = document.createElement('input');
              input.type = 'text';
              input.value = folderName;
              input.className = 'docs-folder-rename-input';
              input.maxLength = 60;
              chip.innerHTML = '';
              chip.appendChild(input);
              input.focus();
              input.select();

              async function commitRename() {
                const newName = input.value.trim();
                if (!newName || newName === folderName) {
                  renderFolders();
                  return;
                }
                try {
                  const res = await fetch('/api/documents', {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
                    body: JSON.stringify({ rename_folder: { from: folderName, to: newName } })
                  });
                  if (res.ok) {
                    const idx = allDossiers.indexOf(folderName);
                    if (idx !== -1) allDossiers[idx] = newName;
                    if (currentDossier === folderName) currentDossier = newName;
                    renderFolders();
                    loadDocuments(currentDossier!);
                  } else {
                    renderFolders();
                  }
                } catch {
                  renderFolders();
                }
              }

              input.addEventListener('blur', commitRename);
              input.addEventListener('keydown', (ev: KeyboardEvent) => {
                if (ev.key === 'Enter') { input.blur(); }
                if (ev.key === 'Escape') { input.value = folderName; input.blur(); }
              });
            });
          });
        }

        async function loadDocuments(dossier: string) {
          const loadingEl = document.getElementById('docsLoading')!;
          const emptyEl = document.getElementById('docsEmpty')!;
          const listEl = document.getElementById('docsList')!;
          loadingEl.style.display = 'block';
          emptyEl.style.display = 'none';
          listEl.style.display = 'none';

          try {
            const res = await fetch(`/api/documents?dossier=${encodeURIComponent(dossier)}`, {
              headers: { Authorization: `Bearer ${token}` }
            });
            if (!res.ok) throw new Error();
            const data = await res.json() as { documents?: any[] };
            const docs = data.documents || [];
            loadingEl.style.display = 'none';
            if (!docs.length) {
              emptyEl.style.display = 'block';
            } else {
              listEl.style.display = 'block';
              renderDocsList(docs);
            }
          } catch {
            loadingEl.style.display = 'none';
            listEl.innerHTML = '<p style="color:#C62828;font-size:.9rem">Erreur de chargement.</p>';
            listEl.style.display = 'block';
          }
        }

        function renderDocsList(docs: any[]) {
          const listEl = document.getElementById('docsList')!;
          listEl.innerHTML = docs.map(doc => `
            <div class="docs-item" data-doc-id="${escDoc(doc.id)}">
              <div class="docs-item-main">
                <span class="docs-item-icon">${escDoc(TYPE_ICONS[doc.type] || '📄')}</span>
                <div class="docs-item-info">
                  <span class="docs-item-title" data-read-doc="${escDoc(doc.id)}">${escDoc(doc.titre)}</span>
                  <span class="docs-item-meta">${fmtDate(doc.created_at)}</span>
                </div>
              </div>
              <div class="docs-item-actions">
                <select class="docs-move-select" data-move-doc="${escDoc(doc.id)}" title="Déplacer vers">
                  <option value="">Déplacer…</option>
                  ${allDossiers.filter(d => d !== currentDossier).map(d => `<option value="${escDoc(d)}">${escDoc(d)}</option>`).join('')}
                </select>
                <button class="docs-delete-btn" data-delete-doc="${escDoc(doc.id)}" type="button" title="Supprimer">🗑</button>
              </div>
            </div>
          `).join('');

          // Read doc
          listEl.querySelectorAll('[data-read-doc]').forEach(el => {
            el.addEventListener('click', () => openDoc(el.getAttribute('data-read-doc')!));
          });

          // Move doc
          listEl.querySelectorAll('[data-move-doc]').forEach(sel => {
            sel.addEventListener('change', async () => {
              const docId = sel.getAttribute('data-move-doc')!;
              const newDossier = (sel as HTMLSelectElement).value;
              if (!newDossier) return;
              try {
                await fetch('/api/documents', {
                  method: 'PATCH',
                  headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
                  body: JSON.stringify({ id: docId, dossier: newDossier })
                });
                loadDocuments(currentDossier!);
              } catch { /* noop */ }
            });
          });

          // Delete doc
          listEl.querySelectorAll('[data-delete-doc]').forEach(btn => {
            btn.addEventListener('click', () => {
              pendingDeleteId = btn.getAttribute('data-delete-doc');
              (document.getElementById('docsDeleteModal') as HTMLElement).style.display = 'flex';
            });
          });
        }

        async function openDoc(docId: string) {
          try {
            const res = await fetch(`/api/documents?id=${docId}`, { headers: { Authorization: `Bearer ${token}` } });
            if (!res.ok) return;
            const data = await res.json() as { document?: any };
            const doc = data.document;
            if (!doc) return;
            currentDocContent = doc.contenu || '';
            document.getElementById('docsPanelTitle')!.textContent = doc.titre || 'Document';
            document.getElementById('docsPanelType')!.textContent = (TYPE_ICONS[doc.type] || '📄') + ' ' + doc.type;
            document.getElementById('docsPanelDate')!.textContent = fmtDate(doc.created_at);
            document.getElementById('docsPanelContent')!.innerHTML = renderDocMarkdown(currentDocContent);
            document.getElementById('docsListContainer')!.style.display = 'none';
            document.getElementById('docsReadPanel')!.style.display = 'block';
          } catch { /* noop */ }
        }

        function closePanelIfOpen() {
          document.getElementById('docsReadPanel')!.style.display = 'none';
          document.getElementById('docsListContainer')!.style.display = 'block';
        }

        document.getElementById('docsClosePanel')?.addEventListener('click', closePanelIfOpen);

        document.getElementById('docsPanelCopyBtn')?.addEventListener('click', () => {
          navigator.clipboard.writeText(currentDocContent).then(() => {
            const btn = document.getElementById('docsPanelCopyBtn')!;
            btn.textContent = '✓ Copié';
            setTimeout(() => { btn.textContent = 'Copier'; }, 2000);
          });
        });

        // New folder
        document.getElementById('docsNewFolderBtn')?.addEventListener('click', () => {
          document.getElementById('docsNewFolderForm')!.style.display = 'flex';
          (document.getElementById('docsNewFolderInput') as HTMLInputElement).focus();
        });

        document.getElementById('docsNewFolderCancel')?.addEventListener('click', () => {
          document.getElementById('docsNewFolderForm')!.style.display = 'none';
          (document.getElementById('docsNewFolderInput') as HTMLInputElement).value = '';
        });

        document.getElementById('docsNewFolderSave')?.addEventListener('click', () => {
          const input = document.getElementById('docsNewFolderInput') as HTMLInputElement;
          const name = input.value.trim();
          if (!name) return;
          if (!allDossiers.includes(name)) {
            allDossiers.push(name);
            currentDossier = name;
            renderFolders();
            loadDocuments(name);
          }
          document.getElementById('docsNewFolderForm')!.style.display = 'none';
          input.value = '';
        });

        // Delete modal
        document.getElementById('docsDeleteConfirm')?.addEventListener('click', async () => {
          if (!pendingDeleteId) return;
          const modal = document.getElementById('docsDeleteModal') as HTMLElement;
          modal.style.display = 'none';
          try {
            await fetch('/api/documents', {
              method: 'DELETE',
              headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
              body: JSON.stringify({ id: pendingDeleteId })
            });
            loadDocuments(currentDossier!);
          } catch { /* noop */ }
          pendingDeleteId = null;
        });

        document.getElementById('docsDeleteCancel')?.addEventListener('click', () => {
          (document.getElementById('docsDeleteModal') as HTMLElement).style.display = 'none';
          pendingDeleteId = null;
        });

        // Init
        loadDossiers();
      }

      document.getElementById('logoutBtn')?.addEventListener('click', async () => {
        await supabase.auth.signOut();
        window.location.href = '/login';
      });

      document.getElementById('exportDataBtn')?.addEventListener('click', async () => {
        try {
          const response = await fetch('/api/export-data', {
            headers: { Authorization: `Bearer ${token}` }
          });

          if (!response.ok) {
            alert("Erreur lors de l'export. Veuillez réessayer.");
            return;
          }

          const blob = await response.blob();
          const url = URL.createObjectURL(blob);
          const anchor = document.createElement('a');
          anchor.href = url;
          anchor.download = 'maryan-mes-donnees.json';
          document.body.appendChild(anchor);
          anchor.click();
          anchor.remove();
          URL.revokeObjectURL(url);
        } catch {
          alert("Erreur lors de l'export. Veuillez réessayer.");
        }
      });
    }
  }
</script>

