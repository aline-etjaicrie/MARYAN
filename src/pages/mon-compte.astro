---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Mon Compte — MARYAN"
  description="Votre point d’entrée MARYAN : agir, comprendre et reprendre rapidement.">

  <main class="dashboard-page">
    <div class="container dashboard-layout">
      <aside class="dashboard-sidebar">
        <div class="dashboard-account card-v3">
          <span class="label-v3">Compte</span>
          <h2 id="profileName">Chargement…</h2>
          <p id="profileMeta" class="dashboard-account-meta"></p>

          <div class="dashboard-account-stats">
            <div class="dashboard-account-stat">
              <span>Forfait</span>
              <strong id="planVal">–</strong>
            </div>
            <div class="dashboard-account-stat">
              <span>Email</span>
              <strong id="userEmail">–</strong>
            </div>
          </div>

          <div class="dashboard-account-actions">
            <a id="sidebarAnalyseurLink" href="/offres" class="btn-secondary-v3">Décrypter un document</a>
            <a href="/tests" class="btn-secondary-v3">Voir les tests</a>
            <button id="exportDataBtn" class="btn-secondary-v3" type="button">Télécharger mes données</button>
            <button id="logoutBtn" class="dashboard-logout-btn" type="button">Se déconnecter</button>
          </div>
        </div>
      </aside>

      <div class="dashboard-main">
        <div id="paymentBanner" class="dashboard-banner" style="display:none;">
          <strong>Abonnement activé</strong>
          <p>Votre accès MARYAN Plus est maintenant disponible.</p>
        </div>

        <section class="dashboard-hero card-v3">
          <span class="label-v3">Mon espace</span>
          <h1 id="helloTitle">Bonjour élu·e,</h1>
          <p id="helloLead" class="dashboard-hero-copy">Chargement…</p>
        </section>

        <section class="dashboard-block">
          <div class="dashboard-block-head">
            <div>
              <h2>Que souhaitez-vous faire ?</h2>
            </div>
          </div>

          <div class="dashboard-action-grid">
            <a href="/diagnostic" class="dashboard-action-card" data-intent="comprendre">
              <span>Comprendre une situation</span>
            </a>
            <a href="/copilote" class="dashboard-action-card" data-intent="decision">
              <span>Prendre une décision</span>
            </a>
            <a href="/copilote" class="dashboard-action-card" data-intent="sensible">
              <span>Gérer une situation sensible</span>
            </a>
            <a href="/copilote" class="dashboard-action-card" data-intent="reponse">
              <span>Rédiger une réponse</span>
            </a>
          </div>

          <div class="dashboard-support-row">
            <span id="analyseurSupportBadge" class="dashboard-support-badge">Service abonné</span>
            <a id="dashboardAnalyseurLink" href="/offres" class="dashboard-support-link">Décrypter un document officiel</a>
          </div>
        </section>

        <section class="dashboard-block">
          <div class="dashboard-block-head">
            <div>
              <h2>Le Radar de MARYAN</h2>
              <p>Trois signaux utiles. Pas plus.</p>
            </div>
            <a href="/radar" class="btn-link">Voir le Radar complet →</a>
          </div>

          <div id="dashboardRadarList" class="dashboard-radar-list"></div>
        </section>

        <section class="dashboard-block">
          <div class="dashboard-block-head">
            <div>
              <h2>Vos sujets du moment</h2>
              <p id="topicsLead">Des points d’appui choisis à partir de votre diagnostic.</p>
            </div>
            <a href="/ressources" class="btn-link">Explorer les ressources →</a>
          </div>

          <div id="topicsGrid" class="dashboard-topics-grid"></div>
        </section>

        <section class="dashboard-block">
          <div class="dashboard-block-head">
            <div>
              <h2>Reprendre</h2>
            </div>
          </div>

          <div id="resumeCard" class="dashboard-resume-card card-v3"></div>
        </section>
      </div>
    </div>
  </main>

</BaseLayout>

<script>
  import { createClient } from '@supabase/supabase-js';
  import { getRecommendedResources, maryanResources } from '../data/resources';
  import { maryanRadarItems } from '../data/radar';
  import { buildStoredDiagnosticEntry } from '../lib/diagnostic-personalization';

  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL as string;
  const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY as string;

  const ANGLES_BY_PROFILE = {
    mandat_recent: ['compréhension', 'repères', 'décision'],
    arbitrage: ['compréhension', 'arbitrage', 'décision'],
    isolement: ['clarification', 'appuis', 'sécurisation'],
    surcharge: ['priorisation', 'sécurisation', 'décision'],
    exposition: ['vigilance', 'parole', 'sécurisation'],
    tension_relationnelle: ['relation', 'cadre', 'décision'],
    besoin_methode: ['compréhension', 'méthode', 'décision'],
    prise_de_parole: ['parole', 'vigilance', 'décision'],
    gouvernance: ['circuits', 'sécurisation', 'décision']
  } as const;

  const GENERIC_RESOURCES = [
    'qui-decide-quoi-dans-la-collectivite',
    'le-conseil-municipal-a-quoi-il-sert-vraiment',
    'prendre-la-parole-en-conseil',
    'comment-se-prend-une-decision-dans-une-commune'
  ];

  function escapeHtml(value: unknown): string {
    return String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');
  }

  function formatShortDate(iso: string): string {
    try {
      return new Date(iso).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' });
    } catch {
      return '';
    }
  }

  function sessionLabel(type: string): string {
    const labels: Record<string, string> = {
      copilote: 'Copilote',
      cr_reunion: 'Compte rendu',
      analyse: 'Analyse'
    };
    return labels[type] || 'Session';
  }

  function sessionHref(session: { id: string; session_type: string }): string {
    if (session.session_type === 'analyse') return '/analyseur';
    return `/copilote?session_id=${session.id}`;
  }

  if (!SUPABASE_URL || !SUPABASE_KEY) {
    window.location.href = '/login';
  } else {
    const supabase = createClient(SUPABASE_URL, SUPABASE_KEY);

    if (window.location.search.includes('session_id')) {
      const paymentBanner = document.getElementById('paymentBanner');
      if (paymentBanner) paymentBanner.style.display = 'block';
      window.history.replaceState({}, '', '/mon-compte');
    }

    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      window.location.href = '/login';
    } else {
      const user = session.user;
      const token = session.access_token;

      const { data: profile } = await supabase
        .from('profiles')
        .select('first_name, commune, role, diagnostic_key, diagnostic_label, plan')
        .eq('id', user.id)
        .single();

      const firstName = profile?.first_name || '';
      const role = profile?.role || 'élu·e local·e';
      const commune = profile?.commune || '';
      const plan = profile?.plan || 'gratuit';
      const isSubscriber = plan === 'plus' || plan === 'admin';

      document.getElementById('profileName')!.textContent = firstName || user.email?.split('@')[0] || 'Mon compte';
      document.getElementById('profileMeta')!.textContent = [role, commune].filter(Boolean).join(' — ');
      document.getElementById('userEmail')!.textContent = user.email || '';
      document.getElementById('planVal')!.textContent = plan === 'plus' ? 'MARYAN Plus' : plan === 'admin' ? 'Admin' : 'Découverte';

      let localDiagnosticRaw = {} as Record<string, any>;
      try {
        const raw = localStorage.getItem('maryan_v4_diag');
        if (raw) localDiagnosticRaw = JSON.parse(raw);
      } catch {
        // noop
      }

      const diagnosticState = buildStoredDiagnosticEntry({
        ...localDiagnosticRaw,
        diagnostic_key: profile?.diagnostic_key || localDiagnosticRaw?.diagnostic_key,
        diagnostic_label: profile?.diagnostic_label || localDiagnosticRaw?.diagnostic_label
      }, maryanResources);

      try {
        if (diagnosticState.diagnostic_key || diagnosticState.profile || diagnosticState.recommended_slugs?.length) {
          localStorage.setItem('maryan_v4_diag', JSON.stringify(diagnosticState));
        }
      } catch {
        // noop
      }

      const helloTitle = document.getElementById('helloTitle');
      if (helloTitle) {
        helloTitle.textContent = firstName ? `Bonjour ${firstName},` : 'Bonjour,';
      }

      const profileAngles = diagnosticState.profile
        ? ANGLES_BY_PROFILE[diagnosticState.profile as keyof typeof ANGLES_BY_PROFILE]
        : null;

      const angles = profileAngles
        ? profileAngles
        : ['compréhension', 'sécurisation', 'décision'];

      const helloLead = document.getElementById('helloLead');
      if (helloLead) {
        const roleSentence = [role, commune ? `à ${commune}` : 'dans votre collectivité'].join(' ');
        helloLead.textContent = `Vous êtes ${roleSentence}. MARYAN privilégie aujourd’hui : ${angles.join(', ')}.`;
      }

      const sidebarAnalyseurLink = document.getElementById('sidebarAnalyseurLink') as HTMLAnchorElement;
      const dashboardAnalyseurLink = document.getElementById('dashboardAnalyseurLink') as HTMLAnchorElement;
      const analyseurSupportBadge = document.getElementById('analyseurSupportBadge');

      if (isSubscriber) {
        sidebarAnalyseurLink.href = '/analyseur';
        dashboardAnalyseurLink.href = '/analyseur';
        analyseurSupportBadge!.textContent = 'Inclus dans votre abonnement';
      } else {
        sidebarAnalyseurLink.href = '/offres';
        dashboardAnalyseurLink.href = '/offres';
        sidebarAnalyseurLink.textContent = 'Décrypter un document (Plus)';
        analyseurSupportBadge!.textContent = 'Réservé aux abonné·es';
        analyseurSupportBadge?.classList.add('dashboard-support-badge--locked');
      }

      const radarList = document.getElementById('dashboardRadarList');
      if (radarList) {
        const radarItems = [...maryanRadarItems]
          .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
          .slice(0, 3);

        radarList.innerHTML = radarItems.map((item) => `
          <article class="dashboard-radar-card">
            <div class="dashboard-radar-top">
              <span class="dashboard-radar-badge">${escapeHtml(item.type)}</span>
              <span class="dashboard-radar-date">${escapeHtml(formatShortDate(item.date))}</span>
            </div>
            <h3>${escapeHtml(item.title)}</h3>
            <p><strong>Impact</strong> ${escapeHtml(item.summary.whyImportant)}</p>
            <p><strong>Implication</strong> ${escapeHtml(item.summary.whatChanges)}</p>
          </article>
        `).join('');
      }

      const topicsGrid = document.getElementById('topicsGrid');
      const topicsLead = document.getElementById('topicsLead');
      if (topicsGrid) {
        let resources = diagnosticState.profile
          ? getRecommendedResources(maryanResources, diagnosticState.profile).slice(0, 5)
          : [];

        if (!resources.length && diagnosticState.recommended_slugs?.length) {
          resources = diagnosticState.recommended_slugs
            .slice(0, 5)
            .map((slug: string) => maryanResources.find((resource) => resource.slug === slug))
            .filter(Boolean);
        }

        if (!resources.length) {
          resources = GENERIC_RESOURCES
            .map((slug) => maryanResources.find((resource) => resource.slug === slug))
            .filter(Boolean);
        }

        if (topicsLead && !diagnosticState.profile) {
          topicsLead.textContent = 'Des points d’appui sobres pour avancer tout de suite.';
        }

        topicsGrid.innerHTML = resources.map((resource) => `
          <a href="/ressources/${escapeHtml(resource.slug)}" class="dashboard-topic-card">
            <span>${escapeHtml(resource.title)}</span>
          </a>
        `).join('');
      }

      const resumeCard = document.getElementById('resumeCard');
      if (resumeCard) {
        resumeCard.innerHTML = `
          <div class="dashboard-resume-empty">
            <p class="dashboard-resume-label">Point d’entrée</p>
            <h3>Commencer par le diagnostic</h3>
            <p>En quelques minutes, vous obtenez une première direction claire.</p>
            <a href="/diagnostic" class="btn-primary-v3">Faire le diagnostic</a>
          </div>
        `;
      }

      try {
        const response = await fetch('/api/sessions', {
          headers: { Authorization: `Bearer ${token}` }
        });

        if (response.ok) {
          const { sessions } = await response.json();
          const latestSession = Array.isArray(sessions) ? sessions[0] : null;

          if (latestSession && resumeCard) {
            resumeCard.innerHTML = `
              <div class="dashboard-resume-live">
                <p class="dashboard-resume-label">${escapeHtml(sessionLabel(latestSession.session_type))}</p>
                <h3>${escapeHtml(latestSession.titre || 'Reprendre votre dernière action')}</h3>
                <p>Dernière mise à jour : ${escapeHtml(formatShortDate(latestSession.updated_at))}</p>
                <a href="${escapeHtml(sessionHref(latestSession))}" class="btn-primary-v3">Reprendre</a>
              </div>
            `;
          }
        }
      } catch {
        // noop
      }

      document.querySelectorAll('[data-intent]').forEach((link) => {
        link.addEventListener('click', () => {
          const intent = link.getAttribute('data-intent');
          if (intent) localStorage.setItem('maryan_copilot_intent', intent);
        });
      });

      document.getElementById('logoutBtn')?.addEventListener('click', async () => {
        await supabase.auth.signOut();
        window.location.href = '/login';
      });

      document.getElementById('exportDataBtn')?.addEventListener('click', async () => {
        try {
          const response = await fetch('/api/export-data', {
            headers: { Authorization: `Bearer ${token}` }
          });

          if (!response.ok) {
            alert("Erreur lors de l'export. Veuillez réessayer.");
            return;
          }

          const blob = await response.blob();
          const url = URL.createObjectURL(blob);
          const anchor = document.createElement('a');
          anchor.href = url;
          anchor.download = 'maryan-mes-donnees.json';
          document.body.appendChild(anchor);
          anchor.click();
          anchor.remove();
          URL.revokeObjectURL(url);
        } catch {
          alert("Erreur lors de l'export. Veuillez réessayer.");
        }
      });
    }
  }
</script>

<style>
  .dashboard-page {
    background: var(--bg);
    min-height: 100vh;
    padding: 3rem 0 5rem;
  }

  .dashboard-layout {
    display: grid;
    grid-template-columns: minmax(0, 320px) minmax(0, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .dashboard-sidebar {
    position: sticky;
    top: 1.5rem;
  }

  .dashboard-account {
    padding: 1.5rem;
    border-radius: 24px;
  }

  .dashboard-account:hover,
  .dashboard-hero:hover,
  .dashboard-resume-card:hover {
    transform: none;
    box-shadow: none;
    border-color: var(--border);
  }

  .dashboard-account h2 {
    font-size: 1.35rem;
    color: var(--deep);
    margin-bottom: 0.35rem;
  }

  .dashboard-account-meta {
    margin: 0;
    color: #45545F;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .dashboard-account-stats {
    display: grid;
    gap: 0.85rem;
    margin: 1.4rem 0;
  }

  .dashboard-account-stat {
    display: grid;
    gap: 0.2rem;
  }

  .dashboard-account-stat span,
  .dashboard-resume-label {
    font-size: 0.74rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #55646F;
  }

  .dashboard-account-stat strong {
    color: var(--deep);
    font-size: 0.96rem;
    font-weight: 700;
    word-break: break-word;
  }

  .dashboard-account-actions {
    display: grid;
    gap: 0.75rem;
  }

  .dashboard-account-actions .btn-secondary-v3 {
    width: 100%;
    justify-content: center;
    text-align: center;
  }

  .dashboard-logout-btn {
    border: none;
    background: transparent;
    padding: 0.2rem 0;
    color: var(--accent-red);
    font-size: 0.92rem;
    font-weight: 800;
    font-family: inherit;
    cursor: pointer;
    text-align: left;
  }

  .dashboard-main {
    display: grid;
    gap: 1.25rem;
  }

  .dashboard-banner {
    background: #F0FFF4;
    border: 1px solid #B7E4C7;
    border-radius: 18px;
    padding: 1rem 1.2rem;
  }

  .dashboard-banner strong {
    display: block;
    color: #1F5F3E;
    margin-bottom: 0.2rem;
  }

  .dashboard-banner p {
    margin: 0;
    color: #2C5D46;
    font-size: 0.92rem;
  }

  .dashboard-hero,
  .dashboard-block,
  .dashboard-resume-card {
    border-radius: 24px;
  }

  .dashboard-hero {
    padding: 1.5rem;
  }

  .dashboard-hero h1 {
    font-size: clamp(2rem, 5vw, 2.8rem);
    color: var(--deep);
    margin-bottom: 0.5rem;
  }

  .dashboard-hero-copy {
    margin: 0;
    color: #41505B;
    font-size: 1rem;
    line-height: 1.6;
    max-width: 48rem;
  }

  .dashboard-block {
    background: white;
    border: 1px solid var(--border);
    padding: 1.5rem;
  }

  .dashboard-block-head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .dashboard-block-head h2 {
    font-size: 1.45rem;
    color: var(--deep);
    margin-bottom: 0.2rem;
  }

  .dashboard-block-head p {
    margin: 0;
    color: #52616B;
    font-size: 0.95rem;
  }

  .dashboard-action-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .dashboard-action-card {
    display: flex;
    align-items: center;
    min-height: 84px;
    border-radius: 18px;
    border: 1px solid var(--border);
    background: #FCFCFB;
    padding: 1rem 1.1rem;
    color: var(--deep);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 800;
    line-height: 1.35;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .dashboard-action-card:hover,
  .dashboard-action-card:focus-visible {
    border-color: var(--deep);
    outline: none;
    transform: translateY(-1px);
  }

  .dashboard-support-row {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .dashboard-support-badge {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    background: rgba(173,255,47,0.16);
    color: var(--deep);
    font-size: 0.76rem;
    font-weight: 800;
  }

  .dashboard-support-badge--locked {
    background: rgba(230,57,70,0.12);
    color: var(--accent-red);
  }

  .dashboard-support-link {
    color: var(--accent-red);
    font-weight: 800;
    text-decoration: none;
    border-bottom: 1px solid rgba(230,57,70,0.25);
  }

  .dashboard-support-link:hover,
  .dashboard-support-link:focus-visible {
    border-bottom-color: var(--accent-red);
    outline: none;
  }

  .dashboard-logout-btn:focus-visible,
  .dashboard-account-actions .btn-secondary-v3:focus-visible {
    outline: 2px solid var(--accent-red);
    outline-offset: 2px;
  }

  .dashboard-radar-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .dashboard-radar-card {
    border-radius: 18px;
    border: 1px solid var(--border);
    background: #FCFCFB;
    padding: 1rem;
  }

  .dashboard-radar-top {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .dashboard-radar-badge {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.3rem 0.65rem;
    background: var(--deep);
    color: white;
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .dashboard-radar-date {
    color: #596874;
    font-size: 0.8rem;
    font-weight: 700;
  }

  .dashboard-radar-card h3 {
    color: var(--deep);
    font-size: 1rem;
    line-height: 1.3;
    margin-bottom: 0.7rem;
  }

  .dashboard-radar-card p {
    margin: 0;
    color: #42515C;
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .dashboard-radar-card p + p {
    margin-top: 0.5rem;
  }

  .dashboard-topics-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .dashboard-topic-card {
    display: flex;
    align-items: center;
    min-height: 72px;
    border-radius: 18px;
    border: 1px solid var(--border);
    background: #FCFCFB;
    padding: 0.95rem 1rem;
    color: var(--deep);
    text-decoration: none;
    font-size: 0.96rem;
    font-weight: 700;
    line-height: 1.45;
  }

  .dashboard-topic-card:hover,
  .dashboard-topic-card:focus-visible {
    border-color: var(--border-neon);
    outline: none;
  }

  .dashboard-resume-card {
    padding: 1.5rem;
  }

  .dashboard-resume-live h3,
  .dashboard-resume-empty h3 {
    color: var(--deep);
    font-size: 1.2rem;
    margin-bottom: 0.4rem;
  }

  .dashboard-resume-live p,
  .dashboard-resume-empty p {
    margin: 0 0 1rem;
    color: #45545F;
    font-size: 0.95rem;
    line-height: 1.55;
  }

  @media (max-width: 1080px) {
    .dashboard-layout {
      grid-template-columns: 1fr;
    }

    .dashboard-sidebar {
      position: static;
    }

    .dashboard-radar-list {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .dashboard-page {
      padding: 2rem 0 4rem;
    }

    .dashboard-account,
    .dashboard-hero,
    .dashboard-block,
    .dashboard-resume-card {
      padding: 1.2rem;
      border-radius: 20px;
    }

    .dashboard-action-grid,
    .dashboard-topics-grid {
      grid-template-columns: 1fr;
    }

    .dashboard-action-card,
    .dashboard-topic-card {
      min-height: auto;
    }
  }

  @media print {
    .dashboard-sidebar,
    .dashboard-support-row,
    .btn-link {
      display: none !important;
    }

    .dashboard-layout {
      grid-template-columns: 1fr;
    }

    .dashboard-page {
      background: white;
      padding: 0;
    }
  }
</style>
