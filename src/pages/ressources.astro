---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import InternalHeader from '../components/InternalHeader.astro';

const allRessources = await getCollection('ressources');
const sortedRessources = allRessources.sort((a, b) => b.data.publishDate - a.data.publishDate);

const categories = [
  { id: 'all', label: 'Toutes' },
  { id: 'tension', label: 'Tensions' },
  { id: 'parole', label: 'Prise de parole' },
  { id: 'recul', label: 'Prendre du recul' },
  { id: 'juridique', label: 'Juridique' },
];
---

<BaseLayout 
  title="Bibliothèque — MARYAN" 
  description="Fiches pratiques, trames, repères simples et contenus pédagogiques pour accompagner les élu·es locaux.">
  
  <InternalHeader 
    label="Ressources"
    title="Des ressources utiles, <span class='emphasis'>classées par situation</span>"
    subtitle="Fiches pratiques, trames et repères simples pour avancer sans se perdre dans la complexité du mandat."
  />

  <main class="ressources-v3">
    
    <section class="section-v3 bg-light">
      <div class="container">
        <!-- Filters (Static for now, but styled) -->
        <div class="filters-v3">
          {categories.map(cat => (
            <button class={`filter-btn ${cat.id === 'all' ? 'active' : ''}`} data-category={cat.id}>
              {cat.label}
            </button>
          ))}
        </div>

        <div class="ressources-grid-v3" id="ressourcesGrid">
          {sortedRessources.map(res => (
            <a href={`/ressources/${res.slug}`} class="res-card-v3 card-v3" data-category={res.data.category}>
              <div class="res-content">
                <span class={`res-badge ${res.data.category}`}>
                  {res.data.kicker}
                </span>
                <h3 class="res-title">{res.data.title}</h3>
                <p class="res-desc">{res.data.description}</p>
              </div>
              <div class="res-footer">
                <span class="read-more">Lire la fiche <span>→</span></span>
                {res.data.isPremium && <span class="premium-tag">Plus</span>}
              </div>
            </a>
          ))}
        </div>

        {sortedRessources.length === 0 && (
          <div class="empty-state">
            <p>La bibliothèque est en cours de remplissage. Revenez très bientôt !</p>
          </div>
        )}
      </div>
    </section>

    <!-- HUB PROMOTE -->
    <section class="section-v3 bg-deep text-white">
      <div class="container container-narrow text-center relative-z">
        <span class="label-v3">Besoin d'aller plus loin ?</span>
        <h2 class="text-white">Certaines situations demandent <br/> un <span class="emphasis text-neon">appui humain.</span></h2>
        <p class="intro-v3 text-white opacity-80" style="margin-bottom: 3rem;">
          Nos experts (stratèges, juristes, communicants) vous répondent sur notre hub dédié.
        </p>
        <a href="/hub-experts" class="btn-primary-v3 big">Accéder au Hub Experts</a>
      </div>
    </section>

  </main>

</BaseLayout>

<style>
  .ressources-v3 { padding-bottom: 6rem; }
  
  .filters-v3 { display: flex; gap: 1rem; margin-bottom: 4rem; flex-wrap: wrap; justify-content: center; }
  .filter-btn { 
    padding: 0.75rem 1.5rem; border-radius: 99px; border: 1.5px solid var(--border); 
    background: white; color: var(--deep); font-weight: 700; font-size: 0.85rem; cursor: pointer;
    transition: all 0.2s;
  }
  .filter-btn:hover { border-color: var(--accent-red); color: var(--accent-red); }
  .filter-btn.active { background: var(--deep); color: white; border-color: var(--deep); }

  .ressources-grid-v3 { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2.5rem; }
  
  .res-card-v3 { 
    display: flex; flex-direction: column; text-decoration: none; 
    border: 1.5px solid var(--border); transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .res-card-v3:hover { transform: translateY(-8px); border-color: var(--accent-red); box-shadow: 0 15px 40px rgba(0,0,0,0.06); }
  
  .res-badge { 
    font-size: 0.65rem; font-weight: 800; text-transform: uppercase; 
    letter-spacing: 0.1em; display: inline-block; padding: 0.4rem 0.8rem; 
    border-radius: 4px; border: 1px solid var(--border); margin-bottom: 1.5rem;
  }
  .res-badge.tension { border-color: #FEE2E2; color: #B91C1C; background: #FEF2F2; }
  .res-badge.parole { border-color: #DBEAFE; color: #1D4ED8; background: #EFF6FF; }
  .res-badge.recul { border-color: #F3F4F6; color: #374151; background: #F9FAFB; }
  
  .res-title { font-size: 1.5rem; margin-bottom: 1rem; color: var(--deep); line-height: 1.3; }
  .res-desc { font-size: 0.95rem; color: #54636C; line-height: 1.6; margin-bottom: 2rem; }
  
  .res-footer { margin-top: auto; display: flex; justify-content: space-between; align-items: center; padding-top: 1.5rem; border-top: 1px dashed var(--border); }
  .read-more { font-weight: 800; font-size: 0.85rem; color: var(--deep); display: flex; align-items: center; gap: 0.5rem; }
  .read-more span { transition: transform 0.2s; }
  .res-card-v3:hover .read-more span { transform: translateX(5px); }
  
  .premium-tag { font-size: 0.65rem; font-weight: 900; background: var(--accent-red); color: white; padding: 0.2rem 0.6rem; border-radius: 4px; text-transform: uppercase; }

  @media (max-width: 768px) {
    .ressources-grid-v3 { grid-template-columns: 1fr; }
    .filters-v3 { justify-content: flex-start; }
  }
</style>
