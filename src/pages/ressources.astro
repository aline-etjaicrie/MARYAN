---
import BaseLayout from '../layouts/BaseLayout.astro';
import InternalHeader from '../components/InternalHeader.astro';
import { maryanResources } from '../data/resources';

const pillars = [
  { id: 'se_situer', label: 'Se Situer', icon: '📍', description: 'Repérer sa place et son rôle réel dans le mandat.' },
  { id: 'comprendre', label: 'Comprendre', icon: '🧠', description: 'Décrypter les circuits de décision et les enjeux locaux.' },
  { id: 'agir', label: 'Agir', icon: '⚡', description: 'Trancher, porter des projets et piloter avec méthode.' },
  { id: 'se_proteger', label: 'Se Protéger', icon: '🛡️', description: 'Sécuriser sa pratique, sa parole et son endurance.' }
];

const getResourcesByPillar = (pillarId: string) => 
  maryanResources.filter(r => r.pillar === pillarId);

---

<BaseLayout 
  title="La Bibliothèque — MARYAN" 
  description="Accédez au savoir-faire MARYAN : fiches pratiques, trames et repères pour tenir votre mandat avec clarté.">
  
  <div class="res-hero-bg">
    <div class="container relative-z header-white-force">
      <InternalHeader 
        label="La Bibliothèque"
        title="Des ressources utiles,<br/><span class='emphasis text-neon'>classées par piliers</span>"
        subtitle="Plus de 20 fiches pratiques, trames et repères simples pour ne plus jamais décider seul·e face à l'incertitude du mandat."
      />
    </div>
    <div class="hero-glow glow-red"></div>
    <div class="hero-glow glow-green"></div>
  </div>

  <main class="ressources-lux">
    
    <!-- PERSONALIZATION SECTION (CLIENT-SIDE) -->
    <section id="personalizedSection" class="section-v3 hidden">
      <div class="container">
        <div class="personalized-banner card-v3">
          <div class="banner-badge">Recommandé pour vous</div>
          <h2 class="section-title-v4">Selon votre dernier diagnostic</h2>
          <div id="recommendedGrid" class="res-grid-small">
            <!-- Filled by JS -->
          </div>
        </div>
      </div>
    </section>

    <!-- PILLARS SECTIONS -->
    {pillars.map(pillar => (
      <section class="section-v3" id={pillar.id}>
        <div class="container">
          <header class="pillar-header">
            <div class="pillar-icon-box">{pillar.icon}</div>
            <div class="pillar-info">
              <span class="label-v3">Pilier {pillar.label}</span>
              <h2 class="pillar-title">{pillar.label}</h2>
              <p class="pillar-desc">{pillar.description}</p>
            </div>
          </header>

          <div class="res-grid">
            {getResourcesByPillar(pillar.id).map(res => (
              <a href={`/ressources/${res.slug}`} class="res-lux-card card-v3">
                <div class="card-inner">
                  <header class="card-top">
                    <span class={`format-tag ${res.format}`}>{res.format}</span>
                    {res.priority === 'haute' && <span class="priority-dot" title="Priorité haute"></span>}
                  </header>
                  <h3 class="card-title">{res.title}</h3>
                  <p class="card-promise">{res.promise}</p>
                  
                  <footer class="card-meta">
                    <div class="roles-tags">
                      {res.targetRoles.slice(0, 2).map(role => <span class="role-mini">{role}</span>)}
                      {res.targetRoles.length > 2 && <span class="role-more">+{res.targetRoles.length - 2}</span>}
                    </div>
                    <div class="arrow-circle">→</div>
                  </footer>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    ))}

    <!-- FINAL CTA -->
    <section class="section-v3">
      <div class="container">
        <div class="app-cta-banner card-v3">
           <div class="banner-content">
             <span class="label-v3">Copilote MARYAN</span>
             <h3>Passez en mode <span class="emphasis">opérationnel.</span></h3>
             <p>Le Copilote utilise toute notre bibliothèque pour vous répondre en direct sur votre situation spécifique.</p>
             <a href="/copilote" class="btn-primary-v3">Ouvrir le copilote</a>
           </div>
           <div class="banner-visual">
             <div class="pwa-mockup">
               <div class="mock-header"></div>
               <div class="mock-body">
                 <span class="mock-line" style="width: 80%;"></span>
                 <span class="mock-line" style="width: 60%;"></span>
                 <span class="mock-line" style="width: 70%;"></span>
               </div>
             </div>
           </div>
        </div>
      </div>
    </section>

  </main>

  <script is:inline define:vars={{ maryanResources }}>
    // Personalization logic based on diagnosticProfile
    function getRecommendedResources(resources, profile, limit = 3) {
      return resources
        .filter((r) => r.diagnosticProfiles.includes(profile))
        .sort((a, b) => {
          if (a.priority === "haute" && b.priority !== "haute") return -1;
          if (a.priority !== "haute" && b.priority === "haute") return 1;
          return 0;
        })
        .slice(0, limit);
    }

    const diag = JSON.parse(localStorage.getItem('maryan_v4_diag') || '{}');
    // Map tension/vigilance to profiles if needed, or use directly if saved that way
    // For now, let's assume if they have a diagnosis, we can pick a profile
    let profile = diag.tension || diag.vigilance; 
    
    // Fallback mapping if keys don't match exactly
    const mapping = {
      'flou': 'besoin_methode',
      'conflit': 'tension_relationnelle',
      'exposition': 'exposition',
      'sollicitations': 'surcharge',
      'seul': 'isolement'
    };
    if (mapping[profile]) profile = mapping[profile];

    if (profile) {
      const recs = getRecommendedResources(maryanResources, profile);
      if (recs.length > 0) {
        const section = document.getElementById('personalizedSection');
        const grid = document.getElementById('recommendedGrid');
        
        grid.innerHTML = recs.map(res => `
          <a href="/ressources/${res.slug}" class="rec-card">
            <div class="rec-icon">⚡</div>
            <div class="rec-info">
              <h4>${res.title}</h4>
              <p>${res.promise}</p>
            </div>
          </a>
        `).join('');
        
        section.classList.remove('hidden');
      }
    }
  </script>

</BaseLayout>

<style>
  :root {
    --deep: #0A192F;
    --neon: #ADFF2F;
    --red: #E63946;
    --bg: #F8F9FA;
    --border: rgba(10, 25, 47, 0.08);
  }

  .hidden { display: none !important; }

  /* ─── HERO ─── */
  .res-hero-bg { background: var(--deep); color: white; padding-bottom: 6rem; position: relative; overflow: hidden; }
  .header-white-force :global(h1), 
  .header-white-force :global(p), 
  .header-white-force :global(.internal-label),
  .header-white-force :global(.back-link) { color: white !important; }
  .header-white-force :global(.emphasis) { color: var(--neon) !important; }
  
  .hero-glow { position: absolute; width: 40vw; height: 40vw; filter: blur(100px); opacity: 0.1; z-index: 1; pointer-events: none; }
  .glow-red { top: -10%; left: -10%; background: var(--red); }
  .glow-green { bottom: -10%; right: -10%; background: var(--neon); }
  .relative-z { position: relative; z-index: 5; }

  /* ─── PILLAR HEADER ─── */
  .pillar-header { display: flex; gap: 2rem; align-items: flex-start; margin-bottom: 4rem; max-width: 800px; }
  .pillar-icon-box { width: 64px; height: 64px; background: white; border: 1px solid var(--border); border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 2rem; box-shadow: 0 10px 20px rgba(0,0,0,0.03); }
  .pillar-title { font-size: 2.2rem; margin: 0.5rem 0; letter-spacing: -0.02em; }
  .pillar-desc { font-size: 1.1rem; opacity: 0.6; line-height: 1.5; }

  /* ─── GRID & CARDS ─── */
  .res-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2rem; }
  .res-lux-card { 
    text-decoration: none; padding: 2.5rem; background: white; 
    border: 1px solid var(--border); border-radius: 28px;
    transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
    height: 100%; display: flex; flex-direction: column;
  }
  .res-lux-card:hover { transform: translateY(-8px); border-color: var(--red); box-shadow: 0 20px 40px rgba(10, 25, 47, 0.05); }
  
  .card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
  .format-tag { font-size: 0.65rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: var(--red); background: rgba(230, 57, 70, 0.05); padding: 0.4rem 0.8rem; border-radius: 6px; }
  .priority-dot { width: 8px; height: 8px; background: var(--red); border-radius: 50%; }

  .card-title { font-size: 1.4rem; color: var(--deep); margin-bottom: 1rem; line-height: 1.2; font-weight: 800; }
  .card-promise { font-size: 0.95rem; line-height: 1.5; color: #54636C; margin-bottom: 2rem; }
  
  .card-meta { margin-top: auto; display: flex; justify-content: space-between; align-items: center; padding-top: 1.5rem; border-top: 1px solid var(--border); }
  .roles-tags { display: flex; gap: 0.5rem; align-items: center; }
  .role-mini { font-size: 0.65rem; font-weight: 700; color: #99A1A7; text-transform: uppercase; background: #F1F3F5; padding: 0.2rem 0.5rem; border-radius: 4px; }
  .role-more { font-size: 0.65rem; font-weight: 800; color: var(--deep); opacity: 0.4; }
  
  .arrow-circle { width: 36px; height: 36px; border-radius: 50%; background: var(--bg); display: flex; align-items: center; justify-content: center; color: var(--deep); font-weight: 900; transition: all 0.3s; }
  .res-lux-card:hover .arrow-circle { background: var(--red); color: white; transform: rotate(-45deg); }

  /* ─── PERSONALIZATION ─── */
  .personalized-banner { background: var(--deep); color: white; padding: 3rem; border-radius: 32px; border: none; overflow: hidden; position: relative; }
  .personalized-banner .section-title-v4 { color: white; margin-bottom: 2rem; }
  .banner-badge { position: absolute; top: 2rem; right: 2rem; background: var(--neon); color: var(--deep); font-size: 0.7rem; font-weight: 800; padding: 0.5rem 1rem; border-radius: 99px; text-transform: uppercase; }
  
  .res-grid-small { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }
  .rec-card { display: flex; gap: 1.2rem; background: rgba(255,255,255,0.05); padding: 1.5rem; border-radius: 20px; text-decoration: none; color: white; border: 1px solid rgba(255,255,255,0.1); transition: all 0.2s; }
  .rec-card:hover { background: rgba(255,255,255,0.1); transform: scale(1.02); }
  .rec-icon { font-size: 1.5rem; }
  .rec-info h4 { font-size: 1.1rem; margin-bottom: 0.4rem; color: var(--neon); }
  .rec-info p { font-size: 0.85rem; opacity: 0.7; line-height: 1.4; }

  /* ─── BANNER CTA ─── */
  .app-cta-banner { 
    background: var(--deep); color: white; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; padding: 5rem;
    align-items: center; overflow: hidden; border: none;
  }
  .banner-content h3 { font-size: 2.5rem; margin: 1.5rem 0; color: white; }
  .banner-content p { font-size: 1.15rem; opacity: 0.7; margin-bottom: 3rem; }
  
  .pwa-mockup { 
    background: rgba(255,255,255,0.03); border: 2px solid rgba(255,255,255,0.1); width: 220px; height: 400px;
    border-radius: 40px; margin: 0 auto; transform: rotate(8deg) translateY(40px);
    display: flex; flex-direction: column; padding: 1rem;
  }
  .mock-header { height: 40px; border-bottom: 1px solid rgba(255,255,255,0.05); margin-bottom: 2rem; }
  .mock-body { display: flex; flex-direction: column; gap: 1rem; padding: 0 1rem; }
  .mock-line { height: 8px; background: rgba(255,255,255,0.1); border-radius: 99px; }

  @media (max-width: 900px) {
    .res-grid { grid-template-columns: 1fr; }
    .pillar-header { flex-direction: column; gap: 1rem; }
    .app-cta-banner { grid-template-columns: 1fr; padding: 3rem; text-align: center; }
    .pwa-mockup { display: none; }
  }
</style>
