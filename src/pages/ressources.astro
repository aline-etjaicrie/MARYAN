---
import BaseLayout from '../layouts/BaseLayout.astro';
import InternalHeader from '../components/InternalHeader.astro';
import { maryanResources } from '../data/resources';
import { maryanPaths } from '../data/paths';

const pillars = [
  { id: 'se_situer', label: 'Se Situer', icon: '📍', description: 'Repérer sa place et son rôle réel dans le mandat.' },
  { id: 'comprendre', label: 'Comprendre', icon: '🧠', description: 'Décrypter les circuits de décision et les enjeux locaux.' },
  { id: 'agir', label: 'Agir', icon: '⚡', description: 'Trancher, porter des projets et piloter avec méthode.' },
  { id: 'se_proteger', label: 'Se Protéger', icon: '🛡️', description: 'Sécuriser sa pratique, sa parole et son endurance.' }
];

const getResourcesByPillar = (pillarId: string) => 
  maryanResources.filter(r => r.pillar === pillarId);

// All unique use cases for filtering
const allUseCases = [...new Set(maryanResources.flatMap(r => r.useCases))].sort();

---

<BaseLayout 
  title="La Bibliothèque — MARYAN" 
  description="Accédez au savoir-faire MARYAN : fiches pratiques, trames et repères pour tenir votre mandat avec clarté.">
  
  <div class="res-hero-bg">
    <div class="container relative-z header-white-force">
      <InternalHeader 
        label="La Bibliothèque"
        title="Des ressources utiles,<br/><span class='emphasis text-neon'>classées par piliers</span>"
        subtitle="Plus de 20 fiches pratiques, trames et repères simples pour ne plus jamais décider seul·e face à l'incertitude du mandat."
      />
    </div>
    <div class="hero-glow glow-red"></div>
    <div class="hero-glow glow-green"></div>
  </div>

  <main class="ressources-lux">
    
    <!-- 1. À COMMENCER PAR LÀ (PERSONALIZED RESOURCES) - DARK THEME -->
    <section id="personalizedResources" class="section-v3 hidden" style="background: var(--deep); color: white; padding: 6rem 0;">
      <div class="container">
        <header class="section-header-v4">
          <span class="label-v3" style="color: var(--neon);">Selon votre dernier diagnostic</span>
          <h2 class="section-title-standard" style="color: white;">À commencer par là</h2>
          <p class="section-subtitle-v4" style="color: white; opacity: 0.9;">Les 3 ressources prioritaires identifiées pour vous.</p>
        </header>
        <div id="recommendedGrid" class="rec-v4-grid">
          <!-- Filled by JS -->
        </div>
      </div>
    </section>

    <!-- 2. UN PARCOURS UTILE (PERSONALIZED PATH) -->
    <section id="personalizedPath" class="section-v3 hidden" style="background: white;">
      <div class="container">
        <div class="path-highlight-card card-v3">
          <div class="path-content">
            <span class="path-badge">Parcours conseillé</span>
            <h2 id="pathTitle" class="path-title-v4">—</h2>
            <p id="pathPromise" class="path-promise-v4">—</p>
            
            <div class="path-priorities-box">
              <h3>Vos 3 priorités dans ce parcours :</h3>
              <ul id="pathPrioritiesList" class="res-check-list-small"></ul>
            </div>

            <div class="path-resources-box">
              <h3>Fiches liées :</h3>
              <div id="pathResourcesGrid" class="path-mini-grid"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. EXPLORER PAR UNIVERS (PILLARS) -->
    <section class="section-v3">
      <div class="container">
        <header class="section-header-v4">
          <span class="label-v3">Univers</span>
          <h2 class="section-title-standard">Explorer par univers</h2>
        </header>

        <div class="pillar-nav-grid">
          {pillars.map(pillar => (
            <a href={`#${pillar.id}`} class="pillar-nav-card card-v3">
              <div class="pillar-nav-icon">{pillar.icon}</div>
              <div class="pillar-nav-info">
                <h3>{pillar.label}</h3>
                <p>{pillar.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- 4. PILLARS CONTENT -->
    {pillars.map(pillar => (
      <section class="section-v3" id={pillar.id} style="padding-top: 4rem;">
        <div class="container">
          <header class="pillar-header">
            <div class="pillar-icon-box">{pillar.icon}</div>
            <div class="pillar-info">
              <span class="label-v3">Pilier {pillar.label}</span>
              <h2 class="pillar-title">{pillar.label}</h2>
            </div>
          </header>

          <div class="res-grid">
            {getResourcesByPillar(pillar.id).map(res => (
              <a href={`/ressources/${res.slug}`} class="res-lux-card card-v3">
                <div class="card-inner">
                  <header class="card-top">
                    <span class={`format-tag ${res.format}`}>{res.format}</span>
                    {res.priority === 'haute' && <span class="priority-dot" title="Priorité haute"></span>}
                  </header>
                  <h3 class="card-title">{res.title}</h3>
                  <p class="card-promise">{res.promise}</p>
                  
                  <footer class="card-meta">
                    <div class="roles-tags">
                      {res.targetRoles.slice(0, 2).map(role => <span class="role-mini">{role}</span>)}
                    </div>
                    <div class="arrow-circle">→</div>
                  </footer>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    ))}

    <!-- 5. SITUATIONS FRÉQUENTES (USE CASES) -->
    <section class="section-v3" style="background: var(--bg);">
      <div class="container">
        <header class="section-header-v4">
          <span class="label-v3">Filtres</span>
          <h2 class="section-title-standard">Situations fréquentes</h2>
        </header>

        <div class="usecases-grid">
           {allUseCases.map(uc => {
             const count = maryanResources.filter(r => r.useCases.includes(uc)).length;
             return (
               <a href={`#`} class="uc-pill" onclick={`filterByUseCase('${uc}'); return false;`}>
                 <span class="uc-label">{uc.replace('_',' ')}</span>
                 <span class="uc-count">{count}</span>
               </a>
             );
           })}
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="section-v3">
      <div class="container">
        <div class="app-cta-banner card-v3">
           <div class="banner-content">
             <span class="label-v3">Copilote MARYAN</span>
             <h3>Passez en mode <span class="emphasis">opérationnel.</span></h3>
             <p>Le Copilote utilise toute notre bibliothèque pour vous répondre en direct sur votre situation spécifique.</p>
             <a href="/copilote" class="btn-primary-v3">Ouvrir le copilote</a>
           </div>
           <div class="banner-visual">
             <div class="pwa-mockup">
               <div class="mock-header"></div>
               <div class="mock-body">
                 <span class="mock-line" style="width: 80%;"></span>
                 <span class="mock-line" style="width: 60%;"></span>
                 <span class="mock-line" style="width: 70%;"></span>
               </div>
             </div>
           </div>
        </div>
      </div>
    </section>

  </main>

  <script is:inline define:vars={{ maryanResources, maryanPaths }}>
    // Personalization logic
    function getRecommendedResources(resources, profile, limit = 3) {
      return resources
        .filter((r) => r.diagnosticProfiles.includes(profile))
        .sort((a, b) => {
          if (a.priority === "haute" && b.priority !== "haute") return -1;
          if (a.priority !== "haute" && b.priority === "haute") return 1;
          return 0;
        })
        .slice(0, limit);
    }

    function getRecommendedPaths(paths, profile, limit = 1) {
      return paths
        .filter((p) => p.diagnosticProfiles.includes(profile))
        .slice(0, limit);
    }

    const diag = JSON.parse(localStorage.getItem('maryan_v4_diag') || '{}');
    let profile = diag.tension || diag.vigilance; 
    const mapping = {
      'flou': 'besoin_methode',
      'conflit': 'tension_relationnelle',
      'exposition': 'exposition',
      'sollicitations': 'surcharge',
      'seul': 'isolement'
    };
    if (mapping[profile]) profile = mapping[profile];

    if (profile) {
      // 1. Recommended Resources
      const recs = getRecommendedResources(maryanResources, profile);
      if (recs.length > 0) {
        document.getElementById('personalizedResources').classList.remove('hidden');
        document.getElementById('recommendedGrid').innerHTML = recs.map(res => `
           <a href="/ressources/${res.slug}" class="rec-lux-card-v4">
                <div class="rec-bolt">⚡</div>
                <div class="rec-content">
                  <h3 class="rec-title-v4">${res.title}</h3>
                  <p class="rec-promise-v4">${res.promise}</p>
                </div>
                <div class="rec-arrow">→</div>
              </a>
        `).join('');
      }

      // 2. Recommended Path
      const recPath = getRecommendedPaths(maryanPaths, profile)[0];
      if (recPath) {
        document.getElementById('personalizedPath').classList.remove('hidden');
        document.getElementById('pathTitle').innerText = recPath.title;
        document.getElementById('pathPromise').innerText = recPath.promise;
        document.getElementById('pathPrioritiesList').innerHTML = recPath.priorities.map(p => `
          <li><span class="check-icon-small">✓</span> ${p}</li>
        `).join('');
        
        const pathResources = recPath.resourceIds.map(id => maryanResources.find(r => r.id === id)).filter(Boolean);
        document.getElementById('pathResourcesGrid').innerHTML = pathResources.map(res => `
          <a href="/ressources/${res.slug}" class="path-mini-card">
            <span class="mini-format">${res.format}</span>
            <h4>${res.title}</h4>
          </a>
        `).join('');
      }
    }

    window.filterByUseCase = (uc) => {
       const firstPillar = maryanResources.find(r => r.useCases.includes(uc))?.pillar;
       if (firstPillar) {
          const el = document.getElementById(firstPillar);
          if (el) el.scrollIntoView({ behavior: 'smooth' });
       }
    };
  </script>

</BaseLayout>

<style>
  :root {
    --deep: #0A192F;
    --neon: #ADFF2F;
    --red: #E63946;
    --bg: #F8F9FA;
    --border: rgba(10, 25, 47, 0.08);
  }

  .hidden { display: none !important; }

  /* ─── HERO ─── */
  .res-hero-bg { background: var(--deep); color: white; padding-bottom: 6rem; position: relative; overflow: hidden; }
  .header-white-force :global(h1), 
  .header-white-force :global(p), 
  .header-white-force :global(.internal-label),
  .header-white-force :global(.back-link) { color: white !important; }
  
  .hero-glow { position: absolute; width: 40vw; height: 40vw; filter: blur(100px); opacity: 0.1; z-index: 1; pointer-events: none; }
  .glow-red { top: -10%; left: -10%; background: var(--red); }
  .glow-green { bottom: -10%; right: -10%; background: var(--neon); }
  .relative-z { position: relative; z-index: 5; }

  /* ─── SECTION HEADERS ─── */
  .section-header-v4 { text-align: left; margin-bottom: 3rem; }
  .section-title-standard { font-size: 2.2rem; font-weight: 800; margin: 0.5rem 0; letter-spacing: -0.02em; }
  .section-subtitle-v4 { opacity: 0.8; font-size: 1.1rem; }

  /* ─── REC CARDS V4 (DARK) ─── */
  .rec-v4-grid { display: grid; grid-template-columns: 1fr; gap: 1rem; }
  .rec-lux-card-v4 { 
    display: flex; gap: 2rem; align-items: center; 
    padding: 2.5rem; background: rgba(255,255,255,0.03); 
    border: 1px solid rgba(255,255,255,0.1); border-radius: 24px;
    text-decoration: none; color: white; transition: all 0.3s;
  }
  .rec-lux-card-v4:hover { background: rgba(255,255,255,0.07); border-color: var(--neon); transform: translateX(10px); }
  .rec-bolt { font-size: 1.5rem; color: var(--neon); }
  .rec-content { flex: 1; }
  .rec-title-v4 { font-size: 1.4rem; font-weight: 800; color: white; margin-bottom: 0.5rem; }
  .rec-promise-v4 { font-size: 1rem; color: white; opacity: 0.9; line-height: 1.4; }
  .rec-arrow { font-size: 1.5rem; opacity: 0.3; transition: all 0.3s; }
  .rec-lux-card-v4:hover .rec-arrow { opacity: 1; color: var(--neon); }

  /* ─── PILLAR NAV ─── */
  .pillar-nav-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }
  .pillar-nav-card { text-decoration: none; padding: 2rem; background: white; border: 1px solid var(--border); border-radius: 24px; transition: all 0.3s; display: flex; gap: 1.5rem; align-items: flex-start; }
  .pillar-nav-card:hover { transform: translateY(-5px); border-color: var(--neon); }
  .pillar-nav-icon { font-size: 1.5rem; background: var(--bg); width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .pillar-nav-info h3 { font-size: 1.1rem; margin-bottom: 0.4rem; }
  .pillar-nav-info p { font-size: 0.85rem; opacity: 0.6; line-height: 1.4; }

  /* ─── PILLAR CONTENT ─── */
  .pillar-header { display: flex; gap: 1.5rem; align-items: center; margin-bottom: 3rem; }
  .pillar-icon-box { width: 48px; height: 48px; background: white; border: 1px solid var(--border); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
  .pillar-title { font-size: 1.8rem; margin: 0; }

  /* ─── PATH CARD ─── */
  .path-highlight-card { background: var(--deep); color: #fff; padding: 4rem; border-radius: 40px; border: none; box-shadow: 0 30px 60px rgba(0,0,0,0.1); }
  .path-badge { background: var(--neon); color: var(--deep); font-size: 0.7rem; font-weight: 800; text-transform: uppercase; padding: 0.5rem 1rem; border-radius: 99px; display: inline-block; margin-bottom: 2rem; }
  .path-title-v4 { font-size: 2.8rem; font-weight: 900; margin-bottom: 1rem; color: #fff; letter-spacing: -0.02em; }
  .path-promise-v4 { font-size: 1.3rem; color: #fff; opacity: 0.95; margin-bottom: 3rem; max-width: 600px; line-height: 1.4; }
  
  .path-priorities-box h3, .path-resources-box h3 { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--neon); letter-spacing: 0.1em; margin-bottom: 1.5rem; }
  .res-check-list-small { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem; margin-bottom: 4rem; }
  .res-check-list-small li { display: flex; gap: 0.8rem; align-items: center; font-size: 1.1rem; font-weight: 600; color: #fff; }
  .check-icon-small { color: var(--neon); font-weight: 900; }

  .path-mini-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; }
  .path-mini-card { background: rgba(255,255,255,0.05); padding: 1.5rem; border-radius: 16px; text-decoration: none; color: white; border: 1px solid rgba(255,255,255,0.1); transition: all 0.2s; }
  .path-mini-card:hover { background: rgba(255,255,255,0.1); transform: translateY(-3px); }
  .mini-format { font-size: 0.6rem; text-transform: uppercase; opacity: 0.5; font-weight: 800; margin-bottom: 0.5rem; display: block; }
  .path-mini-card h4 { font-size: 1rem; line-height: 1.2; }

  /* ─── USE CASES ─── */
  .usecases-grid { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: flex-start; }
  .uc-pill { text-decoration: none; background: white; border: 1px solid var(--border); padding: 0.8rem 1.4rem; border-radius: 99px; display: flex; gap: 0.8rem; align-items: center; transition: all 0.2s; }
  .uc-pill:hover { border-color: var(--red); transform: translateY(-2px); }
  .uc-label { font-size: 0.9rem; font-weight: 700; color: var(--deep); text-transform: capitalize; }
  .uc-count { font-size: 0.7rem; background: var(--bg); color: #99A1A7; width: 20px; height: 20px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; }

  /* ─── REUSE GRID ─── */
  .res-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2rem; }
  .res-lux-card { text-decoration: none; padding: 2.5rem; background: white; border: 1px solid var(--border); border-radius: 28px; transition: all 0.4s; height: 100%; display: flex; flex-direction: column; }
  .res-lux-card:hover { transform: translateY(-8px); border-color: var(--red); box-shadow: 0 20px 40px rgba(10, 25, 47, 0.05); }
  .card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
  .format-tag { font-size: 0.65rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: var(--red); background: rgba(230, 57, 70, 0.05); padding: 0.4rem 0.8rem; border-radius: 6px; }
  .priority-dot { width: 8px; height: 8px; background: var(--red); border-radius: 50%; }
  .card-title { font-size: 1.4rem; color: var(--deep); margin-bottom: 1rem; line-height: 1.2; font-weight: 800; }
  .card-promise { font-size: 0.95rem; line-height: 1.5; color: #54636C; margin-bottom: 2rem; }
  .card-meta { margin-top: auto; display: flex; justify-content: space-between; align-items: center; padding-top: 1.5rem; border-top: 1px solid var(--border); }
  .arrow-circle { width: 36px; height: 36px; border-radius: 50%; background: var(--bg); display: flex; align-items: center; justify-content: center; color: var(--deep); font-weight: 900; transition: 0.3s; }

  /* ─── BANNER CTA ─── */
  .app-cta-banner { background: var(--deep); color: white; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; padding: 5rem; align-items: center; overflow: hidden; border: none; }
  .pwa-mockup { background: rgba(255,255,255,0.03); border: 2px solid rgba(255,255,255,0.1); width: 220px; height: 400px; border-radius: 40px; margin: 0 auto; transform: rotate(8deg) translateY(40px); display: flex; flex-direction: column; padding: 1rem; }
  .mock-header { height: 40px; border-bottom: 1px solid rgba(255,255,255,0.05); margin-bottom: 2rem; }
  .mock-body { display: flex; flex-direction: column; gap: 1rem; padding: 0 1rem; }
  .mock-line { height: 8px; background: rgba(255,255,255,0.1); border-radius: 99px; }

  @media (max-width: 900px) {
    .rec-lux-card-v4 { flex-direction: column; text-align: center; gap: 1rem; }
    .path-highlight-card { padding: 2.5rem 1.5rem; border-radius: 24px; }
    .path-title-v4 { font-size: 2rem; }
    .res-grid { grid-template-columns: 1fr; }
    .app-cta-banner { grid-template-columns: 1fr; padding: 3rem; text-align: center; }
    .pwa-mockup { display: none; }
  }
</style>
