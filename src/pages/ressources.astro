---
import BaseLayout from '../layouts/BaseLayout.astro';
import InternalHeader from '../components/InternalHeader.astro';
import { maryanResources } from '../data/resources';

const pillarLabels: Record<string, string> = {
  se_situer: 'Se repérer',
  comprendre: 'Comprendre',
  agir: 'Agir',
  se_proteger: 'Se protéger'
};

const formatLabels: Record<string, string> = {
  fiche: 'Fiche pratique',
  checklist: 'Checklist',
  guide: 'Guide',
  repere: 'Repere'
};

const pillars = ['all', 'se_situer', 'comprendre', 'agir', 'se_proteger'] as const;

function getTeaser(resource: typeof maryanResources[0]): string {
  if (resource.understand && resource.understand.length > 0) {
    const first = resource.understand[0];
    return first.length > 120 ? first.slice(0, 117) + '...' : first;
  }
  if (resource.intro) {
    return resource.intro.length > 120 ? resource.intro.slice(0, 117) + '...' : resource.intro;
  }
  return '';
}

const sortedResources = [...maryanResources].sort((a, b) => {
  if (a.priority === 'haute' && b.priority !== 'haute') return -1;
  if (a.priority !== 'haute' && b.priority === 'haute') return 1;
  return 0;
});

const copilotSuggestions = [
  'Aide-moi a preparer une prise de parole sensible',
  'Aide-moi a cadrer un arbitrage difficile',
  'Aide-moi a repondre a une tension locale',
  'Aide-moi a preparer mon premier conseil municipal'
];
---

<BaseLayout
  title="Ressources pour les elus — MARYAN"
  description="Des fiches pratiques, des reperes concrets et des methodes pour agir dans votre mandat. Explorez la bibliotheque MARYAN."
>
  <div class="res-hero-bg">
    <div class="container relative-z header-white-force">
      <InternalHeader
        label="Bibliotheque"
        title="Des reperes concrets <span class='emphasis text-neon'>pour votre mandat</span>"
        subtitle="Chaque fiche vous aide a comprendre une situation, eviter les pieges courants et savoir quoi faire concretement."
      />
    </div>
    <div class="hero-glow glow-red"></div>
    <div class="hero-glow glow-green"></div>
  </div>

  <main class="resources-main">

    <!-- ══ FILTRES PAR UNIVERS ══ -->
    <section class="filter-section">
      <div class="container">
        <div class="filter-bar">
          <span class="filter-bar-label">Filtrer par theme :</span>
          <div class="filter-pills" id="pillarFilter">
            <button type="button" class="filter-pill active" data-pillar="all">
              Tout voir <span class="pill-count">{sortedResources.length}</span>
            </button>
            {pillars.filter(p => p !== 'all').map((p) => {
              const count = sortedResources.filter(r => r.pillar === p).length;
              return (
                <button type="button" class="filter-pill" data-pillar={p}>
                  {pillarLabels[p]} <span class="pill-count">{count}</span>
                </button>
              );
            })}
          </div>
        </div>
      </div>
    </section>

    <!-- ══ GRILLE DE RESSOURCES ══ -->
    <section class="catalog-section">
      <div class="container">

        <p class="catalog-count" id="catalogCount">{sortedResources.length} ressources disponibles</p>

        <div class="res-grid" id="resourceGrid">
          {sortedResources.map((resource) => {
            const teaser = getTeaser(resource);
            return (
              <a
                href={`/ressources/${resource.slug}`}
                class="res-card"
                data-pillar={resource.pillar}
              >
                <div class="res-card-top">
                  <span class={`res-card-pillar pillar-${resource.pillar}`}>
                    {pillarLabels[resource.pillar] || resource.pillar}
                  </span>
                  <span class="res-card-format">
                    {formatLabels[resource.format] || resource.format}
                  </span>
                </div>

                <h3 class="res-card-title">{resource.title}</h3>
                <p class="res-card-promise">{resource.promise}</p>

                {teaser && (
                  <div class="res-card-teaser">
                    <span class="teaser-icon">💡</span>
                    <p>{teaser}</p>
                  </div>
                )}

                <div class="res-card-footer">
                  <span class="res-card-cta">Lire la fiche</span>
                  <span class="res-card-arrow">→</span>
                </div>
              </a>
            );
          })}
        </div>

        <div id="emptyState" class="empty-state" style="display:none;">
          <p>Aucune ressource dans cette categorie pour l'instant.</p>
          <button type="button" class="btn-secondary-v3" id="resetFiltersBtn">Tout voir</button>
        </div>

      </div>
    </section>

    <!-- ══ DIAGNOSTIC CTA ══ -->
    <section class="diagnostic-cta-section">
      <div class="container container-medium">
        <div class="diagnostic-cta-card">
          <div class="diagnostic-cta-content">
            <span class="label-v3">Personnalisation</span>
            <h2>Pas sure par ou commencer ?</h2>
            <p>Le diagnostic MARYAN identifie vos priorites en quelques minutes et vous recommande les fiches les plus utiles pour votre situation.</p>
          </div>
          <div class="diagnostic-cta-actions">
            <a href="/diagnostic" class="btn-primary-v3">Faire le diagnostic</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ COPILOTE CTA ══ -->
    <section class="copilot-dark-section">
      <div class="container container-medium">
        <div class="copilot-dark-inner">
          <div class="copilot-dark-header">
            <span class="copilot-dark-kicker">Le copilote MARYAN</span>
            <h2 class="copilot-dark-title">Vous avez une question precise ?</h2>
            <p class="copilot-dark-desc">
              Posez votre question directement au copilote. Il s'appuie sur toutes les fiches de la bibliotheque pour vous repondre.
            </p>
          </div>

          <div class="copilot-suggestions">
            {copilotSuggestions.map((prompt) => (
              <a href={`/copilote?q=${encodeURIComponent(prompt)}`} class="copilot-chip">
                {prompt}
              </a>
            ))}
          </div>

          <div class="copilot-actions">
            <a href="/copilote" class="copilot-dark-btn">Ouvrir le copilote →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ ALLER PLUS LOIN ══ -->
    <section class="section-v3 subtle-support-section">
      <div class="container container-medium">
        <div class="subtle-support-card">
          <div class="subtle-support-copy">
            <span class="label-v3">Aller plus loin</span>
            <h3>Besoin d'un autre niveau d'appui ?</h3>
            <p>Selon votre situation, MARYAN peut aussi vous orienter vers un accompagnement individuel, une offre pour votre collectivite ou un echange direct.</p>
          </div>

          <div class="subtle-support-actions">
            <a href="/offres" class="btn-secondary-v3">Voir les offres</a>
            <a href="/contact" class="btn-secondary-v3">Nous contacter</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- ══ FILTRAGE CÔTÉ CLIENT ══ -->
  <script is:inline>
    (function() {
      var activePillar = 'all';
      var pills = document.querySelectorAll('#pillarFilter .filter-pill');
      var cards = document.querySelectorAll('#resourceGrid .res-card');
      var countEl = document.getElementById('catalogCount');
      var emptyEl = document.getElementById('emptyState');
      var resetBtn = document.getElementById('resetFiltersBtn');

      function filterCards() {
        var visible = 0;
        cards.forEach(function(card) {
          var show = activePillar === 'all' || card.getAttribute('data-pillar') === activePillar;
          card.style.display = show ? '' : 'none';
          if (show) visible++;
        });

        if (countEl) {
          countEl.textContent = visible + ' ressource' + (visible > 1 ? 's' : '') + (activePillar === 'all' ? ' disponibles' : '');
        }
        if (emptyEl) {
          emptyEl.style.display = visible === 0 ? 'block' : 'none';
        }
      }

      pills.forEach(function(pill) {
        pill.addEventListener('click', function() {
          pills.forEach(function(p) { p.classList.remove('active'); });
          pill.classList.add('active');
          activePillar = pill.getAttribute('data-pillar') || 'all';
          filterCards();
        });
      });

      if (resetBtn) {
        resetBtn.addEventListener('click', function() {
          pills.forEach(function(p) { p.classList.remove('active'); });
          var allPill = document.querySelector('#pillarFilter [data-pillar="all"]');
          if (allPill) allPill.classList.add('active');
          activePillar = 'all';
          filterCards();
        });
      }
    })();
  </script>
</BaseLayout>

<style is:global>
  :root {
    --deep: #0a192f;
    --neon: #adff2f;
    --red: #e63946;
    --bg: #f8f9fa;
    --border: rgba(10, 25, 47, 0.08);
    --pillar-se_situer: #3B82F6;
    --pillar-comprendre: #8B5CF6;
    --pillar-agir: #10B981;
    --pillar-se_proteger: #E63946;
  }

  /* ── HERO ── */
  .res-hero-bg {
    background: var(--deep);
    color: white;
    padding-bottom: 4rem;
    position: relative;
    overflow: hidden;
  }

  .header-white-force :global(h1),
  .header-white-force :global(p),
  .header-white-force :global(.internal-label),
  .header-white-force :global(.back-link) {
    color: white !important;
  }

  .hero-glow {
    position: absolute;
    width: 40vw;
    height: 40vw;
    filter: blur(100px);
    opacity: 0.1;
    z-index: 1;
    pointer-events: none;
  }
  .glow-red { top: -10%; left: -10%; background: var(--red); }
  .glow-green { bottom: -10%; right: -10%; background: var(--neon); }
  .relative-z { position: relative; z-index: 5; }

  .resources-main {
    padding-bottom: 0;
  }

  /* ── FILTRE ── */
  .filter-section {
    background: white;
    border-bottom: 1px solid var(--border);
    padding: 1.25rem 0;
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .filter-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .filter-bar-label {
    font-size: 0.82rem;
    font-weight: 700;
    color: rgba(10, 25, 47, 0.5);
    white-space: nowrap;
  }

  .filter-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .filter-pill {
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    border: 1.5px solid rgba(10, 25, 47, 0.1);
    background: white;
    color: #54636C;
    font: inherit;
    font-size: 0.88rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.18s;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .filter-pill:hover {
    border-color: var(--deep);
    color: var(--deep);
  }

  .filter-pill.active {
    background: var(--deep);
    color: white;
    border-color: var(--deep);
  }

  .pill-count {
    font-size: 0.72rem;
    font-weight: 800;
    opacity: 0.5;
  }

  .filter-pill.active .pill-count {
    opacity: 0.7;
  }

  /* ── CATALOGUE ── */
  .catalog-section {
    padding: 2.5rem 0 4rem;
    background: var(--bg);
  }

  .catalog-count {
    margin: 0 0 1.5rem;
    font-size: 0.82rem;
    font-weight: 700;
    color: rgba(10, 25, 47, 0.45);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .res-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  /* ── CARTE RESSOURCE ── */
  .res-card {
    display: flex;
    flex-direction: column;
    background: white;
    border: 1.5px solid var(--border);
    border-radius: 18px;
    padding: 1.75rem;
    text-decoration: none;
    color: var(--deep);
    transition: all 0.22s ease;
    box-shadow: 0 2px 8px rgba(10, 25, 47, 0.03);
    position: relative;
    overflow: hidden;
  }

  .res-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--border);
    transition: background 0.22s;
  }

  .res-card[data-pillar="se_situer"]::before   { background: var(--pillar-se_situer); }
  .res-card[data-pillar="comprendre"]::before  { background: var(--pillar-comprendre); }
  .res-card[data-pillar="agir"]::before        { background: var(--pillar-agir); }
  .res-card[data-pillar="se_proteger"]::before { background: var(--pillar-se_proteger); }

  .res-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(10, 25, 47, 0.08);
    border-color: rgba(10, 25, 47, 0.15);
  }

  .res-card-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .res-card-pillar {
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    white-space: nowrap;
  }

  .pillar-se_situer   { color: var(--pillar-se_situer);   background: rgba(59, 130, 246, 0.1); }
  .pillar-comprendre  { color: var(--pillar-comprendre);  background: rgba(139, 92, 246, 0.1); }
  .pillar-agir        { color: var(--pillar-agir);        background: rgba(16, 185, 129, 0.1); }
  .pillar-se_proteger { color: var(--pillar-se_proteger); background: rgba(230, 57, 70, 0.1); }

  .res-card-format {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(10, 25, 47, 0.35);
    background: rgba(10, 25, 47, 0.04);
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
  }

  .res-card-title {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--deep);
    line-height: 1.2;
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }

  .res-card-promise {
    font-size: 0.92rem;
    line-height: 1.5;
    color: #54636c;
    margin: 0 0 1rem;
  }

  .res-card-teaser {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    background: rgba(10, 25, 47, 0.025);
    border-radius: 10px;
    padding: 0.8rem 0.9rem;
    margin-bottom: 1.25rem;
    flex: 1;
  }

  .teaser-icon {
    font-size: 0.9rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .res-card-teaser p {
    font-size: 0.82rem;
    line-height: 1.45;
    color: rgba(10, 25, 47, 0.65);
    margin: 0;
    font-style: italic;
  }

  .res-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    margin-top: auto;
  }

  .res-card-cta {
    font-size: 0.82rem;
    font-weight: 800;
    color: var(--deep);
    letter-spacing: -0.01em;
  }

  .res-card-arrow {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: rgba(10, 25, 47, 0.05);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--deep);
    font-size: 0.9rem;
    flex-shrink: 0;
    transition: all 0.22s;
  }

  .res-card:hover .res-card-arrow {
    background: var(--deep);
    color: white;
    transform: translateX(2px);
  }

  .res-card:hover .res-card-cta {
    color: var(--red);
  }

  /* ── EMPTY STATE ── */
  .empty-state {
    padding: 3rem 2rem;
    border-radius: 1.4rem;
    border: 1px dashed rgba(10, 25, 47, 0.12);
    background: white;
    text-align: center;
  }

  .empty-state p {
    margin: 0 0 1rem;
    color: #54636c;
    font-size: 1.05rem;
  }

  /* ── DIAGNOSTIC CTA ── */
  .diagnostic-cta-section {
    padding: 4rem 0;
    background: white;
  }

  .diagnostic-cta-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 2.5rem;
    background: linear-gradient(135deg, rgba(173,255,47,0.06) 0%, rgba(10,25,47,0.03) 100%);
    border: 1.5px solid rgba(173,255,47,0.2);
    border-radius: 24px;
  }

  .diagnostic-cta-content h2 {
    margin: 0.5rem 0 0.75rem;
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--deep);
    letter-spacing: -0.02em;
  }

  .diagnostic-cta-content p {
    margin: 0;
    color: #54636c;
    font-size: 1rem;
    line-height: 1.6;
    max-width: 36rem;
  }

  .diagnostic-cta-actions {
    flex-shrink: 0;
  }

  /* ── COPILOTE DARK ── */
  .copilot-dark-section {
    background: var(--deep);
    padding: 5rem 0;
  }

  .copilot-dark-kicker {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--neon);
    margin-bottom: 1rem;
  }

  .copilot-dark-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: white;
    margin: 0 0 1rem;
    line-height: 1.05;
  }

  .copilot-dark-desc {
    font-size: 1.05rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.6);
    max-width: 48rem;
    margin: 0 0 2rem;
  }

  .copilot-dark-header {
    margin-bottom: 0.5rem;
  }

  .copilot-suggestions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-bottom: 2.5rem;
  }

  .copilot-chip {
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.85);
    border-radius: 999px;
    padding: 0.65rem 1.1rem;
    font: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    text-align: left;
    text-decoration: none;
    transition: all 0.18s;
  }

  .copilot-chip:hover,
  .copilot-chip:focus-visible {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.3);
    color: white;
    outline: none;
  }

  .copilot-dark-btn {
    display: inline-block;
    padding: 0.9rem 2rem;
    background: var(--neon);
    color: var(--deep);
    border-radius: 10px;
    font-weight: 900;
    font-size: 1rem;
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: all 0.2s;
  }

  .copilot-dark-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(173, 255, 47, 0.25);
  }

  /* ── ALLER PLUS LOIN ── */
  .subtle-support-card {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 2rem;
    align-items: start;
    padding: 2rem 2.1rem;
    border-radius: 28px;
    background: linear-gradient(180deg, rgba(10, 25, 47, 0.03) 0%, rgba(10, 25, 47, 0.01) 100%);
    border: 1px solid rgba(10, 25, 47, 0.08);
  }

  .subtle-support-copy h3 {
    margin: 1rem 0 0.8rem;
    font-size: 1.5rem;
    line-height: 1.25;
    color: var(--deep);
  }

  .subtle-support-copy p {
    margin: 0;
    color: #54636c;
    line-height: 1.6;
  }

  .subtle-support-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    justify-content: flex-start;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 1100px) {
    .res-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .diagnostic-cta-card {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 768px) {
    .res-hero-bg {
      padding-bottom: 3rem;
    }

    .res-grid {
      grid-template-columns: 1fr;
    }

    .filter-bar {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .filter-bar-label {
      display: none;
    }

    .filter-pills {
      width: 100%;
      overflow-x: auto;
      flex-wrap: nowrap;
      padding-bottom: 0.25rem;
      -webkit-overflow-scrolling: touch;
    }

    .subtle-support-card {
      grid-template-columns: 1fr;
    }

    .subtle-support-actions {
      flex-direction: column;
    }

    .subtle-support-actions .btn-secondary-v3 {
      width: 100%;
      justify-content: center;
    }

    .copilot-dark-section {
      padding: 3.5rem 0;
    }

    .section-v3 {
      padding: 3.5rem 0;
    }

    .diagnostic-cta-card {
      padding: 1.75rem;
    }
  }

  @media (max-width: 480px) {
    .filter-pill {
      font-size: 0.8rem;
      padding: 0.4rem 0.85rem;
    }

    .res-card {
      padding: 1.35rem;
    }

    .res-card-title {
      font-size: 1.05rem;
    }
  }
</style>
