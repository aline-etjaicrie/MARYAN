---
import BaseLayout from '../layouts/BaseLayout.astro';
import InternalHeader from '../components/InternalHeader.astro';
import { maryanResources } from '../data/resources';
import { maryanPaths } from '../data/paths';
import { maryanSituations } from '../data/situations';

const pillars = [
  { id: 'all', label: 'Tous' },
  { id: 'se_situer', label: 'Se situer' },
  { id: 'comprendre', label: 'Comprendre' },
  { id: 'agir', label: 'Agir' },
  { id: 'se_proteger', label: 'Se protéger / se positionner' }
];

const situationFilters = [
  { id: 'all', label: 'Toutes' },
  { id: 'prise_de_fonction', label: 'Prise de fonction', markers: ['prise_de_fonction', 'posture', 'legitimite', 'repères', 'conseil_municipal'] },
  { id: 'arbitrage', label: 'Arbitrage', markers: ['arbitrage', 'decision', 'dossier', 'priorisation', 'budget', 'finances'] },
  { id: 'tension_locale', label: 'Tension locale', markers: ['tension', 'conflit', 'tension_locale', 'situation_sensible', 'crise', 'relations_internes'] },
  { id: 'prise_de_parole', label: 'Prise de parole', markers: ['prise_de_parole', 'parole', 'reponse', 'communication_publique', 'reunion_publique', 'annonce'] },
  { id: 'reseaux_sociaux', label: 'Réseaux sociaux', markers: ['facebook', 'reseaux', 'réseaux', 'publication', 'commentaires', 'communication'] },
  { id: 'participation', label: 'Participation', markers: ['participation', 'concertation', 'co_construction', 'reunion_publique', 'habitants', 'restitution'] },
  { id: 'porteurs_de_projet', label: 'Porteurs de projet', markers: ['projet_citoyen', 'projet_entreprise', 'collectif_habitants', 'initiative_locale', 'relation_partenaire', 'implantation', 'projet'] },
  { id: 'budget', label: 'Budget', markers: ['budget', 'finances', 'arbitrage budgetaire', 'finances locales'] },
  { id: 'services', label: 'Relations avec les services', markers: ['services', 'administration', 'gouvernance', 'relations_internes', 'blocage'] },
  { id: 'ia', label: 'IA / outils numériques', markers: ['ia', 'chatgpt', 'outil', 'numerique', 'numérique'] }
];

const copilotSuggestions = [
  'Aide-moi à préparer une prise de parole sensible',
  'Aide-moi à cadrer un arbitrage',
  'Aide-moi à répondre à une tension locale',
  'Aide-moi à relire une réunion participative',
  'Aide-moi à préparer mon premier conseil'
];
---

<BaseLayout
  title="Vos ressources MARYAN"
  description="Des repères concrets pour comprendre, décider et agir selon votre réalité de mandat."
>
  <div class="res-hero-bg">
    <div class="container relative-z header-white-force">
      <InternalHeader
        label="Vos ressources"
        title="Vos ressources <span class='emphasis text-neon'>MARYAN</span>"
        subtitle="Des repères concrets pour comprendre, décider et agir selon votre réalité de mandat."
      />

      <div class="hero-note-card">
        <p class="hero-note-lead">Votre diagnostic nous aide à vous orienter vers les ressources les plus utiles pour vous.</p>
        <p class="hero-note-text">Mais toutes les ressources restent accessibles à tout moment.</p>
      </div>
    </div>
    <div class="hero-glow glow-red"></div>
    <div class="hero-glow glow-green"></div>
  </div>

  <main class="resources-main">
    <section id="diagnosticHelper" class="section-v3 hidden">
      <div class="container container-medium">
        <div class="diagnostic-helper-card card-v3">
          <div class="diagnostic-helper-copy">
            <span class="label-v3">Personnalisation</span>
            <h2>Commencez par le diagnostic pour orienter vos premières lectures</h2>
            <p>
              MARYAN peut faire remonter les ressources, parcours et situations les plus utiles pour vous. Mais vous restez libre d’explorer tout le reste.
            </p>
          </div>

          <div class="diagnostic-helper-actions">
            <a href="/diagnostic" class="btn-primary-v3">Faire le diagnostic</a>
            <a href="/copilote" class="btn-secondary-v3">Ouvrir le copilote</a>
          </div>
        </div>
      </div>
    </section>

    <section id="prioritiesSection" class="section-v3 hidden">
      <div class="container">
        <header class="section-header-v4">
          <span class="label-v3">Pour vous, en priorité</span>
          <h2 class="section-title-standard">Vos priorités du moment</h2>
          <p class="section-subtitle-v4">
            À partir de votre diagnostic, voici les sujets sur lesquels MARYAN vous recommande de vous concentrer en premier.
          </p>
        </header>

        <div id="priorityGrid" class="priority-grid"></div>

        <div id="prioritySituationBlock" class="priority-situation-block hidden">
          <p class="priority-situation-label">Situations proches de votre réalité actuelle</p>
          <div id="prioritySituationGrid" class="priority-situation-grid"></div>
        </div>
      </div>
    </section>

    <section id="personalizedResources" class="section-v3 hidden recommended-section">
      <div class="container">
        <header class="section-header-v4">
          <span class="label-v3">Sélectionnées à partir de votre diagnostic</span>
          <h2 class="section-title-standard">À commencer par là</h2>
          <p class="section-subtitle-v4">Une première sélection de ressources particulièrement adaptées à votre situation actuelle.</p>
        </header>

        <div id="recommendedGrid" class="rec-v4-grid"></div>
      </div>
    </section>

    <section id="personalizedPath" class="section-v3 hidden path-section">
      <div class="container">
        <header class="section-header-v4">
          <span class="label-v3">Parcours conseillé</span>
          <h2 class="section-title-standard">Un parcours utile pour votre situation</h2>
          <p class="section-subtitle-v4">Si vous voulez avancer de manière plus structurée, commencez par ce parcours.</p>
        </header>

        <div class="path-highlight-card card-v3">
          <div class="path-content">
            <span class="path-badge">Parcours recommandé</span>
            <h2 id="pathTitle" class="path-title-v4">—</h2>
            <p id="pathPromise" class="path-promise-v4">—</p>
            <p id="pathDescription" class="path-description-v4"></p>

            <div class="path-priorities-box">
              <h3>Vos 3 priorités dans ce parcours</h3>
              <ul id="pathPrioritiesList" class="res-check-list-small"></ul>
            </div>

            <div class="path-resources-box">
              <h3>Ressources liées</h3>
              <div id="pathResourcesGrid" class="path-mini-grid"></div>
            </div>

            <div class="path-actions">
              <a id="pathCta" href="/ressources" class="btn-secondary-v3">Commencer ce parcours</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-v3 explore-section">
      <div class="container">
        <header class="section-header-v4">
          <span class="label-v3">Explorer</span>
          <h2 class="section-title-standard">Trouver une ressource</h2>
          <p class="section-subtitle-v4">
            Votre profil nous aide à vous orienter, pas à vous limiter. Vous pouvez explorer librement l’ensemble des ressources MARYAN.
          </p>
        </header>

        <div class="filter-shell card-v3">
          <div class="filter-search">
            <label for="resourceSearch" class="filter-label">Recherche</label>
            <input id="resourceSearch" type="search" class="search-input" placeholder="Rechercher un sujet, un format, une situation..." />
          </div>

          <div class="filter-grid">
            <label class="filter-field">
              <span class="filter-label">Par univers</span>
              <select id="pillarFilter">
                {pillars.map((pillar) => <option value={pillar.id}>{pillar.label}</option>)}
              </select>
            </label>

            <label class="filter-field">
              <span class="filter-label">Par situation</span>
              <select id="situationFilter">
                {situationFilters.map((item) => <option value={item.id}>{item.label}</option>)}
              </select>
            </label>

            <label class="filter-field">
              <span class="filter-label">Par format</span>
              <select id="formatFilter">
                <option value="all">Tous</option>
                <option value="fiche">Fiches</option>
                <option value="checklist">Checklists</option>
                <option value="guide">Guides</option>
                <option value="repere">Repères</option>
              </select>
            </label>

            <label class="filter-field">
              <span class="filter-label">Trier par</span>
              <select id="sortFilter">
                <option value="recommended">Recommandé pour vous</option>
                <option value="useful">Les plus utiles</option>
                <option value="recent">Les plus récentes</option>
                <option value="consulted">Les plus consultées</option>
              </select>
            </label>
          </div>
        </div>

        <div class="catalogue-head">
          <div>
            <p class="catalogue-kicker">Explorer toutes les ressources</p>
            <p class="catalogue-copy">
              Le diagnostic sert à orienter, pas à enfermer. Toutes les fiches restent accessibles à tout moment.
            </p>
          </div>
          <p id="resourceCount" class="resource-count">—</p>
        </div>

        <div id="resourceGrid" class="res-grid"></div>
        <div id="emptyState" class="empty-state hidden">
          <p>Aucune ressource ne correspond à cette combinaison de filtres pour l’instant.</p>
          <button type="button" class="btn-secondary-v3" id="resetFiltersBtn">Réinitialiser les filtres</button>
        </div>
      </div>
    </section>

    <section class="section-v3 situations-section">
      <div class="container">
        <header class="section-header-v4">
          <span class="label-v3">Cas concrets</span>
          <h2 class="section-title-standard">Situations fréquentes</h2>
          <p class="section-subtitle-v4">
            Entrer par un cas concret, quand vous cherchez moins un thème qu’une situation à traverser.
          </p>
        </header>

        <div class="sit-grid">
          {maryanSituations.map((sit) => (
            <button type="button" class="sit-card card-v3" onclick={`openSituation('${sit.id}')`}>
              <div class="sit-card-content">
                <h3 class="sit-title">{sit.title}</h3>
                <p class="sit-desc">{sit.shortDescription}</p>
                <div class="sit-footer">
                  <span class="sit-link">Explorer la situation</span>
                  <span class="sit-arrow">↗</span>
                </div>
              </div>
            </button>
          ))}
        </div>
      </div>
    </section>

    <section class="section-v3 copilot-section">
      <div class="container container-medium">
        <div class="copilot-card card-v3">
          <div class="copilot-copy">
            <span class="label-v3">Poser une question à MARYAN</span>
            <h2>Vous ne trouvez pas exactement votre cas ?</h2>
            <p>
              Si vous ne trouvez pas exactement votre cas, MARYAN peut aussi vous aider à le cadrer directement.
            </p>
          </div>

          <div class="copilot-suggestions">
            {copilotSuggestions.map((prompt) => (
              <button type="button" class="copilot-chip" onclick={`openCopilotPrompt(${JSON.stringify(prompt)})`}>
                {prompt}
              </button>
            ))}
          </div>

          <div class="copilot-actions">
            <a href="/copilote" class="btn-primary-v3">Ouvrir le copilote</a>
          </div>
        </div>
      </div>
    </section>

    <section class="section-v3 subtle-support-section">
      <div class="container container-medium">
        <div class="subtle-support-card">
          <div class="subtle-support-copy">
            <span class="label-v3">Aller plus loin</span>
            <h3>Selon votre situation, MARYAN peut aussi vous orienter vers le bon niveau d’appui.</h3>
            <p>Copilote, accompagnement individuel, offre collectivité ou formation ciblée : l’idée reste la même, vous proposer l’appui juste.</p>
          </div>

          <div class="subtle-support-actions">
            <a href="/offres" class="btn-secondary-v3">Voir les offres</a>
            <a href="/methode" class="btn-secondary-v3">Découvrir la méthode</a>
            <a href="/contact" class="btn-secondary-v3">Être rappelé</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <div id="sitModal" class="modal-overlay hidden">
    <div class="modal-card">
      <button type="button" class="modal-close" onclick="closeSituation()">×</button>
      <div id="sitModalContent"></div>
    </div>
  </div>

  <script
    is:inline
    define:vars={{ maryanResources, maryanPaths, maryanSituations, pillars, situationFilters }}
  >
    const profilePriorityCopy = {
      mandat_recent: [
        'prendre vos repères sans vous disperser',
        'mieux comprendre qui fait quoi dans la collectivité',
        'tenir une posture juste sans surjouer la fonction'
      ],
      arbitrage: [
        'retrouver du recul avant les décisions sensibles',
        'clarifier ce qui mérite un vrai arbitrage',
        'éviter que l’urgence décide à votre place'
      ],
      isolement: [
        'sortir du sentiment de devoir tout porter seul·e',
        'retrouver des repères stables pour le mandat',
        'remettre de la clarté dans votre manière d’agir'
      ],
      surcharge: [
        'reprendre la main sur ce qui mérite vraiment votre énergie',
        'retrouver un ordre d’action plus lisible',
        'ne pas laisser toutes les urgences se valoir'
      ],
      exposition: [
        'tenir une parole publique plus lisible',
        'mieux distinguer réaction rapide et réponse juste',
        'protéger votre clarté dans les séquences exposées'
      ],
      tension_relationnelle: [
        'relire la situation avant de personnaliser le conflit',
        'distinguer ce qui relève du fond, de la méthode ou de la relation',
        'retrouver du cadre pour agir sans sur-réagir'
      ],
      besoin_methode: [
        'clarifier les étapes avant d’entrer dans la complexité',
        'retrouver une méthode simple pour cadrer les sujets',
        'mieux distinguer compréhension, décision et mise en œuvre'
      ],
      prise_de_parole: [
        'tenir une parole plus lisible et plus sobre',
        'préparer vos prises de parole sans les surcharger',
        'trouver le bon tempo dans les séquences visibles'
      ],
      gouvernance: [
        'clarifier les rôles et les marges de manœuvre',
        'mieux lire les tensions de fonctionnement',
        'rendre la conduite du mandat plus stable et plus lisible'
      ]
    };

    const pillarLabels = Object.fromEntries(pillars.filter((pillar) => pillar.id !== 'all').map((pillar) => [pillar.id, pillar.label]));
    const formatLabels = {
      fiche: 'Fiche',
      checklist: 'Checklist',
      guide: 'Guide',
      repere: 'Repère'
    };

    const state = {
      profile: null,
      recommendedPath: null,
      search: '',
      pillar: 'all',
      situation: 'all',
      format: 'all',
      sort: 'recommended'
    };

    const els = {
      diagnosticHelper: document.getElementById('diagnosticHelper'),
      prioritiesSection: document.getElementById('prioritiesSection'),
      priorityGrid: document.getElementById('priorityGrid'),
      prioritySituationBlock: document.getElementById('prioritySituationBlock'),
      prioritySituationGrid: document.getElementById('prioritySituationGrid'),
      personalizedResources: document.getElementById('personalizedResources'),
      recommendedGrid: document.getElementById('recommendedGrid'),
      personalizedPath: document.getElementById('personalizedPath'),
      pathTitle: document.getElementById('pathTitle'),
      pathPromise: document.getElementById('pathPromise'),
      pathDescription: document.getElementById('pathDescription'),
      pathPrioritiesList: document.getElementById('pathPrioritiesList'),
      pathResourcesGrid: document.getElementById('pathResourcesGrid'),
      pathCta: document.getElementById('pathCta'),
      resourceGrid: document.getElementById('resourceGrid'),
      resourceCount: document.getElementById('resourceCount'),
      emptyState: document.getElementById('emptyState'),
      resourceSearch: document.getElementById('resourceSearch'),
      pillarFilter: document.getElementById('pillarFilter'),
      situationFilter: document.getElementById('situationFilter'),
      formatFilter: document.getElementById('formatFilter'),
      sortFilter: document.getElementById('sortFilter'),
      resetFiltersBtn: document.getElementById('resetFiltersBtn')
    };

    initResourcesPage();

    function initResourcesPage() {
      state.profile = resolveProfile();
      state.recommendedPath = state.profile ? getRecommendedPaths(maryanPaths, state.profile, 1)[0] || null : null;

      renderPersonalizedContent();
      bindFilters();
      bindTracking();
      renderCatalog();
    }

    function resolveProfile() {
      const diag = JSON.parse(localStorage.getItem('maryan_v4_diag') || '{}');
      let profile = diag.tension || diag.vigilance || diag.lack || diag.feeling || '';

      const mapping = {
        flou: 'besoin_methode',
        conflit: 'tension_relationnelle',
        exposition: 'exposition',
        sollicitations: 'surcharge',
        surcharge: 'surcharge',
        seul: 'isolement',
        priorites: 'surcharge',
        parole: 'prise_de_parole',
        relation: 'tension_relationnelle',
        cadre: 'besoin_methode',
        recul: 'arbitrage'
      };

      if (mapping[profile]) profile = mapping[profile];
      if (!profile && diag.seniority === 'moins1an') profile = 'mandat_recent';

      return profile || null;
    }

    function getRecommendedResources(resources, profile, limit = 3) {
      return resources
        .filter((resource) => resource.diagnosticProfiles.includes(profile))
        .sort((a, b) => {
          if (a.priority === 'haute' && b.priority !== 'haute') return -1;
          if (a.priority !== 'haute' && b.priority === 'haute') return 1;
          return 0;
        })
        .slice(0, limit);
    }

    function getRecommendedPaths(paths, profile, limit = 1) {
      return paths.filter((path) => path.diagnosticProfiles.includes(profile)).slice(0, limit);
    }

    function getRecommendedSituations(profile, limit = 2) {
      return maryanSituations.filter((item) => item.diagnosticProfiles.includes(profile)).slice(0, limit);
    }

    function renderPersonalizedContent() {
      if (!state.profile) {
        els.diagnosticHelper?.classList.remove('hidden');
        return;
      }

      els.diagnosticHelper?.classList.add('hidden');

      const priorities = state.recommendedPath?.priorities?.slice(0, 3)?.length
        ? state.recommendedPath.priorities.slice(0, 3)
        : (profilePriorityCopy[state.profile] || []).slice(0, 3);
      const recommendedResources = getRecommendedResources(maryanResources, state.profile);
      const recommendedSituations = getRecommendedSituations(state.profile, 2);

      if (priorities.length) {
        els.prioritiesSection?.classList.remove('hidden');
        els.priorityGrid.innerHTML = priorities
          .map(
            (item, index) => `
              <article class="priority-card">
                <span class="priority-index">0${index + 1}</span>
                <p>${item}</p>
              </article>
            `
          )
          .join('');
      }

      if (recommendedSituations.length) {
        els.prioritySituationBlock?.classList.remove('hidden');
        els.prioritySituationGrid.innerHTML = recommendedSituations
          .map(
            (item) => `
              <button type="button" class="priority-situation-pill" onclick="openSituation('${item.id}')">
                ${item.title}
              </button>
            `
          )
          .join('');
      }

      if (recommendedResources.length) {
        els.personalizedResources?.classList.remove('hidden');
        els.recommendedGrid.innerHTML = recommendedResources
          .map(
            (resource, index) => `
              <a href="/ressources/${resource.slug}" class="rec-lux-card-v4" data-resource-link data-slug="${resource.slug}">
                <div class="rec-card-top">
                  <span class="rec-index">0${index + 1}</span>
                  <span class="rec-chip">Pour vous</span>
                </div>
                <div class="rec-content">
                  <h3 class="rec-title-v4">${resource.title}</h3>
                  <p class="rec-promise-v4">${resource.promise}</p>
                </div>
                <div class="rec-card-footer">
                  <span class="rec-link-label">Lire la fiche</span>
                  <span class="rec-arrow">↗</span>
                </div>
              </a>
            `
          )
          .join('');
      }

      if (state.recommendedPath) {
        els.personalizedPath?.classList.remove('hidden');
        const pathResources = state.recommendedPath.resourceIds
          .map((id) => maryanResources.find((resource) => resource.id === id))
          .filter(Boolean);

        els.pathTitle.textContent = state.recommendedPath.title;
        els.pathPromise.textContent = state.recommendedPath.promise;
        els.pathDescription.textContent = state.recommendedPath.description;
        els.pathPrioritiesList.innerHTML = state.recommendedPath.priorities
          .slice(0, 3)
          .map((priority) => `<li><span class="check-icon-small" aria-hidden="true"></span>${priority}</li>`)
          .join('');
        els.pathResourcesGrid.innerHTML = pathResources
          .map(
            (resource) => `
              <a href="/ressources/${resource.slug}" class="path-mini-card" data-resource-link data-slug="${resource.slug}">
                <span class="mini-format">${formatLabels[resource.format] || resource.format}</span>
                <h4>${resource.title}</h4>
              </a>
            `
          )
          .join('');

        if (pathResources[0]) {
          els.pathCta.setAttribute('href', `/ressources/${pathResources[0].slug}`);
        }
      }
    }

    function bindFilters() {
      els.resourceSearch?.addEventListener('input', (event) => {
        state.search = event.currentTarget.value || '';
        renderCatalog();
      });

      els.pillarFilter?.addEventListener('change', (event) => {
        state.pillar = event.currentTarget.value;
        renderCatalog();
      });

      els.situationFilter?.addEventListener('change', (event) => {
        state.situation = event.currentTarget.value;
        renderCatalog();
      });

      els.formatFilter?.addEventListener('change', (event) => {
        state.format = event.currentTarget.value;
        renderCatalog();
      });

      els.sortFilter?.addEventListener('change', (event) => {
        state.sort = event.currentTarget.value;
        renderCatalog();
      });

      els.resetFiltersBtn?.addEventListener('click', () => {
        state.search = '';
        state.pillar = 'all';
        state.situation = 'all';
        state.format = 'all';
        state.sort = 'recommended';

        if (els.resourceSearch) els.resourceSearch.value = '';
        if (els.pillarFilter) els.pillarFilter.value = 'all';
        if (els.situationFilter) els.situationFilter.value = 'all';
        if (els.formatFilter) els.formatFilter.value = 'all';
        if (els.sortFilter) els.sortFilter.value = 'recommended';

        renderCatalog();
      });
    }

    function renderCatalog() {
      const filtered = sortResources(
        maryanResources.filter(matchesActiveFilters),
        state.sort
      );

      els.resourceCount.textContent = `${filtered.length} ressource${filtered.length > 1 ? 's' : ''}`;
      els.resourceGrid.innerHTML = filtered.map(renderResourceCard).join('');
      els.emptyState.classList.toggle('hidden', filtered.length > 0);
    }

    function matchesActiveFilters(resource) {
      if (state.pillar !== 'all' && resource.pillar !== state.pillar) return false;
      if (state.format !== 'all' && resource.format !== state.format) return false;
      if (state.search && !matchesSearch(resource, state.search)) return false;
      if (state.situation !== 'all' && !matchesSituation(resource, state.situation)) return false;
      return true;
    }

    function matchesSearch(resource, query) {
      const corpus = [resource.title, resource.promise, resource.intro, ...(resource.tags || []), ...(resource.useCases || [])].join(' ');
      return normalizeText(corpus).includes(normalizeText(query));
    }

    function matchesSituation(resource, filterId) {
      const filter = situationFilters.find((item) => item.id === filterId);
      if (!filter || filter.id === 'all') return true;

      const corpus = normalizeText([resource.title, resource.promise, resource.intro, ...(resource.tags || []), ...(resource.useCases || [])].join(' '));
      return filter.markers.some((marker) => corpus.includes(normalizeText(marker)));
    }

    function sortResources(resources, sortValue) {
      const profile = state.profile;
      const score = (resource) => {
        let total = 0;
        if (resource.priority === 'haute') total += 2;
        if (profile && resource.diagnosticProfiles.includes(profile)) total += 6;
        if (state.recommendedPath && state.recommendedPath.resourceIds.includes(resource.id)) total += 4;
        return total;
      };

      const viewCounts = JSON.parse(localStorage.getItem('maryan_resource_views') || '{}');

      const sorted = [...resources];
      sorted.sort((a, b) => {
        if (sortValue === 'consulted') {
          const viewedDiff = (viewCounts[b.slug] || 0) - (viewCounts[a.slug] || 0);
          if (viewedDiff !== 0) return viewedDiff;
        }

        if (sortValue === 'recent') {
          return (
            maryanResources.findIndex((item) => item.id === b.id) -
            maryanResources.findIndex((item) => item.id === a.id)
          );
        }

        if (sortValue === 'useful') {
          const usefulDiff = (b.priority === 'haute') - (a.priority === 'haute');
          if (usefulDiff !== 0) return usefulDiff;
        }

        const recommendedDiff = score(b) - score(a);
        if (recommendedDiff !== 0) return recommendedDiff;

        return a.title.localeCompare(b.title, 'fr');
      });

      return sorted;
    }

    function renderResourceCard(resource) {
      return `
        <a href="/ressources/${resource.slug}" class="res-lux-card card-v3" data-resource-link data-slug="${resource.slug}">
          <div class="card-inner">
            <header class="card-top">
              <div class="card-pills">
                <span class="format-tag">${formatLabels[resource.format] || resource.format}</span>
                <span class="meta-pill">${pillarLabels[resource.pillar] || resource.pillar}</span>
              </div>
              ${resource.priority === 'haute' ? '<span class="priority-dot" title="Priorité haute"></span>' : ''}
            </header>
            <h3 class="card-title">${resource.title}</h3>
            <p class="card-promise">${resource.promise}</p>
            <footer class="card-meta">
              <div class="card-tags">
                ${(resource.tags || []).slice(0, 2).map((tag) => `<span class="role-mini">${tag}</span>`).join('')}
              </div>
              <div class="arrow-circle">↗</div>
            </footer>
          </div>
        </a>
      `;
    }

    function bindTracking() {
      document.addEventListener('click', (event) => {
        const link = event.target.closest('[data-resource-link]');
        if (!link) return;

        const slug = link.getAttribute('data-slug');
        if (!slug) return;

        const viewCounts = JSON.parse(localStorage.getItem('maryan_resource_views') || '{}');
        viewCounts[slug] = (viewCounts[slug] || 0) + 1;
        localStorage.setItem('maryan_resource_views', JSON.stringify(viewCounts));
      });
    }

    function normalizeText(value) {
      return value
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9'\s]/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();
    }

    const ctaContent = {
      copilote: {
        label: 'Ouvrir le copilote',
        href: '/copilote',
        note: "Besoin d'un premier cadrage rapide sur cette situation ? Le copilote peut vous aider à faire un point."
      },
      offre_individuelle: {
        label: "Découvrir l'offre individuelle",
        href: '/offres#avancer',
        note: "Si la situation demande un regard plus ajusté, MARYAN peut orienter vers un appui individuel."
      },
      offre_collectivite: {
        label: "Voir l'offre collectivité",
        href: '/offres#collectivites',
        note: "Si le sujet dépasse un besoin individuel, un format collectivité peut être plus cohérent."
      },
      formation_irl: {
        label: 'Découvrir les formations',
        href: '/methode',
        note: "Quand le besoin appelle un travail plus structuré, un appui ou une formation en présentiel peut être utile."
      }
    };

    window.openCopilotPrompt = (prompt) => {
      sessionStorage.setItem('maryan_copilot_prefill', prompt);
      window.location.href = '/copilote';
    };

    window.openSituation = (id) => {
      const sit = maryanSituations.find((item) => item.id === id);
      if (!sit) return;

      const resources = sit.resourceIds.map((rid) => maryanResources.find((resource) => resource.id === rid)).filter(Boolean);
      const paths = sit.pathIds.map((pid) => maryanPaths.find((path) => path.id === pid)).filter(Boolean);
      const cta = ctaContent[sit.ctaType] || ctaContent.copilote;

      const html = `
        <div class="modal-header">
          <span class="label-v3">Situation fréquente</span>
          <h2 class="modal-title">${sit.title}</h2>
          <p class="modal-intro">${sit.longDescription}</p>
        </div>

        <div class="modal-body-grid">
          <div class="modal-main">
            <div class="modal-section">
              <h3 class="modal-sub">Vos priorités</h3>
              <ul class="modal-list">
                ${sit.priorities.map((priority) => `<li>${priority}</li>`).join('')}
              </ul>
            </div>

            <div class="modal-section">
              <h3 class="modal-sub">Ressources indispensables</h3>
              <div class="modal-res-grid">
                ${resources
                  .map(
                    (resource) => `
                      <a href="/ressources/${resource.slug}" class="modal-res-link" data-resource-link data-slug="${resource.slug}">
                        <span class="mini-format">${formatLabels[resource.format] || resource.format}</span>
                        <span class="mini-title">${resource.title}</span>
                      </a>
                    `
                  )
                  .join('')}
              </div>
            </div>
          </div>

          <aside class="modal-aside">
            ${
              paths.length
                ? `
              <div class="modal-section">
                <h3 class="modal-sub">Parcours lié</h3>
                ${paths
                  .map(
                    (path) => `
                      <div class="aside-path-card">
                        <h4>${path.title}</h4>
                        <p>${path.promise}</p>
                      </div>
                    `
                  )
                  .join('')}
              </div>
            `
                : ''
            }

            <div class="modal-section">
              <h3 class="modal-sub">Appui conseillé</h3>
              <div class="cta-mini-box">
                <span class="cta-label">${sit.ctaType.replaceAll('_', ' ')}</span>
                <p>${cta.note}</p>
                <a href="${cta.href}" class="btn-primary-v3 btn-tiny">${cta.label}</a>
              </div>
            </div>
          </aside>
        </div>
      `;

      document.getElementById('sitModalContent').innerHTML = html;
      document.getElementById('sitModal').classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    };

    window.closeSituation = () => {
      document.getElementById('sitModal').classList.add('hidden');
      document.body.style.overflow = '';
    };

    document.getElementById('sitModal').onclick = (event) => {
      if (event.target === document.getElementById('sitModal')) closeSituation();
    };
  </script>
</BaseLayout>

