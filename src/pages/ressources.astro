---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import InternalHeader from '../components/InternalHeader.astro';

const allRessources = await getCollection('ressources');
const sortedRessources = allRessources.sort((a, b) => b.data.publishDate - a.data.publishDate);

// Categories for filtering
const categories = [
  { id: 'all', label: 'Tout explorer' },
  { id: 'tension', label: 'Tensions' },
  { id: 'parole', label: 'Prise de parole' },
  { id: 'recul', label: 'Recul & Stratégie' },
  { id: 'juridique', label: 'Juridique' },
];
---

<BaseLayout 
  title="La Bibliothèque — MARYAN" 
  description="Accédez au savoir-faire MARYAN : fiches pratiques, trames et repères pour tenir votre mandat avec clarté.">
  
  <div class="res-hero-bg">
    <div class="container relative-z">
      <InternalHeader 
        label="La Bibliothèque"
        title="Des ressources utiles,<br/><span class='emphasis text-neon'>classées par situation</span>"
        subtitle="Plus de 20 fiches pratiques, trames et repères simples pour ne plus jamais décider seul·e face à l'incertitude du mandat."
      />
    </div>
    <div class="hero-glow glow-red"></div>
    <div class="hero-glow glow-green"></div>
  </div>

  <main class="ressources-lux">
    
    <!-- DASHBOARD NAVIGATION -->
    <section class="filters-section">
      <div class="container">
        <div class="category-pills">
          {categories.map(cat => (
            <button class={`pill ${cat.id === 'all' ? 'active' : ''}`} data-category={cat.id}>
              <span class="pill-icon">{cat.icon}</span>
              <span class="pill-label">{cat.label}</span>
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- CONTENT GRID -->
    <section class="content-section">
      <div class="container">
        <div class="res-grid" id="ressourcesGrid">
          {sortedRessources.map(res => (
            <a href={`/ressources/${res.slug}`} class="res-lux-card card-v3" data-category={res.data.category}>
              <div class="card-inner">
                <div class="card-top">
                   <div class={`category-tag ${res.data.category}`}>
                     {res.data.kicker}
                   </div>
                   {res.data.isPremium && <span class="premium-badge">Plus</span>}
                </div>
                <h3 class="card-title">{res.data.title}</h3>
                <p class="card-description">{res.data.description}</p>
                
                <div class="card-meta">
                   <span class="read-info">Fiche pratique · 3 min</span>
                   <div class="arrow-circle">→</div>
                </div>
              </div>
            </a>
          ))}
        </div>

        {sortedRessources.length === 0 && (
          <div class="empty-state">
            <div class="empty-box card-v3">
              <p>MARYAN prépare ses prochaines fiches pratiques pour enrichir la bibliothèque.</p>
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- SIDE CTA SECTION -->
    <section class="section-v3">
      <div class="container">
        <div class="app-cta-banner card-v3">
           <div class="banner-content">
             <span class="label-v3">Appli Copilote</span>
             <h3>Passez en mode <span class="emphasis">opérationnel.</span></h3>
             <p>Le Copilote utilise toute notre bibliothèque pour vous répondre en direct sur votre situation spécifique.</p>
             <a href="/copilote" class="btn-primary-v3">Ouvrir MARYAN App</a>
           </div>
           <div class="banner-visual">
             <div class="pwa-mockup">
               <span class="mock-line" style="width: 80%;"></span>
               <span class="mock-line" style="width: 60%;"></span>
               <span class="mock-line" style="width: 70%;"></span>
             </div>
           </div>
        </div>
      </div>
    </section>

  </main>

</BaseLayout>

<style>
  /* ─── HERO ─── */
  .res-hero-bg { background: var(--deep); color: white; padding-bottom: 6rem; position: relative; overflow: hidden; }
  .hero-glow { position: absolute; width: 40vw; height: 40vw; filter: blur(100px); opacity: 0.1; z-index: 1; pointer-events: none; }
  .glow-red { top: -10%; left: -10%; background: var(--accent-red); }
  .glow-green { bottom: -10%; right: -10%; background: var(--neon); }
  .relative-z { position: relative; z-index: 5; }

  /* ─── FILTERS ─── */
  .filters-section { margin-top: -3rem; position: relative; z-index: 10; margin-bottom: 5rem; }
  .category-pills { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .pill { 
    display: flex; align-items: center; gap: 0.75rem; 
    padding: 0.9rem 1.75rem; border-radius: 99px; 
    border: 1.5px solid rgba(10, 25, 47, 0.08); background: white; 
    cursor: pointer; transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
  }
  .pill-label { font-weight: 700; color: var(--deep); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; }
  
  .pill:hover { transform: translateY(-3px); border-color: var(--accent-red); box-shadow: 0 10px 25px rgba(230, 57, 70, 0.08); }
  .pill.active { background: var(--deep); border-color: var(--deep); box-shadow: 0 10px 30px rgba(10, 25, 47, 0.2); }
  .pill.active .pill-label { color: white; }

  /* ─── GRID & CARDS ─── */
  .res-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 3rem; }
  .res-lux-card { 
    display: flex; flex-direction: column; text-decoration: none; padding: 3rem;
    border: 1.5px solid var(--border); background: white; 
    transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
    height: 100%; border-radius: 36px;
  }
  .res-lux-card:hover { transform: translateY(-12px); border-color: var(--accent-red); box-shadow: 0 30px 60px rgba(10, 25, 47, 0.06); }
  
  .card-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem; }
  .category-tag { 
    font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em;
    padding: 0.5rem 1rem; background: #f8f9fa; border-radius: 8px; color: #54636C;
  }
  .category-tag.tension { color: #cc444b; background: #fff5f5; }
  .category-tag.parole { color: #2e5cb8; background: #f0f4ff; }
  .category-tag.recul { color: #54636C; background: #f8f9fa; }
  
  .premium-badge { font-size: 0.65rem; font-weight: 900; background: var(--accent-red); color: white; padding: 0.25rem 0.6rem; border-radius: 6px; text-transform: uppercase; }

  .card-title { font-size: 1.75rem; color: var(--deep); margin-bottom: 1.25rem; line-height: 1.25; }
  .card-description { font-size: 1rem; line-height: 1.6; color: #54636C; opacity: 0.8; margin-bottom: 3rem; }
  
  .card-meta { margin-top: auto; display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--border); padding-top: 2rem; }
  .read-info { font-size: 0.85rem; font-weight: 700; color: #54636C; opacity: 0.6; }
  .arrow-circle { width: 44px; height: 44px; border-radius: 50%; background: var(--bg); display: flex; align-items: center; justify-content: center; color: var(--deep); font-weight: 900; transition: all 0.3s; }
  .res-lux-card:hover .arrow-circle { background: var(--accent-red); color: white; transform: rotate(-45deg); }

  /* ─── BANNER CTA ─── */
  .app-cta-banner { 
    background: var(--deep); color: white; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; padding: 5rem;
    align-items: center; overflow: hidden; position: relative;
  }
  .banner-content h3 { font-size: 2.5rem; margin: 1.5rem 0; color: white; }
  .banner-content p { font-size: 1.15rem; opacity: 0.7; margin-bottom: 3rem; }
  
  .pwa-mockup { 
    background: rgba(255,255,255,0.03); border: 2px solid rgba(255,255,255,0.1); width: 220px; height: 400px;
    border-radius: 40px; margin: 0 auto; transform: rotate(8deg) translateY(40px);
    display: flex; flex-direction: column; gap: 1rem; padding: 2rem; justify-content: flex-end;
  }
  .mock-line { height: 8px; background: rgba(255,255,255,0.1); border-radius: 99px; }

  @media (max-width: 992px) {
    .res-grid { grid-template-columns: 1fr; }
    .app-cta-banner { grid-template-columns: 1fr; padding: 3rem; text-align: center; }
    .pwa-mockup { display: none; }
  }
</style>
