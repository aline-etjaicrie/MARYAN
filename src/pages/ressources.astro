---
import BaseLayout from '../layouts/BaseLayout.astro';
import InternalHeader from '../components/InternalHeader.astro';
import { maryanResources } from '../data/resources';
import { maryanPaths } from '../data/paths';
import { maryanSituations } from '../data/situations';

const pillars = [
  { id: 'se_situer', label: 'Se Situer', marker: '01', description: 'Repérer sa place et son rôle réel dans le mandat.' },
  { id: 'comprendre', label: 'Comprendre', marker: '02', description: 'Décrypter les circuits de décision et les enjeux locaux.' },
  { id: 'agir', label: 'Agir', marker: '03', description: 'Trancher, porter des projets et piloter avec méthode.' },
  { id: 'se_proteger', label: 'Se Protéger', marker: '04', description: 'Sécuriser sa pratique, sa parole et son endurance.' }
];

const getResourcesByPillar = (pillarId: string) =>
  maryanResources.filter(r => r.pillar === pillarId);

---

<BaseLayout 
  title="La Bibliothèque — MARYAN" 
  description="Accédez au savoir-faire MARYAN : fiches pratiques, trames et repères pour tenir votre mandat avec clarté.">
  
  <div class="res-hero-bg">
    <div class="container relative-z header-white-force">
      <InternalHeader 
        label="La Bibliothèque"
        title="Des ressources utiles,<br/><span class='emphasis text-neon'>classées par piliers</span>"
        subtitle="Plus de 20 fiches pratiques, trames et repères simples pour ne plus jamais décider seul·e face à l'incertitude du mandat."
      />
    </div>
    <div class="hero-glow glow-red"></div>
    <div class="hero-glow glow-green"></div>
  </div>

  <main class="ressources-lux">
    
    <!-- 1. À COMMENCER PAR LÀ (PERSONALIZED RESOURCES) - DARK THEME -->
    <section id="personalizedResources" class="section-v3 hidden recommended-section">
      <div class="container">
        <header class="section-header-v4">
          <span class="label-v3">Selon votre dernier diagnostic</span>
          <h2 class="section-title-standard">À commencer par là</h2>
          <p class="section-subtitle-v4">Les 3 ressources prioritaires identifiées pour vous.</p>
        </header>
        <div id="recommendedGrid" class="rec-v4-grid">
          <!-- Filled by JS -->
        </div>
      </div>
    </section>

    <!-- 2. UN PARCOURS UTILE (PERSONALIZED PATH) -->
    <section id="personalizedPath" class="section-v3 hidden" style="background: white;">
      <div class="container">
        <div class="path-highlight-card card-v3">
          <div class="path-content">
            <span class="path-badge">Parcours conseillé</span>
            <h2 id="pathTitle" class="path-title-v4">—</h2>
            <p id="pathPromise" class="path-promise-v4">—</p>
            
            <div class="path-priorities-box">
              <h3>Vos 3 priorités dans ce parcours :</h3>
              <ul id="pathPrioritiesList" class="res-check-list-small"></ul>
            </div>

            <div class="path-resources-box">
              <h3>Fiches liées :</h3>
              <div id="pathResourcesGrid" class="path-mini-grid"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. EXPLORER PAR UNIVERS (PILLARS) -->
    <section class="section-v3">
      <div class="container">
        <header class="section-header-v4">
          <span class="label-v3">Univers</span>
          <h2 class="section-title-standard">Explorer par univers</h2>
        </header>

        <div class="pillar-nav-grid">
          {pillars.map(pillar => (
            <a href={`#${pillar.id}`} class="pillar-nav-card card-v3">
              <div class={`pillar-nav-icon pillar-mark ${pillar.id}`} aria-hidden="true">
                <span>{pillar.marker}</span>
              </div>
              <div class="pillar-nav-info">
                <h3>{pillar.label}</h3>
                <p>{pillar.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- 4. SITUATIONS FRÉQUENTES -->
    <section class="section-v3" style="background: var(--bg);">
      <div class="container">
        <header class="section-header-v4">
          <span class="label-v3">Cas d'usage</span>
          <h2 class="section-title-standard">Situations fréquentes</h2>
          <p class="section-subtitle-v4">Accédez directement aux ressources par situation concrète.</p>
        </header>

        <div class="sit-grid">
          {maryanSituations.map(sit => (
            <button type="button" class="sit-card card-v3" onclick={`openSituation('${sit.id}')`}>
              <div class="sit-card-content">
                <h3 class="sit-title">{sit.title}</h3>
                <p class="sit-desc">{sit.shortDescription}</p>
                <div class="sit-footer">
                  <span class="sit-link">Explorer la situation →</span>
                </div>
              </div>
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- 5. PILLARS CONTENT -->
    {pillars.map(pillar => (
      <section class="section-v3" id={pillar.id} style="padding-top: 4rem;">
        <div class="container">
          <header class="pillar-header">
            <div class={`pillar-icon-box pillar-mark ${pillar.id}`} aria-hidden="true">
              <span>{pillar.marker}</span>
            </div>
            <div class="pillar-info">
              <span class="label-v3">Pilier {pillar.label}</span>
              <h2 class="pillar-title">{pillar.label}</h2>
            </div>
          </header>

          <div class="res-grid">
            {getResourcesByPillar(pillar.id).map(res => (
              <a href={`/ressources/${res.slug}`} class="res-lux-card card-v3">
                <div class="card-inner">
                  <header class="card-top">
                    <span class={`format-tag ${res.format}`}>{res.format}</span>
                    {res.priority === 'haute' && <span class="priority-dot" title="Priorité haute"></span>}
                  </header>
                  <h3 class="card-title">{res.title}</h3>
                  <p class="card-promise">{res.promise}</p>
                  
                  <footer class="card-meta">
                    <div class="roles-tags">
                      {res.targetRoles.slice(0, 2).map(role => <span class="role-mini">{role}</span>)}
                    </div>
                    <div class="arrow-circle">→</div>
                  </footer>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    ))}

    <!-- FINAL CTA -->
    <section class="section-v3">
      <div class="container">
        <div class="app-cta-banner card-v3">
           <div class="banner-content">
             <span class="label-v3">Copilote MARYAN</span>
             <h3>Passez en mode <span class="emphasis">opérationnel.</span></h3>
             <p>Le Copilote utilise toute notre bibliothèque pour vous répondre en direct sur votre situation spécifique.</p>
             <a href="/copilote" class="btn-primary-v3">Ouvrir le copilote</a>
           </div>
           <div class="banner-visual">
             <div class="pwa-mockup">
               <div class="mock-header"></div>
               <div class="mock-body">
                 <span class="mock-line" style="width: 80%;"></span>
                 <span class="mock-line" style="width: 60%;"></span>
                 <span class="mock-line" style="width: 70%;"></span>
               </div>
             </div>
           </div>
        </div>
      </div>
    </section>

  </main>

  <!-- SITUATION MODAL -->
  <div id="sitModal" class="modal-overlay hidden">
    <div class="modal-card">
      <button type="button" class="modal-close" onclick="closeSituation()">×</button>
      <div id="sitModalContent"></div>
    </div>
  </div>

  <script is:inline define:vars={{ maryanResources, maryanPaths, maryanSituations }}>
    // Personalization logic
    function getRecommendedResources(resources, profile, limit = 3) {
      return resources
        .filter((r) => r.diagnosticProfiles.includes(profile))
        .sort((a, b) => {
          if (a.priority === "haute" && b.priority !== "haute") return -1;
          if (a.priority !== "haute" && b.priority === "haute") return 1;
          return 0;
        })
        .slice(0, limit);
    }

    function getRecommendedPaths(paths, profile, limit = 1) {
      return paths
        .filter((p) => p.diagnosticProfiles.includes(profile))
        .slice(0, limit);
    }

    const diag = JSON.parse(localStorage.getItem('maryan_v4_diag') || '{}');
    let profile = diag.tension || diag.vigilance; 
    const mapping = {
      'flou': 'besoin_methode',
      'conflit': 'tension_relationnelle',
      'exposition': 'exposition',
      'sollicitations': 'surcharge',
      'seul': 'isolement'
    };
    if (mapping[profile]) profile = mapping[profile];

    if (profile) {
      // 1. Recommended Resources
      const recs = getRecommendedResources(maryanResources, profile);
      if (recs.length > 0) {
        document.getElementById('personalizedResources').classList.remove('hidden');
        document.getElementById('recommendedGrid').innerHTML = recs.map(res => `
           <a href="/ressources/${res.slug}" class="rec-lux-card-v4">
                <div class="rec-mark" aria-hidden="true"><span></span></div>
                <div class="rec-content">
                  <h3 class="rec-title-v4">${res.title}</h3>
                  <p class="rec-promise-v4">${res.promise}</p>
                </div>
                <div class="rec-arrow">→</div>
              </a>
        `).join('');
      }

      // 2. Recommended Path
      const recPath = getRecommendedPaths(maryanPaths, profile)[0];
      if (recPath) {
        document.getElementById('personalizedPath').classList.remove('hidden');
        document.getElementById('pathTitle').innerText = recPath.title;
        document.getElementById('pathPromise').innerText = recPath.promise;
        document.getElementById('pathPrioritiesList').innerHTML = recPath.priorities.map(p => `
          <li><span class="check-icon-small" aria-hidden="true"></span> ${p}</li>
        `).join('');
        
        const pathResources = recPath.resourceIds.map(id => maryanResources.find(r => r.id === id)).filter(Boolean);
        document.getElementById('pathResourcesGrid').innerHTML = pathResources.map(res => `
          <a href="/ressources/${res.slug}" class="path-mini-card">
            <span class="mini-format">${res.format}</span>
            <h4>${res.title}</h4>
          </a>
        `).join('');
      }
    }

    const ctaContent = {
      copilote: {
        label: 'Ouvrir le copilote',
        href: '/copilote',
        note: "Besoin d'un premier cadrage rapide sur cette situation ? Le copilote peut vous aider à faire un point."
      },
      offre_individuelle: {
        label: "Découvrir l'offre individuelle",
        href: '/offres#avancer',
        note: "Si la situation demande un regard plus ajusté, MARYAN peut orienter vers un appui individuel."
      },
      offre_collectivite: {
        label: "Voir l'offre collectivité",
        href: '/offres#collectivites',
        note: "Si le sujet dépasse un besoin individuel, un format collectivité peut être plus cohérent."
      },
      formation_irl: {
        label: 'Découvrir les formations',
        href: '/methode',
        note: "Quand le besoin appelle un travail plus structuré, un appui ou une formation en présentiel peut être utile."
      }
    };

    // Situation Logic
    window.openSituation = (id) => {
      const sit = maryanSituations.find(s => s.id === id);
      if (!sit) return;

      const resources = sit.resourceIds.map(rid => maryanResources.find(r => r.id === rid)).filter(Boolean);
      const paths = sit.pathIds.map(pid => maryanPaths.find(p => p.id === pid)).filter(Boolean);
      const cta = ctaContent[sit.ctaType] || ctaContent.copilote;

      const html = `
        <div class="modal-header">
          <span class="label-v3">Situation fréquente</span>
          <h2 class="modal-title">${sit.title}</h2>
          <p class="modal-intro">${sit.longDescription}</p>
        </div>
        
        <div class="modal-body-grid">
          <div class="modal-main">
            <div class="modal-section">
              <h3 class="modal-sub">Vos priorités :</h3>
              <ul class="modal-list">
                ${sit.priorities.map(p => `<li>${p}</li>`).join('')}
              </ul>
            </div>
            
            <div class="modal-section">
              <h3 class="modal-sub">Ressources indispensables :</h3>
              <div class="modal-res-grid">
                ${resources.map(res => `
                  <a href="/ressources/${res.slug}" class="modal-res-link">
                    <span class="mini-format">${res.format}</span>
                    <span class="mini-title">${res.title}</span>
                  </a>
                `).join('')}
              </div>
            </div>
          </div>
          
          <aside class="modal-aside">
            ${paths.length > 0 ? `
              <div class="modal-section">
                <h3 class="modal-sub">Parcours lié :</h3>
                ${paths.map(p => `
                  <div class="aside-path-card">
                    <h4>${p.title}</h4>
                    <p>${p.promise}</p>
                  </div>
                `).join('')}
              </div>
            ` : ''}
            
            <div class="modal-section">
              <h3 class="modal-sub">Appui conseillé :</h3>
              <div class="cta-mini-box">
                <span class="cta-label">${sit.ctaType.replace('_', ' ')}</span>
                <p>${cta.note}</p>
                <a href="${cta.href}" class="btn-primary-v3 btn-tiny">${cta.label}</a>
              </div>
            </div>
          </aside>
        </div>
      `;

      document.getElementById('sitModalContent').innerHTML = html;
      document.getElementById('sitModal').classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    };

    window.closeSituation = () => {
      document.getElementById('sitModal').classList.add('hidden');
      document.body.style.overflow = '';
    };

    // Close on overlay click
    document.getElementById('sitModal').onclick = (e) => {
      if (e.target === document.getElementById('sitModal')) closeSituation();
    };

  </script>

</BaseLayout>

<style>
  :root {
    --deep: #0A192F;
    --neon: #ADFF2F;
    --red: #E63946;
    --bg: #F8F9FA;
    --border: rgba(10, 25, 47, 0.08);
  }

  .hidden { display: none !important; }

  /* ─── HERO ─── */
  .res-hero-bg { background: var(--deep); color: white; padding-bottom: 6rem; position: relative; overflow: hidden; }
  .header-white-force :global(h1), 
  .header-white-force :global(p), 
  .header-white-force :global(.internal-label),
  .header-white-force :global(.back-link) { color: white !important; }
  
  .hero-glow { position: absolute; width: 40vw; height: 40vw; filter: blur(100px); opacity: 0.1; z-index: 1; pointer-events: none; }
  .glow-red { top: -10%; left: -10%; background: var(--red); }
  .glow-green { bottom: -10%; right: -10%; background: var(--neon); }
  .relative-z { position: relative; z-index: 5; }

  /* ─── SECTION HEADERS ─── */
  .section-header-v4 { text-align: left; margin-bottom: 3rem; }
  .section-title-standard { font-size: 2.2rem; font-weight: 800; margin: 0.5rem 0; letter-spacing: -0.02em; }
  .section-subtitle-v4 { opacity: 0.8; font-size: 1.1rem; color: #54636C; }

  .recommended-section {
    padding: 6rem 0;
    background: linear-gradient(180deg, #f8f9fa 0%, #eef3f8 100%);
  }

  .recommended-section .section-title-standard,
  .recommended-section .section-subtitle-v4,
  .recommended-section .label-v3 {
    color: var(--deep);
  }

  /* ─── REC CARDS V4 ─── */
  .rec-v4-grid { display: grid; grid-template-columns: 1fr; gap: 1rem; }
  .rec-lux-card-v4 { 
    display: flex; gap: 2rem; align-items: center; 
    padding: 2.2rem; background: rgba(255,255,255,0.92); 
    border: 1px solid rgba(10,25,47,0.08); border-radius: 24px;
    text-decoration: none; color: var(--deep); transition: all 0.3s;
    box-shadow: 0 16px 34px rgba(10, 25, 47, 0.05);
  }
  .rec-lux-card-v4:hover { background: white; border-color: rgba(10,25,47,0.18); transform: translateY(-4px); }
  .rec-mark {
    width: 2.8rem;
    height: 2.8rem;
    border-radius: 0.95rem;
    border: 1px solid rgba(10,25,47,0.1);
    background: rgba(10,25,47,0.03);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .rec-mark span {
    display: block;
    width: 0.95rem;
    height: 0.14rem;
    border-radius: 99px;
    background: var(--accent-red);
    box-shadow: 0 -0.38rem 0 0 rgba(10,25,47,0.2), 0 0.38rem 0 0 var(--neon);
  }
  .rec-content { flex: 1; }
  .rec-title-v4 { font-size: 1.32rem; font-weight: 800; color: var(--deep); margin-bottom: 0.45rem; }
  .rec-promise-v4 { font-size: 1rem; color: #54636C; line-height: 1.45; }
  .rec-arrow { font-size: 1.35rem; opacity: 0.34; color: var(--deep); transition: all 0.3s; }
  .rec-lux-card-v4:hover .rec-arrow { opacity: 1; color: var(--accent-red); }

  /* ─── PILLAR NAV ─── */
  .pillar-nav-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }
  .pillar-nav-card { text-decoration: none; padding: 2rem; background: white; border: 1px solid var(--border); border-radius: 24px; transition: all 0.3s; display: flex; gap: 1.2rem; align-items: flex-start; }
  .pillar-nav-card:hover { transform: translateY(-5px); border-color: var(--neon); }
  .pillar-nav-icon { width: 48px; height: 48px; flex-shrink: 0; }
  .pillar-nav-info h3 { font-size: 1.1rem; margin-bottom: 0.4rem; }
  .pillar-nav-info p { font-size: 0.85rem; opacity: 0.6; line-height: 1.4; }

  /* ─── PILLAR CONTENT ─── */
  .pillar-header { display: flex; gap: 1.5rem; align-items: center; margin-bottom: 3rem; }
  .pillar-icon-box { width: 48px; height: 48px; }
  .pillar-title { font-size: 1.8rem; margin: 0; }

  .pillar-mark {
    background: #fff;
    border: 1px solid rgba(10, 25, 47, 0.08);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 24px rgba(10, 25, 47, 0.04);
  }

  .pillar-mark span {
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: var(--deep);
  }

  .pillar-mark.agir {
    border-color: rgba(173, 255, 47, 0.45);
  }

  .pillar-mark.comprendre {
    border-color: rgba(10, 25, 47, 0.18);
  }

  .pillar-mark.se_situer,
  .pillar-mark.se_proteger {
    border-color: rgba(230, 57, 70, 0.16);
  }

  /* ─── SITUATIONS GRID ─── */
  .sit-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }
  .sit-card { 
    background: white; border: 1px solid var(--border); border-radius: 24px; padding: 2rem; 
    text-align: left; cursor: pointer; transition: all 0.3s; 
    display: flex; flex-direction: column; width: 100%;
  }
  .sit-card:hover { border-color: var(--neon); transform: translateY(-5px); box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
  .sit-title { font-size: 1.2rem; font-weight: 800; color: var(--deep); margin-bottom: 0.8rem; }
  .sit-desc { font-size: 0.9rem; opacity: 0.7; line-height: 1.4; margin-bottom: 1.5rem; }
  .sit-link { font-size: 0.8rem; font-weight: 700; color: var(--red); text-transform: uppercase; letter-spacing: 0.05em; }

  /* ─── MODAL ─── */
  .modal-overlay { 
    position: fixed; inset: 0; background: rgba(10, 25, 47, 0.8); 
    backdrop-filter: blur(10px); z-index: 1000; 
    display: flex; align-items: center; justify-content: center; padding: 2rem;
  }
  .modal-card { 
    background: white; width: 100%; max-width: 900px; max-height: 90vh; 
    border-radius: 32px; position: relative; overflow-y: auto; padding: 4rem;
    box-shadow: 0 40px 100px rgba(0,0,0,0.3);
  }
  .modal-close { 
    position: absolute; top: 1.5rem; right: 1.5rem; 
    width: 40px; height: 40px; border-radius: 50%; border: none;
    background: var(--bg); font-size: 1.5rem; cursor: pointer; transition: 0.2s;
  }
  .modal-close:hover { background: var(--red); color: white; }
  
  .modal-title { font-size: 2.5rem; font-weight: 900; margin-bottom: 1.5rem; letter-spacing: -0.02em; }
  .modal-intro { font-size: 1.1rem; opacity: 0.8; line-height: 1.5; margin-bottom: 3rem; }
  
  .modal-body-grid { display: grid; grid-template-columns: 1.6fr 1fr; gap: 4rem; }
  .modal-sub { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--red); margin-bottom: 1.5rem; letter-spacing: 0.1em; }
  .modal-list { list-style: none; padding: 0; margin-bottom: 3rem; }
  .modal-list li { position: relative; padding-left: 1.5rem; font-size: 1rem; font-weight: 600; margin-bottom: 0.8rem; }
  .modal-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.65rem;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: var(--neon);
    transform: translateY(-50%);
  }
  
  .modal-res-grid { display: flex; flex-direction: column; gap: 0.8rem; }
  .modal-res-link { 
    display: flex; flex-direction: column; padding: 1rem; background: var(--bg); 
    border-radius: 12px; text-decoration: none; border: 1px solid var(--border); transition: 0.2s;
  }
  .modal-res-link:hover { border-color: var(--red); background: white; }
  .modal-res-link .mini-title { font-weight: 700; color: var(--deep); }
  
  .aside-path-card { background: var(--deep); color: white; padding: 1.5rem; border-radius: 16px; margin-bottom: 2rem; }
  .aside-path-card h4 { font-size: 1.1rem; color: var(--neon); margin-bottom: 0.5rem; }
  .aside-path-card p { font-size: 0.85rem; opacity: 0.8; line-height: 1.3; }

  .cta-mini-box { background: #E6F3FF; padding: 2rem; border-radius: 20px; }
  .cta-label { font-size: 0.6rem; font-weight: 800; text-transform: uppercase; color: #0077ED; margin-bottom: 0.5rem; display: block; }
  .cta-mini-box p { font-size: 0.9rem; color: var(--deep); margin-bottom: 1.5rem; }
  .btn-tiny { padding: 0.6rem 1.2rem; font-size: 0.8rem; }

  /* ─── PATH CARD ─── */
  .path-highlight-card { background: var(--deep); color: #fff; padding: 4rem; border-radius: 40px; border: none; box-shadow: 0 30px 60px rgba(0,0,0,0.1); }
  .path-badge { background: var(--neon); color: var(--deep); font-size: 0.7rem; font-weight: 800; text-transform: uppercase; padding: 0.5rem 1rem; border-radius: 99px; display: inline-block; margin-bottom: 2rem; }
  .path-title-v4 { font-size: 2.8rem; font-weight: 900; margin-bottom: 1rem; color: #fff; letter-spacing: -0.02em; }
  .path-promise-v4 { font-size: 1.3rem; color: #fff; opacity: 0.95; margin-bottom: 3rem; max-width: 600px; line-height: 1.4; }
  
