---
import Layout from '../layouts/BaseLayout.astro';
---

<Layout 
  title="MARYAN — Le copilote de mandat local" 
  description="Intelligence de discernement, aide à la décision et accompagnement stratégique pour les élu·es municipaux."
>
  <!-- ═══════════════════════════════════════
       HERO: REPUBLIQUE DESIGN V3 (SIGNATURE)
  ═══════════════════════════════════════ -->
  <section class="hero-v3-signature">
    <!-- Glow Background -->
    <div class="hero-glow-layer">
      <div class="glow-red"></div>
      <div class="glow-green"></div>
    </div>
    
    <div class="container hero-container text-center">
      <div class="hero-header">
        <span class="hero-badge">Liberté de <em class="emphasis">discernement</em></span>
        <div class="hero-brand-wrap">
          <span class="brand-logo-full">MARYAN</span>
        </div>
      </div>

      <div class="hero-content">
        <h1>
          Le copilote de <span class="emphasis">mandat</span> <br />
          au service de la <span class="text-neon">clarté.</span>
        </h1>
        <p class="hero-lead">
          Intelligence de <em class="emphasis">discernement</em>, aide à la décision et posture : 
          un appui stratégique <br class="desktop-only" /> pour naviguer dans l'action publique avec justesse.
        </p>
        
        <div class="hero-actions">
          <a href="/diagnostic" class="btn-primary-v3 big pulse-border">Démarrer le diagnostic</a>
          <div class="hero-hint">
             <span class="dot-neon"></span> Gratuit, immédiat & confidentiel
          </div>
        </div>
      </div>
    </div>

    <!-- Fine separators -->
    <div class="hero-footer-line">
       <span class="dash-neon"></span>
       <span class="dash-red"></span>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       SECTION: POURQUOI MARYAN (COMPARAISON)
  ═══════════════════════════════════════ -->
  <section class="section-v3 bg-light">
    <div class="container container-medium">
      <div class="section-header">
        <span class="label-v3">Différenciation</span>
        <h2>Une intelligence <span class="emphasis">située</span></h2>
        <p class="intro-v3">
          MARYAN n'est pas une IA généraliste. C'est un moteur de discernement qui <em class="emphasis">connaît</em> les réalités, les risques et les codes du mandat municipal.
        </p>
      </div>

      <div class="why-comparison-grid">
         <div class="comparison-card card-v3 dark">
            <span class="kicker">Moteur généraliste</span>
            <h3>Réponse standard</h3>
            <p>Une IA classique compile de l'information brute sans comprendre le <em class="emphasis">contexte local</em> ni les responsabilités de l'élu.</p>
         </div>
         <div class="comparison-card-vs">VS</div>
         <div class="comparison-card card-v3 active-neon">
            <span class="kicker">Moteur MARYAN</span>
            <h3>Appui <span class="emphasis">stratégique</span></h3>
            <p>MARYAN qualifie votre situation, scanne les risques <span class="text-red">juridiques</span> et propose une posture adaptée à votre délégation.</p>
         </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       SECTION: CE QUE VOUS TROUVEZ (CARDS)
  ═══════════════════════════════════════ -->
  <section class="section-v3 bg-deep text-white overflow-hidden">
    <div class="container">
      <div class="section-header text-center">
        <span class="label-v3">L'Appui MARYAN</span>
        <h2 class="text-white">Tout pour tenir <br /><span class="emphasis text-neon">le cap</span> du mandat</h2>
      </div>

      <div class="features-mosaic">
        <div class="card-v3 feature-card">
          <div class="feature-icon-box">🏛️</div>
          <h3><span class="emphasis">Discernement</span> stratégique</h3>
          <p>Clarifiez vos situations réelles avant de décider ou d'agir. Nous identifions les enjeux et les angles morts.</p>
        </div>
        <div class="card-v3 feature-card">
          <div class="feature-icon-box">⚖️</div>
          <h3>Vigilance <span class="emphasis">Risques</span></h3>
          <p>Un scan systématique des risques juridiques, médiatiques et politiques pour sécuriser chaque séquence.</p>
        </div>
        <div class="card-v3 feature-card">
          <div class="feature-icon-box">🎙️</div>
          <h3>Prise de <span class="emphasis">parole</span></h3>
          <p>Des trames de discours et de communication pour rendre votre action enfin lisible et impactante.</p>
        </div>
        <div class="card-v3 feature-card">
          <div class="feature-icon-box">🛠️</div>
          <h3>Outils <span class="emphasis">Méthode</span></h3>
          <p>Bibliothèque de ressources ciblées et guides "Réflexes" par délégation municipal.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       SECTION: LE PARCOURS (COMMENT ÇA MARCHE)
  ═══════════════════════════════════════ -->
  <section class="section-v3">
    <div class="container container-medium">
      <div class="section-header text-center">
        <span class="label-v3">La Méthode</span>
        <h2>Un appui en <span class="emphasis">trois temps</span></h2>
      </div>

      <div class="method-steps">
        <div class="step-v3">
          <div class="step-num">01.</div>
          <h3>Diagnostic initial</h3>
          <p>5 minutes pour qualifier votre profil, votre délégation et vos besoins prioritaires.</p>
        </div>
        <div class="step-arrow-v3"></div>
        <div class="step-v3">
          <div class="step-num">02.</div>
          <h3>Appui Copilote</h3>
          <p>Accès immédiat à l'agent de discernement spécialisé et à vos ressources ciblées.</p>
        </div>
        <div class="step-arrow-v3"></div>
        <div class="step-v3">
          <div class="step-num">03.</div>
          <h3>Hub d'Experts</h3>
          <p>Passage de relais à nos experts humains lorsque la situation exige un arbitrage critique.</p>
        </div>
      </div>

      <div class="method-cta text-center">
         <a href="/diagnostic" class="btn-primary-v3">Démarrer par l'étape 01</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       LE HUB (HYBRIDATION) - REDESIGN V3
  ═══════════════════════════════════════ -->
  <section class="section-v3 bg-deep dark-hub">
     <div class="container">
        <div class="hub-v3-inner">
           <div class="hub-v3-content">
              <span class="label-v3">Le Réseau</span>
              <h2>Le <span class="text-neon emphasis">Hub</span> d'Experts</h2>
              <p>L'IA pour la méthode, <em class="emphasis">l'Expertise</em> pour l'arbitrage.</p>
              <p class="hub-text-detail">
                Notre réseau de consultants (Stratégie, Droit, Communication, RH) intervient 
                en complémentarité de MARYAN pour les dossiers les plus sensibles.
              </p>
              <a href="/hub-experts" class="btn-secondary-v3">Explorer les expertises</a>
           </div>
           <div class="hub-v3-badge">
              <div class="hub-badge-circle">
                 <span>Hybridation <br /><b>Humaine</b></span>
              </div>
           </div>
        </div>
     </div>
  </section>

  <!-- ═══════════════════════════════════════
       FINAL CONVERSION
  ═══════════════════════════════════════ -->
  <section class="section-v3 bg-ivory final-cta-section">
    <div class="container text-center">
       <div class="final-box-v3">
          <span class="label-v3">Prêt à naviguer ?</span>
          <h2>Reprenez de la <span class="emphasis">clarté</span> <br />sur votre mandat.</h2>
          <div class="final-actions-v3">
             <a href="/diagnostic" class="btn-primary-v3 big">Faire le diagnostic (5min)</a>
             <a href="/contact" class="btn-link-simple">Poser une question à l'équipe</a>
          </div>
       </div>
    </div>
  </section>

  <style>
    /* ──────────────────────────────────────────────────────────────────────────
       HERO: REPUBLIQUE DESIGN V3
       ────────────────────────────────────────────────────────────────────────── */
    .hero-v3-signature {
      position: relative;
      background-color: var(--deep);
      padding: 10rem 0 12rem;
      color: white;
      overflow: hidden;
      border-bottom: 1.5px solid var(--neon);
    }
    
    .hero-glow-layer {
      position: absolute; inset: 0; z-index: 0; pointer-events: none;
    }
    .glow-red {
      position: absolute; top: 10%; left: 0%; width: 50vw; height: 50vw;
      background: radial-gradient(circle, rgba(230, 57, 70, 0.08) 0%, transparent 70%);
    }
    .glow-green {
      position: absolute; bottom: 10%; right: 0%; width: 40vw; height: 40vw;
      background: radial-gradient(circle, rgba(173, 255, 47, 0.05) 0%, transparent 70%);
    }

    .hero-container { position: relative; z-index: 2; }

    .hero-badge {
      display: inline-block;
      padding: 0.65rem 1.5rem;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 99px; font-size: 0.85rem; font-weight: 700;
      letter-spacing: 0.05em; color: rgba(255,255,255,0.6);
      margin-bottom: 2.5rem;
    }

    .hero-brand-wrap { margin-bottom: 3.5rem; }
    .brand-logo-full {
      font-size: 8rem; font-weight: 900; letter-spacing: -0.04em;
      background: linear-gradient(180deg, #FFFFFF 0%, rgba(255,255,255,0.7) 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      display: block; line-height: 1;
    }

    .hero-v3-signature h1 {
      font-size: clamp(3rem, 10vw, 5.5rem); color: white; margin-bottom: 2.5rem;
      line-height: 1.05; letter-spacing: -0.02em;
    }
    .text-neon { color: var(--neon); }
    .text-red { color: var(--accent-red); }

    .hero-lead {
      font-size: 1.4rem; line-height: 1.6; opacity: 0.8;
      max-width: 800px; margin: 0 auto 4rem;
    }

    .hero-actions { display: flex; flex-direction: column; align-items: center; gap: 1.5rem; }
    .pulse-border { position: relative; }
    .pulse-border::after {
      content: ''; position: absolute; inset: -3px; border-radius: 99px;
      border: 1.5px solid var(--neon); opacity: 0.3; animation: pulse 2s infinite;
    }
    @keyframes pulse { 0% { scale: 1; opacity: 0.5; } 100% { scale: 1.1; opacity: 0; } }

    .hero-hint { display: flex; align-items: center; gap: 0.75rem; font-size: 0.9rem; opacity: 0.5; font-weight: 600; }
    .dot-neon { width: 8px; height: 8px; background: var(--neon); border-radius: 50%; box-shadow: 0 0 10px var(--neon); }

    .hero-footer-line {
      position: absolute; bottom: 3rem; left: 50%; transform: translateX(-50%);
      display: flex; gap: 2rem;
    }
    .dash-neon { width: 60px; height: 1.5px; background: var(--neon); border-radius: 99px; opacity: 0.5; }
    .dash-red { width: 60px; height: 1.5px; background: var(--accent-red); border-radius: 99px; opacity: 0.5; }

    /* ─── WHY COMPARISON ─── */
    .why-comparison-grid {
      display: flex; align-items: center; gap: 2rem; margin-top: 4rem;
    }
    .comparison-card { flex: 1; }
    .comparison-card.dark { background: var(--deep); color: white; border: none; }
    .comparison-card.dark h3 { color: white; }
    .comparison-card.dark .kicker { color: rgba(255,255,255,0.4); }
    .comparison-card.active-neon { border-color: var(--neon); border-width: 2px; }
    .comparison-card-vs {
      font-family: var(--font-accent); font-style: italic; font-size: 2rem; color: var(--accent-red);
      background: var(--bg); width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;
      border-radius: 50%; margin: 0 -1rem; position: relative; z-index: 5;
    }
    .kicker { font-size: 0.75rem; text-transform: uppercase; font-weight: 800; letter-spacing: 0.1em; color: #54636C; margin-bottom: 1.5rem; display: block; }
    @media (max-width: 900px) { .why-comparison-grid { flex-direction: column; } .comparison-card-vs { margin: -1rem 0; } }

    /* ─── FEATURES MOSAIC ─── */
    .features-mosaic {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;
    }
    .feature-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); color: white; }
    .feature-card h3 { color: white; margin-bottom: 1rem; }
    .feature-card p { opacity: 0.7; font-size: 0.95rem; }
    .feature-icon-box { font-size: 2rem; margin-bottom: 2rem; }
    .feature-card:hover { background: rgba(255,255,255,0.06); }

    /* ─── METHOD STEPS ─── */
    .method-steps { display: flex; align-items: flex-start; gap: 2rem; margin: 4rem 0 6rem; }
    .step-v3 { flex: 1; }
    .step-num { font-size: 3rem; font-weight: 900; color: var(--deep); opacity: 0.1; line-height: 1; margin-bottom: 1.5rem; }
    .step-v3 h3 { margin-bottom: 1rem; font-size: 1.35rem; }
    .step-arrow-v3 { width: 40px; height: 1.5px; background: var(--border); margin-top: 5rem; }
    @media (max-width: 768px) { .method-steps { flex-direction: column; gap: 3rem; } .step-arrow-v3 { display: none; } }

    /* ─── HUB V3 ─── */
    .dark-hub { border-radius: 60px 60px 0 0; margin-top: -2rem; }
    .hub-v3-inner { display: flex; align-items: center; gap: 5rem; }
    .hub-v3-content { flex: 1; }
    .hub-v3-content h2 { color: white; font-size: 3.5rem; margin-bottom: 1.5rem; }
    .hub-v3-content p { font-size: 1.25rem; opacity: 0.8; margin-bottom: 1rem; }
    .hub-text-detail { font-size: 1rem !important; opacity: 0.5 !important; max-width: 500px; margin-bottom: 2.5rem !important; }
    .hub-v3-badge { flex-shrink: 0; }
    .hub-badge-circle {
      width: 180px; height: 180px; border: 1px solid var(--neon); border-radius: 50%;
      display: flex; align-items: center; justify-content: center; text-align: center;
      font-size: 1rem; line-height: 1.3;
    }
    .hub-badge-circle b { color: var(--neon); text-transform: uppercase; font-size: 1.1rem; }
    @media (max-width: 768px) { .hub-v3-inner { flex-direction: column; text-align: center; } .hub-v3-badge { order: -1; } .hub-text-detail { margin: 0 auto 2.5rem !important; } }

    /* ─── FINAL CTA ─── */
    .bg-ivory { background-color: #FDFBFA; }
    .final-box-v3 { padding: 4rem 2rem; }
    .final-box-v3 h2 { font-size: 4rem; line-height: 1.1; margin: 2rem 0 3.5rem; }
    .final-actions-v3 { display: flex; flex-direction: column; align-items: center; gap: 1.5rem; }
    .btn-link-simple { font-weight: 700; color: #54636C; text-decoration: underline; }

    .text-center { text-align: center !important; }
    .bg-deep { background: var(--deep); }
    .bg-light { background: var(--bg); }
    .text-white { color: white !important; }
    .overflow-hidden { overflow: hidden; }
    .container-medium { max-width: 1000px; margin: 0 auto; }
  </style>
</Layout>
