---
// src/pages/index.astro — Homepage MARYAN V2
import Layout from '../layouts/BaseLayout.astro';
---

<Layout
  title="MARYAN — Votre copilote de mandat"
  description="Un agent conversationnel conçu pour les élu·es municipaux. Pour comprendre, décider et prendre la parole sans naviguer à l'aveugle."
>

  <!-- ═══════════════════════════════════════
       HERO
  ═══════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-ambiance"></div>
    <img src="/logo.png" alt="MARYAN Logo" class="hero-logo" />
    <p class="hero-surtitre">Mandat local · comprendre · décider · agir</p>
    <h1>Votre copilote de mandat</h1>
    <p class="hero-accroche">
      Un agent conversationnel conçu pour les élu·es municipaux.<br>
      Pour comprendre, décider et prendre la parole sans naviguer à l'aveugle.
    </p>
    <a href="/diagnostic" class="btn-primary">👉 Faire mon diagnostic</a>
  </section>

  <!-- ═══════════════════════════════════════
       POURQUOI MARYAN
  ═══════════════════════════════════════ -->
  <section class="section">
    <p class="section-label">Pourquoi MARYAN</p>
    <h2>🔥 Pourquoi MARYAN plutôt qu'une IA généraliste ?</h2>
    <p class="intro-block">Parce que tout n'est pas une question de prompt.</p>

    <ul class="liste-points">
      <li>part de votre situation réelle, pas d'une question isolée</li>
      <li>vous pose les bonnes questions avant de répondre</li>
      <li>structure vos sujets (et pas seulement vos phrases)</li>
      <li>vous alerte sur les points de vigilance</li>
      <li>vous oriente vers des ressources utiles</li>
      <li>et, si nécessaire, vous dirige vers un appui humain adapté</li>
    </ul>

    <p class="double-cta-text">
      👉 Pas une IA qui répond.<br>
      👉 Un outil qui vous aide à exercer votre mandat.
    </p>
  </section>

  <!-- ═══════════════════════════════════════
       CE QUE VOUS TROUVEZ ICI
  ═══════════════════════════════════════ -->
  <section class="section section-alt">
    <p class="section-label">Ce que vous trouvez ici</p>
    <h2>🧠 Ce que vous trouvez ici</h2>

    <ul class="liste-points">
      <li>un diagnostic rapide pour mieux comprendre votre situation dans votre mandat</li>
      <li>un agent conversationnel spécialisé pour les élu·es</li>
      <li>des repères clairs pour vous aider à comprendre et décider</li>
      <li>des outils pour préparer vos prises de parole</li>
      <li>et, si besoin, un appui ciblé</li>
    </ul>
  </section>

  <!-- ═══════════════════════════════════════
       COMMENT ÇA FONCTIONNE
  ═══════════════════════════════════════ -->
  <section class="section">
    <p class="section-label">Comment ça fonctionne</p>
    <h2>⚙️ Comment ça fonctionne</h2>

    <ol class="liste-etapes">
      <li>
        <span class="etape-num">1</span>
        <div>
          <strong>Faire le point</strong>
          <p>Vous clarifiez votre situation, vos priorités et vos zones de vigilance.</p>
        </div>
      </li>
      <li>
        <span class="etape-num">2</span>
        <div>
          <strong>Échanger avec MARYAN</strong>
          <p>Vous utilisez un agent conçu pour les réalités du mandat local.</p>
        </div>
      </li>
      <li>
        <span class="etape-num">3</span>
        <div>
          <strong>Être orienté·e</strong>
          <p>Vous accédez aux bons contenus, aux bons outils et, si nécessaire, au bon niveau d'appui.</p>
        </div>
      </li>
    </ol>
  </section>

  <!-- ═══════════════════════════════════════
       POUR QUI
  ═══════════════════════════════════════ -->
  <section class="section section-alt">
    <p class="section-label">Pour qui</p>
    <h2>👥 Pour qui</h2>

    <ul class="liste-points">
      <li>élu·es municipaux</li>
      <li>adjoint·es avec délégation</li>
      <li>élu·es de petites et moyennes communes</li>
      <li>élu·es avec peu de temps ou peu d'appui</li>
    </ul>
  </section>

  <!-- ═══════════════════════════════════════
       CTA FINAL
  ═══════════════════════════════════════ -->
  <section class="section section-cta">
    <p class="section-label">Commencer</p>
    <h2>🎯 Commencer par le bon diagnostic</h2>
    <p class="intro-block">
      Avant les outils, avant les ressources, commencez par faire le point.
    </p>
    <div class="cta-groupe">
      <a href="/diagnostic" class="btn-primary">👉 Faire mon diagnostic</a>
      <a href="/offres" class="btn-secondary">👉 Découvrir les offres MARYAN</a>
    </div>
  </section>

</Layout>

<style>
  :root {
    --space-xs: 0.5rem;
    --space-s: 1rem;
    --space-m: 2rem;
    --space-l: 3rem;
    --space-xl: 5rem;
    --color-muted: var(--muted, #54636c);
    --color-text-soft: #475569;
    --color-surface-alt: var(--surface-2, #fffdf8);
    --color-border: var(--border, #d8d3ca);
    --color-bg: var(--bg, #fcfaf6);
    --color-text: var(--text, #1e2a32);
    --color-accent: var(--blue, #7fa7c9);
  }

  /* ─── HERO ─── */
  .hero {
    position: relative;
    padding: var(--space-xl) var(--space-m);
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-ambiance {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 250%;
    height: 150%;
    transform: translate(-50%, -50%);
    z-index: -1;
    background: 
      radial-gradient(ellipse at 40% 30%, rgba(217, 59, 59, 0.14) 0%, transparent 45%),
      radial-gradient(ellipse at 65% 65%, rgba(57, 255, 110, 0.16) 0%, transparent 50%),
      radial-gradient(ellipse at 35% 70%, rgba(127, 167, 201, 0.22) 0%, transparent 50%);
    filter: blur(80px);
    pointer-events: none;
  }

  .hero-logo {
    max-width: 260px;
    width: 100%;
    height: auto;
    margin: 0 auto 1.5rem auto;
    display: block;
  }

  .hero-surtitre {
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    margin-bottom: var(--space-s);
    text-transform: uppercase;
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: var(--space-m);
  }

  .hero-accroche {
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--color-text-soft);
    margin-bottom: var(--space-l);
  }

  /* ─── SECTIONS ─── */
  .section {
    position: relative;
    padding: var(--space-xl) var(--space-m);
    max-width: 720px;
    margin: 0 auto;
  }

  .section-alt {
    background-color: var(--color-surface-alt);
    max-width: 100%;
    padding-left: calc(50% - 360px);
    padding-right: calc(50% - 360px);
  }

  @media (max-width: 760px) {
    .section-alt {
      padding-left: var(--space-m);
      padding-right: var(--space-m);
    }
  }

  .section-label {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: var(--space-xs);
    font-weight: 700;
  }

  .section h2 {
    font-size: clamp(1.3rem, 3vw, 1.75rem);
    font-weight: 700;
    margin-bottom: var(--space-m);
    line-height: 1.25;
  }

  .intro-block {
    font-size: 1.05rem;
    font-weight: 500;
    margin-bottom: var(--space-m);
    color: var(--color-text-soft);
  }

  /* ─── LISTES ─── */
  .liste-points {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-m) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .liste-points li {
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.55;
    font-size: 1.05rem;
  }

  .liste-points li::before {
    content: "·";
    position: absolute;
    left: 0;
    color: var(--pink, #d93b3b);
    font-weight: 800;
    font-size: 1.3em;
    top: -0.05em;
  }

  /* ─── ÉTAPES ─── */
  .liste-etapes {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .liste-etapes li {
    display: flex;
    gap: var(--space-m);
    align-items: flex-start;
  }

  .etape-num {
    flex-shrink: 0;
    width: 2.2rem;
    height: 2.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--color-accent);
    border-radius: 50%;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-top: 0.1rem;
    background: white;
  }

  .liste-etapes strong {
    display: block;
    font-size: 1.05rem;
    margin-bottom: 0.35rem;
    font-weight: 700;
  }

  .liste-etapes p {
    font-size: 0.95rem;
    color: var(--color-text-soft);
    margin: 0;
    line-height: 1.55;
  }

  /* ─── CTA ─── */
  .double-cta-text {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.8;
    margin-top: var(--space-m);
  }

  .section-cta {
    text-align: center;
  }

  .cta-groupe {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s);
    justify-content: center;
    margin-top: var(--space-l);
  }

  .btn-primary,
  .btn-secondary {
    display: inline-block;
    padding: 0.85rem 1.6rem;
    border-radius: 999px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .btn-primary {
    background-color: var(--color-accent);
    color: white;
  }

  .btn-secondary {
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .btn-primary:hover,
  .btn-secondary:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }
</style>
