---
import Layout from '../layouts/BaseLayout.astro';

const microProofs = [
  'Répondre à une interpellation sans se fragiliser',
  'Arbitrer avec des marges de manœuvre plus claires',
  'Agir quand le temps manque ou que ça bloque'
];

const situations = [
  {
    title: 'Interpellation publique sur un sujet sensible',
    text: 'MARYAN relit les enjeux, les risques et les marges de réponse.',
    result: 'Une réponse plus juste, sans promesse intenable.'
  },
  {
    title: 'Arbitrage budgétaire ou décision floue',
    text: 'MARYAN structure les options, les impacts et les points de vigilance.',
    result: 'Une décision plus claire et plus assumable.'
  },
  {
    title: 'Conseil municipal préparé dans l’urgence',
    text: 'MARYAN aide à remettre de l’ordre, du cadre et des priorités.',
    result: 'Une préparation plus sûre, sans dispersion.'
  },
  {
    title: 'Début de mandat, repères encore flous',
    text: 'MARYAN aide à prioriser et à retrouver un cadre institutionnel lisible.',
    result: 'Une montée en compétence plus rapide.'
  }
];

const steps = [
  {
    title: 'Vous décrivez votre situation',
    text: 'Question libre ou diagnostic guidé.'
  },
  {
    title: 'MARYAN fait remonter le vrai nœud',
    text: 'Ce qui relève du contexte, du risque, de la marge de manœuvre et de la bonne lecture de la situation.'
  },
  {
    title: 'Vous repartez avec une réponse structurée',
    text: 'Enjeux, options, vigilance, prochaine étape.'
  }
];

const comparisonRows = [
  {
    generic: 'Point de départ = question générique',
    maryan: 'Point de départ = situation réelle du mandat'
  },
  {
    generic: 'Contexte intégré = faible ou absent',
    maryan: 'Contexte intégré = règles, marges de manœuvre, risques, repères de mandat'
  },
  {
    generic: 'Type de réponse = texte souvent long',
    maryan: 'Type de réponse = structure claire + prochaine étape'
  },
  {
    generic: 'Finalité = produire du texte',
    maryan: 'Finalité = aider à décider, répondre et tenir sa position'
  }
];

const scenarios = [
  {
    title: 'Interpellation sensible',
    before: 'Stress, réponse trop rapide, risque de surpromesse.',
    after: 'Une réponse cadrée en 10 à 15 minutes, avec les bons points de vigilance.'
  },
  {
    title: 'Décision à arbitrer',
    before: 'Trop d’options, pas assez de lisibilité, difficulté à trancher.',
    after: 'Un arbitrage plus clair, plus argumentable, plus tenable.'
  },
  {
    title: 'Début de mandat',
    before: 'Impression de courir après tous les sujets à la fois.',
    after: 'Des repères plus solides et une meilleure priorisation.'
  }
];

const credibilityPoints = [
  'Plus de 20 ans d’expérience en communication publique et en cabinet',
  'Un outil nourri par des situations concrètes du mandat local',
  'Un diagnostic, un copilote et des ressources conçus pour aider à comprendre, décider et agir'
];

const resourceExamples = [
  {
    label: 'Faire passer une délibération',
    href: '/ressources/faire-passer-une-deliberation'
  },
  {
    label: 'Quand l’administration freine',
    href: '/ressources/administration-qui-freine'
  },
  {
    label: 'Réseaux sociaux : ce qu’un élu peut et ne peut pas dire',
    href: '/ressources/reseaux-sociaux-elu-ce-quon-peut-dire'
  },
  {
    label: 'Prévenir et gérer les situations de VSS et harcèlement',
    href: '/ressources/prevenir-gerer-vss-harcelement'
  }
];

const individualOffer = ['Diagnostic initial', 'Accès au copilote', 'Ressources', 'Activation immédiate'];
const teamOffer = ['Plusieurs accès', 'Même socle d’usage', 'Déploiement léger', 'Tarif ajusté selon le nombre d’élu·es'];
---

<Layout
  title="MARYAN — Une situation de mandat. Une réponse exploitable."
  description="MARYAN aide les élu·es à clarifier une situation, trancher plus vite et passer à l’action sans se fragiliser."
>
  <section class="home-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="label-v3">Copilote de mandat</span>
        <h1>Une situation de mandat. Une réponse exploitable.</h1>
        <p class="hero-subtitle">
          MARYAN aide les élu·es à clarifier une situation, trancher plus vite et passer à l’action
          sans se fragiliser.
        </p>

        <ul class="hero-proofs">
          {microProofs.map((item) => (
            <li>{item}</li>
          ))}
        </ul>

        <div class="hero-actions">
          <a href="/diagnostic" class="btn-primary-v3">Faire le diagnostic</a>
          <a href="/copilote" class="btn-secondary-v3 hero-secondary">Tester une situation réelle</a>
        </div>
      </div>

      <aside class="hero-product card-v3" aria-label="Aperçu du produit">
        <div class="product-bar">
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="dot"></span>
          <strong>Copilote MARYAN</strong>
        </div>
        <div class="product-body">
          <div class="product-input">
            <span>Situation</span>
            <p>
              « Interpellation en conseil sur un dossier sensible. Je dois répondre sans fermer la
              discussion ni promettre ce que je ne peux pas tenir. »
            </p>
          </div>
          <div class="product-flow" aria-hidden="true">
            <span>Situation</span>
            <span>Clarification</span>
            <span>Options</span>
            <span>Prochaine étape</span>
          </div>
          <div class="product-output">
            <h3>Réponse structurée</h3>
            <ul>
              <li><strong>Enjeu :</strong> préserver la confiance sans surpromesse.</li>
              <li><strong>Option recommandée :</strong> réponse cadrée + calendrier de suivi.</li>
              <li><strong>Vigilance :</strong> distinguer engagement politique et faisabilité technique.</li>
              <li><strong>Prochaine étape :</strong> formuler une réponse orale de 90 secondes.</li>
            </ul>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section-v3">
    <div class="container">
      <div class="section-head">
        <span class="label-v3">Situations</span>
        <h2>Vous reconnaissez ces moments ?</h2>
      </div>

      <div class="situations-grid">
        {situations.map((item) => (
          <article class="usage-card card-v3">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <p class="result-line">
              <span>Résultat :</span> {item.result}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="comment-ca-marche" class="section-v3 section-how">
    <div class="container">
      <div class="section-head">
        <span class="label-v3">Méthode</span>
        <h2>En pratique, ça donne ça</h2>
        <p class="section-intro">
          MARYAN ne part pas d’une consigne abstraite. Il commence par relire la situation que vous
          vivez.
        </p>
      </div>

      <div class="steps-grid">
        {steps.map((step, index) => (
          <article class="step-card card-v3">
            <span class="step-index">{String(index + 1).padStart(2, '0')}</span>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </article>
        ))}
      </div>

      <div class="mockups-grid">
        <article class="mockup-card card-v3">
          <span class="mockup-label">Exemple — Entrée utilisateur</span>
          <h3>Question saisie dans le copilote</h3>
          <p>
            « Conseil municipal demain. Le sujet est conflictuel. Je veux rester ferme sur le cadre,
            sans fermer la discussion. »
          </p>
        </article>
        <article class="mockup-card card-v3">
          <span class="mockup-label">Exemple — Sortie structurée</span>
          <h3>Réponse exploitable</h3>
          <ul>
            <li>Lecture politique de la situation</li>
            <li>Options argumentées</li>
            <li>Points de vigilance</li>
            <li>Prochaine étape activable</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section-v3 section-compare">
    <div class="container">
      <div class="section-head">
        <span class="label-v3">Différence</span>
        <h2>Pensé pour le mandat local, pas pour répondre à tout.</h2>
      </div>

      <div class="comparison-shell">
        <div class="comparison-head comparison-row">
          <strong>IA généraliste</strong>
          <strong>MARYAN</strong>
        </div>
        {comparisonRows.map((row) => (
          <div class="comparison-row">
            <p>{row.generic}</p>
            <p>{row.maryan}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-v3">
    <div class="container">
      <div class="section-head">
        <span class="label-v3">Impact concret</span>
        <h2>Ce que MARYAN change dans des situations très concrètes</h2>
      </div>

      <div class="scenario-grid">
        {scenarios.map((scenario) => (
          <article class="scenario-card card-v3">
            <h3>{scenario.title}</h3>
            <div class="scenario-lines">
              <p>
                <strong>Avant :</strong> {scenario.before}
              </p>
              <p>
                <strong>Après :</strong> {scenario.after}
              </p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-v3 section-credibility">
    <div class="container">
      <div class="credibility-shell">
        <div class="section-head section-head-light">
          <span class="label-v3">Crédibilité</span>
          <h2>Conçu à partir du réel, pas d’un chatbot générique.</h2>
        </div>

        <div class="credibility-points">
          {credibilityPoints.map((point) => (
            <article class="credibility-card">
              <p>{point}</p>
            </article>
          ))}
        </div>

        <div class="resource-examples card-v3">
          <h3>Exemples de ressources</h3>
          <ul>
            {resourceExamples.map((item) => (
              <li>
                <a href={item.href}>{item.label}</a>
              </li>
            ))}
          </ul>
        </div>

        <div class="proof-slot" aria-label="Emplacement futur pour retour d'expérience">
          <p>Emplacement réservé pour un retour d’expérience terrain (pilote ou témoignage vérifié).</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-v3">
    <div class="container">
      <div class="section-head section-head-center">
        <span class="label-v3">Accès</span>
        <h2>Simple à démarrer</h2>
      </div>

      <div class="offers-grid">
        <article class="offer-card card-v3">
          <span class="offer-audience">Pour un élu</span>
          <h3>Un accès individuel, activable immédiatement.</h3>
          <ul class="clean-list">
            {individualOffer.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <a href="/offres" class="btn-primary-v3">Voir les offres</a>
        </article>

        <article class="offer-card offer-card-dark">
          <span class="offer-audience">Pour une équipe ou une collectivité</span>
          <h3>Un déploiement léger, avec un cadre d’usage commun.</h3>
          <ul class="clean-list">
            {teamOffer.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <a href="/contact" class="btn-secondary-v3">Demander une démo</a>
        </article>
      </div>
    </div>
  </section>

  <section class="section-v3 final-cta-section">
    <div class="container">
      <div class="final-cta-panel">
        <h2>Prêt à tester sur une vraie situation de votre mandat ?</h2>
        <div class="final-cta-actions">
          <a href="/diagnostic" class="btn-primary-v3">Faire le diagnostic</a>
          <a href="/copilote" class="btn-secondary-v3">Tester une situation réelle</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .home-hero {
      background:
        radial-gradient(circle at top left, rgba(230, 57, 70, 0.16), transparent 34%),
        radial-gradient(circle at bottom right, rgba(173, 255, 47, 0.14), transparent 32%),
        var(--deep);
      color: white;
      padding: 5.5rem 0;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 1.4rem;
      align-items: stretch;
    }

    .hero-copy h1 {
      color: white;
      font-size: clamp(2.1rem, 4vw, 3.6rem);
      line-height: 1.04;
      letter-spacing: -0.03em;
      margin: 0 0 1.1rem;
      text-wrap: balance;
    }

    .hero-subtitle {
      margin: 0 0 1.5rem;
      color: rgba(255, 255, 255, 0.86);
      max-width: 42ch;
      line-height: 1.65;
    }

    .hero-proofs {
      list-style: none;
      display: grid;
      gap: 0.65rem;
      margin: 0 0 1.5rem;
      padding: 0;
    }

    .hero-proofs li {
      position: relative;
      padding-left: 1rem;
      color: rgba(255, 255, 255, 0.92);
      font-size: 0.98rem;
      line-height: 1.5;
    }

    .hero-proofs li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.72rem;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--neon);
      transform: translateY(-50%);
    }

    .hero-actions,
    .final-cta-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.9rem;
      align-items: center;
    }

    .hero-secondary {
      background: rgba(255, 255, 255, 0.13);
      color: white;
      border-color: rgba(255, 255, 255, 0.2);
    }

    .hero-secondary:hover,
    .hero-secondary:focus-visible {
      background: white !important;
      color: var(--deep) !important;
      border-color: white !important;
    }

    .hero-product {
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 28px;
      padding: 1.2rem;
      backdrop-filter: blur(8px);
    }

    .product-bar {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      color: rgba(255, 255, 255, 0.8);
      font-size: 0.86rem;
      margin-bottom: 0.95rem;
    }

    .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.42);
    }

    .product-bar strong {
      margin-left: 0.35rem;
      color: white;
      letter-spacing: 0.03em;
    }

    .product-body {
      display: grid;
      gap: 0.9rem;
    }

    .product-input,
    .product-output {
      border-radius: 18px;
      padding: 1rem;
      border: 1px solid rgba(255, 255, 255, 0.14);
      background: rgba(8, 20, 34, 0.52);
    }

    .product-input span,
    .mockup-label {
      display: inline-block;
      font-size: 0.76rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--neon);
      margin-bottom: 0.55rem;
    }

    .product-input p,
    .product-output ul,
    .product-output li {
      margin: 0;
      color: rgba(255, 255, 255, 0.9);
      line-height: 1.58;
      font-size: 0.95rem;
    }

    .product-flow {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0.4rem;
    }

    .product-flow span {
      text-align: center;
      border-radius: 999px;
      padding: 0.45rem 0.55rem;
      font-size: 0.8rem;
      color: rgba(255, 255, 255, 0.88);
      background: rgba(173, 255, 47, 0.1);
      border: 1px solid rgba(173, 255, 47, 0.25);
    }

    .product-output h3 {
      color: white;
      margin: 0 0 0.6rem;
      font-size: 1.05rem;
    }

    .product-output ul {
      list-style: none;
      display: grid;
      gap: 0.45rem;
      padding: 0;
    }

    .section-head {
      max-width: 46rem;
      margin-bottom: 2rem;
    }

    .section-head-center {
      margin-left: auto;
      margin-right: auto;
      text-align: center;
    }

    .section-head h2 {
      font-size: clamp(1.8rem, 3.3vw, 3rem);
      margin: 0 0 0.85rem;
      text-wrap: balance;
    }

    .section-intro {
      margin: 0;
      color: #54636c;
      line-height: 1.66;
      max-width: 56ch;
    }

    .situations-grid,
    .steps-grid,
    .scenario-grid,
    .offers-grid {
      display: grid;
      gap: 1rem;
    }

    .situations-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .usage-card h3,
    .step-card h3,
    .scenario-card h3,
    .offer-card h3,
    .resource-examples h3,
    .mockup-card h3 {
      margin: 0 0 0.65rem;
      font-size: 1.2rem;
      line-height: 1.28;
    }

    .usage-card p,
    .step-card p,
    .scenario-card p,
    .offer-card p,
    .mockup-card p {
      margin: 0;
      color: #54636c;
      line-height: 1.62;
    }

    .result-line {
      margin-top: 0.65rem !important;
      padding-top: 0.65rem;
      border-top: 1px solid var(--border);
      font-size: 0.95rem;
    }

    .result-line span {
      color: var(--deep);
      font-weight: 700;
    }

    .section-how {
      background: linear-gradient(180deg, #f8f9fa 0%, #eef3f7 100%);
    }

    .steps-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      margin-bottom: 1rem;
    }

    .step-index {
      display: inline-block;
      margin-bottom: 0.6rem;
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      color: var(--accent-red);
    }

    .mockups-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .mockup-card {
      border: 1px solid rgba(10, 25, 47, 0.1);
    }

    .mockup-card ul {
      margin: 0;
      padding-left: 1rem;
      display: grid;
      gap: 0.45rem;
      color: #54636c;
    }

    .section-compare {
      background: var(--deep);
    }

    .section-compare .section-head h2,
    .section-compare .section-head {
      color: white;
    }

    .section-compare .label-v3 {
      color: white;
    }

    .section-compare .label-v3::before {
      background: white;
    }

    .comparison-shell {
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: 24px;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.04);
    }

    .comparison-row {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
      padding: 1rem 1.2rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .comparison-row:last-child {
      border-bottom: 0;
    }

    .comparison-head {
      background: rgba(255, 255, 255, 0.08);
    }

    .comparison-row strong {
      color: white;
      font-size: 0.95rem;
    }

    .comparison-row p {
      margin: 0;
      color: rgba(255, 255, 255, 0.85);
      line-height: 1.54;
    }

    .scenario-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .scenario-lines {
      display: grid;
      gap: 0.7rem;
      margin-top: 0.7rem;
      padding-top: 0.8rem;
      border-top: 1px solid var(--border);
    }

    .scenario-lines strong {
      color: var(--deep);
    }

    .section-credibility {
      background: linear-gradient(180deg, #f8f9fa 0%, #edf2f6 100%);
    }

    .credibility-shell {
      background: var(--deep);
      border-radius: 28px;
      padding: 2rem;
    }

    .section-head-light h2,
    .section-head-light p {
      color: white;
    }

    .section-head-light .label-v3 {
      color: white;
    }

    .section-head-light .label-v3::before {
      background: white;
    }

    .credibility-points {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.8rem;
      margin-bottom: 1rem;
    }

    .credibility-card {
      border-radius: 18px;
      padding: 1rem;
      border: 1px solid rgba(255, 255, 255, 0.13);
      background: rgba(255, 255, 255, 0.06);
    }

    .credibility-card p {
      margin: 0;
      color: rgba(255, 255, 255, 0.89);
      line-height: 1.55;
    }

    .resource-examples {
      margin-bottom: 0.9rem;
      border-radius: 22px;
      padding: 1.2rem;
    }

    .resource-examples ul {
      list-style: none;
      display: grid;
      gap: 0.55rem;
      padding: 0;
      margin: 0;
    }

    .resource-examples a {
      color: var(--deep);
      text-decoration: none;
      font-weight: 600;
    }

    .resource-examples a:hover {
      color: var(--accent-red);
    }

    .proof-slot {
      border: 1px dashed rgba(255, 255, 255, 0.28);
      border-radius: 16px;
      padding: 0.8rem 1rem;
    }

    .proof-slot p {
      margin: 0;
      font-size: 0.92rem;
      color: rgba(255, 255, 255, 0.78);
    }

    .offers-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .offer-card {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .offer-audience {
      display: inline-block;
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent-red);
    }

    .clean-list {
      list-style: none;
      display: grid;
      gap: 0.5rem;
      margin: 0;
      padding: 0;
    }

    .clean-list li {
      position: relative;
      padding-left: 1rem;
      color: #54636c;
      line-height: 1.5;
    }

    .clean-list li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.68rem;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--neon);
      transform: translateY(-50%);
    }

    .offer-card-dark {
      background: var(--deep);
      border-radius: 32px;
      padding: 3rem;
      border: 1px solid rgba(255, 255, 255, 0.12);
    }

    .offer-card-dark h3,
    .offer-card-dark p,
    .offer-card-dark li {
      color: white;
    }

    .offer-card-dark .offer-audience {
      color: var(--neon);
    }

