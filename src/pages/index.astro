---
import BaseLayout from '../layouts/BaseLayout.astro';

const heroSignals = [
  'Diagnostic en 5 minutes',
  'Appui progressif selon la situation',
  'Pensé pour les élus municipaux'
];

const supportPaths = [
  'des ressources en autonomie',
  'un appui digital renforcé',
  'ou une expertise ciblée, lorsque la situation le justifie'
];

const gestures = [
  {
    number: '01',
    title: 'Faire le point',
    text: 'Clarifier votre situation, vos points de vigilance et vos priorités réelles avant de chercher des réponses partout.'
  },
  {
    number: '02',
    title: "S'outiller",
    text: 'Accéder à des repères, des ressources et un copilote utile pour mieux comprendre, préparer et décider.'
  },
  {
    number: '03',
    title: 'Se faire épauler',
    text: "Quand le sujet l'exige, être orienté vers le bon niveau d'appui humain, sans surcharger ni sous-calibrer."
  }
];

const profiles = [
  {
    title: 'Nouveaux élus',
    text: 'Pour celles et ceux qui découvrent la machine municipale et cherchent des repères solides dès le début du mandat.'
  },
  {
    title: 'Adjoints qui prennent une délégation',
    text: 'Pour les élus qui doivent rapidement arbitrer, expliquer et tenir des dossiers plus techniques ou plus exposés.'
  },
  {
    title: 'Élus de petites et moyennes communes',
    text: 'Pour les mandats exercés avec peu de temps, peu de relais, et une forte proximité avec les habitants.'
  },
  {
    title: 'Élus qui gardent une activité professionnelle',
    text: 'Pour celles et ceux qui ont besoin d’un appui lisible, utile et compatible avec un agenda contraint.'
  }
];

const urgencyLines = [
  'Les mandats sont plus techniques.',
  'La pression de visibilité est plus forte.',
  'Les anciens relais sont souvent moins structurants.'
];
---
<BaseLayout
  title="MARYAN — copilote de mandat pour élus municipaux"
  description="MARYAN aide les élus municipaux à faire le point, s’outiller et se faire épauler selon leur situation réelle."
>
  <header class="site-header">
    <div class="container row between center">
      <div>
        <p class="brand">MARYAN</p>
        <p class="brand-sub">appui intelligent pour élus municipaux</p>
      </div>
      <nav class="nav">
        <a href="/diagnostic">Diagnostic</a>
        <a href="/ressources">Ressources</a>
        <a href="/copilote">Copilote</a>
        <a href="/offres">Appui</a>
        <a href="/expertises">Expertises</a>
      </nav>
    </div>
  </header>

  <main class="home-main">
    <section class="manifest-hero">
      <div class="container manifest-grid">
        <div class="manifest-copy">
          <p class="eyebrow">Mandat local · point d'appui · sobriété numérique</p>
          <h1>Le mandat local ne devrait pas se faire à l’aveugle.</h1>
          <p class="lead manifest-lead">
            Entre la formation ponctuelle et la réalité quotidienne du mandat, il y a souvent un vide.
            MARYAN aide les élus municipaux à faire le point, s’outiller et se faire épauler, selon leur
            situation réelle.
          </p>
          <div class="actions">
            <a class="btn btn-primary" href="/diagnostic">Faire mon diagnostic</a>
          </div>
        </div>

        <aside class="card signal-panel">
          <p class="card-label">En bref</p>
          <ul class="signal-list">
            {heroSignals.map((item) => <li>{item}</li>)}
          </ul>
          <p class="signal-note">Pas une boîte à outils de plus. Un point d’appui de mandat.</p>
        </aside>
      </div>
    </section>

    <section class="section problem-section">
      <div class="container problem-grid">
        <div class="problem-copy">
          <p class="section-kicker">Le problème</p>
          <h2>Le mandat local s’exerce encore trop souvent sans mode d’emploi.</h2>
          <p class="problem-text">
            Institutions complexes, sujets techniques, pression publique, temps contraint : beaucoup d’élus
            apprennent en marchant. Entre la formation et la réalité quotidienne, il y a un vide.
          </p>
        </div>

        <article class="card problem-panel">
          <p class="card-subtitle">MARYAN commence par un diagnostic</p>
          <ul class="feature-list">
            {supportPaths.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>
    </section>

    <section class="section alt">
      <div class="container">
        <p class="section-kicker">Ce que fait MARYAN</p>
        <h2>Trois gestes simples. Pas douze promesses.</h2>
        <div class="gestures-grid">
          {gestures.map((gesture) => (
            <article class="card gesture-card">
              <p class="gesture-number">{gesture.number}</p>
              <h3>{gesture.title}</h3>
              <p>{gesture.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <p class="section-kicker">Pour qui</p>
        <h2>Tous les élus n’ont pas les mêmes besoins, ni au même moment.</h2>
        <div class="profiles-grid">
          {profiles.map((profile) => (
            <article class="card profile-card">
              <h3>{profile.title}</h3>
              <p>{profile.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section alt">
      <div class="container">
        <div class="why-now-panel">
          <p class="section-kicker">Pourquoi maintenant</p>
          <h2>Les élus doivent aller plus vite, sur des sujets plus exposés, avec moins d’appuis stables.</h2>
          <div class="urgency-lines">
            {urgencyLines.map((line) => <p>{line}</p>)}
          </div>
          <p class="why-now-text">
            Beaucoup découvrent des règles, des postures, des rapports de force et des outils qu’ils n’ont
            jamais appris à manier. MARYAN naît précisément dans cet entre-deux : quand il faut comprendre,
            agir et prendre la parole sans ajouter du bruit, ni perdre du temps.
          </p>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container narrow">
        <div class="cta-panel final-panel">
          <p class="section-kicker">Commencer</p>
          <h2>Commencer par le bon diagnostic.</h2>
          <p>
            Avant les outils, avant les ressources, avant l’expertise, il faut d’abord savoir où vous en êtes
            et de quoi vous avez réellement besoin.
          </p>
          <div class="actions">
            <a class="btn btn-primary" href="/diagnostic">Faire mon diagnostic</a>
            <a class="btn btn-secondary" href="/offres">Découvrir les offres MARYAN</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .home-main {
    padding-bottom: 1rem;
  }

  .manifest-hero {
    position: relative;
    padding: 5.2rem 0 3.2rem;
    overflow: hidden;
  }

  .manifest-hero::before {
    content: '';
    position: absolute;
    inset: 0 0 auto;
    height: 100%;
    background:
      radial-gradient(circle at top right, rgba(127, 167, 201, 0.22), transparent 36%),
      radial-gradient(circle at 18% 16%, rgba(217, 59, 59, 0.08), transparent 26%);
    pointer-events: none;
  }

  .manifest-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.65fr);
    gap: 1.25rem;
    align-items: end;
  }

  .manifest-copy h1 {
    max-width: 11ch;
  }

  .manifest-lead {
    max-width: 40rem;
    color: var(--text);
    font-size: 1.12rem;
    line-height: 1.6;
  }

  .signal-panel {
    position: relative;
    padding: 1.35rem;
    background: linear-gradient(180deg, rgba(255, 253, 248, 0.98), rgba(245, 235, 221, 0.88));
  }

  .signal-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .signal-list li {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-weight: 600;
  }

  .signal-list li::before {
    content: '';
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
    background: var(--neon);
    box-shadow: 0 0 10px rgba(57, 255, 110, 0.6);
    flex-shrink: 0;
  }

  .signal-note {
    margin: 1rem 0 0;
    padding-top: 1rem;
    border-top: 1px solid rgba(216, 211, 202, 0.9);
    color: var(--muted);
    font-size: 0.94rem;
  }

  .problem-section {
    padding-top: 0;
  }

  .problem-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
    gap: 1rem;
    align-items: start;
  }

  .problem-copy h2 {
    max-width: 14ch;
  }

  .problem-text {
    max-width: 36rem;
    margin: 0;
    color: var(--muted);
    font-size: 1.03rem;
    line-height: 1.65;
  }

  .problem-panel {
    padding: 1.3rem;
    background: linear-gradient(135deg, rgba(127, 167, 201, 0.1), rgba(255, 253, 248, 0.98));
  }

  .gestures-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .gesture-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    height: 100%;
    padding: 1.4rem;
  }

  .gesture-card h3,
  .profile-card h3 {
    margin-bottom: 0;
  }

  .gesture-card p:last-child,
  .profile-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.6;
  }

  .gesture-number {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pink);
  }

  .profiles-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .profile-card {
    min-height: 100%;
  }

  .why-now-panel {
    position: relative;
    overflow: hidden;
    padding: 1.8rem;
    border: 1px solid rgba(127, 167, 201, 0.28);
    border-radius: 28px;
    background: linear-gradient(135deg, rgba(127, 167, 201, 0.16), rgba(245, 235, 221, 0.95));
    box-shadow: var(--shadow);
  }

  .why-now-panel::after {
    content: '';
    position: absolute;
    inset: auto -4rem -4rem auto;
    width: 12rem;
    height: 12rem;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(57, 255, 110, 0.18), transparent 70%);
    pointer-events: none;
  }

  .urgency-lines {
    display: grid;
    gap: 0.55rem;
    margin: 1.2rem 0;
  }

  .urgency-lines p {
    margin: 0;
    font-size: clamp(1.1rem, 2vw, 1.45rem);
    line-height: 1.25;
    color: var(--text);
  }

  .why-now-text {
    max-width: 46rem;
    margin: 0;
    color: var(--text);
    line-height: 1.65;
  }

  .final-panel {
    text-align: center;
  }

  .final-panel p {
    max-width: 35rem;
    margin-left: auto;
    margin-right: auto;
  }

  .final-panel .actions {
    justify-content: center;
  }

  @media (max-width: 980px) {
    .manifest-grid,
    .problem-grid,
    .gestures-grid,
    .profiles-grid {
      grid-template-columns: 1fr;
    }

    .manifest-copy h1,
    .problem-copy h2 {
      max-width: none;
    }
  }

  @media (max-width: 720px) {
    .manifest-hero {
      padding: 4rem 0 2.6rem;
    }

    .why-now-panel,
    .gesture-card,
    .signal-panel {
      padding: 1.2rem;
    }
  }
</style>
