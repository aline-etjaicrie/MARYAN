---
import { Image } from 'astro:assets';
import Layout from '../layouts/BaseLayout.astro';
import heroScene from '../assets/maryan-hero-mandat.png';

const heroPreview = [
  {
    title: 'Situation',
    copy: 'Comprendre ce qui se joue vraiment avant d’agir.'
  },
  {
    title: 'Priorité',
    copy: 'Identifier le sujet à traiter en premier.'
  },
  {
    title: 'Suite',
    copy: 'Choisir le bon niveau d’appui pour avancer.'
  }
];

const diagnosticPoints = [
  {
    title: 'Clarifier votre situation',
    copy: 'Nommer plus clairement ce qui se joue dans votre mandat.'
  },
  {
    title: 'Identifier vos priorités',
    copy: 'Faire ressortir ce qui demande votre attention en premier.'
  },
  {
    title: 'Savoir quoi faire en premier',
    copy: 'Repartir avec une direction lisible, sans dispersion.'
  }
];

const copilotePoints = [
  'une situation à gérer',
  'une décision à prendre',
  'un doute à lever'
];

const benefits = [
  'comprendre plus rapidement',
  'structurer vos décisions',
  'éviter les erreurs classiques',
  'gagner du temps au quotidien'
];

const credibilityPoints = [
  'plus de 20 ans d’expérience en communication publique et en cabinet',
  'une connaissance directe des pratiques institutionnelles',
  'des situations concrètes intégrées dans l’outil'
];

const individualOffer = [
  'abonnement individuel',
  'accès direct à l’outil',
  'démarrage immédiat'
];

const collectiveOffer = [
  'accès groupé pour plusieurs élu.e.s',
  'déploiement simple',
  'moins de 10 € / élu.e / mois dans de nombreuses configurations'
];
---

<Layout
  title="MARYAN — Le copilote de mandat au service de la clarté"
  description="Faites le point en quelques minutes. Clarifiez votre situation, avancez avec des réponses adaptées à votre mandat, en accès individuel ou collectif."
>
  <section class="home-hero">
    <div class="container home-hero-grid">
      <div class="hero-copy">
        <h1>
          <span class="hero-title-brand">MARYAN</span>
          <span class="hero-title-line">
            Le <span class="accent-keyword">copilote</span> de <span class="accent-keyword">mandat</span>
          </span>
          <span class="hero-title-line">
            au service de la <span class="accent-keyword">clarté</span>
          </span>
        </h1>

        <p class="hero-hook">
          Exercer un mandat aujourd’hui est complexe.
          <br />
          Vous n’êtes pas censé.e tout savoir.
        </p>

        <p class="hero-support">
          Faites le point en quelques minutes.
          <br />
          Avancez avec des réponses adaptées à votre situation.
        </p>

        <div class="hero-actions">
          <a href="/diagnostic" class="btn-primary-v3 hero-primary">Lancer le diagnostic</a>
          <a href="/copilote" class="btn-secondary-v3 hero-secondary">Poser une question</a>
        </div>

        <p class="hero-note">Le diagnostic ouvre le parcours, en accès individuel comme en déploiement collectif.</p>
      </div>

      <div class="hero-media">
        <figure class="hero-scene">
          <div class="hero-scene-frame">
            <Image
              src={heroScene}
              alt="Écharpe tricolore, carnet, lunettes et smartphone posés sur une table de travail."
              class="hero-scene-image"
              widths={[720, 960, 1280]}
              sizes="(max-width: 1024px) calc(100vw - 4rem), 46vw"
              quality={84}
              loading="eager"
              fetchpriority="high"
            />
          </div>
          <figcaption class="hero-scene-caption">
            <strong>Une scène de travail réelle.</strong>
            <span>Mandat local, arbitrages concrets, appui numérique discret.</span>
          </figcaption>
        </figure>

        <aside class="hero-context-card">
          <span class="label-v3">Première étape</span>
          <h2>Le diagnostic vous donne une première direction.</h2>

          <div class="hero-context-grid">
            {heroPreview.map((item) => (
              <div class="hero-context-item">
                <strong>{item.title}</strong>
                <span>{item.copy}</span>
              </div>
            ))}
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section-v3">
    <div class="container">
      <div class="section-head">
        <span class="label-v3">Diagnostic</span>
        <h2>Par où <span class="accent-keyword">commencer</span> ?</h2>
        <p class="section-intro">Le diagnostic vous permet de :</p>
      </div>

      <div class="point-grid point-grid-three">
        {diagnosticPoints.map((point, index) => (
          <article class="point-card">
            <span class="point-index">{String(index + 1).padStart(2, '0')}</span>
            <h3>{point.title}</h3>
            <p>{point.copy}</p>
          </article>
        ))}
      </div>

      <div class="section-close">
        <p class="section-conclusion">En quelques minutes, vous avez une direction claire.</p>
        <a href="/diagnostic" class="btn-primary-v3">Lancer le diagnostic</a>
      </div>
    </div>
  </section>

  <section class="section-v3 section-copilote">
    <div class="container copilote-grid">
      <div class="section-head section-head-light">
        <span class="label-v3">Copilote</span>
        <h2>
          Une question concrète, une réponse
          <span class="accent-keyword"> structurée</span>
        </h2>
        <p class="section-intro">
          Posez votre question.
          <br />
          Obtenez une réponse claire, directement applicable.
        </p>
        <p class="copilote-note">
          <strong>Un appui, pas un substitut.</strong>
          <br />
          Pour décider plus clairement, plus vite, avec plus de sécurité.
        </p>
        <a href="/copilote" class="btn-secondary-v3">Accéder au copilote</a>
      </div>

      <div class="copilote-panel">
        <span class="copilote-panel-label">Pour traiter</span>
        <ul class="copilote-list">
          {copilotePoints.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section-v3 benefits-section">
    <div class="container">
      <div class="section-head section-head-center">
        <span class="label-v3">Bénéfices</span>
        <h2>Moins <span class="accent-keyword">subir</span>. Plus <span class="accent-keyword">agir</span>.</h2>
      </div>

      <div class="point-grid point-grid-four">
        {benefits.map((benefit) => (
          <article class="point-card benefit-card">
            <h3>{benefit}</h3>
          </article>
        ))}
      </div>

      <p class="section-conclusion section-conclusion-center">Être plus serein dans son mandat.</p>
    </div>
  </section>

  <section class="section-v3 credibility-section">
    <div class="container">
      <div class="credibility-shell">
        <div class="section-head section-head-light">
          <span class="label-v3">Crédibilité</span>
          <h2>
            Un outil conçu à partir de la <span class="accent-keyword">réalité</span> du
            <span class="accent-keyword"> mandat</span>
          </h2>
        </div>

        <div class="point-grid point-grid-three">
          {credibilityPoints.map((item) => (
            <article class="credibility-card">
              <p>{item}</p>
            </article>
          ))}
        </div>

        <p class="credibility-conclusion">Une IA construite à partir de cas réels, pas une IA abstraite.</p>
      </div>
    </div>
  </section>

  <section class="section-v3 offers-section">
    <div class="container">
      <div class="section-head section-head-center">
        <span class="label-v3">Accès</span>
        <h2>Choisir le bon format d’<span class="accent-keyword">accès</span></h2>
        <p class="section-intro section-intro-narrow">
          MARYAN s’adresse aux élu.e.s qui veulent avancer seul.e.s comme aux équipes qui veulent
          équiper plusieurs élu.e.s.
        </p>
      </div>

      <div class="offers-grid">
        <article class="offer-card card-v3">
          <span class="offer-audience">Pour un.e élu.e</span>
          <h3>Un accès individuel, direct et simple à activer.</h3>
          <ul class="clean-list">
            {individualOffer.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <a href="/offres" class="btn-primary-v3">Découvrir les offres</a>
        </article>

        <article class="offer-card offer-card-highlight">
          <span class="offer-audience">Pour une équipe ou une collectivité</span>
          <h3>Un format pensé pour déployer MARYAN à plusieurs.</h3>
          <ul class="clean-list">
            {collectiveOffer.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <a href="/contact" class="btn-secondary-v3">Demander une démo</a>
        </article>
      </div>

      <div class="final-cta-panel">
        <p>Anticiper, plutôt que subir.</p>
        <div class="final-cta-actions">
          <a href="/diagnostic" class="btn-primary-v3 hero-primary">Lancer le diagnostic</a>
          <a href="/offres" class="btn-secondary-v3">Voir les offres</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .accent-keyword {
      color: var(--neon) !important;
      font-family: var(--font-accent);
      font-style: italic;
      font-weight: 700;
      display: inline;
      white-space: normal;
    }

    .home-hero {
      position: relative;
      overflow: hidden;
      background:
        radial-gradient(circle at top left, rgba(230, 57, 70, 0.16), transparent 34%),
        radial-gradient(circle at bottom right, rgba(173, 255, 47, 0.14), transparent 32%),
        var(--deep);
      color: white;
      padding: 5.5rem 0 6.25rem;
      border-bottom: 1px solid rgba(173, 255, 47, 0.24);
    }

    .home-hero-grid {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(380px, 0.98fr);
      gap: 3rem;
      align-items: center;
    }

    .hero-copy {
      max-width: 38rem;
    }

    .home-hero h1,
    .section-head h2 {
      text-wrap: balance;
    }

    .home-hero h1 {
      color: white;
      font-size: clamp(2.8rem, 5.1vw, 4.9rem);
      line-height: 0.98;
      letter-spacing: -0.045em;
      margin-bottom: 1.4rem;
    }

    .hero-title-brand,
    .hero-title-line {
      display: block;
    }

    .hero-title-brand {
      margin-bottom: 1rem;
      font-size: clamp(0.95rem, 1.5vw, 1.08rem);
      line-height: 1.2;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.7);
    }

    .hero-hook {
      max-width: 34rem;
      margin: 0 0 1rem;
      font-size: clamp(1.18rem, 2vw, 1.45rem);
      line-height: 1.5;
      font-weight: 600;
      color: white;
    }

    .hero-support {
      max-width: 34rem;
      margin: 0 0 1.75rem;
      font-size: 1.05rem;
      line-height: 1.7;
      color: rgba(255, 255, 255, 0.8);
    }

    .hero-actions,
    .final-cta-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      align-items: center;
    }

    .hero-primary {
      min-width: 16rem;
    }

    .hero-secondary {
      background: rgba(255, 255, 255, 0.12);
      color: white;
      border-color: rgba(255, 255, 255, 0.18);
    }

    .hero-secondary:hover,
    .hero-secondary:focus-visible {
      background: white !important;
      color: var(--deep) !important;
      border-color: white !important;
    }

    .hero-note {
      margin-top: 1rem;
      color: rgba(255, 255, 255, 0.68);
      font-size: 0.94rem;
      line-height: 1.55;
    }

    .hero-media {
      display: grid;
      gap: 1rem;
      align-content: start;
    }

    .hero-scene {
      margin: 0;
      display: grid;
      gap: 0.9rem;
    }

    .hero-scene-frame {
      position: relative;
      overflow: hidden;
      border-radius: 32px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: rgba(255, 255, 255, 0.08);
    }

    .hero-scene-frame::after {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        linear-gradient(180deg, rgba(10, 25, 47, 0.02) 0%, rgba(10, 25, 47, 0.12) 100%);
    }

    .hero-scene-image {
      display: block;
      width: 100%;
      height: auto;
      aspect-ratio: 0.94 / 1.02;
      object-fit: cover;
      object-position: 40% 54%;
    }

    .hero-scene-caption {
      display: grid;
      gap: 0.15rem;
      padding-left: 0.2rem;
      color: rgba(255, 255, 255, 0.7);
      font-size: 0.94rem;
      line-height: 1.5;
    }

    .hero-scene-caption strong {
      color: white;
      font-size: 1rem;
    }

    .hero-context-card {
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 28px;
      padding: 1.4rem;
      backdrop-filter: blur(8px);
    }

    .hero-context-card .label-v3,
    .section-head-light .label-v3,
    .credibility-shell .label-v3 {
      color: white !important;
    }

    .hero-context-card .label-v3::before,
    .section-head-light .label-v3::before,
    .credibility-shell .label-v3::before {
      background: white !important;
    }

    .hero-context-card h2 {
      color: white;
      font-size: clamp(1.4rem, 2vw, 1.8rem);
      margin-bottom: 1rem;
      line-height: 1.15;
    }

    .hero-context-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.8rem;
    }

    .hero-context-item {
      padding: 0.95rem 1rem;
      border-radius: 18px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(255, 255, 255, 0.05);
    }

    .hero-context-item strong {
      display: block;
      margin-bottom: 0.3rem;
      color: white;
      font-size: 0.98rem;
    }

    .hero-context-item span {
      display: block;
      color: rgba(255, 255, 255, 0.74);
      font-size: 0.9rem;
      line-height: 1.55;
    }

    .section-head {
      max-width: 46rem;
      margin-bottom: 2.75rem;
    }

    .section-head-center {
      margin-left: auto;
      margin-right: auto;
      text-align: center;
    }

    .section-head h2 {
      font-size: clamp(2.1rem, 4vw, 3.35rem);
      margin-bottom: 1rem;
    }

    .section-head-light h2,
    .section-head-light p,
    .credibility-shell h2,
    .credibility-shell p {
      color: white !important;
    }

    .section-intro {
      color: #54636C;
      font-size: 1.06rem;
      line-height: 1.7;
    }

    .section-intro-narrow {
      max-width: 40rem;
      margin-left: auto;
      margin-right: auto;
    }

    .point-grid {
      display: grid;
      gap: 1rem;
    }

    .point-grid-three {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .point-grid-four {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .point-card {
      padding: 1.5rem;
      border-radius: 28px;
      background: white;
      border: 1px solid var(--border);
      box-shadow: 0 18px 50px rgba(10, 25, 47, 0.05);
    }

    .point-index {
      display: inline-block;
      margin-bottom: 1rem;
      font-size: 0.85rem;
      font-weight: 800;
      letter-spacing: 0.16em;
      color: var(--accent-red);
    }

    .point-card h3 {
      margin-bottom: 0.65rem;
      font-size: 1.2rem;
    }

    .point-card p {
      color: #54636C;
    }

    .section-close {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-top: 1.75rem;
    }

    .section-conclusion {
      font-size: 1.08rem;
      font-weight: 700;
      color: var(--deep);
    }

    .section-conclusion-center {
      margin-top: 1.75rem;
      text-align: center;
    }

    .section-copilote {
      background:
        radial-gradient(circle at top right, rgba(173, 255, 47, 0.1), transparent 24%),
        linear-gradient(180deg, var(--deep) 0%, #11253B 100%);
    }

    .copilote-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(320px, 0.82fr);
      gap: 1.5rem;
      align-items: center;
    }

    .copilote-note {
      margin: 0 0 1.75rem;
      color: rgba(255, 255, 255, 0.8);
      font-size: 1rem;
      line-height: 1.7;
    }

    .copilote-panel {
      padding: 2rem;
      border-radius: 32px;
      background: rgba(255, 255, 255, 0.96);
      border: 1px solid rgba(255, 255, 255, 0.14);
      box-shadow: 0 22px 60px rgba(4, 10, 18, 0.2);
    }

    .copilote-panel-label {
      display: inline-block;
      margin-bottom: 1rem;
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--accent-red);
    }

    .copilote-list {
      list-style: none;
      display: grid;
      gap: 0.9rem;
      padding: 0;
      margin: 0;
    }

    .copilote-list li {
      position: relative;
      padding: 1rem 1.1rem 1rem 2.5rem;
      border-radius: 20px;
      background: rgba(10, 25, 47, 0.04);
      border: 1px solid rgba(10, 25, 47, 0.07);
      color: var(--deep);
      font-size: 1.02rem;
      font-weight: 700;
      line-height: 1.5;
    }

    .copilote-list li::before {
      content: '';
      position: absolute;
      left: 1rem;
      top: 1.45rem;
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: var(--neon);
      box-shadow: 0 0 10px rgba(173, 255, 47, 0.6);
      transform: translateY(-50%);
    }

    .benefits-section {
      background: linear-gradient(180deg, var(--bg) 0%, #EEF3F7 100%);
    }

    .benefit-card {
      text-align: center;
      min-height: 100%;
    }

    .benefit-card h3 {
      margin: 0;
      font-size: 1.15rem;
    }

    .credibility-shell {
      position: relative;
      overflow: hidden;
      padding: 2.5rem;
      border-radius: 36px;
      background:
        radial-gradient(circle at bottom left, rgba(173, 255, 47, 0.14), transparent 28%),
        var(--deep);
    }

    .credibility-card {
      padding: 1.4rem;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .credibility-card p {
      margin: 0;
      color: rgba(255, 255, 255, 0.82) !important;
      line-height: 1.65;
    }

    .credibility-conclusion {
      margin-top: 1.75rem;
      font-size: 1.08rem;
      font-weight: 700;
      color: white !important;
    }

    .offers-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .offer-card {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      justify-content: space-between;
      padding: 2rem;
      border-radius: 32px;
    }

    .offer-card h3 {
      font-size: 1.55rem;
      margin: 0;
    }

    .offer-audience {
      display: inline-block;
      font-size: 0.82rem;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--accent-red);
    }

    .offer-card-highlight {
      background:
        radial-gradient(circle at top right, rgba(173, 255, 47, 0.16), transparent 30%),
        var(--deep);
      color: white;
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 24px 60px rgba(10, 25, 47, 0.18);
      border-radius: 32px;
      padding: 2rem;
    }

    .offer-card-highlight h3,
    .offer-card-highlight p,
    .offer-card-highlight li {
      color: white !important;
    }

    .offer-card-highlight .offer-audience {
      color: var(--neon);
    }

    .clean-list {
      list-style: none;
      display: grid;
      gap: 0.8rem;
      padding: 0;
      margin: 0;
    }

    .clean-list li {
      position: relative;
      padding-left: 1.25rem;
      color: #54636C;
      line-height: 1.55;
    }

    .clean-list li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.78rem;
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--neon);
      box-shadow: 0 0 8px rgba(173, 255, 47, 0.4);
      transform: translateY(-50%);
    }

    .offer-card-highlight .clean-list li::before {
      background: white;
      box-shadow: none;
    }

    .final-cta-panel {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 1.25rem;
      padding: 2rem 2.15rem;
      border-radius: 32px;
      background: var(--deep);
    }

    .final-cta-panel p {
      margin: 0;
      color: white;
      font-size: clamp(1.55rem, 3vw, 2.25rem);
      font-weight: 800;
      line-height: 1.15;
    }

    @media (max-width: 1024px) {
      .home-hero-grid,
      .copilote-grid,
      .point-grid-three,
      .point-grid-four,
      .offers-grid,
      .hero-context-grid {
        grid-template-columns: 1fr;
      }

      .home-hero {
        padding: 4.75rem 0 5.5rem;
      }

      .hero-copy {
        max-width: 100%;
      }

      .hero-scene-image {
        aspect-ratio: 1.3 / 1;
        object-position: 44% 56%;
      }
    }

    @media (max-width: 768px) {
      .home-hero h1 {
        font-size: clamp(2.3rem, 10vw, 3.2rem);
      }

      .hero-actions,
      .final-cta-actions,
      .section-close {
        flex-direction: column;
        align-items: stretch;
      }

      .hero-actions a,
      .final-cta-actions a,
      .section-close a,
      .copilote-grid .btn-secondary-v3 {
        width: 100%;
      }

      .hero-primary {
        min-width: 0;
      }

      .hero-context-card,
      .copilote-panel,
      .point-card,
      .credibility-shell,
      .offer-card,
      .offer-card-highlight,
      .final-cta-panel {
        padding: 1.6rem;
      }

      .section-head h2,
