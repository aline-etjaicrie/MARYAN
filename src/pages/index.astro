---
import { Image } from 'astro:assets';
import Layout from '../layouts/BaseLayout.astro';
import heroScene from '../assets/maryan-hero-mandat.png';
import hubPortraits from '../assets/hub-experts-portraits.png';
import droitsImg from '../assets/droits-devoirs-documents.png';
import decryptageImg from '../assets/decryptage-espace-travail.png';

const situations = [
  {
    title: 'Délibération technique à présenter',
    text: 'Vous devez en dire l\'essentiel sans vous noyer dans le jargon.',
    result: 'Maryan traduit le technique en posture politique lisible.'
  },
  {
    title: 'Interpellation publique sensible',
    text: 'Vous avez besoin de la bonne réponse, pas de la réponse rapide.',
    result: 'Maryan relit les enjeux, les risques, ce que vous pouvez dire.'
  },
  {
    title: 'Décision à arbitrer, options floues',
    text: 'Vous devez trancher. Pas demain. Ce soir.',
    result: 'Maryan structure les options et les points de vigilance.'
  },
  {
    title: 'Début de mandat, repères encore flous',
    text: 'Tout va vite et vous courez après les sujets.',
    result: 'Maryan aide à prioriser et à retrouver un cadre.'
  }
];

const steps = [
  {
    title: 'Vous posez votre situation',
    text: 'Question libre ou diagnostic guidé. Pas de formulaire compliqué.'
  },
  {
    title: 'Maryan lit entre les lignes',
    text: 'Ce qui relève du risque, du contexte, de la marge de manœuvre réelle.'
  },
  {
    title: 'Vous repartez avec quelque chose d\'utilisable',
    text: 'Enjeux, options, points de vigilance, prochaine étape.'
  }
];

const resourceCards = [
  {
    title: 'Lire et présenter une délibération',
    desc: 'Comprendre ce qui est vraiment en jeu, pas juste ce qui est écrit.',
    href: '/ressources/le-conseil-municipal-a-quoi-il-sert-vraiment'
  },
  {
    title: 'Quand l\'administration freine',
    desc: 'Distinguer le blocage technique du blocage politique. Et quoi faire.',
    href: '/ressources/travailler-services-mairie'
  },
  {
    title: 'Ce qu\'un élu peut et ne peut pas dire publiquement',
    desc: 'Les limites réelles, sans le vernis juridique.',
    href: '/ressources/polemique-reseaux-sociaux'
  },
  {
    title: 'Prévenir et gérer une situation sensible',
    desc: 'Ce que la loi impose. Ce que la posture exige.',
    href: '/ressources/reagir-interpellation-agressive'
  }
];
---

<Layout
  title="MARYAN — L'assistant IA pour votre mandat"
  description="MARYAN est l'assistant IA pour les élu·es locaux : clarifier une situation, trancher plus vite et passer à l'action sans se fragiliser."
>

  <!-- 1. HERO -->
  <section class="home-hero">
    <!-- Photo plein fond -->
    <Image
      src={heroScene}
      alt="Écharpe tricolore, carnet, lunettes et smartphone posés sur une table de travail."
      class="hero-photo"
      widths={[720, 960, 1280]}
      sizes="100vw"
      quality={84}
      loading="eager"
      fetchpriority="high"
    />
    <!-- Dégradé par-dessus -->
    <div class="hero-gradient"></div>
    <!-- Contenu texte -->
    <div class="container">
      <div class="hero-content">
        <span class="label-v3">Premier assistant IA pour les élus locaux</span>
        <h1>L'assistant IA pour <span class="accent-keyword">votre mandat</span></h1>
        <p class="hero-subtitle">
          Gagnez du temps sur vos dossiers,
          vos délibérations et vos prises de parole.
        </p>
        <div class="hero-actions">
          <a href="/diagnostic" class="btn-primary-v3">Faire le diagnostic</a>
          <a href="/copilote" class="btn-secondary-v3 hero-secondary">Essayer le copilote</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2–8. SCROLL-STACK — toutes sections intermédiaires -->
  <div class="scroll-stack">

    <!-- 2. SITUATIONS -->
    <section class="scroll-card light" style="background: #F4F4F0;">
      <div class="container">
        <div class="section-head">
          <span class="label-v3">Situations réelles</span>
          <h2>Vous connaissez ces <span class="accent-keyword">moments</span>.</h2>
        </div>
        <div class="situations-grid">
          {situations.map((item) => (
            <article class="usage-card card-v3">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
              <p class="result-line">
                <span>Résultat :</span> {item.result}
              </p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- 3. MÉTHODE -->
    <section id="comment-ca-marche" class="scroll-card" style="background: #0A192F;">
      <div class="container">
        <div class="section-head">
          <span class="label-v3">Méthode</span>
          <h2>En <span class="accent-keyword">pratique</span>, ça donne ça.</h2>
          <p class="section-intro">
            Vous décrivez ce que vous vivez.
            Maryan fait remonter ce qui compte vraiment.
          </p>
        </div>
        <div class="steps-grid">
          {steps.map((step, index) => (
            <article class="step-card card-v3">
              <span class="step-index">{String(index + 1).padStart(2, '0')}</span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- 4. RESSOURCES -->
    <section class="scroll-card light" style="background: #F4F4F0;">
      <div class="container">
        <div class="section-head">
          <span class="label-v3">Bibliothèque de ressources</span>
          <h2>Pas des articles. Des fiches pour <span class="accent-keyword">tenir sa posture</span>.</h2>
          <p class="section-intro">
            Courtes, pédagos, ancrées dans le réel du mandat.
            Entre le décryptage et le coaching — sans le jargon des deux.
          </p>
        </div>
        <div class="resources-grid">
          {resourceCards.map((card) => (
            <a href={card.href} class="resource-card card-v3">
              <h3>{card.title}</h3>
              <p>{card.desc}</p>
              <span class="resource-link-label">Lire la fiche →</span>
            </a>
          ))}
        </div>
        <div class="section-cta-center">
          <a href="/ressources" class="btn-primary-v3">Accéder aux ressources</a>
        </div>
      </div>
    </section>

    <!-- 5. HUB EXPERTS -->
    <section class="scroll-card" style="background: #0A192F;">
      <div class="scroll-card-split">
        <div class="scroll-card-img-wrap">
          <Image src={hubPortraits} alt="Portraits de professionnels experts." class="scroll-card-image" widths={[400, 700]} sizes="(max-width: 768px) 0vw, 42vw" quality={84} />
          <div class="scroll-card-img-overlay" style="background: linear-gradient(to left, #0A192F 0%, rgba(10,25,47,0.6) 40%, transparent 100%);"></div>
        </div>
        <div class="scroll-card-inner">
          <span class="section-eyebrow eyebrow-neon">Experts &amp; formation</span>
          <h2 style="color: #F4F4F0; font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 800; max-width: 480px; margin-bottom: 16px; line-height: 1.25;">Un appui humain, quand <span class="accent-keyword">il le faut</span>.</h2>
          <p style="color: rgba(244,244,240,0.65); font-size: 1.05rem; max-width: 420px; line-height: 1.75; margin-bottom: 28px;">Les ressources donnent les repères. Le copilote aide à mettre les choses en mots. Le hub permet ensuite de solliciter un expert ou d'envisager un accompagnement sur mesure.</p>
          <div class="hub-cta-group">
            <a href="/hub-experts" class="btn-neon-stack">Trouver un expert →</a>
            <a href="/hub-experts" class="btn-outline-white btn-secondary-v3">Proposer mon expertise</a>
          </div>
        </div>
      </div>
    </section>

    <!-- 6. DROITS & DEVOIRS -->
    <section class="scroll-card light" style="background: #F4F4F0;">
      <div class="scroll-card-split">
        <div class="scroll-card-inner">
          <span class="section-eyebrow eyebrow-dark">Droits &amp; devoirs</span>
          <h2 style="color: #0A192F; font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 800; max-width: 480px; margin-bottom: 16px; line-height: 1.25;">Vous avez plus de <span class="accent-keyword">pouvoir</span> que vous ne le pensez.</h2>
          <p style="color: rgba(10,25,47,0.6); font-size: 1.05rem; max-width: 420px; line-height: 1.75; margin-bottom: 28px;">Formation, protection fonctionnelle, droit d'alerte, indemnités — la loi vous protège. Encore faut-il le savoir, et savoir s'en saisir. MARYAN vous aide à connaître le cadre exact dans lequel vous exercez votre mandat.</p>
          <a href="/droits" class="btn-dark-stack">Lire les droits &amp; devoirs →</a>
        </div>
        <div class="scroll-card-img-wrap">
          <Image src={droitsImg} alt="Documents administratifs et enveloppe officielle." class="scroll-card-image" widths={[400, 700]} sizes="(max-width: 768px) 0vw, 42vw" quality={84} />
          <div class="scroll-card-img-overlay" style="background: linear-gradient(to right, #F4F4F0 0%, rgba(244,244,240,0.6) 40%, transparent 100%);"></div>
        </div>
      </div>
    </section>

    <!-- 7. DÉCRYPTAGE -->
    <section class="scroll-card" style="background: #0A192F;">
      <div class="scroll-card-split">
        <div class="scroll-card-img-wrap">
          <Image src={decryptageImg} alt="Espace de travail politique et médiatique." class="scroll-card-image" widths={[400, 700]} sizes="(max-width: 768px) 0vw, 42vw" quality={84} />
          <div class="scroll-card-img-overlay" style="background: linear-gradient(to left, #0A192F 0%, rgba(10,25,47,0.6) 40%, transparent 100%);"></div>
        </div>
        <div class="scroll-card-inner">
          <span class="section-eyebrow eyebrow-neon">Décryptage</span>
          <h2 style="color: #F4F4F0; font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 800; max-width: 480px; margin-bottom: 16px; line-height: 1.25;">Le mandat local, vu de <span class="accent-keyword">l'intérieur</span>.</h2>
          <p style="color: rgba(244,244,240,0.65); font-size: 1.05rem; max-width: 420px; line-height: 1.75; margin-bottom: 28px;">Des articles longs, sans jargon et sans langue de bois. Pour comprendre ce qui se joue vraiment dans une délibération, une commission, un conseil municipal. Pas de l'information — de l'analyse.</p>
          <a href="/blog" class="btn-neon-stack">Lire les articles →</a>
        </div>
      </div>
    </section>

    <!-- 8. EXPLORER AUSSI -->
    <section class="scroll-card light" style="background: #FDFBF8; align-items: flex-start; padding-top: 80px; padding-bottom: 60px;">
      <div style="width: 100%;">
        <span class="section-eyebrow eyebrow-dark" style="margin-bottom: 32px; font-size: 1rem; letter-spacing: 0.1em;">Explorer aussi</span>
        <div class="grid-4">
          <div class="mini-card">
            <span class="mini-card-accent" style="background: #C6FF4D;"></span>
            <span class="mini-card-label">Les mots</span>
            <strong class="mini-card-title">La langue politique, traduite.</strong>
            <p class="mini-card-body">La langue institutionnelle est un outil d'exclusion autant qu'un outil de gouvernance. DGF, délibération, mandat impératif, pouvoir de police — MARYAN construit un glossaire vivant, avec les élu·e·s, pour nommer ce qui se passe vraiment.</p>
            <a href="/mots" class="mini-card-link">Explorer le glossaire →</a>
          </div>
          <div class="mini-card">
            <span class="mini-card-accent" style="background: #E43644;"></span>
            <span class="mini-card-label">À propos</span>
            <strong class="mini-card-title">Un outil engagé, pas partisan.</strong>
            <p class="mini-card-body">MARYAN est né d'un constat simple : entre la formation et l'exercice quotidien du mandat, il manque quelque chose. Un appui plus immédiat, plus lisible, plus ajusté à la réalité de ceux qui tiennent un conseil municipal un mardi soir.</p>
            <a href="/a-propos" class="mini-card-link">Lire →</a>
          </div>
        </div>
      </div>
    </section>

  </div>

  <!-- 9. CTA FINAL -->
  <section class="section-v3 final-cta-section">
    <div class="container">
      <div class="final-cta-panel">
        <h2>
          Une délibération à présenter.
          Un conseil qui commence demain.
          <span class="accent-keyword">C'est maintenant.</span>
        </h2>
        <div class="final-cta-actions">
          <a href="/diagnostic" class="btn-primary-v3">Faire le diagnostic</a>
          <a href="/copilote" class="btn-secondary-v3">Essayer le copilote</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* ─── SCROLL-STACK ─── */
    .scroll-stack {
      position: relative;
      margin: 0;
      padding: 0;
    }
    .scroll-card {
      position: sticky;
      top: 0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 80px 10%;
      overflow: hidden;
    }
    .scroll-card:nth-child(1) { z-index: 1; }
    .scroll-card:nth-child(2) { z-index: 2; }
    .scroll-card:nth-child(3) { z-index: 3; }
    .scroll-card:nth-child(4) { z-index: 4; }
    .scroll-card:nth-child(5) { z-index: 5; }
    .scroll-card:nth-child(6) { z-index: 6; }
    .scroll-card:nth-child(7) { z-index: 7; }
    .scroll-card-inner { max-width: 640px; }

    /* Annule le padding latéral du container à l'intérieur des scroll-cards */
    .scroll-card .container {
      padding-left: 0;
      padding-right: 0;
    }

    /* ─── EYEBROW ─── */
    .section-eyebrow {
      font-size: 0.85rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      display: block;
      margin-bottom: 16px;
    }
    .eyebrow-neon { color: #C6FF4D; }
    .eyebrow-dark { color: rgba(10,25,47,0.45); }

    /* ─── BOUTONS STACK ─── */
    .btn-neon-stack {
      background: #C6FF4D;
      color: #0A192F;
      font-weight: 700;
      padding: 10px 22px;
      border-radius: 8px;
      text-decoration: none;
      font-size: 0.875rem;
      display: inline-block;
    }
    .btn-dark-stack {
      background: #0A192F;
      color: #F4F4F0;
      font-weight: 700;
      padding: 10px 22px;
      border-radius: 8px;
      text-decoration: none;
      font-size: 0.875rem;
      display: inline-block;
    }

    /* ─── GRILLE EXPLORER ─── */
    .grid-4 {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    /* ─── MINI-CARDS ─── */
    .mini-card {
      background: #fff;
      border: 0.5px solid rgba(10,25,47,0.1);
      border-radius: 12px;
      padding: 20px 20px 20px;
      padding-bottom: 20px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .mini-card-accent {
      display: block;
      width: 24px;
      height: 3px;
      border-radius: 2px;
      margin-bottom: 4px;
    }
    .mini-card-label {
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(10,25,47,0.4);
    }
    .mini-card-title {
      font-size: 1rem;
      font-weight: 700;
      color: #0A192F;
      line-height: 1.3;
    }
    .mini-card-body {
      font-size: 0.875rem;
      color: rgba(10,25,47,0.55);
      line-height: 1.5;
      flex: 1;
    }
    .mini-card-link {
      font-size: 0.8rem;
      font-weight: 600;
      color: #0A192F;
      text-decoration: none;
      margin-top: 4px;
    }

    /* ─── DARK CARD — textes sur fond sombre ─── */
    .scroll-card:not(.light) .label-v3 {
      color: #C6FF4D;
      border-color: rgba(198, 255, 77, 0.25);
      background: rgba(198, 255, 77, 0.07);
    }
    .scroll-card:not(.light) .section-head h2 {
      color: #F4F4F0;
    }
    .scroll-card:not(.light) .section-intro {
      color: rgba(244, 244, 240, 0.65);
    }
    .scroll-card:not(.light) .card-v3 {
      background: rgba(255, 255, 255, 0.05);
      border-color: rgba(255, 255, 255, 0.1);
    }
    .scroll-card:not(.light) .step-card h3,
    .scroll-card:not(.light) .usage-card h3 {
      color: #F4F4F0;
    }
    .scroll-card:not(.light) .step-card p,
    .scroll-card:not(.light) .usage-card p {
      color: rgba(244, 244, 240, 0.65);
    }
    .scroll-card:not(.light) .step-index {
      color: #C6FF4D;
    }
    .scroll-card:not(.light) .result-line {
      border-top-color: rgba(255, 255, 255, 0.12);
    }

    /* ─── TOKENS ─── */
    .accent-keyword {
      color: var(--neon);
      font-family: var(--font-accent);
      font-style: italic;
      font-weight: 700;
      text-transform: none;
    }

    /* Variante sur fond clair : accent rouge */
    .scroll-card.light .accent-keyword {
      color: var(--accent-red);
      -webkit-text-stroke: 0;
    }

    /* ─── ANIMATIONS ─── */
    @keyframes heroTextIn {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ─── HERO ─── */
    .home-hero {
      position: relative;
      min-height: 75vh;
      background: #0A192F;
      color: white;
      display: flex;
      align-items: center;
      overflow: hidden;
    }

    /* Photo plein fond */
    .hero-photo {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      object-position: 54% 52%;
      z-index: 0;
    }

    /* Dégradé */
    .hero-gradient {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: linear-gradient(
        to right,
        #0A192F 45%,
        rgba(10,25,47,0.7) 65%,
        rgba(10,25,47,0.1) 100%
      );
      z-index: 1;
    }

    /* Colle le texte au bord gauche du hero */
    .home-hero .container {
      padding-left: 0;
      padding-right: 0;
      max-width: 100%;
      width: 100%;
      padding: 0 5vw;
    }

    /* Contenu texte */
    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 50%;
      padding: 4rem 0;
      animation: heroTextIn 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
      animation-delay: 0s;
      opacity: 0;
    }

    .hero-content h1 {
      color: white;
      font-size: clamp(2rem, 5vw, 3.2rem);
      line-height: 1.06;
      letter-spacing: -0.03em;
      margin: 0 0 1rem;
      text-wrap: balance;
    }

    /* Le h1 du hero est sur fond sombre → accent-keyword reste neon */
    .home-hero .accent-keyword {
      color: var(--neon);
      -webkit-text-stroke: 0;
    }

    .hero-subtitle {
      margin: 0 0 1.5rem;
      color: rgba(255, 255, 255, 0.86);
      max-width: 44ch;
      line-height: 1.65;
      font-size: 1.1rem;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.9rem;
      align-items: center;
      margin-bottom: 1.5rem;
    }

    .hero-secondary {
      background: rgba(255, 255, 255, 0.13);
      color: white;
      border-color: rgba(255, 255, 255, 0.2);
    }

    .hero-secondary:hover,
    .hero-secondary:focus-visible {
      background: white !important;
      color: var(--deep) !important;
      border-color: white !important;
    }

    /* ─── SECTION HEAD ─── */
    .section-head {
      max-width: 46rem;
      margin-bottom: 2rem;
    }

    .section-head-center {
      margin-left: auto;
      margin-right: auto;
      text-align: center;
    }

    .section-head h2 {
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      margin: 0 0 0.85rem;
      text-wrap: balance;
    }

    .section-intro {
      margin: 0;
      color: #54636c;
      line-height: 1.66;
      max-width: 56ch;
    }

    /* ─── SITUATIONS ─── */
    .situations-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .usage-card h3,
    .step-card h3,
    .offer-card h3 {
      margin: 0 0 0.65rem;
      font-size: 1.2rem;
      line-height: 1.28;
    }

    .usage-card p,
    .step-card p,
    .offer-card p {
      margin: 0;
      color: #54636c;
      line-height: 1.62;
    }

    .result-line {
      margin-top: 0.65rem !important;
      padding-top: 0.65rem;
      border-top: 1px solid var(--border);
      font-size: 0.95rem;
    }

    .result-line span {
      color: var(--deep);
      font-weight: 700;
    }

    /* ─── MÉTHODE ─── */
    .steps-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }

    .step-index {
      display: inline-block;
      margin-bottom: 0.6rem;
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      color: var(--accent-red);
    }

    /* ─── RESSOURCES ─── */
    .resources-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .resource-card {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .resource-card:hover {
      border-color: var(--deep);
      box-shadow: 0 4px 20px rgba(10, 25, 47, 0.08);
    }

    .resource-card h3 {
      margin: 0;
      font-size: 1.1rem;
      line-height: 1.3;
      color: var(--deep);
    }

    .resource-card p {
      margin: 0;
      color: #54636c;
      line-height: 1.6;
      font-size: 0.95rem;
      flex: 1;
    }

    .resource-link-label {
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--accent-red);
      margin-top: auto;
    }

    .section-cta-center {
      display: flex;
      justify-content: center;
    }

    /* ─── SECTIONS AVEC IMAGE (split layout) ─── */
    .scroll-card-split {
