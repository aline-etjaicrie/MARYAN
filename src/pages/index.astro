---
import { Image } from 'astro:assets';
import Layout from '../layouts/BaseLayout.astro';
import heroScene from '../assets/maryan-hero-mandat.png';

const situations = [
  {
    title: 'Délibération technique à présenter',
    text: 'Vous devez en dire l\'essentiel sans vous noyer dans le jargon.',
    result: 'Maryan traduit le technique en posture politique lisible.'
  },
  {
    title: 'Interpellation publique sensible',
    text: 'Vous avez besoin de la bonne réponse, pas de la réponse rapide.',
    result: 'Maryan relit les enjeux, les risques, ce que vous pouvez dire.'
  },
  {
    title: 'Décision à arbitrer, options floues',
    text: 'Vous devez trancher. Pas demain. Ce soir.',
    result: 'Maryan structure les options et les points de vigilance.'
  },
  {
    title: 'Début de mandat, repères encore flous',
    text: 'Tout va vite et vous courez après les sujets.',
    result: 'Maryan aide à prioriser et à retrouver un cadre.'
  }
];

const steps = [
  {
    title: 'Vous posez votre situation',
    text: 'Question libre ou diagnostic guidé. Pas de formulaire compliqué.'
  },
  {
    title: 'Maryan lit entre les lignes',
    text: 'Ce qui relève du risque, du contexte, de la marge de manœuvre réelle.'
  },
  {
    title: 'Vous repartez avec quelque chose d\'utilisable',
    text: 'Enjeux, options, points de vigilance, prochaine étape.'
  }
];

const resourceCards = [
  {
    title: 'Lire et présenter une délibération',
    desc: 'Comprendre ce qui est vraiment en jeu, pas juste ce qui est écrit.',
    href: '/ressources/le-conseil-municipal-a-quoi-il-sert-vraiment'
  },
  {
    title: 'Quand l\'administration freine',
    desc: 'Distinguer le blocage technique du blocage politique. Et quoi faire.',
    href: '/ressources/travailler-services-mairie'
  },
  {
    title: 'Ce qu\'un élu peut et ne peut pas dire publiquement',
    desc: 'Les limites réelles, sans le vernis juridique.',
    href: '/ressources/polemique-reseaux-sociaux'
  },
  {
    title: 'Prévenir et gérer une situation sensible',
    desc: 'Ce que la loi impose. Ce que la posture exige.',
    href: '/ressources/reagir-interpellation-agressive'
  }
];

const scenarios = [
  {
    title: 'Délibération technique',
    before: 'Vous lisez. Vous relisez. Vous ne savez pas quoi en dire politiquement.',
    after: 'Vous savez ce qui est en jeu, ce que vous pouvez défendre et comment le formuler.'
  },
  {
    title: 'Interpellation sensible',
    before: 'Vous improvisez. Vous en dites trop ou pas assez.',
    after: 'Une réponse cadrée, avec ce que vous pouvez promettre et ce que vous ne pouvez pas.'
  },
  {
    title: 'Décision à arbitrer',
    before: 'Trop d\'options, pas de lisibilité, difficile de trancher sans se fragiliser.',
    after: 'Un arbitrage argumentable, avec les bons points de vigilance.'
  }
];

const individualOffer = ['Diagnostic initial', 'Copilote', 'Ressources', 'Activation immédiate'];
const teamOffer = ['Pack groupe jusqu\'à 8 élu·es', 'Offre collectivité à partir de 5 élu·es', 'Tarif ajusté'];
---

<Layout
  title="MARYAN — L'assistant IA pour votre mandat"
  description="MARYAN est l'assistant IA pour les élu·es locaux : clarifier une situation, trancher plus vite et passer à l'action sans se fragiliser."
>

  <!-- 1. HERO -->
  <section class="home-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="label-v3">Premier assistant IA pour les élus locaux</span>
        <h1>L'assistant IA pour votre mandat</h1>
        <p class="hero-subtitle">
          Gagnez du temps sur vos dossiers,
          vos délibérations et vos prises de parole.
        </p>
        <div class="hero-actions">
          <a href="/diagnostic" class="btn-primary-v3">Faire le diagnostic</a>
          <a href="/copilote" class="btn-secondary-v3 hero-secondary">Essayer le copilote</a>
        </div>
      </div>

      <aside class="hero-product" aria-label="Aperçu du produit">
        <Image
          src={heroScene}
          alt="Écharpe tricolore, carnet, lunettes et smartphone posés sur une table de travail."
          class="hero-photo"
          widths={[720, 960, 1280]}
          sizes="(max-width: 768px) 100vw, (max-width: 1024px) calc(100vw - 4rem), 42vw"
          quality={84}
          loading="eager"
          fetchpriority="high"
        />
      </aside>
    </div>
  </section>

  <!-- 2. SITUATIONS -->
  <section class="section-v3">
    <div class="container">
      <div class="section-head">
        <span class="label-v3">Situations réelles</span>
        <h2>Vous connaissez ces <span class="accent-keyword">moments</span>.</h2>
      </div>
      <div class="situations-grid">
        {situations.map((item) => (
          <article class="usage-card card-v3">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <p class="result-line">
              <span>Résultat :</span> {item.result}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. MÉTHODE -->
  <section id="comment-ca-marche" class="section-v3 section-how">
    <div class="container">
      <div class="section-head">
        <span class="label-v3">Méthode</span>
        <h2>En <span class="accent-keyword">pratique</span>, ça donne ça.</h2>
        <p class="section-intro">
          Vous décrivez ce que vous vivez.
          Maryan fait remonter ce qui compte vraiment.
        </p>
      </div>
      <div class="steps-grid">
        {steps.map((step, index) => (
          <article class="step-card card-v3">
            <span class="step-index">{String(index + 1).padStart(2, '0')}</span>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. RESSOURCES -->
  <section class="section-v3 section-resources">
    <div class="container">
      <div class="section-head">
        <span class="label-v3">Bibliothèque de ressources</span>
        <h2>Pas des articles. Des fiches pour <span class="accent-keyword">tenir sa posture</span>.</h2>
        <p class="section-intro">
          Courtes, pédagos, ancrées dans le réel du mandat.
          Entre le décryptage et le coaching — sans le jargon des deux.
        </p>
      </div>
      <div class="resources-grid">
        {resourceCards.map((card) => (
          <a href={card.href} class="resource-card card-v3">
            <h3>{card.title}</h3>
            <p>{card.desc}</p>
            <span class="resource-link-label">Lire la fiche →</span>
          </a>
        ))}
      </div>
      <div class="section-cta-center">
        <a href="/ressources" class="btn-primary-v3">Accéder aux ressources</a>
      </div>
    </div>
  </section>

  <!-- 6. HUB EXPERTS -->
  <section class="section-v3 section-hub">
    <div class="container">
      <div class="hub-shell">
        <div class="section-head section-head-light">
          <span class="label-v3">Experts & formation</span>
          <h2>Quand <span class="accent-keyword">Maryan</span> ne suffit plus.</h2>
        </div>
        <p class="hub-text">
          Les ressources donnent le socle. Le copilote aide à formuler.
          Le hub prend le relais quand il faut un regard humain, qualifié, contextuel —
          ou quand un crédit formation peut financer un accompagnement sur mesure.
        </p>
        <div class="hub-cta-group">
          <a href="/hub-experts" class="btn-primary-v3 btn-neon">Trouver un expert</a>
          <a href="/hub-experts" class="btn-secondary-v3 btn-outline-white">Proposer mon expertise</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. SCROLL-STACK -->
  <div class="scroll-stack">

    <section class="scroll-card" style="background: #0A192F;">
      <div class="scroll-card-inner">
        <span class="section-eyebrow eyebrow-neon">Droits &amp; devoirs</span>
        <h2 style="color: #F4F4F0; font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; max-width: 560px; margin-bottom: 16px; line-height: 1.25;">Vous avez plus de pouvoir que vous ne le pensez.</h2>
        <p style="color: rgba(244,244,240,0.65); font-size: 1rem; max-width: 480px; line-height: 1.75; margin-bottom: 28px;">Formation, protection fonctionnelle, droit d'alerte, indemnités — la loi vous protège. Encore faut-il le savoir, et savoir s'en saisir. MARYAN vous aide à connaître le cadre exact dans lequel vous exercez votre mandat.</p>
        <a href="/droits" class="btn-neon-stack">Lire les droits &amp; devoirs →</a>
      </div>
    </section>

    <section class="scroll-card" style="background: #F4F4F0;">
      <div class="scroll-card-inner">
        <span class="section-eyebrow eyebrow-dark">Décryptage</span>
        <h2 style="color: #0A192F; font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; max-width: 560px; margin-bottom: 16px; line-height: 1.25;">Le mandat local, vu de l'intérieur.</h2>
        <p style="color: rgba(10,25,47,0.6); font-size: 1rem; max-width: 480px; line-height: 1.75; margin-bottom: 28px;">Des articles longs, sans jargon et sans langue de bois. Pour comprendre ce qui se joue vraiment dans une délibération, une commission, un conseil municipal. Pas de l'information — de l'analyse.</p>
        <a href="/blog" class="btn-dark-stack">Lire les articles →</a>
      </div>
    </section>

    <section class="scroll-card" style="background: #FDFBF8; align-items: flex-start; padding-top: 80px;">
      <div style="width: 100%;">
        <span class="section-eyebrow eyebrow-dark" style="margin-bottom: 32px;">Explorer aussi</span>
        <div class="grid-4">
          <div class="mini-card">
            <span class="mini-card-accent" style="background: #C6FF4D;"></span>
            <span class="mini-card-label">Les mots</span>
            <strong class="mini-card-title">La langue politique, traduite.</strong>
            <p class="mini-card-body">Un glossaire vivant, construit avec les élu·e·s, pour nommer ce qui se passe vraiment.</p>
            <a href="/mots" class="mini-card-link">Explorer →</a>
          </div>
          <div class="mini-card">
            <span class="mini-card-accent" style="background: #E43644;"></span>
            <span class="mini-card-label">À propos</span>
            <strong class="mini-card-title">Un outil engagé, pas partisan.</strong>
            <p class="mini-card-body">Né d'un constat simple sur le mandat local et ceux qui l'exercent chaque soir.</p>
            <a href="/a-propos" class="mini-card-link">Lire →</a>
          </div>
          <div class="mini-card">
            <span class="mini-card-accent" style="background: #C6FF4D;"></span>
            <span class="mini-card-label">Tests</span>
            <strong class="mini-card-title">Quelle est votre posture d'élu·e ?</strong>
            <p class="mini-card-body">5 auto-évaluations pour mieux vous situer dans votre mandat.</p>
            <a href="/tests" class="mini-card-link">Faire un test →</a>
          </div>
          <div class="mini-card">
            <span class="mini-card-accent" style="background: #E43644;"></span>
            <span class="mini-card-label">Hub experts</span>
            <strong class="mini-card-title">Quand MARYAN ne suffit plus.</strong>
            <p class="mini-card-body">Un regard humain, qualifié, contextuel — ou un accompagnement sur mesure.</p>
            <a href="/hub-experts" class="mini-card-link">Trouver un expert →</a>
          </div>
        </div>
      </div>
    </section>

  </div>

  <!-- 8. CTA FINAL -->
  <section class="section-v3 final-cta-section">
    <div class="container">
      <div class="final-cta-panel">
        <h2>
          Une délibération à présenter.
          Un conseil qui commence demain.
          <span class="accent-keyword">C'est maintenant.</span>
        </h2>
        <div class="final-cta-actions">
          <a href="/diagnostic" class="btn-primary-v3">Faire le diagnostic</a>
          <a href="/copilote" class="btn-secondary-v3">Essayer le copilote</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* ─── SCROLL-STACK ─── */
    .scroll-stack { position: relative; }
    .scroll-card {
      position: sticky;
      top: 0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 80px 10%;
      overflow: hidden;
    }
    .scroll-card:nth-child(1) { z-index: 1; }
    .scroll-card:nth-child(2) { z-index: 2; }
    .scroll-card:nth-child(3) { z-index: 3; }
    .scroll-card-inner { max-width: 640px; }

    .section-eyebrow {
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      display: block;
      margin-bottom: 16px;
    }
    .eyebrow-neon { color: #C6FF4D; }
    .eyebrow-dark { color: rgba(10,25,47,0.45); }

    .btn-neon-stack {
      background: #C6FF4D;
      color: #0A192F;
      font-weight: 700;
      padding: 10px 22px;
      border-radius: 8px;
      text-decoration: none;
      font-size: 0.875rem;
      display: inline-block;
    }
    .btn-dark-stack {
      background: #0A192F;
      color: #F4F4F0;
      font-weight: 700;
      padding: 10px 22px;
      border-radius: 8px;
      text-decoration: none;
      font-size: 0.875rem;
      display: inline-block;
    }

    .grid-4 {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }

    .mini-card {
      background: #fff;
      border: 0.5px solid rgba(10,25,47,0.1);
      border-radius: 12px;
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .mini-card-accent {
      display: block;
      width: 24px;
      height: 3px;
      border-radius: 2px;
      margin-bottom: 4px;
    }
    .mini-card-label {
      font-size: 0.65rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(10,25,47,0.4);
    }
    .mini-card-title {
      font-size: 0.9rem;
      font-weight: 700;
      color: #0A192F;
      line-height: 1.3;
    }
    .mini-card-body {
      font-size: 0.8rem;
      color: rgba(10,25,47,0.55);
      line-height: 1.5;
      flex: 1;
    }
    .mini-card-link {
      font-size: 0.8rem;
      font-weight: 600;
      color: #0A192F;
      text-decoration: none;
      margin-top: 4px;
    }

    /* ─── TOKENS ─── */
    .accent-keyword {
      color: var(--neon);
      font-family: var(--font-accent);
      font-style: italic;
      font-weight: 700;
      text-transform: none;
    }

    /* ─── HERO ─── */
    .home-hero {
      background:
        radial-gradient(circle at top left, rgba(230, 57, 70, 0.16), transparent 34%),
        radial-gradient(circle at bottom right, rgba(173, 255, 47, 0.14), transparent 32%),
        var(--deep);
      color: white;
      padding: 4rem 0;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
      gap: 2rem;
      align-items: stretch;
    }

    .hero-copy h1 {
      color: white;
      font-size: clamp(2rem, 5vw, 3.2rem);
      line-height: 1.06;
      letter-spacing: -0.03em;
      margin: 0 0 1rem;
      text-wrap: balance;
    }

    .hero-subtitle {
      margin: 0 0 1.5rem;
      color: rgba(255, 255, 255, 0.86);
      max-width: 44ch;
      line-height: 1.65;
      font-size: 1.1rem;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.9rem;
      align-items: center;
      margin-bottom: 1.5rem;
    }

    .hero-secondary {
      background: rgba(255, 255, 255, 0.13);
      color: white;
      border-color: rgba(255, 255, 255, 0.2);
    }

    .hero-secondary:hover,
    .hero-secondary:focus-visible {
      background: white !important;
      color: var(--deep) !important;
      border-color: white !important;
    }


    .hero-product {
      overflow: hidden;
      display: flex;
    }

    .hero-photo {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: 54% 52%;
    }

    /* ─── SECTION HEAD + ICONS ─── */
    .section-head {
      max-width: 46rem;
      margin-bottom: 2rem;
    }

    .section-head-center {
      margin-left: auto;
      margin-right: auto;
      text-align: center;
    }

    .section-head h2 {
      font-size: clamp(1.5rem, 4vw, 2.5rem);
      margin: 0 0 0.85rem;
      text-wrap: balance;
    }


    .section-intro {
      margin: 0;
      color: #54636c;
      line-height: 1.66;
      max-width: 56ch;
    }

    /* ─── SITUATIONS ─── */
    .situations-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .usage-card h3,
    .step-card h3,
    .scenario-card h3,
    .offer-card h3 {
      margin: 0 0 0.65rem;
      font-size: 1.2rem;
      line-height: 1.28;
    }

    .usage-card p,
    .step-card p,
    .scenario-card p,
    .offer-card p {
      margin: 0;
      color: #54636c;
      line-height: 1.62;
    }

    .result-line {
      margin-top: 0.65rem !important;
      padding-top: 0.65rem;
      border-top: 1px solid var(--border);
      font-size: 0.95rem;
    }

    .result-line span {
      color: var(--deep);
      font-weight: 700;
    }

    /* ─── MÉTHODE ─── */
    .section-how {
      background: linear-gradient(180deg, #f8f9fa 0%, #eef3f7 100%);
    }

    .steps-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }

    .step-index {
      display: inline-block;
      margin-bottom: 0.6rem;
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      color: var(--accent-red);
    }

    /* ─── RESSOURCES ─── */
    .resources-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .resource-card {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .resource-card:hover {
      border-color: var(--deep);
      box-shadow: 0 4px 20px rgba(10, 25, 47, 0.08);
    }

    .resource-card h3 {
      margin: 0;
      font-size: 1.1rem;
      line-height: 1.3;
      color: var(--deep);
    }

    .resource-card p {
      margin: 0;
      color: #54636c;
      line-height: 1.6;
      font-size: 0.95rem;
      flex: 1;
    }

    .resource-link-label {
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--accent-red);
      margin-top: auto;
    }

    .section-cta-center {
      display: flex;
      justify-content: center;
    }

    /* ─── IMPACT CONCRET ─── */
    .scenario-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }

    .scenario-lines {
      display: grid;
      gap: 0.7rem;
      margin-top: 0.7rem;
      padding-top: 0.8rem;
      border-top: 1px solid var(--border);
    }

    .scenario-lines strong {
      color: var(--deep);
    }

    /* ─── HUB EXPERTS ─── */
    .hub-shell {
      background: var(--deep);
      border-radius: 28px;
      padding: 3rem;
    }

    .section-head-light h2,
    .section-head-light p {
      color: white;
    }

    .section-head-light .label-v3 {
      color: white;
    }

    .section-head-light .label-v3::before {
      background: white;
    }

    .hub-text {
      color: rgba(255, 255, 255, 0.8);
      line-height: 1.7;
      max-width: 56ch;
      margin: 0 0 2rem;
    }

    .hub-cta-group {
      display: flex;
      flex-wrap: wrap;
      gap: 0.9rem;
      align-items: center;
    }

    .btn-neon {
      background: var(--neon);
      color: var(--deep);
      border-color: var(--neon);
    }

    .btn-neon:hover,
    .btn-neon:focus-visible {
      background: white !important;
      border-color: white !important;
    }

    .btn-outline-white {
      background: transparent;
      color: white;
      border-color: rgba(255, 255, 255, 0.35);
    }

    .btn-outline-white:hover,
    .btn-outline-white:focus-visible {
      background: white !important;
      color: var(--deep) !important;
      border-color: white !important;
    }

    /* ─── ACCÈS + PRIX ─── */
    .offers-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .offer-card {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .offer-audience {
      display: inline-block;
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent-red);
    }

    .offer-price {
      font-weight: 800;
      font-size: 1.05rem;
      color: var(--deep);
      margin: 0 !important;
    }

    .clean-list {
      list-style: none;
      display: grid;
      gap: 0.5rem;
      margin: 0;
      padding: 0;
    }

    .clean-list li {
      position: relative;
      padding-left: 1rem;
      color: #54636c;
      line-height: 1.5;
    }

    .clean-list li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.68rem;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--neon);
      transform: translateY(-50%);
    }

    .offer-card-dark {
      background: var(--deep);
      border-radius: 32px;
      padding: 3rem;
      border: 1px solid rgba(255, 255, 255, 0.12);
    }

    .offer-card-dark h3,
    .offer-card-dark li {
      color: white;
    }

    .offer-card-dark .offer-audience {
      color: var(--neon);
    }

    .offer-card-dark .clean-list li::before {
      background: white;
    }

    /* ─── CTA FINAL ─── */
    .final-cta-section {
