---
import { Image } from 'astro:assets';
import Layout from '../layouts/BaseLayout.astro';
import heroScene from '../assets/maryan-hero-mandat.png';

const situations = [
  {
    title: 'Délibération technique à présenter',
    text: 'Vous devez en dire l\'essentiel sans vous noyer dans le jargon.',
    result: 'Maryan traduit le technique en posture politique lisible.'
  },
  {
    title: 'Interpellation publique sensible',
    text: 'Vous avez besoin de la bonne réponse, pas de la réponse rapide.',
    result: 'Maryan relit les enjeux, les risques, ce que vous pouvez dire.'
  },
  {
    title: 'Décision à arbitrer, options floues',
    text: 'Vous devez trancher. Pas demain. Ce soir.',
    result: 'Maryan structure les options et les points de vigilance.'
  },
  {
    title: 'Début de mandat, repères encore flous',
    text: 'Tout va vite et vous courez après les sujets.',
    result: 'Maryan aide à prioriser et à retrouver un cadre.'
  }
];

const steps = [
  {
    title: 'Vous posez votre situation',
    text: 'Question libre ou diagnostic guidé. Pas de formulaire compliqué.'
  },
  {
    title: 'Maryan lit entre les lignes',
    text: 'Ce qui relève du risque, du contexte, de la marge de manœuvre réelle.'
  },
  {
    title: 'Vous repartez avec quelque chose d\'utilisable',
    text: 'Enjeux, options, points de vigilance, prochaine étape.'
  }
];

const resourceCards = [
  {
    title: 'Lire et présenter une délibération',
    desc: 'Comprendre ce qui est vraiment en jeu, pas juste ce qui est écrit.',
    href: '/ressources/le-conseil-municipal-a-quoi-il-sert-vraiment'
  },
  {
    title: 'Quand l\'administration freine',
    desc: 'Distinguer le blocage technique du blocage politique. Et quoi faire.',
    href: '/ressources/travailler-services-mairie'
  },
  {
    title: 'Ce qu\'un élu peut et ne peut pas dire publiquement',
    desc: 'Les limites réelles, sans le vernis juridique.',
    href: '/ressources/polemique-reseaux-sociaux'
  },
  {
    title: 'Prévenir et gérer une situation sensible',
    desc: 'Ce que la loi impose. Ce que la posture exige.',
    href: '/ressources/reagir-interpellation-agressive'
  }
];

const scenarios = [
  {
    title: 'Délibération technique',
    before: 'Vous lisez. Vous relisez. Vous ne savez pas quoi en dire politiquement.',
    after: 'Vous savez ce qui est en jeu, ce que vous pouvez défendre et comment le formuler.'
  },
  {
    title: 'Interpellation sensible',
    before: 'Vous improvisez. Vous en dites trop ou pas assez.',
    after: 'Une réponse cadrée, avec ce que vous pouvez promettre et ce que vous ne pouvez pas.'
  },
  {
    title: 'Décision à arbitrer',
    before: 'Trop d\'options, pas de lisibilité, difficile de trancher sans se fragiliser.',
    after: 'Un arbitrage argumentable, avec les bons points de vigilance.'
  }
];

const individualOffer = ['Diagnostic initial', 'Copilote', 'Ressources', 'Activation immédiate'];
const teamOffer = ['Pack groupe jusqu\'à 8 élu·es', 'Offre collectivité à partir de 5 élu·es', 'Tarif ajusté'];
---

<Layout
  title="Maryan — Le premier assistant IA pour les élus locaux"
  description="Gagnez du temps sur vos dossiers, vos délibérations et vos prises de parole."
>

  <!-- 1. HERO -->
  <section class="home-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="label-v3">Premier assistant IA pour les élus locaux</span>
        <h1>
          Maryan : le premier assistant IA<br />
          pour les <span class="accent-keyword">élus locaux</span>.
        </h1>
        <p class="hero-subtitle">
          Gagnez du temps sur vos dossiers,
          vos délibérations et vos prises de parole.
        </p>
        <div class="hero-actions">
          <a href="/diagnostic" class="btn-primary-v3">Faire le diagnostic</a>
          <a href="/copilote" class="btn-secondary-v3 hero-secondary">Essayer le copilote</a>
        </div>
        <ul class="hero-chips">
          <li><span class="chip-icon">⚡</span>Décrypter une délibération en 5 minutes</li>
          <li><span class="chip-icon">🎤</span>Préparer une prise de parole sans improviser</li>
          <li><span class="chip-icon">🧭</span>Comprendre sa posture d'élu, pas juste ses droits</li>
        </ul>
      </div>

      <aside class="hero-product" aria-label="Aperçu du produit">
        <Image
          src={heroScene}
          alt="Écharpe tricolore, carnet, lunettes et smartphone posés sur une table de travail."
          class="hero-photo"
          widths={[720, 960, 1280]}
          sizes="(max-width: 768px) 100vw, (max-width: 1024px) calc(100vw - 4rem), 42vw"
          quality={84}
          loading="eager"
          fetchpriority="high"
        />
      </aside>
    </div>
  </section>

  <!-- 2. SITUATIONS -->
  <section class="section-v3">
    <div class="container">
      <div class="section-head">
        <span class="label-v3">Situations réelles</span>
        <span class="section-icon" aria-hidden="true">🗺️</span>
        <h2>Vous connaissez ces <span class="accent-keyword">moments</span>.</h2>
      </div>
      <div class="situations-grid">
        {situations.map((item) => (
          <article class="usage-card card-v3">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <p class="result-line">
              <span>Résultat :</span> {item.result}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. MÉTHODE -->
  <section id="comment-ca-marche" class="section-v3 section-how">
    <div class="container">
      <div class="section-head">
        <span class="label-v3">Méthode</span>
        <span class="section-icon" aria-hidden="true">⚙️</span>
        <h2>En <span class="accent-keyword">pratique</span>, ça donne ça.</h2>
        <p class="section-intro">
          Vous décrivez ce que vous vivez.
          Maryan fait remonter ce qui compte vraiment.
        </p>
      </div>
      <div class="steps-grid">
        {steps.map((step, index) => (
          <article class="step-card card-v3">
            <span class="step-index">{String(index + 1).padStart(2, '0')}</span>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. RESSOURCES -->
  <section class="section-v3 section-resources">
    <div class="container">
      <div class="section-head">
        <span class="label-v3">Bibliothèque de ressources</span>
        <span class="section-icon" aria-hidden="true">📚</span>
        <h2>Pas des articles. Des fiches pour <span class="accent-keyword">tenir sa posture</span>.</h2>
        <p class="section-intro">
          Courtes, pédagos, ancrées dans le réel du mandat.
          Entre le décryptage et le coaching — sans le jargon des deux.
        </p>
      </div>
      <div class="resources-grid">
        {resourceCards.map((card) => (
          <a href={card.href} class="resource-card card-v3">
            <h3>{card.title}</h3>
            <p>{card.desc}</p>
            <span class="resource-link-label">Lire la fiche →</span>
          </a>
        ))}
      </div>
      <div class="section-cta-center">
        <a href="/ressources" class="btn-primary-v3">Accéder aux ressources</a>
      </div>
    </div>
  </section>

  <!-- 5. IMPACT CONCRET -->
  <section class="section-v3">
    <div class="container">
      <div class="section-head">
        <span class="label-v3">Impact concret</span>
        <span class="section-icon" aria-hidden="true">✅</span>
        <h2>Ce que ça <span class="accent-keyword">change</span>, concrètement.</h2>
      </div>
      <div class="scenario-grid">
        {scenarios.map((scenario) => (
          <article class="scenario-card card-v3">
            <h3>{scenario.title}</h3>
            <div class="scenario-lines">
              <p><strong>Avant :</strong> {scenario.before}</p>
              <p><strong>Après :</strong> {scenario.after}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. HUB EXPERTS -->
  <section class="section-v3 section-hub">
    <div class="container">
      <div class="hub-shell">
        <div class="section-head section-head-light">
          <span class="label-v3">Experts & formation</span>
          <span class="section-icon section-icon-light" aria-hidden="true">👥</span>
          <h2>Quand <span class="accent-keyword">Maryan</span> ne suffit plus.</h2>
        </div>
        <p class="hub-text">
          Les ressources donnent le socle. Le copilote aide à formuler.
          Le hub prend le relais quand il faut un regard humain, qualifié, contextuel —
          ou quand un crédit formation peut financer un accompagnement sur mesure.
        </p>
        <div class="hub-cta-group">
          <a href="/hub-experts" class="btn-primary-v3 btn-neon">Trouver un expert</a>
          <a href="/hub-experts" class="btn-secondary-v3 btn-outline-white">Proposer mon expertise</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. ACCÈS + PRIX -->
  <section class="section-v3">
    <div class="container">
      <div class="section-head section-head-center">
        <span class="label-v3">Accès</span>
        <span class="section-icon" aria-hidden="true">🚀</span>
        <h2>Vous commencez ce soir <span class="accent-keyword">si vous voulez</span>.</h2>
      </div>
      <div class="offers-grid">
        <article class="offer-card card-v3">
          <span class="offer-audience">Pour un élu</span>
          <h3>Un accès individuel. Vous payez vous-même, vous utilisez vous-même.</h3>
          <ul class="clean-list">
            {individualOffer.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <p class="offer-price">À partir de 10 € / mois</p>
          <a href="/offres" class="btn-primary-v3">Voir les offres</a>
        </article>

        <article class="offer-card offer-card-dark">
          <span class="offer-audience">Pour un groupe ou une collectivité</span>
          <h3>Plusieurs élus, le même outil, les mêmes repères.</h3>
          <ul class="clean-list">
            {teamOffer.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <a href="/contact" class="btn-secondary-v3">Demander un devis</a>
        </article>
      </div>
    </div>
  </section>

  <!-- 8. CTA FINAL -->
  <section class="section-v3 final-cta-section">
    <div class="container">
      <div class="final-cta-panel">
        <h2>
          Une délibération à présenter.
          Un conseil qui commence demain.
          <span class="accent-keyword">C'est maintenant.</span>
        </h2>
        <div class="final-cta-actions">
          <a href="/diagnostic" class="btn-primary-v3">Faire le diagnostic</a>
          <a href="/copilote" class="btn-secondary-v3">Essayer le copilote</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* ─── TOKENS ─── */
    .accent-keyword {
      color: var(--neon);
      font-family: var(--font-accent);
      font-style: italic;
      font-weight: 700;
      text-transform: none;
    }

    /* ─── HERO ─── */
    .home-hero {
      background:
        radial-gradient(circle at top left, rgba(230, 57, 70, 0.16), transparent 34%),
        radial-gradient(circle at bottom right, rgba(173, 255, 47, 0.14), transparent 32%),
        var(--deep);
      color: white;
      padding: 4rem 0;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
      gap: 2rem;
      align-items: stretch;
    }

    .hero-copy h1 {
      color: white;
      font-size: clamp(2rem, 5vw, 3.2rem);
      line-height: 1.06;
      letter-spacing: -0.03em;
      margin: 0 0 1rem;
      text-wrap: balance;
    }

    .hero-subtitle {
      margin: 0 0 1.5rem;
      color: rgba(255, 255, 255, 0.86);
      max-width: 44ch;
      line-height: 1.65;
      font-size: 1.1rem;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.9rem;
      align-items: center;
      margin-bottom: 1.5rem;
    }

    .hero-secondary {
      background: rgba(255, 255, 255, 0.13);
      color: white;
      border-color: rgba(255, 255, 255, 0.2);
    }

    .hero-secondary:hover,
    .hero-secondary:focus-visible {
      background: white !important;
      color: var(--deep) !important;
      border-color: white !important;
    }

    /* Hero chips (emoji vignettes) */
    .hero-chips {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
    }

    .hero-chips li {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      background: rgba(255, 255, 255, 0.09);
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: 999px;
      padding: 0.35rem 0.85rem;
      font-size: 0.85rem;
      color: rgba(255, 255, 255, 0.88);
      line-height: 1.3;
    }

    .chip-icon {
      font-size: 1rem;
      flex-shrink: 0;
    }

    .hero-product {
      overflow: hidden;
      display: flex;
    }

    .hero-photo {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: 54% 52%;
    }

    /* ─── SECTION HEAD + ICONS ─── */
    .section-head {
      max-width: 46rem;
      margin-bottom: 2rem;
    }

    .section-head-center {
      margin-left: auto;
      margin-right: auto;
      text-align: center;
    }

    .section-head h2 {
      font-size: clamp(1.5rem, 4vw, 2.5rem);
      margin: 0 0 0.85rem;
      text-wrap: balance;
    }

    .section-icon {
      display: block;
      font-size: 1.5rem;
      opacity: 0.8;
      margin-bottom: 0.5rem;
    }

    .section-icon-light {
      opacity: 0.7;
    }

    .section-intro {
      margin: 0;
      color: #54636c;
      line-height: 1.66;
      max-width: 56ch;
    }

    /* ─── SITUATIONS ─── */
    .situations-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .usage-card h3,
    .step-card h3,
    .scenario-card h3,
    .offer-card h3 {
      margin: 0 0 0.65rem;
      font-size: 1.2rem;
      line-height: 1.28;
    }

    .usage-card p,
    .step-card p,
    .scenario-card p,
    .offer-card p {
      margin: 0;
      color: #54636c;
      line-height: 1.62;
    }

    .result-line {
      margin-top: 0.65rem !important;
      padding-top: 0.65rem;
      border-top: 1px solid var(--border);
      font-size: 0.95rem;
    }

    .result-line span {
      color: var(--deep);
      font-weight: 700;
    }

    /* ─── MÉTHODE ─── */
    .section-how {
      background: linear-gradient(180deg, #f8f9fa 0%, #eef3f7 100%);
    }

    .steps-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }

    .step-index {
      display: inline-block;
      margin-bottom: 0.6rem;
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      color: var(--accent-red);
    }

    /* ─── RESSOURCES ─── */
    .resources-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .resource-card {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .resource-card:hover {
      border-color: var(--deep);
      box-shadow: 0 4px 20px rgba(10, 25, 47, 0.08);
    }

    .resource-card h3 {
      margin: 0;
      font-size: 1.1rem;
      line-height: 1.3;
      color: var(--deep);
    }

    .resource-card p {
      margin: 0;
      color: #54636c;
      line-height: 1.6;
      font-size: 0.95rem;
      flex: 1;
    }

    .resource-link-label {
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--accent-red);
      margin-top: auto;
    }

    .section-cta-center {
      display: flex;
      justify-content: center;
    }

    /* ─── IMPACT CONCRET ─── */
    .scenario-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }

    .scenario-lines {
      display: grid;
      gap: 0.7rem;
      margin-top: 0.7rem;
      padding-top: 0.8rem;
      border-top: 1px solid var(--border);
    }

    .scenario-lines strong {
      color: var(--deep);
    }

    /* ─── HUB EXPERTS ─── */
    .hub-shell {
      background: var(--deep);
      border-radius: 28px;
      padding: 3rem;
    }

    .section-head-light h2,
    .section-head-light p {
      color: white;
    }

    .section-head-light .label-v3 {
      color: white;
    }

    .section-head-light .label-v3::before {
      background: white;
    }

    .hub-text {
      color: rgba(255, 255, 255, 0.8);
      line-height: 1.7;
      max-width: 56ch;
      margin: 0 0 2rem;
    }

    .hub-cta-group {
      display: flex;
      flex-wrap: wrap;
      gap: 0.9rem;
      align-items: center;
    }

    .btn-neon {
      background: var(--neon);
      color: var(--deep);
      border-color: var(--neon);
    }

    .btn-neon:hover,
    .btn-neon:focus-visible {
      background: white !important;
      border-color: white !important;
    }

    .btn-outline-white {
      background: transparent;
      color: white;
      border-color: rgba(255, 255, 255, 0.35);
    }

    .btn-outline-white:hover,
    .btn-outline-white:focus-visible {
      background: white !important;
      color: var(--deep) !important;
      border-color: white !important;
    }

    /* ─── ACCÈS + PRIX ─── */
    .offers-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .offer-card {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .offer-audience {
      display: inline-block;
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent-red);
    }

    .offer-price {
      font-weight: 800;
      font-size: 1.05rem;
      color: var(--deep);
      margin: 0 !important;
    }

    .clean-list {
      list-style: none;
      display: grid;
      gap: 0.5rem;
      margin: 0;
      padding: 0;
    }

    .clean-list li {
      position: relative;
      padding-left: 1rem;
      color: #54636c;
      line-height: 1.5;
    }

    .clean-list li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.68rem;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--neon);
      transform: translateY(-50%);
    }

    .offer-card-dark {
      background: var(--deep);
      border-radius: 32px;
      padding: 3rem;
      border: 1px solid rgba(255, 255, 255, 0.12);
    }

    .offer-card-dark h3,
    .offer-card-dark li {
      color: white;
    }

    .offer-card-dark .offer-audience {
      color: var(--neon);
    }

    .offer-card-dark .clean-list li::before {
      background: white;
    }

    /* ─── CTA FINAL ─── */
    .final-cta-section {
      padding-top: 2rem;
    }

    .final-cta-panel {
      border-radius: 28px;
      background: var(--deep);
      padding: 3rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
    }

    .final-cta-panel h2 {
      color: white;
      margin: 0;
      font-size: clamp(1.5rem, 2.8vw, 2.3rem);
      line-height: 1.2;
      max-width: 22ch;
    }

    .final-cta-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.9rem;
      align-items: center;
      flex-shrink: 0;
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 1024px) {
      .hero-grid,
      .offers-grid {
        grid-template-columns: 1fr;
      }

      .offer-card-dark {
        padding: 2rem;
      }

      .final-cta-panel {
        flex-direction: column;
        align-items: flex-start;
      }
    }

    @media (max-width: 768px) {
      .home-hero {
        padding: 2rem 0 2rem;
        overflow: hidden;
      }

      /* Cache l'image sur mobile pour garder le hero compact */
      .hero-product {
        display: none;
      }

      .hero-copy h1 {
        font-size: clamp(1.75rem, 8vw, 2.4rem);
      }

      .hero-subtitle {
        font-size: 1rem;
        margin-bottom: 1.2rem;
      }

      .hero-actions {
        flex-direction: column;
        align-items: stretch;
        margin-bottom: 1.2rem;
      }

      .hero-actions a {
        width: 100%;
        text-align: center;
        min-height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .hero-chips {
        flex-direction: column;
        gap: 0.5rem;
      }

      .hero-chips li {
        border-radius: 12px;
        font-size: 0.88rem;
      }

      .situations-grid,
      .steps-grid,
      .resources-grid,
      .scenario-grid,
      .offers-grid {
        grid-template-columns: 1fr;
      }

      .final-cta-actions,
      .hub-cta-group,
      .section-cta-center {
        flex-direction: column;
        align-items: stretch;
      }

      .final-cta-actions a,
      .hub-cta-group a,
      .section-cta-center a {
        width: 100%;
        text-align: center;
        min-height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .usage-card,
      .step-card,
      .resource-card,
      .scenario-card,
      .offer-card,
      .final-cta-panel {
        padding: 1.5rem;
      }

