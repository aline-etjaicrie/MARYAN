---
import { Image } from 'astro:assets';
import Layout from '../layouts/BaseLayout.astro';
import heroScene from '../assets/maryan-hero-mandat.png';

const microProofs = [
  'Décrypter une délibération technique et en dire l\'essentiel politiquement',
  'Préparer une prise de parole sans improviser',
  'Comprendre sa posture d\'élu, pas juste ses droits'
];

const situations = [
  {
    title: 'Délibération technique à présenter',
    text: 'Vous devez en dire l\'essentiel sans vous noyer dans le jargon.',
    result: 'MARYAN traduit le technique en posture politique lisible.'
  },
  {
    title: 'Interpellation publique sur un sujet sensible',
    text: 'Vous avez besoin de la bonne réponse, pas de la réponse rapide.',
    result: 'MARYAN relit les enjeux, les risques, ce que vous pouvez dire.'
  },
  {
    title: 'Décision à arbitrer, options floues',
    text: 'Vous devez trancher. Pas demain. Ce soir.',
    result: 'MARYAN structure les options et les points de vigilance.'
  },
  {
    title: 'Début de mandat, repères encore flous',
    text: 'Tout va vite et vous courez après les sujets.',
    result: 'MARYAN aide à prioriser et à retrouver un cadre institutionnel lisible.'
  }
];

const steps = [
  {
    title: 'Vous posez votre situation',
    text: 'Question libre ou diagnostic guidé. Pas de formulaire compliqué.'
  },
  {
    title: 'MARYAN lit entre les lignes',
    text: 'Ce qui relève du risque, du contexte, de la marge de manœuvre réelle.'
  },
  {
    title: 'Vous repartez avec quelque chose d\'utilisable',
    text: 'Enjeux, options, points de vigilance, prochaine étape.'
  }
];

const comparisonRows = [
  {
    generic: 'Part d\'une question générique',
    maryan: 'Part de votre situation réelle'
  },
  {
    generic: 'Peu ou pas de contexte de mandat',
    maryan: 'Règles, risques, marges de manœuvre intégrés'
  },
  {
    generic: 'Produit du texte',
    maryan: 'Vous aide à décider et à tenir une position'
  },
  {
    generic: 'Réponse longue, à déchiffrer',
    maryan: 'Structure claire + prochaine étape'
  }
];

const scenarios = [
  {
    title: 'Délibération technique',
    before: 'Vous lisez. Vous relisez. Vous ne savez pas quoi en dire politiquement.',
    after: 'Vous savez ce qui est en jeu, ce que vous pouvez défendre et comment le formuler.'
  },
  {
    title: 'Interpellation sensible',
    before: 'Vous improvisez. Vous en dites trop ou pas assez.',
    after: 'Une réponse cadrée, avec ce que vous pouvez promettre et ce que vous ne pouvez pas.'
  },
  {
    title: 'Décision à arbitrer',
    before: 'Trop d\'options, pas de lisibilité, difficile de trancher sans se fragiliser.',
    after: 'Un arbitrage argumentable, avec les bons points de vigilance.'
  }
];

const credibilityPoints = [
  'Plus de 20 ans dans les cabinets et la communication publique locale',
  'Des situations réelles de mandat comme matière première — pas des cas d\'école',
  'Un diagnostic, un copilote, des ressources — pour comprendre, décider, agir'
];

const resourceExamples = [
  {
    label: 'Faire passer une délibération',
    href: '/ressources/le-conseil-municipal-a-quoi-il-sert-vraiment'
  },
  {
    label: 'Quand l\'administration freine',
    href: '/ressources/travailler-services-mairie'
  },
  {
    label: 'Réseaux sociaux : ce qu\'un élu peut et ne peut pas dire',
    href: '/ressources/polemique-reseaux-sociaux'
  },
  {
    label: 'Prévenir et gérer les situations de VSS',
    href: '/ressources/reagir-interpellation-agressive'
  }
];

const individualOffer = ['Diagnostic initial', 'Copilote', 'Ressources', 'Activation immédiate'];
const teamOffer = ['Pack groupe jusqu\'à 8 élu·es', 'Offre collectivité à partir de 5 élu·es', 'Tarif ajusté'];

const resourceCards = [
  {
    title: 'Lire et présenter une délibération',
    body: 'Comprendre ce qui est vraiment en jeu, pas juste ce qui est écrit.',
    href: '/ressources/faire-passer-une-deliberation'
  },
  {
    title: 'Quand l\'administration freine',
    body: 'Distinguer le blocage technique du blocage politique. Et quoi faire.',
    href: '/ressources/administration-qui-freine'
  },
  {
    title: 'Ce qu\'un élu peut et ne peut pas dire publiquement',
    body: 'Les limites réelles, sans le vernis juridique.',
    href: '/ressources/reseaux-sociaux-elu-ce-quon-peut-dire'
  },
  {
    title: 'Prévenir et gérer une situation de VSS',
    body: 'Ce que la loi impose. Ce que la posture exige.',
    href: '/ressources/prevenir-gerer-vss-harcelement'
  }
];
---

<Layout
  title="MARYAN — Une situation de mandat. Une réponse exploitable."
  description="MARYAN aide les élu·es à clarifier une situation, trancher plus vite et passer à l’action sans se fragiliser."
>
  <section class="home-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="label-v3">Copilote de mandat</span>
        <h1>
          Le temps que vous n’avez pas,<br />
          <span class="accent-keyword">Maryan</span> le prend pour vous.
        </h1>
        <p class="hero-subtitle">
          Décidez sans douter. Parlez sans vous fragiliser. Un copilote qui lit votre situation — et une bibliothèque de ressources courtes, ancrées dans le réel du mandat.
        </p>

        <ul class="hero-proofs">
          {microProofs.map((item) => (
            <li>{item}</li>
          ))}
        </ul>

        <div class="hero-actions">
          <a href="/diagnostic" class="btn-primary-v3">Faire le diagnostic</a>
          <a href="/copilote" class="btn-secondary-v3 hero-secondary">Essayer le copilote</a>
        </div>
      </div>

      <aside class="hero-product" aria-label="Aperçu du produit">
        <Image
          src={heroScene}
          alt="Écharpe tricolore, carnet, lunettes et smartphone posés sur une table de travail."
          class="hero-photo"
          widths={[720, 960, 1280]}
          sizes="(max-width: 1024px) calc(100vw - 4rem), 42vw"
          quality={84}
          loading="eager"
          fetchpriority="high"
        />
      </aside>
    </div>
  </section>

  <section class="section-v3">
    <div class="container">
      <div class="section-head">
        <span class="label-v3">Situations réelles</span>
        <h2>Vous connaissez ces <span class="accent-keyword">moments</span>.</h2>
      </div>

      <div class="situations-grid">
        {situations.map((item) => (
          <article class="usage-card card-v3">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <p class="result-line">
              <span>Résultat :</span> {item.result}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="comment-ca-marche" class="section-v3 section-how">
    <div class="container">
      <div class="section-head">
        <span class="label-v3">Méthode</span>
        <h2>En <span class="accent-keyword">pratique</span>, ça donne ça.</h2>
        <p class="section-intro">
          Vous décrivez ce que vous vivez. MARYAN fait remonter ce qui compte vraiment.
        </p>
      </div>

      <div class="steps-grid">
        {steps.map((step, index) => (
          <article class="step-card card-v3">
            <span class="step-index">{String(index + 1).padStart(2, '0')}</span>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </article>
        ))}
      </div>

      <div class="mockups-grid">
        <article class="mockup-card card-v3">
          <span class="mockup-label">Exemple — Entrée utilisateur</span>
          <h3>Question saisie dans le copilote</h3>
          <p>
            « Conseil municipal demain. Le sujet est conflictuel. Je veux rester ferme sur le cadre,
            sans fermer la discussion. »
          </p>
        </article>
        <article class="mockup-card card-v3">
          <span class="mockup-label">Exemple — Sortie structurée</span>
          <h3>Réponse exploitable</h3>
          <ul>
            <li>Lecture politique de la situation</li>
            <li>Options argumentées</li>
            <li>Points de vigilance</li>
            <li>Prochaine étape activable</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section-v3 section-compare">
    <div class="container">
      <div class="section-head">
        <span class="label-v3">Différence</span>
        <h2>
          Pensée pour votre <span class="accent-keyword">mandat</span>. Pas pour répondre à tout.
        </h2>
      </div>

      <div class="comparison-shell">
        <div class="comparison-head comparison-row">
          <strong>IA généraliste</strong>
          <strong>MARYAN</strong>
        </div>
        {comparisonRows.map((row) => (
          <div class="comparison-row">
            <p>{row.generic}</p>
            <p>{row.maryan}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-v3">
    <div class="container">
      <div class="section-head">
        <span class="label-v3">Impact concret</span>
        <h2>Ce que ça <span class="accent-keyword">change</span>, concrètement.</h2>
      </div>

      <div class="scenario-grid">
        {scenarios.map((scenario) => (
          <article class="scenario-card card-v3">
            <h3>{scenario.title}</h3>
            <div class="scenario-lines">
              <p>
                <strong>Avant :</strong> {scenario.before}
              </p>
              <p>
                <strong>Après :</strong> {scenario.after}
              </p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-v3 section-credibility">
    <div class="container">
      <div class="credibility-shell">
        <div class="section-head section-head-light">
          <span class="label-v3">Pourquoi MARYAN</span>
          <h2>Pas construit pour répondre à tout. <span class="accent-keyword">Construit pour ça.</span></h2>
        </div>

        <div class="credibility-points">
          {credibilityPoints.map((point) => (
            <article class="credibility-card">
              <p>{point}</p>
            </article>
          ))}
        </div>

        <div class="resource-examples card-v3">
          <h3>Exemples de ressources</h3>
          <ul>
            {resourceExamples.map((item) => (
              <li>
                <a href={item.href}>{item.label}</a>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>

  <section class="section-v3">
    <div class="container">
      <div class="section-head section-head-center">
        <span class="label-v3">Accès</span>
        <h2>Vous commencez ce soir <span class="accent-keyword">si vous voulez</span>.</h2>
      </div>

      <div class="offers-grid">
        <article class="offer-card card-v3">
          <span class="offer-audience">Pour un élu</span>
          <h3>Un accès individuel. Vous payez vous-même, vous utilisez vous-même.</h3>
          <ul class="clean-list">
            {individualOffer.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <a href="/offres" class="btn-primary-v3">Voir les offres</a>
        </article>

        <article class="offer-card offer-card-dark">
          <span class="offer-audience">Pour une équipe ou une collectivité</span>
          <h3>Un déploiement léger, avec un cadre d’usage commun.</h3>
          <ul class="clean-list">
            {teamOffer.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <a href="/contact" class="btn-secondary-v3">Demander une démo</a>
        </article>
      </div>
    </div>
  </section>

  <section class="section-v3 final-cta-section">
    <div class="container">
      <div class="final-cta-panel">
        <h2>
          Prêt à tester sur une vraie <span class="accent-keyword">situation</span> de votre mandat ?
        </h2>
        <div class="final-cta-actions">
          <a href="/diagnostic" class="btn-primary-v3">Faire le diagnostic</a>
          <a href="/copilote" class="btn-secondary-v3">Tester une situation réelle</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .accent-keyword {
      color: var(--neon);
      font-family: var(--font-accent);
      font-style: italic;
      font-weight: 700;
      text-transform: none;
    }

    .home-hero {
      background:
        radial-gradient(circle at top left, rgba(230, 57, 70, 0.16), transparent 34%),
        radial-gradient(circle at bottom right, rgba(173, 255, 47, 0.14), transparent 32%),
        var(--deep);
      color: white;
      padding: 5.5rem 0;
    }

    .hero-grid {
      display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
        gap: 2rem;
        align-items: stretch;
    }

    .hero-copy h1 {
      color: white;
      font-size: clamp(2.1rem, 4vw, 3.6rem);
      line-height: 1.04;
      letter-spacing: -0.03em;
      margin: 0 0 1.1rem;
      text-wrap: balance;
    }

    .hero-subtitle {
      margin: 0 0 1.5rem;
      color: rgba(255, 255, 255, 0.86);
      max-width: 42ch;
      line-height: 1.65;
    }

    .hero-proofs {
      list-style: none;
      display: grid;
      gap: 0.65rem;
      margin: 0 0 1.5rem;
      padding: 0;
    }

    .hero-proofs li {
      position: relative;
      padding-left: 1rem;
      color: rgba(255, 255, 255, 0.92);
      font-size: 0.98rem;
      line-height: 1.5;
    }

    .hero-proofs li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.72rem;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--neon);
      transform: translateY(-50%);
    }

    .hero-actions,
    .final-cta-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.9rem;
      align-items: center;
    }

    .hero-secondary {
      background: rgba(255, 255, 255, 0.13);
      color: white;
      border-color: rgba(255, 255, 255, 0.2);
    }

    .hero-secondary:hover,
    .hero-secondary:focus-visible {
      background: white !important;
      color: var(--deep) !important;
      border-color: white !important;
    }

    .hero-product {
      overflow: hidden;
      display: flex;
    }

    .hero-photo {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: 54% 52%;
    }

    .mockup-label {
      display: inline-block;
      font-size: 0.76rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent-red);
      margin-bottom: 0.55rem;
    }

    .section-head {
      max-width: 46rem;
      margin-bottom: 2rem;
    }

    .section-head-center {
      margin-left: auto;
      margin-right: auto;
      text-align: center;
    }

    .section-head h2 {
      font-size: clamp(1.8rem, 3.3vw, 3rem);
      margin: 0 0 0.85rem;
      text-wrap: balance;
    }

    .section-intro {
      margin: 0;
      color: #54636c;
      line-height: 1.66;
      max-width: 56ch;
    }

    .situations-grid,
    .steps-grid,
    .scenario-grid,
    .offers-grid {
      display: grid;
      gap: 1rem;
    }

    .situations-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .usage-card h3,
    .step-card h3,
    .scenario-card h3,
    .offer-card h3,
    .resource-examples h3,
    .mockup-card h3 {
      margin: 0 0 0.65rem;
      font-size: 1.2rem;
      line-height: 1.28;
    }

    .usage-card p,
    .step-card p,
    .scenario-card p,
    .offer-card p,
    .mockup-card p {
      margin: 0;
      color: #54636c;
      line-height: 1.62;
    }

    .result-line {
      margin-top: 0.65rem !important;
      padding-top: 0.65rem;
      border-top: 1px solid var(--border);
      font-size: 0.95rem;
    }

    .result-line span {
      color: var(--deep);
      font-weight: 700;
    }

    .section-how {
      background: linear-gradient(180deg, #f8f9fa 0%, #eef3f7 100%);
    }

    .steps-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      margin-bottom: 1rem;
    }

    .step-index {
      display: inline-block;
      margin-bottom: 0.6rem;
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      color: var(--accent-red);
    }

    .mockups-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .mockup-card {
      border: 1px solid rgba(10, 25, 47, 0.1);
    }

    .mockup-card ul {
      margin: 0;
      padding-left: 1rem;
      display: grid;
      gap: 0.45rem;
      color: #54636c;
    }

    .section-compare {
      background: var(--deep);
    }

    .section-compare .section-head h2,
    .section-compare .section-head {
      color: white;
    }

    .section-compare .label-v3 {
      color: white;
    }

    .section-compare .label-v3::before {
      background: white;
    }

    .comparison-shell {
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: 24px;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.04);
    }

    .comparison-row {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
      padding: 1rem 1.2rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .comparison-row:last-child {
      border-bottom: 0;
    }

    .comparison-head {
      background: rgba(255, 255, 255, 0.08);
    }

    .comparison-row strong {
      color: white;
      font-size: 0.95rem;
    }

    .comparison-row p {
      margin: 0;
      color: rgba(255, 255, 255, 0.85);
      line-height: 1.54;
    }

    .scenario-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .scenario-lines {
      display: grid;
      gap: 0.7rem;
      margin-top: 0.7rem;
      padding-top: 0.8rem;
      border-top: 1px solid var(--border);
    }

    .scenario-lines strong {
      color: var(--deep);
    }

    .section-credibility {
      background: linear-gradient(180deg, #f8f9fa 0%, #edf2f6 100%);
    }

    .credibility-shell {
      background: var(--deep);
      border-radius: 28px;
      padding: 2rem;
    }

    .section-head-light h2,
    .section-head-light p {
      color: white;
    }

    .section-head-light .label-v3 {
      color: white;
    }

    .section-head-light .label-v3::before {
      background: white;
    }

    .credibility-points {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.8rem;
      margin-bottom: 1rem;
    }

    .credibility-card {
      border-radius: 18px;
      padding: 1rem;
      border: 1px solid rgba(255, 255, 255, 0.13);
      background: rgba(255, 255, 255, 0.06);
    }

    .credibility-card p {
      margin: 0;
      color: rgba(255, 255, 255, 0.89);
      line-height: 1.55;
    }

    .resource-examples {
      margin-bottom: 0.9rem;
      border-radius: 22px;
      padding: 1.2rem;
    }

    .resource-examples ul {
      list-style: none;
      display: grid;
      gap: 0.55rem;
      padding: 0;
      margin: 0;
    }

    .resource-examples a {
      color: var(--deep);
      text-decoration: none;
      font-weight: 600;
    }

    .resource-examples a:hover {
      color: var(--accent-red);
    }

    .proof-slot {
      border: 1px dashed rgba(255, 255, 255, 0.28);
      border-radius: 16px;
      padding: 0.8rem 1rem;
    }

    .proof-slot p {
      margin: 0;
      font-size: 0.92rem;
      color: rgba(255, 255, 255, 0.78);
    }

    .offers-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .offer-card {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .offer-audience {
      display: inline-block;
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent-red);
    }

    .clean-list {
      list-style: none;
      display: grid;
      gap: 0.5rem;
      margin: 0;
      padding: 0;
    }

    .clean-list li {
      position: relative;
      padding-left: 1rem;
      color: #54636c;
      line-height: 1.5;
    }

    .clean-list li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.68rem;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--neon);
      transform: translateY(-50%);
    }

    .offer-card-dark {
      background: var(--deep);
      border-radius: 32px;
      padding: 3rem;
      border: 1px solid rgba(255, 255, 255, 0.12);
    }

    .offer-card-dark h3,
    .offer-card-dark p,
    .offer-card-dark li {
      color: white;
    }

    .offer-card-dark .offer-audience {
      color: var(--neon);
    }

    .offer-card-dark .clean-list li::before {
      background: white;
    }

    .final-cta-section {
      padding-top: 2rem;
    }

    .final-cta-panel {
      border-radius: 28px;
      background: var(--deep);
      padding: 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    .final-cta-panel h2 {
      color: white;
      margin: 0;
      font-size: clamp(1.5rem, 2.8vw, 2.3rem);
      line-height: 1.15;
      max-width: 20ch;
    }

    @media (max-width: 1024px) {
      .hero-grid,
      .situations-grid,
      .steps-grid,
      .mockups-grid,
      .scenario-grid,
      .credibility-points,
      .offers-grid,
      .comparison-row {
        grid-template-columns: 1fr;
      }

      .home-hero {
        padding: 4.25rem 0;
      }

      .comparison-head {
        display: none;
      }

      .comparison-row {
        gap: 0.6rem;
      }

      .comparison-row p:first-child::before {
        content: 'IA généraliste';
        display: block;
        color: rgba(255, 255, 255, 0.64);
        font-size: 0.76rem;
        font-weight: 700;
