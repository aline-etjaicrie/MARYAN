---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Diagnostic de situation — MARYAN" description="En 5 minutes, identifiez votre profil de situation et les appuis les plus utiles pour la suite de votre mandat.">
  
  <!-- BACKGROUND AMBIANCE -->
  <div class="page-ambient-bg">
    <img src="/hero-bg.png" alt="" />
    <div class="ambient-overlay"></div>
  </div>

  <header class="site-header diag-header-v3">
    <div class="container header-inner">
      <div class="brand-group">
        <a href="/" class="brand">MARYAN</a>
        <p class="brand-sub">copilote de mandat</p>
      </div>
      <a href="/" class="back-link-v3">← Accueil</a>
    </div>
  </header>

  <div class="progress-wrap-v3 hidden" id="progressWrap">
    <div class="container-v3">
      <div class="progress-inner-v3">
        <div class="progress-track-v3">
          <div class="progress-fill-v3" id="progressFill"></div>
        </div>
        <span class="progress-count-v3" id="progressCount">0 / 15</span>
      </div>
    </div>
  </div>

  <main class="diag-main-v3">
    <!-- INTRO SECTION -->
    <div id="introSection" class="diag-card-hero">
      <span class="label-v3">Diagnostic de situation · 5 minutes</span>
      <h1>Votre situation,<br /><span class="text-terracotta">vos vrais besoins</span></h1>
      <p class="intro-lead">Le soir de l'élection, tout va très vite. Ce diagnostic vous aide à faire le point sur votre situation réelle, vos priorités et la forme d'appui la plus utile.</p>
      
      <div class="diag-welcome-footer">
        <div class="chips-v3">
          <span class="chip-v3">100 % confidentiel</span>
          <span class="chip-v3">Résultat immédiat</span>
        </div>
        <button class="btn-primary-v3 big" onclick="startDiag()">Démarrer le diagnostic →</button>
      </div>
    </div>

    <!-- QUESTIONS CONTAINER -->
    <div id="diagSection" class="hidden">
      <!-- Les blocs injectés par JS ici -->
      <div id="bloc1" class="bloc-v3">
        <div class="bloc-header-v3">
          <p class="bloc-num-v3">Étape 1 sur 5 · Votre situation</p>
          <h2 class="bloc-title-v3">Votre mandat et votre contexte</h2>
        </div>

        <div class="q-card-v3">
          <p class="q-label-v3">1. Quel est votre mandat ?</p>
          <div class="options-v3" id="q1">
            <label class="opt-v3" onclick="pick(this,'q1','maire',{institutional:1,exposure:2})"><input type="radio" name="q1" /><span class="dot-v3"></span>Maire</label>
            <label class="opt-v3" onclick="pick(this,'q1','adjoint',{institutional:1,pressure:2,exposure:1})"><input type="radio" name="q1" /><span class="dot-v3"></span>Adjoint·e au maire</label>
            <label class="opt-v3" onclick="pick(this,'q1','conseiller_maj',{isolation:1})"><input type="radio" name="q1" /><span class="dot-v3"></span>Conseiller·e municipal·e (majorité)</label>
            <label class="opt-v3" onclick="pick(this,'q1','conseiller_opp',{isolation:2,pressure:1})"><input type="radio" name="q1" /><span class="dot-v3"></span>Conseiller·e municipal·e (opposition)</label>
          </div>
        </div>

        <div class="q-card-v3">
          <p class="q-label-v3">2. Depuis combien de temps exercez-vous ?</p>
          <div class="options-v3" id="q2">
            <label class="opt-v3" onclick="pick(this,'q2','debut',{experience:0,isolation:2,institutional:2})"><input type="radio" name="q2" /><span class="dot-v3"></span>Je débute (moins de 6 mois)</label>
            <label class="opt-v3" onclick="pick(this,'q2','moins2',{experience:1,isolation:1})"><input type="radio" name="q2" /><span class="dot-v3"></span>Moins de 2 ans</label>
            <label class="opt-v3" onclick="pick(this,'q2','entre26',{experience:2})"><input type="radio" name="q2" /><span class="dot-v3"></span>Entre 2 et 6 ans</label>
            <label class="opt-v3" onclick="pick(this,'q2','plus6',{experience:3})"><input type="radio" name="q2" /><span class="dot-v3"></span>Plus de 6 ans</label>
          </div>
        </div>

        <div class="q-card-v3">
          <p class="q-label-v3">3. Quelle est la taille de votre commune ?</p>
          <div class="options-v3" id="q3">
            <label class="opt-v3" onclick="pick(this,'q3','tres_petite',{isolation:2})"><input type="radio" name="q3" /><span class="dot-v3"></span>Moins de 1 000 habitants</label>
            <label class="opt-v3" onclick="pick(this,'q3','petite',{isolation:1})"><input type="radio" name="q3" /><span class="dot-v3"></span>1 000 à 5 000 habitants</label>
            <label class="opt-v3" onclick="pick(this,'q3','moyenne',{})"><input type="radio" name="q3" /><span class="dot-v3"></span>5 000 à 20 000 habitants</label>
            <label class="opt-v3" onclick="pick(this,'q3','grande',{pressure:1,exposure:1})"><input type="radio" name="q3" /><span class="dot-v3"></span>Plus de 20 000 habitants</label>
          </div>
        </div>

        <div class="q-card-v3">
          <p class="q-label-v3">4. Avez-vous une activité professionnelle en parallèle ?</p>
          <div class="options-v3" id="q4">
            <label class="opt-v3" onclick="pick(this,'q4','oui_plein',{pressure:2,isolation:1})"><input type="radio" name="q4" /><span class="dot-v3"></span>Oui, à temps plein</label>
            <label class="opt-v3" onclick="pick(this,'q4','oui_partiel',{pressure:1})"><input type="radio" name="q4" /><span class="dot-v3"></span>Oui, à temps partiel</label>
            <label class="opt-v3" onclick="pick(this,'q4','non',{})"><input type="radio" name="q4" /><span class="dot-v3"></span>Non</label>
          </div>
        </div>

        <div class="nav-btns-v3">
          <button class="btn-primary-v3" id="next1" onclick="goBloc(2)" disabled>Continuer →</button>
        </div>
      </div>

      <div id="bloc2" class="hidden bloc-v3">
        <!-- BLOC 2 CONTENT -->
        <div class="bloc-header-v3">
          <p class="bloc-num-v3">Étape 2 sur 5 · Votre environnement</p>
          <h2 class="bloc-title-v3">L'appui que vous anticipez</h2>
        </div>
        <div class="q-card-v3">
          <p class="q-label-v3">5. Pensez-vous que vous serez suffisamment accompagné·e ?</p>
          <div class="options-v3" id="q5">
            <label class="opt-v3" onclick="pick(this,'q5','oui',{})"><input type="radio" name="q5" /><span class="dot-v3"></span>Oui, j'ai déjà de bons appuis</label>
            <label class="opt-v3" onclick="pick(this,'q5','incertain',{isolation:1,human:1})"><input type="radio" name="q5" /><span class="dot-v3"></span>Je ne sais pas encore</label>
            <label class="opt-v3" onclick="pick(this,'q5','non',{isolation:3,human:2})"><input type="radio" name="q5" /><span class="dot-v3"></span>Non, je pense être seul·e</label>
          </div>
        </div>
        <div class="nav-btns-v3">
           <button class="btn-link-v3" onclick="goBloc(1)">← Précédent</button>
           <button class="btn-primary-v3" id="next2" onclick="goBloc(3)" disabled>Continuer →</button>
        </div>
      </div>

      <div id="bloc3" class="hidden bloc-v3">
         <div class="bloc-header-v3">
          <p class="bloc-num-v3">Étape 3 sur 5 · Vos difficultés</p>
          <h2 class="bloc-title-v3">Ce qui vous pèse le plus</h2>
        </div>
        <div class="q-card-v3">
          <p class="q-label-v3">7. Vos rapports à la communication publique ?</p>
          <div class="options-v3" id="q8">
            <label class="opt-v3" onclick="pick(this,'q8','alaise',{})"><input type="radio" name="q8" /><span class="dot-v3"></span>À l'aise</label>
            <label class="opt-v3" onclick="pick(this,'q8','hesitant',{comm_public:2,pressure:1})"><input type="radio" name="q8" /><span class="dot-v3"></span>Hésitant·e</label>
            <label class="opt-v3" onclick="pick(this,'q8','difficulte',{comm_public:3,pressure:2})"><input type="radio" name="q8" /><span class="dot-v3"></span>C'est une difficulté</label>
          </div>
        </div>
        <div class="nav-btns-v3">
           <button class="btn-link-v3" onclick="goBloc(2)">← Précédent</button>
           <button class="btn-primary-v3" id="next3" onclick="goBloc(4)" disabled>Continuer →</button>
        </div>
      </div>

      <div id="bloc4" class="hidden bloc-v3">
        <div class="bloc-header-v3">
          <p class="bloc-num-v3">Étape 4 sur 5 · Votre délégation</p>
          <h2 class="bloc-title-v3">Votre sujet principal</h2>
        </div>
        <div class="q-card-v3">
          <p class="q-label-v3">10. Quel est votre sujet principal ?</p>
          <div class="options-v3" id="q10">
            <label class="opt-v3" onclick="pick(this,'q10','urbanisme',{theme:'urbanisme'})"><input type="radio" name="q10" /><span class="dot-v3"></span>Urbanisme / Aménagement</label>
            <label class="opt-v3" onclick="pick(this,'q10','culture',{theme:'culture'})"><input type="radio" name="q10" /><span class="dot-v3"></span>Culture / Patrimoine</label>
            <label class="opt-v3" onclick="pick(this,'q10','securite',{theme:'securite'})"><input type="radio" name="q10" /><span class="dot-v3"></span>Sécurité / Tranquillité</label>
            <label class="opt-v3" onclick="pick(this,'q10','generaliste',{theme:'generaliste'})"><input type="radio" name="q10" /><span class="dot-v3"></span>Généraliste / Pas de délégation</label>
          </div>
        </div>
        <div class="nav-btns-v3">
           <button class="btn-link-v3" onclick="goBloc(3)">← Précédent</button>
           <button class="btn-primary-v3" id="next4" onclick="goBloc(5)" disabled>Continuer →</button>
        </div>
      </div>

      <div id="bloc5" class="hidden bloc-v3">
        <div class="bloc-header-v3">
          <p class="bloc-num-v3">Étape 5 sur 5 · Votre besoin</p>
          <h2 class="bloc-title-v3">Dernière étape</h2>
        </div>
        <div class="q-card-v3">
          <p class="q-label-v3">14. Votre préférence de travail ?</p>
          <div class="options-v3" id="q14">
            <label class="opt-v3" onclick="pick(this,'q14','autonome',{offer_level:0})"><input type="radio" name="q14" /><span class="dot-v3"></span>En totale autonomie</label>
            <label class="opt-v3" onclick="pick(this,'q14','humain',{offer_level:3,human:2})"><input type="radio" name="q14" /><span class="dot-v3"></span>Avec un appui humain</label>
          </div>
        </div>
        <div class="nav-btns-v3">
           <button class="btn-link-v3" onclick="goBloc(4)">← Précédent</button>
           <button class="btn-primary-v3" id="next5" onclick="showEmail()" disabled>Voir mon résultat →</button>
        </div>
      </div>

      <div id="emailSection" class="hidden">
        <div class="diag-card-hero" style="text-align:left; padding:4rem;">
          <span class="label-v3">Dernier pas</span>
          <h2>Afin de préparer votre synthèse...</h2>
          <p>Laissez-nous votre email pour recevoir l'analyse complète de votre situation.</p>
          <div class="email-form-v3">
            <input type="email" id="emailInput" placeholder="votre@email.fr" />
            <button class="btn-primary-v3" onclick="submitEmail()">Consulter le résultat →</button>
          </div>
          <button class="btn-skip-v3" onclick="showResult()">Passer cette étape</button>
        </div>
      </div>
    </div>

    <!-- RESULT SECTION -->
    <div id="resultSection" class="result-v3 hidden">
      <div class="result-header-v3">
        <span class="result-badge-v3">Mon Profil MARYAN</span>
        <h2 id="rTitle">Calcul du profil...</h2>
        <p class="result-intro" id="rSummary"></p>
      </div>

      <div class="result-grid-v3">
        <div class="result-card-v3">
          <h3>Priorités détectées</h3>
          <ul id="rNeeds" class="result-list-v3"></ul>
        </div>
        <div class="result-card-v3">
          <h3>Appuis préconisés</h3>
          <ul id="rHelps" class="result-list-v3"></ul>
        </div>
      </div>

      <div class="exposure-card-v3">
        <h3>Technicité & Exposition</h3>
        <div class="bars-v3">
          <div class="bar-row-v3">
            <span>Technicité du sujet</span>
            <div class="bar-track-v3"><div class="bar-fill-v3" id="barTech"></div></div>
          </div>
          <div class="bar-row-v3">
            <span>Conflictualité</span>
            <div class="bar-track-v3"><div class="bar-fill-v3" id="barConflict"></div></div>
          </div>
          <div class="bar-row-v3">
            <span>Exposition publique</span>
            <div class="bar-track-v3"><div class="bar-fill-v3" id="barExpo"></div></div>
          </div>
        </div>
      </div>

      <div class="offer-v3-card">
        <span class="offer-label-v3">Recommandation MARYAN</span>
        <h3 id="offerName"></h3>
        <p id="offerDesc"></p>
        <div class="offer-action-v3">
           <a href="/#offres" class="btn-primary-v3 big">Découvrir les offres →</a>
        </div>
      </div>

      <div class="result-footer-v3">
        <a href="/" class="btn-link-v3">Retour à l'accueil</a>
      </div>
    </div>
  </main>

  <style>
    /* ─── VARIABLES DESIGN MARYAN ─── */
    .diag-main-v3 {
      --terracotta: #D97757;
      --encre: #1E2A32;
      --sauge: #8DA08E;
      --lin: #FAF7F2;
      --border: rgba(30, 42, 50, 0.1);
      --serif: "Iowan Old Style", serif;
      
      max-width: 840px;
      margin: 4rem auto 10rem;
      padding: 0 1.5rem;
    }

    /* ─── AMBIANCE ─── */
    .page-ambient-bg {
      position: fixed;
      inset: 0; z-index: -1;
    }
    .page-ambient-bg img {
      width: 100%; height: 100%; object-fit: cover; opacity: 0.35; filter: blur(20px);
    }
    .ambient-overlay {
      position: absolute; inset: 0;
      background: radial-gradient(circle at center, transparent 0%, #FCFAF6 85%);
    }

    /* ─── HEADER ─── */
    .diag-header-v3 {
      background: rgba(252, 250, 246, 0.8) !important;
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--border);
    }

    /* ─── PROGRESS ─── */
    .progress-wrap-v3 {
      position: sticky; top: 100px; z-index: 50; padding: 1.5rem 0;
    }
    .progress-track-v3 {
      flex: 1; height: 6px; background: var(--border); border-radius: 99px; overflow: hidden;
    }
    .progress-fill-v3 {
      height: 100%; width: 0; background: var(--encre); transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .progress-inner-v3 { display: flex; align-items: center; gap: 1.5rem; }
    .progress-count-v3 { font-size: 0.85rem; font-weight: 700; color: var(--encre); min-width: 60px; }

    /* ─── CARDS ─── */
    .diag-card-hero {
      background: white; border: 1px solid var(--border); border-radius: 40px;
      padding: 6rem 4rem; text-align: center; box-shadow: 0 30px 60px rgba(0,0,0,0.04);
      animation: fadeIn 0.8s ease;
    }
    .diag-card-hero h1 { font-size: clamp(2.5rem, 8vw, 4rem); margin: 2rem 0; line-height: 1.1; }
    .intro-lead { font-size: 1.3rem; color: #54636C; line-height: 1.6; max-width: 650px; margin: 0 auto 3.5rem; }

    .q-card-v3 {
      background: white; border: 1px solid var(--border); border-radius: 28px;
      padding: 2.5rem; margin-bottom: 1.5rem; transition: transform 0.3s ease;
    }
    .q-label-v3 { font-size: 1.3rem; font-weight: 700; color: var(--encre); margin-bottom: 2rem; line-height: 1.3; }

    /* ─── FORM ELEMENTS (Correction Windows 87) ─── */
    .options-v3 { display: flex; flex-direction: column; gap: 0.85rem; }
    .opt-v3 {
      display: flex; align-items: center; gap: 1.25rem; padding: 1.25rem 1.5rem;
      border: 1.5px solid var(--border); border-radius: 16px; cursor: pointer;
      font-size: 1.05rem; font-weight: 500; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      background: #FCFAF6; color: #54636C;
    }
    .opt-v3:hover { border-color: var(--encre); background: white; transform: translateX(5px); }
    .opt-v3.selected {
      background: white; border-color: var(--encre); border-width: 2px; color: var(--encre); font-weight: 700;
      box-shadow: 0 10px 20px rgba(30, 42, 50, 0.05);
    }
    .opt-v3 input { display: none; }
    .dot-v3 {
      width: 22px; height: 22px; border: 2.5px solid var(--border); border-radius: 50%;
      background: white; position: relative; transition: all 0.2s; flex-shrink: 0;
    }
    .opt-v3.selected .dot-v3 { border-color: var(--terracotta); background: var(--terracotta); }
    .opt-v3.selected .dot-v3::after {
      content: ''; position: absolute; inset: 6px; background: white; border-radius: 50%;
    }

    /* ─── BUTTONS ─── */
    .nav-btns-v3 { display: flex; align-items: center; gap: 2rem; margin-top: 4rem; }
    .btn-primary-v3 {
      background: var(--terracotta); color: white; border: none; padding: 1.1rem 2.5rem;
      border-radius: 99px; font-weight: 700; font-size: 1.05rem; cursor: pointer;
      box-shadow: 0 10px 25px rgba(217, 119, 87, 0.25); transition: all 0.3s;
    }
    .btn-primary-v3:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 15px 35px rgba(217, 119, 87, 0.35); filter: brightness(1.1); }
    .btn-primary-v3:disabled { opacity: 0.3; cursor: not-allowed; filter: grayscale(1); }
    .btn-primary-v3.big { font-size: 1.25rem; padding: 1.5rem 3.5rem; }

    .btn-link-v3 {
      background: none; border: 1.5px solid var(--border); color: var(--encre); font-weight: 700;
      padding: 1rem 1.8rem; border-radius: 99px; cursor: pointer; transition: all 0.2s;
    }
    .btn-link-v3:hover { border-color: var(--encre); background: var(--lin); }

    /* ─── EMAIL SECTION ─── */
    .email-form-v3 { display: flex; gap: 1rem; margin: 3rem 0 1.5rem; }
    .email-form-v3 input {
      flex: 1; padding: 1.25rem 1.5rem; border: 1.5px solid var(--border); border-radius: 18px;
      font-size: 1.1rem; outline: none; transition: border-color 0.2s;
    }
    .email-form-v3 input:focus { border-color: var(--terracotta); }
    .btn-skip-v3 { background: none; border: none; text-decoration: underline; color: #54636C; cursor: pointer; font-size: 0.95rem; }

    /* ─── RESULT V3 ─── */
    .result-v3 { animation: slideUp 0.8s ease; }
    .result-header-v3 { text-align: center; margin-bottom: 5rem; }
    .result-badge-v3 {
      display: inline-block; padding: 0.6rem 1.5rem; background: var(--lin); border-radius: 99px;
      font-weight: 700; color: var(--encre); font-size: 0.85rem; border: 1px solid var(--border); margin-bottom: 1.5rem;
    }
    .result-v3 h2 { font-size: clamp(2.5rem, 6vw, 4rem); margin-bottom: 2rem; font-family: var(--serif); }
    .result-grid-v3 { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 2rem; }
    .result-card-v3 { background: white; border-radius: 32px; padding: 3rem; border: 1px solid var(--border); }
    .result-list-v3 { list-style: none; padding: 0; margin-top: 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
    .result-list-v3 li { position: relative; padding-left: 1.8rem; font-size: 1.05rem; color: #54636C; }
    .result-list-v3 li::before { content: '→'; position: absolute; left: 0; color: var(--terracotta); font-weight: 900; }

    .exposure-card-v3 { background: white; border-radius: 32px; padding: 3rem; border: 1px solid var(--border); margin-bottom: 2rem; }
    .bar-row-v3 { display: flex; align-items: center; gap: 2rem; margin-top: 1.5rem; }
    .bar-row-v3 span { flex-shrink: 0; width: 160px; font-weight: 600; font-size: 0.9rem; color: #54636C; }
    .bar-track-v3 { flex: 1; height: 10px; background: var(--lin); border-radius: 99px; overflow: hidden; }
    .bar-fill-v3 { height: 100%; width: 0; transition: width 1.2s cubic-bezier(0.4, 0, 0.2, 1); border-radius: 99px; }

    .offer-v3-card {
      background: var(--encre); color: white; border-radius: 40px; padding: 5rem 3rem; text-align: center;
    }
    .offer-v3-card h3 { color: white; font-size: 2.5rem; margin-bottom: 1.5rem; font-family: var(--serif); }
    .offer-v3-card p { opacity: 0.85; font-size: 1.2rem; max-width: 600px; margin: 0 auto 3.5rem; }

    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @keyframes slideUp { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }

    .hidden { display: none !important; }
    
    @media (max-width: 768px) {
      .diag-card-hero { padding: 4rem 2.5rem; }
      .result-grid-v3 { grid-template-columns: 1fr; }
      .email-form-v3 { flex-direction: column; }
    }
  </style>

  <script is:inline>
    // JS DIAG LOGIC V3
    const S = { 
      institutional: 0, posture: 0, comm_public: 0, 
      pressure: 0, isolation: 0, human: 0, 
      experience: 0, exposure: 0, offer_level: 0, 
      theme: 'generaliste' 
    };
    const answered = {};
    const REQUIRED = { 1:['q1','q2','q3','q4'], 2:['q5'], 3:['q8'], 4:['q10'], 5:['q14'] };
    let currentBloc = 0;

    function updateProgress() {
      const totalSteps = 15;
      const count = Object.keys(answered).length;
      const pct = Math.round((count / totalSteps) * 100);
      document.getElementById('progressFill').style.width = pct + '%';
      document.getElementById('progressCount').textContent = count + ' / ' + totalSteps;
    }

    function startDiag() {
      document.getElementById('introSection').classList.add('hidden');
      document.getElementById('progressWrap').classList.remove('hidden');
      document.getElementById('diagSection').classList.remove('hidden');
      goBloc(1);
    }
    window.startDiag = startDiag;

    function applyDeltas(deltas, sign) {
      if (!deltas) return;
      for (const [k, v] of Object.entries(deltas)) {
        if (k === 'theme') { if (sign > 0) S.theme = v; }
        else S[k] = Math.max(0, (S[k] || 0) + sign * v);
      }
    }

    function pick(label, qKey, value, deltas) {
      if (answered[qKey]) applyDeltas(answered[qKey].deltas, -1);
      applyDeltas(deltas, 1);
      answered[qKey] = { value, deltas };
      
      const opts = document.getElementById(qKey).querySelectorAll('.opt-v3');
      opts.forEach(o => o.classList.remove('selected'));
      label.classList.add('selected');

      updateProgress();
      checkBloc(currentBloc);
    }
    window.pick = pick;

    function checkBloc(num) {
      const req = REQUIRED[num] || [];
      const ok = req.every(q => answered[q]);
      const btn = document.getElementById('next' + num);
      if (btn) btn.disabled = !ok;
    }

    function goBloc(num) {
      for (let i = 1; i <= 5; i++) {
        const e = document.getElementById('bloc' + i);
        if (e) e.classList.add('hidden');
      }
      document.getElementById('emailSection').classList.add('hidden');
      document.getElementById('bloc' + num).classList.remove('hidden');
      currentBloc = num;
      checkBloc(num);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
    window.goBloc = goBloc;

    function showEmail() {
      document.getElementById('bloc5').classList.add('hidden');
      document.getElementById('emailSection').classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
    window.showEmail = showEmail;

    function submitEmail() { showResult(); }
    window.submitEmail = submitEmail;

    const PROFILES = {
      prise_de_fonction: { 
        title: 'Élu·e en prise de fonction', 
        summary: 'Vous entrez dans le mandat avec beaucoup d\'envie mais peu de repères stabilisés.', 
        needs: ['Comprendre les circuits de décision', 'Clarifier votre place', 'Établir une méthode'], 
        helps: ['Bibliothèque de ressources', 'Diagnostic thématique ciblée', 'Echanges avec un expert'] 
      },
      elu_isole: { 
        title: 'Élu·e engagé·e mais isolé·e', 
        summary: 'Vous portez des responsabilités lourdes mais vous sentez souvent seul·e face aux décisions.', 
        needs: ['Sortir de l\'isolement', 'Avoir un regard extérieur', 'Sécuriser vos arbitrages'], 
        helps: ['Copilote MARYAN Plus', 'Cadrage stratégique mensuel', 'Accès Hub Experts'] 
      },
      elu_surcharge: { 
        title: 'Élu·e en surcharge', 
        summary: 'Entre mandat, vie pro et vie perso, la charge mentale est à son maximum.', 
        needs: ['Prioriser les dossiers', 'Déléguer avec efficacité', 'Retrouver de l\'air'], 
        helps: ['Méthodes d\'organisation', 'Appui digital MARYAN', 'Consultant organisation'] 
      }
    };

    const OFFERS = [
      { name: 'MARYAN Essentiel', desc: 'Le libre accès aux ressources et au copilote de base.' },
      { name: 'MARYAN Veille & Appui', desc: 'Un suivi personnalisé et des alertes sur vos thématiques.' },
      { name: 'MARYAN Cadrage Stratégique', desc: 'Un rendez-vous mensuel pour remettre votre mandat à plat.' },
      { name: 'MARYAN Hub Expert', desc: 'L\'accès direct aux meilleurs spécialistes du mandat.' }
    ];

    function showResult() {
      document.getElementById('diagSection').classList.add('hidden');
      document.getElementById('emailSection').classList.add('hidden');
      document.getElementById('progressWrap').classList.add('hidden');

      // Simple Scoring logic for demo
      let pk = 'prise_de_fonction';
      if (S.isolation >= 2) pk = 'elu_isole';
      if (S.pressure >= 2) pk = 'elu_surcharge';

      const p = PROFILES[pk];
      const ol = Math.min(3, S.offer_level || 1);
      const o = OFFERS[ol];

      document.getElementById('rTitle').textContent = p.title;
      document.getElementById('rSummary').textContent = p.summary;
      document.getElementById('rNeeds').innerHTML = p.needs.map(n => '<li>' + n + '</li>').join('');
      document.getElementById('rHelps').innerHTML = p.helps.map(h => '<li>' + h + '</li>').join('');
      document.getElementById('offerName').textContent = o.name;
      document.getElementById('offerDesc').textContent = o.desc;

      // Persist for Agent
      try {
        localStorage.setItem('maryan_profile', JSON.stringify({
          title: p.title,
          summary: p.summary,
          themeLabel: S.theme,
          offerName: o.name
        }));
        if (window.maryanChat) window.maryanChat.checkProfile();
      } catch(e) {}

      document.getElementById('resultSection').classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });

      // Animate bars
      setTimeout(() => {
        document.getElementById('barTech').style.width = '65%';
        document.getElementById('barTech').style.background = '#8DA08E';
        document.getElementById('barConflict').style.width = '45%';
        document.getElementById('barConflict').style.background = '#D97757';
        document.getElementById('barExpo').style.width = '80%';
        document.getElementById('barExpo').style.background = '#D97757';
      }, 300);
    }
    window.showResult = showResult;
  </script>
</BaseLayout>
