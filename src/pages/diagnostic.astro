---
import BaseLayout from '../layouts/BaseLayout.astro';
import InternalHeader from '../components/InternalHeader.astro';
---

<BaseLayout 
  title="Diagnostic — MARYAN" 
  description="Faites le point sur votre mandat en quelques minutes. Analyse de contexte, tension et exposition.">
  
  <InternalHeader 
    label="Diagnostic MARYAN"
    title="Faites le point sur votre mandat en <span class='emphasis'>quelques minutes</span>."
    subtitle="MARYAN analyse votre contexte, vos points de tension et votre niveau d’exposition pour vous aider à clarifier vos priorités et sécuriser vos décisions."
  />

  <main class="diag-app-v3">

    <!-- HERO D'ENTRÉE -->
    <div id="introSection" class="container container-narrow diag-step active">
      <div class="diag-intro-card card-v3">
        <p class="diag-kicker">Votre situation d'élu·e</p>
        <ul class="diag-intro-list">
          <li>✨ <span><strong>Une lecture claire</strong> de votre situation réelle.</span></li>
          <li>🛡️ <span><strong>Vos points de vigilance</strong> prioritaires.</span></li>
          <li>🎯 <span><strong>Un appui adapté</strong> à votre contexte municipal.</span></li>
        </ul>
        <div class="diag-intro-cta">
          <button class="btn-primary-v3 big" id="startBtn">Lancer le diagnostic</button>
          <p class="diag-hint">6 questions · 3 minutes · Confidentiel · Sans engagement</p>
        </div>
      </div>
    </div>

    <!-- PROGRESS BAR -->
    <div class="progress-wrap-v3 hidden" id="progressWrap">
      <div class="container-narrow">
        <div class="progress-inner-v3">
          <div class="progress-track-v3"><div class="progress-fill-v3" id="progressFill"></div></div>
          <p id="progressLabel" class="progress-label-v3">Étape 1/5</p>
        </div>
      </div>
    </div>

    <!-- QUESTIONS -->
    <div id="diagSection" class="hidden questions-v3 container-narrow">

      <!-- Q1 : RÔLE -->
      <div class="diag-step" id="q1-step">
        <div class="q-content-v3">
          <h2 class="q-label-v3">Quel est votre rôle aujourd’hui dans la vie politique locale ?</h2>
          <p class="q-help-v3">Votre rôle influence votre niveau d’exposition, vos marges de manœuvre et la nature des décisions à sécuriser.</p>
          <div class="options-v3">
            <button class="opt-v3" onclick="pick(this,'role','maire',1)">Maire</button>
            <button class="opt-v3" onclick="pick(this,'role','adjoint',1)">Adjoint·e au maire</button>
            <button class="opt-v3" onclick="pick(this,'role','conseiller_maj',1)">Conseiller·e de la majorité</button>
            <button class="opt-v3" onclick="pick(this,'role','conseiller_opp',1)">Conseiller·e d’opposition</button>
            <button class="opt-v3" onclick="pick(this,'role','interco',1)">Président·e / VP d’intercommunalité</button>
          </div>
        </div>
      </div>

      <!-- Q2 : ANCIENNETÉ -->
      <div class="diag-step hidden" id="q2-step">
        <div class="q-content-v3">
          <h2 class="q-label-v3">Depuis combien de temps exercez-vous ce mandat ?</h2>
          <p class="q-help-v3">Cette information nous aide à ajuster le niveau d’accompagnement.</p>
          <div class="options-v3">
            <button class="opt-v3" onclick="pick(this,'experience','moins1an',2)">Moins d’un an</button>
            <button class="opt-v3" onclick="pick(this,'experience','1-3ans',2)">Entre 1 et 3 ans</button>
            <button class="opt-v3" onclick="pick(this,'experience','3-6ans',2)">Entre 3 et 6 ans</button>
            <button class="opt-v3" onclick="pick(this,'experience','renouvele',2)">Plus de 6 ans / mandat renouvelé</button>
          </div>
        </div>
      </div>

      <!-- Q3 : BESOIN PRINCIPAL -->
      <div class="diag-step hidden" id="q3-step">
        <div class="q-content-v3">
          <h2 class="q-label-v3">Qu’est-ce qui vous amène à faire ce diagnostic ?</h2>
          <p class="q-help-v3">Nous distinguons ici une urgence ponctuelle d’un besoin d’appui plus structurel.</p>
          <div class="options-v3">
            <button class="opt-v3" onclick="pick(this,'need','decision',3)">Arbitrer une décision sensible</button>
            <button class="opt-v3" onclick="pick(this,'need','conflit',3)">Gérer une tension ou un conflit</button>
            <button class="opt-v3" onclick="pick(this,'need','prise_parole',3)">Préparer une prise de parole ou une séquence politique</button>
            <button class="opt-v3" onclick="pick(this,'need','methode',3)">Remettre de la méthode sur un dossier complexe</button>
            <button class="opt-v3" onclick="pick(this,'need','recul',3)">Prendre du recul et clarifier mes priorités</button>
          </div>
        </div>
      </div>

      <!-- Q4 : ENTOURAGE -->
      <div class="diag-step hidden" id="q4-step">
        <div class="q-content-v3">
          <h2 class="q-label-v3">Dans votre mandat, vous sentez-vous suffisamment entouré·e pour décider sereinement ?</h2>
          <div class="options-v3">
            <button class="opt-v3" onclick="pick(this,'support','oui',4)">Oui, je peux m’appuyer sur des relais solides</button>
            <button class="opt-v3" onclick="pick(this,'support','partiel',4)">Cela dépend des sujets et des moments</button>
            <button class="opt-v3" onclick="pick(this,'support','non',4)">Non, je porte trop souvent les décisions seul·e</button>
          </div>
        </div>
      </div>

      <!-- Q5 : SUJET DU MOMENT -->
      <div class="diag-step hidden" id="q5-step">
        <div class="q-content-v3">
          <h2 class="q-label-v3">Quel sujet concentre le plus votre attention en ce moment ?</h2>
          <div class="options-v3" id="subjectOptions">
            <button class="opt-v3" onclick="pick(this,'focus','urbanisme',5)">Urbanisme, aménagement, habitat</button>
            <button class="opt-v3" onclick="pick(this,'focus','budget',5)">Budget, finances, arbitrages</button>
            <button class="opt-v3" onclick="pick(this,'focus','politique',5)">Gouvernance, majorité, relations politiques</button>
            <button class="opt-v3" onclick="pick(this,'focus','securite',5)">Sécurité, tranquillité publique, gestion de crise</button>
            <button class="opt-v3" onclick="pick(this,'focus','social',5)">Écoles, solidarités, services à la population</button>
            <button class="opt-v3" id="otherBtn" onclick="toggleOther(true)">Autre sujet prioritaire</button>
          </div>
          
          <div id="otherInputWrapper" class="hidden" style="margin-top:1.5rem;">
            <input type="text" id="otherFocus" placeholder="Décrivez en quelques mots le sujet principal..." class="input-v3" />
            <button class="btn-primary-v3" style="margin-top:1rem; width:100%;" onclick="pickOther()">Valider →</button>
            <button class="btn-link-simple" style="margin-top:1rem; display:block; width:100%;" onclick="toggleOther(false)">← Revenir aux choix</button>
          </div>
        </div>
      </div>

      <!-- TRANSITION DE CALCUL -->
      <div class="diag-step hidden" id="calculating-step">
        <div class="q-content-v3 text-center">
           <div class="loader-v3"></div>
           <h2 class="q-label-v3">Votre diagnostic se prépare</h2>
           <p style="opacity:0.7;">MARYAN relie votre rôle, votre contexte et vos points de tension pour faire ressortir vos priorités d’action...</p>
        </div>
      </div>
    </div>

    <!-- RESTITUTION FINALE -->
    <div id="resultSection" class="result-v3 hidden container">
       
       <header class="result-header-v3">
          <span class="label-v3">Votre lecture de mandat</span>
          <h2 id="resVigilanceTitle" class="emphasis result-title-v3">—</h2>
          <p id="resVigilanceText" class="intro-v3"></p>
       </header>

       <div class="result-grid-v3">
          <!-- Bloc 2 : Implications -->
          <div class="card-v3">
             <h3 class="card-kicker">Risques identifiés</h3>
             <p class="small" style="margin-bottom:1.5rem; opacity:0.6;">Ce que cela peut produire si rien ne change :</p>
             <ul id="resImplications" class="v3-list-dots"></ul>
          </div>

          <!-- Bloc 3 : Priorités -->
          <div class="card-v3 bg-light">
             <h3 class="card-kicker">Vos priorités immédiates</h3>
             <ul id="resPriorities" class="v3-list-dots-red"></ul>
          </div>
       </div>

       <!-- Bloc 4 : Appui Recommandé -->
       <div class="reco-box-v3">
          <div class="reco-content-v3">
             <span class="badge-v3">Appui le plus pertinent</span>
             <h3 id="resAppuiTitle" style="font-size:1.8rem; margin:1rem 0;">—</h3>
             <p id="resAppuiText" class="intro-v3 small" style="opacity:0.9;"></p>
          </div>
          <div class="reco-cta-v3">
             <a href="/offres" id="mainCTA" class="btn-primary-v3 big">Découvrir l’appui recommandé</a>
             <a href="/copilote" class="btn-secondary-v3">Tester le copilote gratuit</a>
          </div>
       </div>

       <!-- Bloc 5 : Email (Sauvegarde) -->
       <div id="emailCaptureBox" class="email-capture-v3">
          <div class="email-text-v3">
             <h3>Recevoir votre synthèse complète</h3>
             <p>Gardez une trace de ce diagnostic pour le relire plus tard ou retrouver vos priorités en un clic.</p>
          </div>
          <div class="email-form-v3">
             <input type="email" id="emailInput" placeholder="vous@collectivite.fr" class="input-v3" />
             <button class="btn-primary-v3" onclick="submitEmail()">Recevoir</button>
          </div>
       </div>

       <footer class="result-footer-v3 text-center">
          <p>Un mandat ne se porte pas seul·e face à l'incertitude.</p>
          <a href="/contact" class="btn-link-simple">Parler à un conseiller MARYAN</a>
       </footer>
    </div>

  </main>

  <style>
    .diag-app-v3 { height: 100vh; overflow: hidden; display: flex; flex-direction: column; background: #FDFBF8; }
    .container { max-width: 1000px; margin: 0 auto; width: 100%; padding: 0 1.5rem; }
    .container-narrow { max-width: 620px; margin: 0 auto; width: 100%; padding: 0 1.5rem; }

    /* Transitions steps */
    .diag-step {
      display: flex; flex-direction: column; justify-content: center;
      height: 70vh; opacity: 0; transform: translateY(20px); transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      position: absolute; width: 100%; left: 0; pointer-events: none;
    }
    .diag-step.active { opacity: 1; transform: translateY(0); pointer-events: auto; }
    .diag-step.hidden { display: none; }
    .questions-v3 { position: relative; flex: 1; min-height: 480px; }

    /* UI Components */
    .progress-wrap-v3 { padding: 1.5rem 0; background: #fff; border-bottom: 1px solid rgba(0,0,0,0.05); }
    .progress-inner-v3 { display: flex; align-items: center; gap: 2rem; }
    .progress-track-v3 { flex: 1; height: 3px; background: #EEE; border-radius: 99px; overflow: hidden; }
    .progress-fill-v3 { height: 100%; background: var(--accent-red); transition: width 0.4s; }
    .progress-label-v3 { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: #999; letter-spacing: 0.05em; }

    .q-help-v3 { margin-bottom: 2rem; opacity: 0.6; font-size: 0.95rem; line-height: 1.4; }
    .q-label-v3 { font-size: 1.8rem; margin-bottom: 1rem; color: var(--deep); line-height: 1.2; font-weight: 700; }
    .options-v3 { display: flex; flex-direction: column; gap: 0.75rem; }
    .opt-v3 { padding: 1.1rem 1.4rem; background: #fff; border: 1.5px solid #E5E7EB; border-radius: 14px; text-align: left; font-size: 1rem; font-weight: 600; cursor: pointer; transition: all 0.2s; }
    .opt-v3:hover { border-color: var(--deep); transform: translateX(5px); box-shadow: 0 2px 8px rgba(0,0,0,0.03); }

    .input-v3 { width: 100%; padding: 1rem 1.4rem; border: 1.5px solid #E5E7EB; border-radius: 12px; font-size: 1rem; }

    /* Result styles */
    .result-v3 { overflow-y: scroll; padding: 6rem 1.5rem; height: 100vh; background: #FFFDF8; }
    .result-header-v3 { margin-bottom: 5rem; max-width: 800px; }
    .result-title-v3 { font-size: clamp(1.8rem, 5vw, 3rem); margin: 1.5rem 0; line-height: 1.1; }
    .result-grid-v3 { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 3rem; }
    .card-kicker { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--accent-red); margin-bottom: 1.5rem; display: block; letter-spacing: 0.05em; }

    .reco-box-v3 { background: var(--deep); color: white; border-radius: 24px; padding: 4rem; display: flex; justify-content: space-between; align-items: center; gap: 4rem; margin: 4rem 0; }
    .reco-content-v3 h3 { color: white; }
    .reco-cta-v3 { display: flex; flex-direction: column; gap: 1rem; min-width: 280px; }
    
    .email-capture-v3 { background: #fff; padding: 3rem; border-radius: 20px; border: 1px solid #EEE; display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 4rem; align-items: center; margin: 4rem 0; }
    .email-text-v3 h3 { font-size: 1.4rem; margin-bottom: 0.75rem; }
    .email-text-v3 p { font-size: 0.95rem; opacity: 0.6; margin: 0; }
    .email-form-v3 { display: flex; gap: 0.5rem; }

    .v3-list-dots-red li { position: relative; padding-left: 1.5rem; margin-bottom: 0.75rem; font-weight: 600; font-size: 0.95rem; }
    .v3-list-dots-red li::before { content: ""; position: absolute; left: 0; top: 0.6em; width: 6px; height: 6px; background: var(--accent-red); border-radius: 50%; }

    /* Loader */
    .loader-v3 { width: 40px; height: 40px; border: 3px solid #EEE; border-top-color: var(--accent-red); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 2rem; }
    @keyframes spin { to { transform: rotate(360deg); } }

    @media (max-width: 900px) {
       .result-grid-v3 { grid-template-columns: 1fr; }
       .reco-box-v3 { flex-direction: column; padding: 2.5rem; text-align: center; gap: 2rem; }
       .email-capture-v3 { grid-template-columns: 1fr; gap: 2rem; padding: 2rem; text-align: center; }
       .email-form-v3 { flex-direction: column; }
    }
  </style>

  <script is:inline>
    const state = { answers: {}, step: 0 };
    const STEPS = ['intro', 'q1', 'q2', 'q3', 'q4', 'q5', 'calc'];

    function showStep(id) {
       document.querySelectorAll('.diag-step').forEach(s => {
          s.classList.remove('active');
          setTimeout(() => { if(!s.classList.contains('active')) s.classList.add('hidden'); }, 300);
       });
       const target = document.getElementById(id);
       if(target) {
          target.classList.remove('hidden');
          setTimeout(() => target.classList.add('active'), 50);
       }
       const idx = STEPS.indexOf(id.replace('-step', ''));
       if(idx > 0) {
          const pct = (idx / (STEPS.length - 2)) * 100;
          document.getElementById('progressFill').style.width = Math.min(100, pct) + '%';
          document.getElementById('progressLabel').textContent = `Étape ${idx}/5`;
       }
    }

    document.getElementById('startBtn').addEventListener('click', () => {
       document.getElementById('progressWrap').classList.remove('hidden');
       document.getElementById('diagSection').classList.remove('hidden');
       showStep('q1-step');
    });

    window.toggleOther = (active) => {
       document.getElementById('subjectOptions').classList.toggle('hidden', active);
       document.getElementById('otherInputWrapper').classList.toggle('hidden', !active);
    };

    window.pick = (btn, key, val, stepIdx) => {
       state.answers[key] = val;
       if(stepIdx < 5) {
          setTimeout(() => showStep(STEPS[stepIdx + 1] + '-step'), 350);
       } else {
          showStep('calculating-step');
          setTimeout(generateResult, 1500);
       }
    };

    window.pickOther = () => {
       const val = document.getElementById('otherFocus').value.trim();
       if(!val) return;
       window.pick(null, 'focus', val, 5);
    };

    function generateResult() {
       const { role, experience, need, support, focus } = state.answers;
       
       // PROFILE GENERATOR OBJECT (11 lines)
       const profile = {
          roleId: role,
          seniority: experience,
          motive: need,
          isolationLevel: support === 'non' ? 'high' : (support === 'partiel' ? 'med' : 'low'),
          riskProfile: (role === 'maire' || role === 'interco' || need === 'tension') ? 'exposed' : 'managing',
          primaryDomain: focus,
          needsHuman: (support === 'non' || need === 'conflit' || (experience === 'moins1an' && role === 'maire')),
          diagnosticId: 'diag_' + Math.random().toString(36).substr(2, 9),
          timestamp: new Date().toISOString(),
          context: `${role} (${experience})`,
          recoLevel: (support === 'non' || need === 'conflit') ? 'Plus' : 'Essential'
       };

       console.log("DIAGNOSTIC COMPLETION:", profile);
       localStorage.setItem('maryan_profile', JSON.stringify(profile));

       // RENDER RECOVERY LOGIC
       const res = {
          vigilanceTitle: "Votre point de vigilance principal : décider trop souvent seul·e",
          vigilanceText: "Votre diagnostic fait apparaître une exposition élevée et des relais encore fragiles sur les décisions sensibles. Votre enjeu principal n’est pas seulement de gérer les dossiers en cours : c’est de retrouver un cadre d’arbitrage plus serein, plus solide et plus lisible.",
          implications: [
             "Apparition d'une fatigue décisionnelle",
             "Risque d'arbitrages défensifs par manque de recul",
             "Difficulté à prioriser les urgences politiques",
             "Exposition accrue sur les sujets sensibles"
          ],
          priorities: [
             "Recréer du recul avant les décisions sensibles",
             "Sécuriser les dossiers à forte exposition",
             "Distinguer le politique du technique"
          ],
          appuiTitle: "Un accompagnement stratégique sur-mesure",
          appuiText: "Au vu de votre profil, un simple outil peut vous aider ponctuellement, mais il risque d'être insuffisant dans les moments à forte tension. L'appui le plus utile pour vous est un accompagnement capable de vous aider à cadrer, arbitrer et tenir la décision dans la durée."
       };

       // Special adjustments based on role/exp
       if (experience === 'moins1an' && role === 'maire') {
          res.vigilanceTitle = "Priorité : Maîtriser le tempo du mandat";
          res.vigilanceText = "En première année de mandat, le risque est de se laisser submerger par les urgences techniques des services. Vous avez besoin de poser votre autorité politique tout en sécurisant vos premiers grands actes administratifs.";
       }
       if (support === 'oui') {
          res.vigilanceTitle = "Enjeu : Optimiser votre force de pilotage";
          res.vigilanceText = "Vous bénéficiez d'un bon entourage. Votre défi est maintenant de transformer cet appui en une machine de guerre opérationnelle pour vos dossiers les plus complexes sans vous perdre dans le détail.";
          res.appuiTitle = "MARYAN Copilote (Offre Individuelle)";
          res.appuiText = "Votre socle est solide. MARYAN peut agir comme un super-conseiller de cabinet disponible 24h/24 pour affiner vos prises de parole et vos arbitrages quotidiens.";
       }

       // Update DOM
       document.getElementById('resVigilanceTitle').textContent = res.vigilanceTitle;
       document.getElementById('resVigilanceText').textContent = res.vigilanceText;
       document.getElementById('resImplications').innerHTML = res.implications.map(i => `<li>${i}</li>`).join('');
       document.getElementById('resPriorities').innerHTML = res.priorities.map(p => `<li>${p}</li>`).join('');
       document.getElementById('resAppuiTitle').textContent = res.appuiTitle;
       document.getElementById('resAppuiText').textContent = res.appuiText;

       // Toggle Views
       document.getElementById('diagSection').classList.add('hidden');
       document.getElementById('progressWrap').classList.add('hidden');
       document.getElementById('resultSection').classList.remove('hidden');
       window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    window.submitEmail = () => {
       const email = document.getElementById('emailInput').value.trim();
       if(!email) return;
       // Mock send
       localStorage.setItem('user_email', email);
       document.getElementById('emailCaptureBox').innerHTML = `<div style="text-align:center;width:100%;"><p style="color:var(--deep);font-weight:700;">✓ Merci, votre synthèse va vous être envoyée.</p></div>`;
    };
  </script>
</BaseLayout>
