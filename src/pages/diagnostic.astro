---
import BaseLayout from '../layouts/BaseLayout.astro';
import InternalHeader from '../components/InternalHeader.astro';
---

<BaseLayout 
  title="Diagnostic de mandat — MARYAN" 
  description="En quelques minutes, MARYAN repère ce qui vous pèse, ce qui vous expose, et la meilleure manière de vous aider concrètement.">
  
  <InternalHeader 
    label="Diagnostic de situation"
    title="Faire le point avant de continuer <span class='emphasis'>seul·e</span>."
    subtitle="En quelques minutes, MARYAN repère ce qui vous pèse, ce qui vous expose, et la meilleure manière de vous aider concrètement."
  />

  <main class="diag-app-v3">

    <!-- INTRO -->
    <div id="introSection" class="container container-narrow diag-step active">
      <div class="diag-intro-card card-v3">
        <p class="diag-kicker">Votre situation</p>
        <ul class="diag-intro-list">
          <li>✨ <span><strong>Y voir plus clair</strong> — comprendre ce qui se joue vraiment dans votre mandat.</span></li>
          <li>🛡️ <span><strong>Éviter les faux pas</strong> — repérer les points de vigilance avant qu'ils ne coûtent cher.</span></li>
          <li>🎯 <span><strong>Trouver le bon appui</strong> — outils, ressources ou accompagnement selon votre situation.</span></li>
        </ul>
        <div class="diag-intro-cta">
          <button class="btn-primary-v3 big" id="startBtn">
            Démarrer le diagnostic
          </button>
          <p class="diag-hint">Confidentiel · Résultat immédiat</p>
        </div>
      </div>
    </div>

    <!-- PROGRESS BAR -->
    <div class="progress-wrap-v3 hidden" id="progressWrap">
      <div class="container-narrow">
        <div class="progress-inner-v3">
          <div class="progress-track-v3"><div class="progress-fill-v3" id="progressFill"></div></div>
        </div>
      </div>
    </div>

    <!-- QUESTIONS CONTAINER (Fixed Height, Single Screen) -->
    <div id="diagSection" class="hidden questions-v3 container-narrow">

      <!-- Q1 -->
      <div class="diag-step" id="q1-step">
        <div class="q-content-v3">
          <p class="q-num-v3">Question 1/6</p>
          <h2 class="q-label-v3">Quel est votre mandat actuel ?</h2>
          <div class="options-v3" id="q1">
            <button class="opt-v3" onclick="pick(this,'q1','maire',1)">Maire</button>
            <button class="opt-v3" onclick="pick(this,'q1','adjoint',1)">Adjoint·e au maire</button>
            <button class="opt-v3" onclick="pick(this,'q1','conseiller_maj',1)">Conseiller·e (majorité)</button>
            <button class="opt-v3" onclick="pick(this,'q1','conseiller_opp',1)">Conseiller·e (opposition)</button>
            <button class="opt-v3" onclick="pick(this,'q1','interco_vp',1)">Vice-président·e intercommunal</button>
          </div>
        </div>
      </div>

      <!-- Q2 -->
      <div class="diag-step hidden" id="q2-step">
        <div class="q-content-v3">
          <p class="q-num-v3">Question 2/6</p>
          <h2 class="q-label-v3">Depuis combien de temps exercez-vous ce mandat ?</h2>
          <div class="options-v3" id="q2">
            <button class="opt-v3" onclick="pick(this,'q2','debut',2)">Moins de 6 mois</button>
            <button class="opt-v3" onclick="pick(this,'q2','moins2',2)">Entre 6 mois et 2 ans</button>
            <button class="opt-v3" onclick="pick(this,'q2','entre26',2)">Entre 2 et 6 ans</button>
            <button class="opt-v3" onclick="pick(this,'q2','plus6',2)">Plus de 6 ans</button>
          </div>
        </div>
      </div>

      <!-- Q3 -->
      <div class="diag-step hidden" id="q3-step">
        <div class="q-content-v3">
          <p class="q-num-v3">Question 3/6</p>
          <h2 class="q-label-v3">Aujourd'hui, vous venez surtout avec :</h2>
          <div class="options-v3" id="q3">
            <button class="opt-v3" onclick="pick(this,'q3','decision',3)">Une décision à prendre</button>
            <button class="opt-v3" onclick="pick(this,'q3','tension',3)">Une situation tendue ou un litige</button>
            <button class="opt-v3" onclick="pick(this,'q3','prise_parole',3)">Une prise de parole à préparer</button>
            <button class="opt-v3" onclick="pick(this,'q3','technique',3)">Un sujet que vous ne maîtrisez pas encore</button>
            <button class="opt-v3" onclick="pick(this,'q3','recul',3)">Un besoin de recul général</button>
          </div>
        </div>
      </div>

      <!-- Q4 -->
      <div class="diag-step hidden" id="q4-step">
        <div class="q-content-v3">
          <p class="q-num-v3">Question 4/6</p>
          <h2 class="q-label-v3">Comment vous sentez-vous accompagné·e ?</h2>
          <div class="options-v3" id="q4">
            <button class="opt-v3" onclick="pick(this,'q4','oui',4)">J'ai de bons appuis (adjoints, cabinet...)</button>
            <button class="opt-v3" onclick="pick(this,'q4','partiel',4)">C'est variable, je me sens parfois seul·e</button>
            <button class="opt-v3" onclick="pick(this,'q4','non',4)">Je me sens très isolé·e face aux décisions</button>
          </div>
        </div>
      </div>

      <!-- Q5 -->
      <div class="diag-step hidden" id="q5-step">
        <div class="q-content-v3">
          <p class="q-num-v3">Question 5/6</p>
          <h2 class="q-label-v3">Quel est le sujet qui vous occupe le plus ?</h2>
          <div class="options-v3" id="q5">
            <button class="opt-v3" onclick="pick(this,'q5','urbanisme',5)">Urbanisme et aménagement</button>
            <button class="opt-v3" onclick="pick(this,'q5','securite',5)">Sécurité et tranquillité</button>
            <button class="opt-v3" onclick="pick(this,'q5','budget',5)">Finances et fiscalité</button>
            <button class="opt-v3" onclick="pick(this,'q5','interco',5)">Intercommunalité</button>
            <button class="opt-v3" onclick="pick(this,'q5','humain',5)">Relations humaines / équipe</button>
          </div>
        </div>
      </div>

      <!-- Q6 -->
      <div class="diag-step hidden" id="q6-step">
        <div class="q-content-v3">
          <p class="q-num-v3">Question 6/6</p>
          <h2 class="q-label-v3">Comment préférez-vous avancer ?</h2>
          <div class="options-v3" id="q6">
            <button class="opt-v3" onclick="pick(this,'q6','autonomie',6)">En autonomie avec de bons outils</button>
            <button class="opt-v3" onclick="pick(this,'q6','mixte',6)">En mixant outils digitaux et appui léger</button>
            <button class="opt-v3" onclick="pick(this,'q6','humain',6)">Avec un regard humain et stratégique</button>
          </div>
        </div>
      </div>

      <!-- EMAIL REVEAL -->
      <div class="diag-step hidden" id="email-step">
        <div class="q-content-v3 text-center">
          <h2 class="q-label-v3">Votre synthèse est prête</h2>
          <p style="margin-bottom:2rem; opacity:0.7;">Laissez-votre email pour recevoir votre profil détaillé ou continuez directement vers le résultat.</p>
          <div class="email-input-v3">
            <input type="email" id="emailInput" placeholder="votre@email.fr" />
            <button class="btn-primary-v3" onclick="showResult()">Recevoir →</button>
          </div>
          <button class="btn-skip-v3" onclick="showResult()">Voir le résultat sans email →</button>
        </div>
      </div>

    </div>

    <!-- RÉSULTAT (Full Page Screen) -->
    <div id="resultSection" class="result-v3 hidden container-narrow">
      <div class="result-top-v3 text-center">
        <span class="label-v3">Synthèse MARYAN</span>
        <h2 id="rTitle" class="emphasis result-title-v3">—</h2>
        <p class="intro-v3" id="rSummary"></p>
      </div>

      <div class="result-grid-v3">
        <div class="result-card-v3 card-v3">
           <h3>Vos points de <span class="emphasis">vigilance</span></h3>
           <ul id="rNeeds" class="v3-list-dots"></ul>
        </div>
        <div class="result-card-v3 card-v3">
           <h3>L'appui <span class="emphasis">recommandé</span></h3>
           <h4 id="offerName" class="text-neon" style="margin-top:1rem;">—</h4>
           <p id="offerDesc" class="small"></p>
           <a href="/offres" class="btn-primary-v3" style="margin-top:1.5rem; width:100%; text-align:center;">Voir la solution adaptée</a>
        </div>
      </div>

      <div class="result-actions-v3">
        <a href="/copilote" class="btn-secondary-v3">Accéder au Copilote</a>
        <a href="/" class="btn-link-simple">Retour à l'accueil</a>
      </div>
    </div>

  </main>

  <style>
    .diag-app-v3 { height: 100vh; overflow: hidden; display: flex; flex-direction: column; }
    .container-narrow { max-width: 600px; margin: 0 auto; width: 100%; padding: 0 1.5rem; }

    /* Transitions */
    .diag-step {
      display: flex; flex-direction: column; justify-content: center;
      height: 70vh; opacity: 0; transform: translateY(20px); transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
      position: absolute; width: 100%; left: 0; pointer-events: none;
    }
    .diag-step.active { opacity: 1; transform: translateY(0); pointer-events: auto; }
    .diag-step.hidden { display: none; }

    .questions-v3 { position: relative; flex: 1; display: flex; align-items: center; justify-content: center; }

    /* Progress bar */
    .progress-wrap-v3 { padding: 1rem 0; background: white; border-bottom: 1px solid rgba(0,0,0,0.05); }
    .progress-track-v3 { height: 4px; background: #F0F2F5; border-radius: 99px; overflow: hidden; }
    .progress-fill-v3 { height: 100%; background: var(--accent-red); width: 0; transition: width 0.4s; }

    /* Question styles */
    .q-num-v3 { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--accent-red); margin-bottom: 1rem; }
    .q-label-v3 { font-size: 1.8rem; margin-bottom: 2.5rem; line-height: 1.2; }
    .options-v3 { display: flex; flex-direction: column; gap: 0.75rem; }
    .opt-v3 { 
        padding: 1.1rem 1.5rem; background: #fff; border: 1.5px solid #eee; border-radius: 16px; 
        text-align: left; font-size: 1rem; font-weight: 600; color: var(--deep); cursor: pointer;
        transition: all 0.2s;
    }
    .opt-v3:hover { border-color: var(--deep); transform: translateX(5px); }
    .opt-v3:active { background: #F8F9FA; transform: scale(0.98); }

    /* Results */
    .result-v3 { position: relative; overflow-y: auto; height: 100vh; padding: 4rem 1.5rem; display: flex; flex-direction: column; gap: 3rem; }
    .result-grid-v3 { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
    .result-actions-v3 { display: flex; flex-direction: column; align-items: center; gap: 1rem; padding-bottom: 5rem; }

    .email-input-v3 { display: flex; gap: 0.5rem; margin-bottom: 1rem; }
    .email-input-v3 input { flex: 1; padding: 1rem; border: 1.5px solid #eee; border-radius: 12px; }
    .btn-skip-v3 { background: none; border: none; text-decoration: underline; opacity: 0.5; color: var(--deep); cursor: pointer; }

    #introSection.hidden { display: none; }
  </style>

  <script is:inline>
    const state = { answers: {}, currentStep: 0 };
    const STEPS = ['intro', 'q1', 'q2', 'q3', 'q4', 'q5', 'q6', 'email'];

    function showStep(id) {
      document.querySelectorAll('.diag-step').forEach(s => {
        s.classList.remove('active');
        setTimeout(() => { if(!s.classList.contains('active')) s.classList.add('hidden'); }, 500);
      });
      
      const target = document.getElementById(id);
      if(target) {
        target.classList.remove('hidden');
        setTimeout(() => target.classList.add('active'), 50);
      }

      // Progress bar Update
      const stepIdx = STEPS.indexOf(id.replace('-step', ''));
      const pct = (stepIdx / (STEPS.length - 1)) * 100;
      const fill = document.getElementById('progressFill');
      if (fill) fill.style.width = pct + '%';
    }

    document.getElementById('startBtn').addEventListener('click', () => {
      document.getElementById('progressWrap').classList.remove('hidden');
      document.getElementById('diagSection').classList.remove('hidden');
      showStep('q1-step');
    });

    window.pick = (btn, qKey, value, stepNum) => {
      state.answers[qKey] = value;
      
      // Animation flash on pick
      btn.style.background = "#F0F2F5";
      btn.style.borderColor = "var(--deep)";

      setTimeout(() => {
        const nextStepId = STEPS[stepNum + 1] + '-step';
        showStep(nextStepId);
      }, 400);
    };

    window.showResult = () => {
       const email = document.getElementById('emailInput').value;
       localStorage.setItem('user_email', email);
       
       // Build profile for MARYAN
       const p = {
          title: state.answers.q1 === 'maire' ? "Diagnostic de pilotage" : "Clarification de mandat",
          summary: "Votre situation actuelle demande du recul stratégique sur vos appuis.",
          needs: ["Sécuriser vos décisions", "Structurer vos temps forts", "Sortir de l'isolement"],
          offer: { name: "MARYAN Plus", desc: "L'appui complet pour votre situation." }
       };

       document.getElementById('rTitle').textContent = p.title;
       document.getElementById('rSummary').textContent = p.summary;
       document.getElementById('rNeeds').innerHTML = p.needs.map(n => `<li>${n}</li>`).join('');
       document.getElementById('offerName').textContent = p.offer.name;
       document.getElementById('offerDesc').textContent = p.offer.desc;

       // Persist
       localStorage.setItem('maryan_profile', JSON.stringify({ 
         title: p.title, 
         summary: p.summary,
         tags: [state.answers.q5],
         plan: "Gratuit"
       }));

       document.getElementById('diagSection').classList.add('hidden');
       document.getElementById('progressWrap').classList.add('hidden');
       document.getElementById('resultSection').classList.remove('hidden');
    }
  </script>
</BaseLayout>
