---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'MARYAN — appui intelligent pour élus municipaux',
  description = "MARYAN aide les élus municipaux à diagnostiquer leurs besoins, accéder à des ressources ciblées et s'orienter vers le bon niveau d'accompagnement."
} = Astro.props;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <!-- Inter for reliability, Playfair Display for editorial italics -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:ital,wght@1,400;1,700&display=swap" rel="stylesheet">
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#0A192F">
  </head>
  <body>
    <!-- Grain Texture Overlay -->
    <div class="grain-overlay"></div>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="header-logo" aria-label="Retour à l'accueil MARYAN">
          <span class="header-logo-wordmark">MARYAN</span>
        </a>
        <nav class="header-nav">
          <a href="/diagnostic" class="nav-primary">Diagnostic</a>
          <a href="/copilote">Copilote</a>
          <a href="/ressources">Ressources</a>
          <a href="/droits">Droits & devoirs</a>
          <a href="/blog">Blog</a>
          <a href="/login" id="accountEntry" class="header-compte">Se connecter</a>
        </nav>
      </div>
    </header>
    <slot />

    <!-- Bandeau cookies RGPD -->
    <div id="cookieBar" class="cookie-bar" style="display:none;">
      <p class="cookie-bar-text">
        MARYAN n’utilise que les cookies strictement nécessaires à votre connexion. Aucun suivi, aucune publicité.
        <a href="/confidentialite">En savoir plus</a>
      </p>
      <button id="cookieBarBtn" class="cookie-bar-btn">J'ai compris</button>
    </div>
    <script>
      (function() {
        if (!localStorage.getItem('maryan_cookies_ok')) {
          var bar = document.getElementById('cookieBar');
          if (bar) bar.style.display = 'flex';
        }
        var btn = document.getElementById('cookieBarBtn');
        if (btn) {
          btn.addEventListener('click', function() {
            localStorage.setItem('maryan_cookies_ok', '1');
            var b = document.getElementById('cookieBar');
            if (b) b.style.display = 'none';
          });
        }
      })();
    </script>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div class="footer-brand">
          <div class="footer-brand-copy">
            <p class="brand">MARYAN</p>
            <p class="brand-sub">République Design · Mandat local</p>
            <p class="footer-credit">
              MARYAN est une offre de <a href="https://www.etjaicrie.com/index.html">Et j'ai crié</a>.
            </p>
          </div>
        </div>
        <div class="footer-links">
          <p class="footer-kicker">Navigation</p>
          <ul class="footer-nav">
            <li><a href="/login" id="footerAccountEntry" style="color:var(--neon); font-weight:800;">Se connecter</a></li>
            <li><a href="/a-propos">À propos</a></li>
            <li><a href="/offres">Nos offres</a></li>
            <li><a href="/diagnostic">Diagnostic</a></li>
            <li><a href="/mots">Les mots</a></li>
            <li><a href="/droits">Droits & devoirs</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/contact">Contact</a></li>
            <li><a href="/mentions-legales">Mentions légales</a></li>
            <li><a href="/confidentialite">Confidentialité</a></li>
            <li><a href="/cgv">CGV</a></li>
          </ul>
        </div>
        <div class="footer-eco">
          <p class="footer-kicker" style="color:var(--neon);">Innovation Sobriété · EcoIndex A</p>
          <div class="footer-note">
            <strong>MARYAN est conçu pour une sobriété numérique forte :</strong>
            Architecture Astro statique et hébergement éco-responsable.
          </div>
        </div>
      </div>
    </footer>

    <script>
      import { createClient } from '@supabase/supabase-js';

      const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
      const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

      const accountLinks = ['accountEntry', 'footerAccountEntry']
        .map((id) => document.getElementById(id))
        .filter(Boolean);

      function updateAccountLinks(href, label) {
        accountLinks.forEach((link) => {
          link.setAttribute('href', href);
          link.textContent = label;
        });
      }

      updateAccountLinks('/login', 'Se connecter');

      if (SUPABASE_URL && SUPABASE_KEY) {
        const supabase = createClient(SUPABASE_URL, SUPABASE_KEY);

        supabase.auth.getSession().then(async ({ data: { session } }) => {
          if (!session) return;

          // Prénom depuis user_metadata (rapide, pas de requête extra)
          let firstName = session.user.user_metadata?.first_name || '';

          // Fallback : requête légère sur profiles
          if (!firstName) {
            try {
              const { data } = await supabase
                .from('profiles')
                .select('first_name')
                .eq('id', session.user.id)
                .single();
              firstName = data?.first_name || '';
            } catch { /* noop */ }
          }

          const headerLabel = firstName ? `Bonjour ${firstName}` : 'Mon compte';
          const headerLink = document.getElementById('accountEntry');
          if (headerLink) { headerLink.setAttribute('href', '/mon-compte'); headerLink.textContent = headerLabel; }
          const footerLink = document.getElementById('footerAccountEntry');
          if (footerLink) { footerLink.setAttribute('href', '/mon-compte'); footerLink.textContent = 'Mon compte'; }
        });
      }
    </script>
  </body>
</html>

<style>
  .cookie-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--deep);
    color: rgba(255,255,255,0.85);
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.85rem;
    z-index: 9999;
    flex-wrap: wrap;
  }
  .cookie-bar-text { margin: 0; line-height: 1.5; }
  .cookie-bar a { color: var(--neon); }
  .cookie-bar-btn {
    background: var(--neon);
    color: var(--deep);
    border: none;
    border-radius: 4px;
    padding: 0.4rem 1rem;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
    white-space: nowrap;
  }
</style>
