---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'MARYAN — appui intelligent pour élus municipaux',
  description = "MARYAN aide les élus municipaux à diagnostiquer leurs besoins, accéder à des ressources ciblées et s'orienter vers le bon niveau d'accompagnement."
} = Astro.props;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <slot />
  </body>
</html>
