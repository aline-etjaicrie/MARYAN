---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'MARYAN — appui intelligent pour élus municipaux',
  description = "MARYAN aide les élus municipaux à diagnostiquer leurs besoins, accéder à des ressources ciblées et s'orienter vers le bon niveau d'accompagnement."
} = Astro.props;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <slot />
    <footer class="site-footer">
      <div class="container footer-grid">
        <div>
          <p class="brand">MARYAN</p>
          <p class="brand-sub">MVP de cadrage · appui intelligent pour élus municipaux</p>
          <p class="footer-credit">
            MARYAN est une offre de <a href="https://www.etjaicrie.com/index.html">Et j'ai crié</a>.
          </p>
        </div>
        <div>
          <p class="footer-kicker">Green IT & EcoIndex</p>
          <div class="footer-note">
            <strong>MARYAN est conçu dès le départ pour une sobriété numérique forte :</strong>
            hébergement Scaleway, architecture Astro statique, pages légères, JavaScript limité
            et objectif <strong>EcoIndex A</strong>.
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
